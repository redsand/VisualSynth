  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "db=(bass-lbass)*fps;",
      "lbass=bass;",
      "avgdb=avgdb*.99+abs(db)*.01;",
      "",
      "//beatdection",
      "rawbeatb=above(abs(db),avgdb*4);",
      "beatb=rawbeatb*above(time-lbbtime,avgbeatrate*.5);",
      "beathard=beatb*(abs(db)-avgdb*4);",
      "//beatrate calc",
      "beatrate=beatb*(time-lbbtime)+(1-beatb)*beatrate;",
      "avgbeatrate=beatb*(avgbeatrate*.9+beatrate*.1)+(1-beatb)*avgbeatrate;",
      "lbbtime=time*beatb+(1-beatb)*lbbtime;",
      "",
      "ph=(time-lbbtime)*(60/avgbeatrate)*const;",
      "phase=max(min( ph, 1 ),0);",
      "",
      "//const=beatb*( bool*(const-.001)+(1-bool)*(const+.001) ) + (1-beatb)*const;",
      "const=const*(1-beatb)+beatb*( const+ (.01*bool) );",
      "",
      "bool=below(phase,.98)*(.99-ph)-above(phase,.98)*(ph*.5);",
      "monitor=const;",
      "bc=bc+beatb;",
      "",
      "vol=(rawbeatb*(db-(avgdb))*.01);",
      "avgvol=avgvol*.999+vol*.01;",
      "",
      "mtime=mtime+min(avgvol*.5,.25);",
      "",
      "q1=beatb;",
      "q2=phase;",
      "q3=avgbeatrate;",
      "q4=avgvol;",
      "q5=mtime;",
      "q6=vol;",
      "wrap=1;",
      "decay=.99+.01*q6;"
    ],
    "perFrameInitCode": [
      "db=.01;",
      "beatrate=1;",
      "avgbeatrate=2;",
      "lbbtime=time;",
      "avgdb=.01;",
      "vol=1;",
      "avgvol=.2;",
      "phase=0;",
      "bool=0;",
      "const=.02;"
    ],
    "perPixelCode": [
      "dx=pow(rad*q2,(q6))*.01*sin((bass_att*3.14-treb_att*3.14));",
      "dy=pow(rad*q4*bass,q4*q3)*.1*sin(treb_att*treb*6.28+bass_att*bass*6.28);",
      "",
      "sx=dy*q6*.002+1;",
      "sy=dx*q5*.002+1;"
    ],
