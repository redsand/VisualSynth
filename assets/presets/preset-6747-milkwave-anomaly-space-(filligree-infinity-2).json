    "comp": null,
    "perFrameCode": [
      "mv_r = .5-.5*sin(time*2.83);",
      "mv_b = .5-.5*cos(time*2.63);",
      "mv_g = .5+.5*sin(time*2.95);",
      "",
      "//ib_r = ob_g;",
      "//ib_g = ob_b;",
      "//ib_b = ob_r;",
      "wave_mystery = rand(100)*.01;",
      "",
      "",
      "count = count+1;",
      "bc = bc+bass;",
      "tc = tc+treb;",
      "mc = mc+mid;",
      "bb = .5*bd+.5*bass_att;",
      "bt = .5*bt+.5*treb_att;",
      "mt = .5*mt+.5*mid_att;",
      "bimp = if(above(3*bass,bass+treb+mid),1,0);",
      "timp = if(above(3*treb,bass+treb+mid),1,0);",
      "mimp = if(above(3*mid,bass+treb+mid),1,0);",
      "is_beat = if(above(bb*.9,bc/count),1*bimp,if(above(bt*.9,tc/count),1*timp,if(above(mt*.9,mc/count),1*mimp,0)));",
      "is_beat = if(above(reha,0),0,is_beat);",
      "reha = if(is_beat,fps*.25,if(below(reha,1),0,reha-1));",
      "",
      "",
      "xrand = if(is_beat,.25+rand(500)/1000,xrand);",
      "xpos = xpos+bass_att*(xrand-xpos)/40;",
      "",
      "yrand = if(is_beat,.3+rand(400)/1000,yrand);",
      "ypos = ypos+bass_att*(yrand-ypos)/40;",
      "",
      "dx = 2* xpos/ypos;",
      "dy = 2*ypos/xpos;",
      "",
      "monitor = xrand/yrand;",
      "",
      "q1 = xpos;",
      "q2 = ypos;"
    ],
    "perFrameInitCode": [
      "xpos = .5;",
      "ypos = .5;"
    ],
    "perPixelCode": [
      "ceny = q1;",
      "cenx = q2;",
      "brad = 2*sqrt( pow((x-cenx),2) + pow ((y-ceny),2));",
      "",
      "",
      "box = below(x,cenx+.15)*above(x,cenx-.15)*above(y,ceny-.15)*below(y,ceny+.15);",
      "",
      "c = 1001; // sharpness",
      "",
      "sx = 0.85-1.8*(1-box)*(1-brad+brad*sigmoid(-brad+.45,c))+.33*(1-box)*(1-brad+brad*sigmoid(brad*1.5-1,c));",
      "sy = 0.85-1.8*(1-box)*(1-brad+brad*sigmoid(-brad+.45,c))+.33*(1-box)*(1-brad+brad*sigmoid(brad*1.5-1,c));",
      "",
      "cy = ceny;",
      "cx = cenx;"
    ],
