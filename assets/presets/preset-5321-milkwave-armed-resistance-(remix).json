      "ib_g=if(mid_changed,ob_r,ob_b);",
      "ib_a=.01+.01*wave_g;",
      "ib_size=.05+.04*bass_residual;",
      "rot=rot+.1*bnot(mid_changed)*q5;",
      "zoom=if(bass_changed*treb_changed,1.3,.98+.1*sin(pulse*entropy*.2));",
