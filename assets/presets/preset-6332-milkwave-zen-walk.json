    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nret = GetPixel(vUvOriginal);\nmask = 1;\nuv1 = (vUvOriginal-vec2(.5, .5)) * uAspect.xy;\n\nuvg.z = SysZ;\nuvg.x = uv1.x * uvg.z/fov;\nuvg.y = alti (uvg.x, uvg.z);\nuvn = uvg;\nfloat y1 = uvg.y;\nfloat y2 = alti (uvg.x+4,uvg.z);\n\nweg = WegX - uvg.x  + noise3_lq(uvg.xz*.0014)*WegR;\nwstruc = noise3_lq(weg*0.004 + uvg.xz*0.00);\nweg = clamp01(3-abs(weg) - WegR/8);\n\nfels = sat(noise3_lq(.0012*uvg.xz)-.2)*3*(1-weg); //Fels nicht hoeher als YCam !\n\ngras = sat(1-fels)*sat(1-weg) * sat(2+4*noise3_lq(uvg.xz*.0003));;\ngrasart = 0.25*ceil(4*texture(sampler_noise_lq,uvg.xz*0.000723+q10).xy);\nuvpat = vUv*mix(vec2(2,1)*texture(sampler_noise_lq,uvg.xz*0.0063).xz,\n           vec2(32,8)*grasart.xy,\n           clamp01(2*gras - 2*weg));\n\nfloat pat0 = sat(texture(sampler_noise_lq,uvpat*RelZ+rand_frame).g +wstruc*weg) ;;\nfloat pat = mix(pat0, .0, clamp01(fels*2));\n\nuvg.y += fels + (pat-0.5)* gras*1.3 ;\nuvg.y = mix(uvg.y-weg/2,WegY-wstruc/2,weg*0.7);\n\n//PROJEKTION\nuvg.yz = multiply(uvg.yz,CamRot);\nrs     = fov/uvg.z * vec2 (uvg.x,uvg.y - YCam);\ngnd = clamp01((4*512*RelZ*pow(rs.y+uv1.y,1))) ;\n\nret1 = vec3 (mix(0.65*sat(.7+grasart.y-gras),0.9-wstruc,weg), (0.3*gnd*pat+weg/16)*Hell*(1+0*(y2-y1)), RelVis-RelZ);\n//ret1.g *= 0.2+0.8*sat(GetBlur2(vUvOriginal).g); //hm !!!!!!!!!!!!!!\nret = mix(ret, ret1, gnd*mask);\n\n//BodenNebel\nuvn.yz = multiply(uvn.yz,CamRot);\nrs     = fov/uvn.z * vec2 (uvn.x,uvn.y - YCam + 0); //Nebelhoehe noch definieren ####\nfloat noise = texture(sampler_noise_hq,uvn.xz*0.005).r;\ngnd = clamp01((1-8000*RelZ*rand_frame.x*pow(rs.y+uv1.y,2)))*0.1*noise;\nret.b = mix(ret.b, ret.b*0.15*0, gnd*mask);\n\nuv2.x = 1- abs( fract((uv2.x-.5) * 0.5 ) * vec2(2,1.8) - 1.0 ); // Eo.S. mirror code\n\nuv2 = (vUvOriginal - 0.5)*2+0.6;\nvec3 a1 = GetPixel(uv2-vec2(0,0));\nvec3 copy = a1;\nfloat cmask = sat (1-pow(2*max(1*abs(uv2.x-0.5), abs(uv2.y-0.5)),2))*0.4;\nif (q30) {ret =  mix(vec3(1,1,0),copy,vec3(0,cmask,cmask)*q25) ;};\n//ret = cmask/3;\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvUv += uTexSize.zw/4;\n\nmat = GetPixel(vUv).r;\nbri = GetPixel(vUv).g*1.2;\nfloat land = sat (2-2*GetPixel(vUv).g);\ndist = (1-GetPixel(vUv).b)*0.99;\n\nfloat ov = sat ((vUv.y-0.5)*1);\nsky = mix(skycolhi,skycollo,mix(ov, 1-ov,q28));\nambience = mix(sky, Hell*.2, q26*land); //exp. mit 0*land - 1*land;\n\nvec2 uv1 = vUv-vec2(0.5,0);\nfloat z = 0.05/(uv1.y);\nfloat fogdens = texture(sampler_noise_hq, vec2(uv1.x*z/4+uTime*0.0047, z)).r * land ;\nret = mix(ambience, bri*matcol(mat)*ambience, pow(1-dist,q27*fogdens));\n//ret = fogdens;\n\n  fragColor = ret;\n}",
