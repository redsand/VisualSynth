      "rd=rad+(.26*rad)/(3-bass_att); rd-=int(rd); tm=time+(q8*(time*3))*sin((rd*2-1)*(time*q8));",
      "var=tan(tm)*treb*treb_att;",
      "",
      "zoom=1+(rd/40)+(var/40);",
      "rot=((rd/100)*var)*sin(tm);"
    ],
