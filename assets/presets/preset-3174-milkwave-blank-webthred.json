  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).zxx;\n  lfo1=(vec3(1/3,-1/3,0)+1)*(.5+.5*sin(uTime/5));\n  lfo2=(vec3(1/3,-1/3,0)+1)*(.5+.5*cos(uTime/5));\n\n // darken (decay) over uTime\n    ret *= 0.75; //or try: ret -= 0.004;\nret +=.12* tex2d(sampler_pc_rand00,max(vUvOriginal,vUv)).xyz*lfo1;\nret +=.12* tex2d(sampler_fw_rand01,max(vUvOriginal,vUv)).xyz*lfo2;\n\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "snd=mid+mid_att-bass_att-treb;thit=above(treb,max(.5,treb_att*1.08));",
      "sdd=(snd/(fps*(3-mid_att)))+sdd;ssd=.1*(int((sdd-int(sdd))*10));",
      "sss=if(thit,ssd,sss);mss=max(sss,1-sss);",
      "wave_mystery+=snd;",
      "wave_xq=abs(wave_x*2-1)*mss*.57;wave_x=wave_xq+.5;",
      "wave_yq=abs(wave_y*2-1)*.7;wave_y=wave_yq+.5+sss;",
      "wave_x+=5;wave_x-=int(wave_x);",
      "wave_y+=5;wave_y-=int(wave_y);",
      "",
      "wave_a=(sdd*wave_x+sin(x*time)*cos(mss*q8*((wave_x*sss))));",
      "wave_a=max(wave_a,1-wave_a)-.3; wave_a-=int(wave_a);",
      "",
      "",
      "//krash's beat detection code",
      "volume = 0.3*(bass+mid+att);",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.95 + (1-above(time - lastbeat, 2*beatrate))*0.995);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "beat = above(volume,0.8)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatcounter = beatcounter + beat;",
      "mode = if(beat*equal(beatcounter%2,0),1-mode,mode);",
      "flip = 2*mode-1;",
      "monitor=sss;",
      "q8=flip;",
      "",
      "",
      "decay=1;",
      "zoom=1.002;",
      "",
      "vol=(bass_att+mid_att+treb_att)*0.25;",
      "vol=vol*vol;",
      "mtime=mtime+vol*0.1*flip*(55/fps);",
      "",
      "q1=mtime*0.4;",
      "",
      "warp=0.0"
    ],
    "perFrameInitCode": [
      "snd=0;sdd=0;",
      "mv_x=64;mv_y=48;",
      "nut=0;",
