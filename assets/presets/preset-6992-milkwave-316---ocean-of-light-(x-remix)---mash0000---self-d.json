  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).xyz;\n\n    // take the difference between the crisp and blurred images,\n    // then add it back into the image.  Creates spots and stripes over uTime.\n    ret += (ret - GetBlur2(vUv))*0.3;\n    ret *= 0.95;\n\n   // add noise:\n   vec2 dither_uv = vUvOriginal*uTexSize.xy*texsize_noise_lq.zw * 0.4 + rand_frame.xy;\n   ret += (texture(sampler_noise_lq, dither_uv).xyz-0.5)/256.0 * 12 * clamp01(audioHighSmooth-1);\n\n   // desaturate over uTime, to keep the globs white\n   ret = mix(ret, lum(ret), 0.18);\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "// -------------------------------- Beat Detective v0.07 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "warp=0;",
      "zoom=1.04;",
      "",
      "rnd=equal(frame%400,0);",
      "offy=(1-rnd)*offy+rnd*(-3+int(rand(600))/100);",
      "offz=(1-rnd)*offz+rnd*(-80-0*int(rand(1000))/1000);",
      "sc=(1-rnd)*sc+rnd*(1+int(rand(500))/100);",
      "offx=0;",
      "offy=-3.1;",
      "offz=-300+160*pow(contVol,.25);",
      "sc=4;",
      "",
      "q2=offy; // y-offset",
      "q3=offz; // z-offset",
      "q4=sc; // scale",
      "",
      "q5=3.1415*cos(.05*time+.84+sin(time*.1+6.43)); // rot-y;",
      "q6=.2;//.6-.45*abs(sin(time*.15+2.43+cos(time*.09+1.87))); // rot-x;",
      "",
      "q5=0;q6=0;",
      "",
      "",
      "stime=if(equal(stime,0),time,stime );",
      "mytime=time-stime;",
      "phase = .1*mytime - int(.1*mytime);",
      "",
      "q7=pow(contVol,.333);",
      "contVol=((bass+mid+att)*.3333)*.02+contVol*.98;",
      "contVol=min(1,contVol);",
      "zoom=1.01+.05*contVol;",
      "",
      "c1=above(contvol,.7)*min(contvol-.7,.3);",
      "dx=c1*.0015*(-10+int(rand(20)));",
      "dy=c1*.0015*(-10+int(rand(20)));",
      "",
      "darken=1;",
      "brighten=1-darken;",
      "",
      "q8=min((frame-lastbeat)/interval,1);",
      "q1=.05*cos(1.943*time+2.43+sin(1.83*time+2.01) );",
      "",
      "sx=1-2*below(q8,.15)*above(contVol,.75);",
      "sy=1-2*below(q8,.15)*above(contVol,.75);",
      "invert=below( q8,.15);",
      "solarize=invert*above(q7,.85);"
    ],
