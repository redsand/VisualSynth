      "wave_g=if(treb_changed,0,if(mid_changed,0,.49));",
      "wave_b=if(treb_flop,.8+.2*q4,bass_changed*mid_changed);",
      "cx=.5+.2*q3;",
      "cy=.5+.2*q4;",
      "wave_x=.5+.2*q4*bnot(q1%7);",
      "wave_y=.5+if(bnot(q1%2),.2*q3,0)+.1*bnot(q1%3)-.1*bnot(q1%5);",
      "ob_r=if(bass_flop,treb_flop,wave_g);",
      "ob_b=if(treb_flop,.5+.5*q3,wave_b);",
      "ob_g=if(mid_flop,wave_r,wave_b);",
      "ob_a=.07+.05*q3;",
      "ob_size=.01*entropy*bnot(q1%6);",
      "ib_r=ib_r+.4*bnot(q1%10)-.4*bnot(q1%30);",
      "ib_b=ib_b+.4*bnot(q1%42)-.4*bnot(q1%21);",
      "ib_g=ib_g+.5*sin(time*.02*entropy);",
      "ib_a=.07+.05*q3*q4;",
      "ib_size=.01+.009*q3;",
      "zoom=zoom+.03*bnot(q1%3)-.03*bnot(q1%35);"
