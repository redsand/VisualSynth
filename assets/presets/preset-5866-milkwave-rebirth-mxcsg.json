      "dx_r = equal(thresh,2)*0.15*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.15*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "",
      "zoom = zoom - 0.01;",
      "zoom = zoom + dx_r*3*tan(dy_r*(2*(sin(3*bass_att)*0.5-rad*(2-rad)*sin(12*rad))*bass_att*4));",
      "zoom = zoom - dy_r*3*tan(dx_r*(2*(sin(4*bass_att)*(0.75-rad)*sin(6*ang))*bass_att*4));",
