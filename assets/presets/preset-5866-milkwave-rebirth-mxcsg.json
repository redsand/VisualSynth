      "dx=dx*0.001;",
      "",
      "dy=sin(x*4.28+time*0.1)+sin(x*6.28*4+time*0.14)+sin(x*6.28*09+time*0.2);",
      "dy=dy*0.001;",
      "",
      "///////////////////////////////////////",
      "cr1=(int(sin(time*1)/2+.5+.99));",
      "cr2=cr1;",
      "crx=cr2-cr1;",
      "ci=rad;",
      "cb=.25  ;",
      "crs=2;",
      "cr=pow(sin(ci*6.3-(cb*6.3))/2+.5,crs)*crx+cr1;",
      "cqr=if( above (ci,.25+cb),cr,crx+cr1);crr=if( below(ci,1.5),cqr,crx+cr1);",
      "jx1=crr;",
      "kx1=1-crr;",
      "",
