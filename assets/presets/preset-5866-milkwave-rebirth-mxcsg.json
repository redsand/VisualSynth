      "dx_residual = equal(bass_thresh,2)*0.016*sin(time*7) + (q2-equal(bass_thresh,2))*dx_residual;",
      "dy_residual = equal(bass_thresh,2)*0.012*sin(time*9) + (q2-equal(bass_thresh,2))*dy_residual;",
