  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).xyz;\n\n    // darken (decay) over uTime\n    ret *= 0.95; //or try: ret -= 0.004;\nret =max(1*(0.7+0.3*sin(vAngle-vRadius+uFrame/uFps+audioLowSmooth-audioHighSmooth%uFrame/1000/uFrame))- tex2d(sampler_rand01 ,vUvOriginal),\n1*(0.7+0.3*cos(vAngle-vRadius+uFrame/uFps+audioLowSmooth-audioHighSmooth%uFrame/1000/uFrame))- tex2d(sampler_rand02 ,vUvOriginal));\n//ret +=1*(0.7+0.3*cos(uFrame/uFps+audioMidSmooth+audioLowSmooth%uFrame/1000/uFrame))- tex2d(sampler_rand02 ,vUvOriginal);\nret *=q22;\nret=max(ret,1-ret)-(min(ret,1-ret)*q22);\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "dec_med = pow (0.9, 30/fps);",
      "dec_slow = pow (0.96, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, 0.2+avg+peak) * above (time, t0+.1);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %12;",
      "index2 = (index2 + is_beat*bnot(index))%8;",
      "",
      "q20 = avg;",
      "q21 = beat;",
      "q22 = peak;",
      "q24 = is_beat;",
      "vol = (bass_att + mid_att + treb_att)/2;",
      "vol_ = dec_med * vol_ + (1-dec_med)* vol;",
      "vol__ = dec_med * vol__ + (1-dec_med)* vol_;",
      "q27 = index + 1;",
      "q28 = index2 + 2;",
      "",
      "k1 =  is_beat*equal(index%4,0);",
      "p1 =  k1*(p1+1) + (1-k1)*p1;",
      "p2 = dec_med * p2+ (1-dec_med)*p1;",
      "rott = p2 * 3.1416/4;",
      "",
      "q1 = cos(rott);",
      "q2 = sin(rott);",
      "q3 = -q2;",
      "q4 = q1;",
      "",
      "trig = q24 * bnot(index%8);",
      "vx = vx*bnot(trig) + trig* (int(rand(100))/100-.5);",
      "vy = vy*bnot(trig) + trig* (int(rand(100))/100-.5);",
      "vz = vz*bnot(trig) + trig* (int(rand(100))/100-.5);",
      "",
      "speed = min(vol_-vol__+.5,1);",
      "speed = max(speed,-.5);",
      "speed_ = bnot(trig)*speed_ + trig*speed;",
      "spg = dec_med*spg + (1-dec_med)*speed_;",
      "movz = movz + 1/fps*(speed_+0*vol_/6);",
      "q9 = movz;",
      "q12 = min(q22,6)*2;",
      "",
      "//puls = puls*dec_med + (1-dec_med)*q22;",
      "",
      "q13 = 2* sin(movz/3-time/11);",
      "",
      "trig = bnot(index%4) * q24;",
      "dir = bnot(trig)*dir + trig*(int(rand(10))-5);",
      "trel = trel + .1/fps*dir;",
      "q5 = cos(trel-movz);",
      "q6 = sin(trel/2-movz);",
      "q7 = -q6;",
      "q8 = q5;",
      "",
      "ang0 = ang0*dec_med + vz*(1-dec_med);",
      "q17 = ang0*2;",
      "q30 = .2*sin(time/8);",
      "",
      "q31 = .5 + .5*sin(time/3.3);",
      "",
      "zoom = 1;",
      "rot = .0;",
      "dx = .00;",
      "monitor = q28;"
    ],
