  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n  vRadius = pow(vRadius,0.4)*1;\n  vec2 ang_hq = atan(vUv.x-0.5,vUv.y-0.5) - vRadius*q1;\n\n\n  float ang2 = fract(ang_hq/6.28*3 + q2);\n  ang2 = abs(ang2*2-1) - uTime*0.15;\n  vec2 uv2 = 0.5 + vRadius*0.5*vec2(cos(ang2),sin(ang2));\n\n  vUv = uv2;\n    ret = texture(sampler_main, vUv).xyz;\n    ret *= 1.00; //gamma\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "q8 =oldq8+ 0.001*(pow(1.2*bass+0.4*bass_att+0.2*treb+0.2*treb_att+0.2*mid+0.2*mid_att,6)/fps) +0.1/fps;",
      "oldq8 = q8;",
      "ob_r = 0.3 - 0.3*(0.5*sin(time*0.3701)+ 0.3*cos(q8*0.438));",
      "ob_g = 0.6- 0.4*sin(time*0.24);",
      "ob_b = 0.35 - 0.3*cos(time*0.4816);",
      "warp =0;",
      "ib_size = 0.02;",
      "ib_r = ib_r + 0.5*sin(time*0.234);",
      "ib_g = ib_g + 0.5*sin(time*0.547);",
      "ib_b = ib_b - 0.5*sin(time*1.431);",
      "cx = cx +0.3150*( 0.60*sin(0.23874*time) + 0.14*sin(0.194*time) );",
      "cy = cy + 0.476*( 0.60*sin(0.1274*time) + 0.10*sin(0.394*time) );",
      "",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "mybeat = if(beat,mybeat+1,mybeat);",
      "mybeat = if(above(mybeat,7),0,mybeat);",
      "mybeat2 = if(equal(mybeat,1),1,0);",
      "q7 = if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq7);",
      "oldq7=q7;",
      "q6 = if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq6);",
      "oldq6=q6;",
      "q5= if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq5);",
      "oldq5=q5;",
      "q4 = if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq4);",
      "oldq4=q4;",
      "Flag = If(beat*mybeat2,if(int(Rand(2))-1,1,0),oldFlag);",
      "oldflag = flag;",
      "Ratio = If(Beat*mybeat2,100+int(rand(60)),oldRatio);",
      "OldRatio = Ratio;",
      "q3 = if(beat*mybeat2,if(flag,ratio,0.75*ratio),oldq3);",
      "oldq3=q3;",
      "q2 = if(beat*mybeat2,if(flag,0.75*ratio,ratio),oldq2);",
      "oldq2=q2;",
      "rot=0;"
    ],
    "perFrameInitCode": [
      "q8=0;"
    ],
    "perPixelCode": [
      "ukdx=dx;//////////////////////////////////////////",
      "ukdy=dy;",
      "uksx=sx;",
      "uksy=sy;",
      "ukrt=rot;",
      "ukzm=zoom;",
      "ukcx=cx;",
      "ukcy=cy;",
      "ukwp=warp;",
      "",
      "dx=0;",
      "dy=0;",
      "sx=1;",
      "sy=1;",
      "rot=0;",
      "zoom=1;",
      "cx=.5;",
      "cy=.5;",
      "warp=0;/////////////////////////////////////////////////////",
      "",
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "",
      "zoom = zoom + 0.2*abs(0.3*cos(4*rad))*cos(12*ang);",
      "sx = sx - 13*dx_r*sin(2*sin(6*rad)*2*cos(6*rad));",
      "sy = sy - 13*dy_r*sin(2*cos(6*rad)*2*sin(6*rad));",
      "///////////////////////////////////////",
      "cr1=(int(sin(bass*treb/2)/2+.5+.1));",
      "cr2=cr1;",
      "crx=cr2-cr1;",
      "ci=rad;",
      "cb=.25  ;",
      "crs=2;",
      "cr=pow(sin(ci*6.3-(cb*6.3))/2+.5,crs)*crx+cr1;",
      "cqr=if( above (ci,.25+cb),cr,crx+cr1);crr=if( below(ci,1.5),cqr,crx+cr1);",
      "jx1=crr;",
      "kx1=1-crr;",
      "",
      "ujdx=dx;",
      "ujdy=dy;",
      "ujsx=sx;",
      "ujsy=sy;",
      "ujrt=rot;",
      "ujzm=zoom;",
      "ujcx=cx;",
      "ujcy=cy;",
      "ujwp=warp;",
      "",
      "dx=(jx1*ujdx+kx1*ukdx);",
      "dy=(jx1*ujdy+kx1*ukdy);",
      "sx=(jx1*ujsx+kx1*uksx);",
      "sy=(jx1*ujsy+kx1*uksy);",
      "rot=(jx1*ujrt+kx1*ukrt);",
      "zoom=(jx1*ujzm+kx1*ukzm);",
      "cx=(jx1*ujcx+kx1*ukcx);",
      "cy=(jx1*ujcy+kx1*ukcy);",
      "warp=(jx1*ujwp+kx1*ukwp);////////////////////////////////////////////////////"
    ],
