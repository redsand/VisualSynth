      "fy = 0.5*cos(mid_att*rad)*dy_r*(sin(1.1*time))*sin(bass_att);",
      "",
      "bruch = fx*((sit+sib+sim)*2)*below(bass,0.4*sin(fy*time));",
      "brach = fy*((sit*sib*sim)*2)*above(bass_att*bass/2,0.4*cos(fx*time));",
      "",
      "rot = rot + 2*sin(2*sin(sit*fx))*(2*cos(sib*fy))*below(rad,0.2+0.3*tan(4*bass*time));",
      "zoom = zoom - 2*abs(((cos(1.5*time)-y)*fx*sib/sim)*((sin(time)-y)*fy*sit/sim))*rad;"
    ],
