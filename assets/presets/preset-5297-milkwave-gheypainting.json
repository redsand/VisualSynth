  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.9+.1*sin(beat);",
      "entropy=if(bnot(entropy),2,if(equal(pulse,-3.14),1+int(rand(3)),entropy));",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*chaos+1.3);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*chaos+1.3);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.3)*chaos+1.3);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse*.1*entropy) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*.1*entropy) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*.1*entropy) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),3.14),-3.14,pulse+(bass_thresh+mid_thresh+treb_thresh)*.01);",
      "beat=if(above(abs(beat),3.14),-3.14,beat+(bass+treb+mid)*.01);",
      "q1=mid_residual;",
      "q2=bass_residual;",
      "q3=treb_residual;",
      "q4=sin(pulse);",
      "q5=sin(beat);",
      "wave_r=wave_r+.5*bass_residual;",
      "wave_g=wave_g+.5*mid_residual;",
      "wave_b=wave_b+.5*treb_residual;",
      "mv_a=.5+.5*bass_residual;",
      "mv_x=abs(beat*10)*entropy;",
      "mv_y=mv_x;",
      "mv_r=wave_b;",
      "mv_b=wave_g;",
      "mv_g=wave_r;",
      "ripple1r = (ripple1r + ripple1s)*below(ripple1r,2.7);",
      "ripple1x = if(equal(ripple1r,0),0.01*int(rand(100)),ripple1x);",
      "ripple1y = if(equal(ripple1r,0),0.01*int(rand(100)),ripple1y);",
      "ripple1s = if(equal(ripple1r,0),0.0001*(25+int(rand(25))),ripple1s);",
      "ripple2r = (ripple2r + ripple2s)*below(ripple2r,2.7);",
      "ripple2x = if(equal(ripple2r,0),0.01*int(rand(100)),ripple2x);",
      "ripple2y = if(equal(ripple2r,0),0.01*int(rand(100)),ripple2y);",
      "ripple2s = if(equal(ripple2r,0),0.0001*(25+int(rand(25))),ripple2s);",
      "ripple3r = (ripple3r + ripple3s)*below(ripple3r,2.7);",
      "ripple3x = if(equal(ripple3r,0),0.01*int(rand(100)),ripple3x);",
      "ripple3y = if(equal(ripple3r,0),0.01*int(rand(100)),ripple3y);",
      "ripple3s = if(equal(ripple3r,0),0.0001*(25+int(rand(25))),ripple3s);",
      "q1 = if(equal(frame%3,0),ripple1x,if(equal(frame%3,1),ripple2x,ripple3x));",
      "q2 = if(equal(frame%3,0),ripple1y,if(equal(frame%3,1),ripple2y,ripple3y));",
      "q3 = if(equal(frame%3,0),ripple1r,if(equal(frame%3,1),ripple2r,ripple3r));",
      "wave_x = q1;",
      "wave_y = 1-q2;",
      "decay = decay - 0.005*equal(frame%30,0);",
      "wave_mystery = q3-0.5;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "newx = x - q1;",
      "newy = y - q2;",
      "newrad = sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2;",
      "newzoom = 1 + if(below(newrad,q3),if(above(newrad,q3 - 0.4),0.01*sin(50*newrad-10*time),0),0);",
      "dx = (newx)*newzoom - newx;",
      "dy = (newy)*newzoom - newy;",
      "zoom=zoom+.005*q4;",
      "rot=rot+.002*q5;"
    ],
