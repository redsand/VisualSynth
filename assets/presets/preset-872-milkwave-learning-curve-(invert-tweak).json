  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "vol_now =  .4 * bass + 0.1 * (bass_att + treb + mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean - 0.5 * (vol_mean-vol_now),0.1 * (vol_mean * 9 + vol_now));",
      "beat = if(above(vol_now,1.15 * vol_mean),1,0);",
      "sinbeat =sin(beat * (vol_now-vol_mean));",
      "wave_b = cos(time)  + abs(cos(time));",
      "wave_g = abs(sin(time)) ;",
      "wave_r = (-1 * cos(time))  + abs(-1 * cos(time)) + 0.2 * (cos(sin(time))+(abs(cos(sin(time)))+cos(sin(time))));",
      "ib_r = if(above(wave_r,1),1,if(above(wave_r,0), abs(wave_r),0));",
      "ib_g = if(above(wave_g,1),1,if(above(wave_g,0), abs(wave_g),0));",
      "ib_b = if(above(wave_b,1),1,if(above(wave_b,0), abs(wave_b),0));",
      "ob_r = 1 - if(above(wave_r,1),1,if(above(wave_r,0), abs(wave_r),0));",
      "ob_g = 1 - if(above(wave_g,1),1,if(above(wave_g,0), abs(wave_g),0));",
      "ob_b = 1 - if(above(wave_b,1),1,if(above(wave_b,0), abs(wave_b),0));",
      "q1 = sinbeat+.35 ;",
      "wave_mystery = vol_now;",
      "monitor = sinbeat;"
    ],
