      "// 1 - zoom in",
      "// 6 - zoom out",
      "// 2 - left",
      "// 5 - right",
      "// 3 - top",
      "// 4 - bottom",
      "",
      "// change motion?",
      "newmotion = motion + int(rand(4)) + 1;",
      "newmotion = if(above(newmotion,6),newmotion-6,newmotion);",
      "newmotion = if(equal(newmotion+motion,7),motion-1,newmotion);",
      "",
      "// change = equal(int(rand(10)),0);",
      "beat = above(bass_att,1.3);",
      "",
      "timer = if(above(timer,0),timer-1,0);",
      "change = beat*bnot(timer);",
      "//change = beat;",
      "timer = if(change,5,timer);",
      "motion = if(change,newmotion,motion);",
      "",
      "dzoom = if(change,0.02 + int(rand(10))*0.01,dzoom);",
      "dd = if(change,0.01 + int(rand(5))*0.01,dd);",
      "",
      "zoom = 1;",
      "dx = 0;",
      "dy = 0;",
      "",
      "",
      "zoom = if(equal(motion,1),1+dzoom,zoom);",
      "zoom = if(equal(motion,6),1-dzoom,zoom);",
      "",
      "dx = if(equal(motion,2),-dd,dx);",
      "dx = if(equal(motion,5),dd,dx);",
      "",
      "dy = if(equal(motion,3),-dd,dy);",
      "dy = if(equal(motion,4),dd,dy);",
      "",
      "q1 = 0.5*(1+sin(time));",
      "q2 = 0.5*(1+sin(2*time));",
      "q3 = 0.5*(1+sin(3*time));",
      "",
      "ob_r = q1;",
      "ob_g = q2;",
      "ob_b = q3;",
      "",
      "monitor = dzoom;"
