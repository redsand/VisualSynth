  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// JIAN SIMANJUNTAK CODE EDITION //",
      "",
      "// Mosaic Bass //",
      "q13=.7+.3*sin(.2*time);        //// zoom",
      "// END //",
      "",
      "// Shape Bass //",
      "tic = min(time - tin,.1);",
      "tin = time;",
      "",
      "ra = 10;",
      "",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "",
      "rb = 1;",
      "vav = tic*(vav*(1/tic - rb) + rb*(bass+treb+mid)*.33333);",
      "",
      "q1 = treb_avg;",
      "q2 = mid_avg;",
      "q3 = bass_avg;",
      "q4 = vav;",
      "",
      "",
      "tm = if(above(vav,tm),tm + tic,tm - tic*.3);",
      "td = (td + tic*tm*4)*below(td,10000);",
      "",
      "q6 = .75 + sin(td)*.25;",
      "q7 = tm;",
      " // END //",
      "",
      "// ZOOM BASS //",
      "zoom = zoom + 0.001*( 0.60*sin(0.1904*time+3) + 0.40*sin(0.275*time+9) );",
      "zoom = zoom + max(0,bass_att-1.1)*0.2;",
      "// END //"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "dx=0.009*sin(x*100+bass)*cos(q13);",
      "dy=0.009*sin(y*60+bass)*sin(q13);"
    ],
