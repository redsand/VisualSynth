    "perFrameCode": [
      "ob_size = 1;mv_x=2; mv_y=46+2*cos(time*10);",
      "// -------------------------------- Beat Detective 007 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "q8=frame%8;",
      "wave_mode = if(equal(q8,7),1,0);",
      "wave_mystery = if(equal(q8,7),-.3,-.44);",
      "wave_y=.9-q8*.13;",
      "wave_y=if(equal(q8,7),.1+.8*abs(cos(time/8)),wave_y);",
      "//wave_mystery=wave_mystery+beat*.1;",
      "wave_mystery = if( beat*below(q8,7),-.34,wave_mystery -0.05*abs(cos(time*4)));",
      "wave_mystery=if(equal(q8,0),wave_mystery*1.2,wave_mystery);",
      "q7=if(below(q8,7),wave_y,0);",
      "q6=beat;",
      "q6=if(below(frame,StopFrame),1,0);",
      "wave_r=equal(q8,0)*rc1 +equal(q8,1)*rc2+equal(q8,2)*rc3+equal(q8,3)*rc4 +equal(q8,4)*rc5 + equal(q8,5)*rc6+equal(q8,6)*rc7 +equal(q8,7)*1;",
      "wave_g=equal(q8,0)*gc1 +equal(q8,1)*gc2+equal(q8,2)*gc3+equal(q8,3)*gc4 +equal(q8,4)*gc5 + equal(q8,5)*gc6+equal(q8,6)*gc7 +equal(q8,7)*1;",
      "wave_b=equal(q8,0)*bc1 +equal(q8,1)*bc2+equal(q8,2)*bc3+equal(q8,3)*bc4 +equal(q8,4)*bc5 + equal(q8,5)*bc6+equal(q8,6)*bc7 +equal(q8,7)*1;",
      "decay = .99;"
