      "6.28-sphi,3.14+sphi));",
      "arad=sqrt(sqr(y-q2)+sqr(x-q1))*q3;",
      "atx=cos(aang+q4)*arad;",
      "aty=sin(aang+q4)*arad;",
      "ina=if(below(aty,-.4),0,if(below(aty,-.27),band(",
      "above(atx,-.05),below(atx,.05)),if(below(aty,-.2),",
      "band(above(atx,-.824*aty-.228),",
      "below(atx,1.214*aty+.348)),if(",
      "below(aty,.33),band(above(atx,-.125),",
      "below(atx,.125)),0))));",
      "dx=if(ina,.01*bass*sign(x-q1),",
      ".0015*(mid+treb_att)*sign(x-q1)*",
      "sin(12*x+25*y+7*ang+3*time+bass));",
      "dy=if(ina,.01*mid*sign(y-q2),",
      ".0015*(mid+treb_att)*sign(y-q2)*",
      "sin(17*x+31*y+5*ang+2.8*time+bass));"
