  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "slowtime = slowtime+beat*time;",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "beat = if(above(vol_now,1.5*vol_mean),1,0);",
      "ib_r=sin(cos(slowtime*0.235));",
      "ib_g=sin(cos(slowtime*0.335));",
      "ib_b=sin(cos(slowtime*0.435));",
      "redneg = if(below(ib_r,0),1,0);",
      "greenneg = if(below(ib_g,0),1,0);",
      "blueneg = if(below(ib_b,0),1,0);",
      "ib_r = 1 - (if(redneg,if(bor(greenneg , blueneg),1,1+ib_r),ib_r));",
      "ib_g = 1 - (if(greenneg,if(equal(greenneg + blueneg,2),1,1+ib_g),ib_g));",
      "ib_b =1 -  (if(blueneg,1 + ib_b, ib_b));",
      "ff = slowtime/100;",
      "wave_r = sin(5*ff/bass)/2+0.5;",
      "wave_g = cos(ff/mid)/2+0.5;",
      "wave_b = cos(3*ff/treb)/2+0.5;",
      "rot = rot + 0.040*( 0.60*sin(0.381*slowtime) + 0.40*sin(0.579*slowtime) );",
      "zoom=max(0.97, min(0.15+0.7*bass_att, 1.75 ));",
      "ob_r=sin(beat*cos(slowtime*0.735));",
      "ob_g=sin(bass*cos(slowtime*0.635));",
      "ob_b=sin(bass*cos(slowtime*0.535));",
      "redneg = if(below(ob_r,0),1,0);",
      "greenneg = if(below(ob_g,0),1,0);",
      "blueneg = if(below(ob_b,0),1,0);",
      "ob_r = 1 - (if(redneg,if(bor(greenneg , blueneg),1,1+ob_r),ob_r));",
      "ob_g = 1 - (if(greenneg,if(equal(greenneg + blueneg,2),1,1+ob_g),ob_g));",
      "ob_b =1 -  (if(blueneg,1 + ob_b, ob_b));",
      "q1 = sin(slowtime);"
    ],
