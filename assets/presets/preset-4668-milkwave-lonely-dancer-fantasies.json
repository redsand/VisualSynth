  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "decay=.30;",
      "",
      "meanmid = 0.01*(meanmid*99+mid);",
      "middiff = (mid - meanmid)*15;",
      "mi = min(above(middiff,0)*middiff*.005,.11);",
      "",
      "mi_prg = mi_prg+mi;",
      "gam = abs(gam-above(mi_prg,.5));",
      "mi_prg= if(above(mi_prg,.5),0,mi_prg);",
      "q1=gam;",
      "monitor =mi_prg;",
      "",
      "//Thanks to krash for beat detection (modified)",
      "volume = 0.3*bass+mid;",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "runmeanbass =(runmeanbass*2 + bass_att)/3;",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beat = above(volume,0.8)*above(bass_att,runmeanbass*1.1)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.95 + (1-above(time - lastbeat, 2*beatrate))*0.995);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "",
      "flag=if(beat,INT(rand(6)),flag);",
      "flag=if(above(flag,6),0,flag);",
      "mov= if(beat,oldecho,mov+if(equal(flag,0),.005,-.002));",
      "mov=if(below(mov,.111),.111,mov);",
      "echo_zoom =",
      "if(equal(flag,0),mov",
      ",if(equal(flag,1),mov",
      ",if(equal(flag,2),.330",
      ",if(equal(flag,3),.199",
      ",if(equal(flag,4),2.7",
      ",echo_zoom)))));",
      "oldecho = echo_zoom;"
    ],
    "perFrameInitCode": [
      "q1=acos(-1)*2;"
    ],
    "perPixelCode": [
      "",
      "",
      "",
      "DY =dy-.004*below(y,1)*(rad+.1)*bass;//*(1-below(y,.50)*above(y,.479));",
      "//zoom=zoom+above(y,.49)*.1;",
      "sx = sy-below(y,1)*.001;",
      "dx=dx+.01*bass*(1-q1*2);//sin(bass*.2);",
      "rot=rot+.051*below(y,1);//*(1-below(y,.49)*above(y,.47));",
      "cx=int(x*16)/16;",
      "cy=int(y*16)/16;"
    ],
