  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// sensor - alpha",
      "// le = signal level; desired average value = 2",
      "// th = threshold",
      "le=1.4*bass_att+.1*bass+.5*treb;",
      "pulse=band(above(le,th),above(le-th,block));",
      "block=le-th;",
      "th=if(above(le,th),le+114/(le+10)-7.407,",
      "th+th*.07/(th-12)+below(th,2.7)*.1*(2.7-th));",
      "th=if(above(th,6),6,th);",
      "",
      "// pulse cycler",
      "pcl=if(pulse,pcl+1,pcl);",
      "q1=pcl;",
      "",
      "ib_r=.5+.5*sin(pcl)+.3*sin(time*2.2);",
      "ib_g=.5+.5*sin(pcl*1.1)+.3*sin(time*2.1);",
      "ib_b=.5+.5*sin(pcl*1.2)+.3*sin(time*2);",
      "mv_r=ib_g;",
      "mv_g=ib_b;",
      "mv_b=ib_r;",
      "wave_r=1-ib_r;",
      "wave_g=1-ib_g;",
      "wave_b=1-ib_b;",
      "",
      "// level cycler",
      "levccl=levccl+le;",
      "q2=.1*levccl;",
      "",
      "mvx=if(pulse,int(rand(2))*int(rand(25)),mvx);mv_x=mvx;",
      "mvy=if(pulse,int(rand(2))*int(rand(19)),mvy);mv_y=mvy;",
      "",
      "q3=.5+.2*sin(23*pcl)+.2*sin(.023*levccl);",
      "wave_x=q3;",
      "q4=.5+.2*sin(24*pcl)+.2*sin(.02*levccl);",
      "wave_y=1-q4;",
      "thavg=.5*thavg+.5*th;",
      "q6=.2*thavg;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "// coordinates transfomation",
      "// q3,q4 = position; q6 = 1/size;",
      "aang=atan2(y-q4,x-q3);",
      "arad=sqrt(sqr(y-q4)+sqr(x-q3))*q6;",
      "atx=cos(aang)*arad;",
      "aty=sin(aang)*arad;",
      "",
      "boxzone=below(arad,.1);",
      "",
      "fxzone=band(band(above(x,.1),below(x,.9)),",
      "band(above(y,.1),below(y,9)));",
      "",
      "",
      "zoom=zoom+(1-boxzone)*if(fxzone,(-.2+.3*sin(3*q1)),-.2);",
      "rot=(1-boxzone)*fxzone*(3.142*sin(12*q1));",
      "",
      "dx=.01*bor(band(above(x,.05),below(x,.1)),above",
      "(x,.95))-.01*bor(below(x,.05),band(above(x,.9),below(x,.95)));",
      "dy=.01*bor(band(above(y,.05),below(y,.1)),above",
      "(y,.95))-.01*bor(below(y,.05),band(above(y,.9),below(y,.95)));",
      "",
      "dx=if(boxzone,.1*atx,dx+fxzone*(.05*sin(q1+(9+4*sin(q1*2.3))*x+",
      "(6+3*sin(q1*2.4))*y+q2)+sin(q1*13)));",
      "dy=if(boxzone,.1*aty,dy+fxzone*(.05*sin(q1+(8+4*sin(q1*2.2))*x+",
      "(5+3*sin(q1*2.1))*y+q2*1.2)+sin(q1*14)));"
    ],
