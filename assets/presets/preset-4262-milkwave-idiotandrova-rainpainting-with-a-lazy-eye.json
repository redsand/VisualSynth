  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).xyz;\n\n    // motion blur:\n    // 'v' points exactly one pixel, in the direction of motion\n    vec2 v = normalize(vUv-vUvOriginal)*uTexSize.zw;\n    vec3 s;\n    ret = max(ret, texture(sampler_main, vUv+v*-1)*0.90);\n    ret = max(ret, texture(sampler_main, vUv+v* 1)*0.97);\n    ret = max(ret, texture(sampler_main, vUv+v* 2)*0.97);\n    ret = max(ret, texture(sampler_main, vUv+v* 3)*0.90);\n\n    // darken over uTime\n    ret *= 0.92;\n\n    // add noise\n    //vec2 uv_noise = vUv*texsize_noise_lq.zw*uTexSize.xy + rand_frame.xy;\n    //ret += (texture(sampler_noise_lq, uv_noise)*2-1)*0.02;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "beatcounter = if(above(beat,0),beatcounter +1, beatcounter);",
      "beatcounter = if(above(beatcounter,7), 0, beatcounter);",
      "beateven = beatcounter%2;",
      "drip1grav = if(beateven,0.001*(1+(3*bass)),drip1grav) + equal(drip1grav,0)*0.05;",
      "drip1x = if(beat,0.5*beateven +0.005*int(rand(100)),drip1x);",
      "drip1y = if(beat,0,drip1y);",
      "drip2grav = if(beateven,0.001*(1+(3*treb)),drip2grav) + equal(drip2grav,0)*0.06;",
      "drip2x = if(beat,0.5*beateven +0.005*int(rand(100)),drip2x);",
      "drip2y = if(beat,0,drip2y);",
      "drip3grav = if(beat,0.001*(1+(3*mid)),drip3grav) + equal(drip3grav,0)*0.07;",
      "drip3x = if(beat,0.5*beateven +0.005*int(rand(100)),drip3x);",
      "drip3y = if(beat,0,drip3y);",
      "drip4grav = if(beat,0.001*(1+(1*(mid+treb+bass))),drip4grav) + equal(drip4grav,0)*0.08;",
      "drip4x = if(beat,0.5*beateven +0.005*int(rand(100)),drip4x);",
      "drip4y = if(beat,0,drip4y);",
      "drip1y = min(0.001 + drip1y + drip1grav,1.2);",
      "drip2y = min(0.001 + drip2y + drip2grav,1.2);",
      "drip3y = min(0.001 + drip3y + drip3grav,1.2);",
      "drip4y = min(0.001 + drip4y + drip4grav,1.2);",
      "q1 = if(equal(frame%4,0),drip1x,if(equal(frame%4,1),drip2x,if(equal(frame%4,2),drip3x,drip4x)));",
      "q2 = if(equal(frame%4,0),drip1y,if(equal(frame%4,1),drip2y,if(equal(frame%4,2),drip3y,drip4y)));",
      "wave_r = wave_r + 0.350*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );",
      "wave_g = wave_g + 0.350*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );",
      "wave_b = wave_b + 0.350*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );",
      "ob_r = 1-wave_b;",
      "ob_g = wave_r;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "dy = if(below(abs(q1-x),0.01),if(below(y,q2),max(0.02-abs(q1-x),0),0.001),0.001+-raD*.01-.03)+.05;",
      "//sy = 1+ if(above(bass,1),0.02*(bass+bass_att),0);",
      "//sy = if(dy,sy,2);"
