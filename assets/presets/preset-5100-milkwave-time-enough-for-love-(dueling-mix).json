  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "",
      "x1 = 0.5 + 0.15*sin(0.416*time) + 0.15*sin(0.832*time) + 0.1*sin(1.324*time);",
      "x2 = 0.5 + 0.15*sin(0.341*time) + 0.15*sin(0.768*time) + 0.1*sin(1.523*time);",
      "y1 = 0.5 + 0.15*sin(0.287*time) + 0.15*sin(0.913*time) + 0.1*sin(1.142*time);",
      "y2 = 0.5 + 0.15*sin(0.531*time) + 0.15*sin(0.671*time) + 0.1*sin(1.442*time);",
      "",
      "ob_r = 0;",
      "ob_g = pow(abs(sign(sin(slowtime))),2)*sin(slowtime);",
      "ob_b= cos(slowtime)*sign(cos(slowtime))*pow(abs(sign(sin(slowtime))),2);",
      "",
      "redneg = if(below(ob_r,0),1,0);",
      "greenneg = if(below(ob_g,0),1,0);",
      "blueneg = if(below(ob_b,0),1,0);",
      "wave_r = 1 - (if(redneg,if(bor(greenneg , blueneg),1,1+ob_r),ob_r));",
      "wave_g = 1 - (if(greenneg,if(equal(greenneg + blueneg,2),1,1+ob_g),ob_g));",
      "wave_b =1 -  (if(blueneg,1 + ob_b, ob_b));",
      "",
      "volume = 0.3*(bass+mid);",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beat = above(volume,0.7)*below(peakbass_att - bass_att, 0.3*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.99 + (1-above(time - lastbeat, 2*beatrate))*0.998);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "mode = if(beat,abs(mode-1),mode);",
      "",
      "slowtime = slowtime+beat*time;",
      "framehalf = frame%2;",
      "q1 = if(framehalf,x1,x2);",
      "q2 = if(framehalf,y1,y2);",
      "q3 = equal(mode,framehalf)*(0.5*sin(0.814*slowtime) + 0.5*(0.654*slowtime));",
      "",
      "q4 = equal(mode,framehalf)*(5 + 0.2*sin(slowtime*0.385) + 0.2*sin(slowtime*0.641) + 0.2*sin(slowtime*0.846));",
      "q5 = 8 - 6*equal(mode,framehalf);",
      "",
      "wave_x = q1;",
      "wave_y = 1-q2;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "newx = x - q1;",
      "newy = y - q2;",
      "newrad = sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2;",
      "newang = atan2(newx,newy);",
      "newzoom = pow(1.04 + 0.05*sin(q4*(newang+q3)), pow((0.01-0.2*newrad)+sin(newrad*newrad), newrad*q5-1));",
      "dx = (newx)*newzoom - newx;",
      "dy = (newy)*newzoom - newy;"
    ],
