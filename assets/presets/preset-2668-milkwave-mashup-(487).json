  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n\nret = GetPixel(vUv) + (GetBlur2(vUv)) ;\n\n//ret +=.1- .1*clamp01(1-4*lum(ret)) * lum(GetBlur1(vUv-.2));\nret += .2*(1-vUv.y)*(hue_shader-.8)*4;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "flen = 512; //Wave Punkte",
      "reg00 = FLen;",
      "SLen = FLen/2;",
      "dec_m = pow(.94, 30/fps);",
      "",
      "//Volume",
      "n = 0; vol = 0;",
      "loop (SLen,",
      "  vol = vol + pow(gmegabuf(n),2)/FLen;",
      "  n = n+1;",
      ");",
      "vol = sqrt(vol)/2;",
      "vol_ = vol_*dec_m + (1-dec_m)* (vol);",
      "",
      "//switches",
      "lev1 = lev1 * dec_m + (1-dec_m) * gmegabuf(1);",
      "lev2 = lev2 * dec_m + (1-dec_m) * gmegabuf(20);",
      "lev3 = lev3 * dec_m + (1-dec_m) * gmegabuf(50);",
      "lev4 = lev4 * dec_m + (1-dec_m) * gmegabuf(100);",
      "sw1 = sw1 + (lev1-gmegabuf(1)>0)/fps;",
      "sw2 = sw2 + (lev2-gmegabuf(20)>0)/fps;",
      "sw3 = sw3 + (lev3-gmegabuf(50)>0)/fps;",
      "sw4 = sw4 + (lev4-gmegabuf(100)>0)/fps;",
      "",
      "dif = (1+sin(sw3/4))*16+2;",
      "ofs = sin(sw2/3)*8;",
      "n = 0; k1 = frame*0;",
      "loop (SLen,",
      "      m1 = (n)%SLen;",
      "      m2 = (n+ofs)%SLen;",
      "",
      "      k = (m1+dif)%SLen;",
      "      i = (SLen+m2-dif)%SLen;",
      "",
      "      in1 = (gmegabuf(m1)-gmegabuf(k))/pow(vol_+.03,.8)*1.2;",
      "      in2 = (gmegabuf(m2)-gmegabuf(i))/pow(vol_+.03,.8)*1.2;",
      "",
      "      dec = if (pow(gmegabuf(2000+n),2) + pow(gmegabuf(2000+FLen+n),2)> in1*in1+in2*in2,.8,.94) ;",
      "      dec = pow (dec, 30/fps);",
      "",
      "      gmegabuf(2000+n) =       gmegabuf(2000+n)*dec      +(1-dec)* in1;",
      "      gmegabuf(2000+FLen+n) =  gmegabuf(2000+FLen+n)*dec +(1-dec)* in2;",
      "      n=n+1;",
      ");",
      "",
      "q1 = (bass+treb+mid)/3;",
      "q2 = (bass_att+treb_att+mid_att)/3;",
      "q3 = vol_;",
      "q11 = sw1;",
      "q12 = sw2;",
      "q13 = sw3;",
      "q14 = sw4;",
      "",
      "rot = 0; zoom = .98; warp = .3; rot = 0;",
      "",
      "q32 = aspecty;",
      "monitor = dif;"
    ],
    "perFrameInitCode": [
      "n = 0;",
      "loop (50000,",
