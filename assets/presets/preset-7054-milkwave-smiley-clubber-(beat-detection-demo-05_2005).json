  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "ob_size=0;",
      "decay = .9; zoom=1;",
      "// -------------------------------- beat detection code ----------------------------------",
      "// - one time init",
      "sure=if(equal(sure,0),.5,sure);",
      "interval=if(equal(interval,0),.7*FPS,interval);",
      "avginterval=if(equal(avginterval,0),.7*FPS,avginterval);",
      "lockinterval=if(equal(lockinterval,0),.7*FPS,lockinterval );",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "// - do main calcs",
      "dbass=(bass-pbass)*FPS;",
      "beat=above(dbass,.5*avgbass*maxdbass)*above(bass,avgbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "// - value decay and clipping",
      "avgbass=.995*avgbass+.005*bass;",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=min(200,maxdbass);",
      "maxdbass=max(.02,maxdbass);",
      "interval=if(beat*below(frame-lastbeat,1.8*interval), ((frame-lastbeat)*.25+.75*interval),interval);",
      "// - update vars",
      "lastbeat=if((1-force)*beat+equal(lastbeat+interval,frame),frame,lastbeat);",
      "avginterval=if(beat,.9*avginterval+.1*interval, avginterval);",
      "lockinterval=if(beat,.9*lockinterval+.1*avginterval,lockinterval);",
      "pbass=bass;",
      "bpm=60*FPS*.3333*( (1/interval)+(1/avginterval)+(1/lockinterval) );",
      "phase=min( (frame-lastbeat)/(.333*(avginterval+interval+lockinterval)), 1 );",
      "// - clip frame intervals",
      "interval=min(interval,.7*FPS);",
      "avginterval=min(avginterval,.7*FPS);",
      "lockinterval=min(lockinterval,.7*FPS);",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "//////////////////////////////////////////////////",
      "// Turn the variable monitor on to watch the BPM     (and wait to get it right!)",
      "//////////////////////////////////////////////////",
      "",
      "q1=phase;",
      "q8=above(frame-lastbeat,2.5*interval)* min( (frame-lastbeat)/interval-2,1 );",
      "myq8=above(frame-lastbeat,1.2*interval)* min( (frame-lastbeat)/interval-1,1 );",
      "mytime=if( equal(q8,0), mytime+1/FPS, mytime );",
      "q2=mytime;",
      "dir=-1+2*(int(mytime/5)%2);",
      "totalbeats=totalbeats+beat;",
      "q4=totalbeats/6;",
      "p2=mytime*.2-int(mytime*.2);",
      "q5=if( equal(dir,1), p2, 1-p2 );",
      "p2=(mytime+1)*.2-int((mytime+1)*.2);",
      "dir=-1+2*(int((mytime+1)/5)%2);",
      "q3=if( equal(dir,1), p2, 1-p2 );",
      "q6=.15+( max( (min(bpm,160)-100) ,0) /60)* .425*sin(q1*3.1415);",
      "ob_size=beat;",
      "monitor=bpm;"
    ],
