  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvUv *=2 ;\nvec2 m = floor(fract(vUv*0.5)*2);\nvUv = fract(vUv)*(1-m) + (m)*fract(1-vUv);\n\nvec2 d = uTexSize.zw * 4;\nvec3 dx = ( GetBlur2(vUv + vec2(1,0)*d) - GetBlur2(vUv - vec2(1,0)*d) );\nvec3 dy = ( GetBlur2(vUv + vec2(0,1)*d) - GetBlur2(vUv - vec2(0,1)*d) );\n\n    ret = texture(sampler_main, vUv).xyz;\n    ret *= 1.00; //gamma\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "",
      "db=(bass-lbass)*fps;",
      "//dt=(treb-ltreb)*fps;",
      "",
      "ltreb=treb;",
      "//lbass=bass;",
      "",
      "avgdb=avgdb*.9+abs(db)*.1;",
      "//avgdt=avgdt*.9+abs(dt)*.1;",
      "",
      "avgdb2=avgdb2*.99+abs(db)*.01;",
      "//avgdt2=avgdt2*.99+abs(dt)*.01;",
      "",
      "",
      "//beatdection",
      "rbeatb=above(abs(db),avgdb*2);",
      "//rbeatb2=above(abs(dt),avgdt*3);",
      "//rbeatb=above(avgdb,avgdb2*1.618);",
      "//rbeatb2=above(avgdt,avgdt2*1.618);",
      "",
      "beatb=rbeatb*above(time-lbt,avgbr*.75);",
      "//beatb2=rbeatb2*above(time-lbt2,avgbr2*.75);",
      "",
      "",
      "",
      "// custom beat detection code: (fps-independent; quiet songs don't freak out)",
      "decay_rate = pow(0.993, fps);  // lower # = more hasty to declare a beat",
      "min_att    = 2.5;               // lower # = quieter songs can declare beats",
      "decay_to   = 1.0;               // lower # = more hasty to declare a beat",
      "beat =           bass/max(min_att,bass_att);",
      "beat = max(beat, mid /max(min_att,mid_att ));",
      "beat = max(beat, treb/max(min_att,treb_att));",
      "beat = max( beat, (prev_beat-decay_to)*decay_rate + decay_to );",
      "beat_level     = (beat - prev_beat - 0.07)*24+1;",
      "is_beat = above(beat_level, 0.5);",
      "prev_beat = beat;",
      "  // put your beat responses HERE:",
      "//monitor = beat_level;",
      "beatb2 = is_beat;",
      "",
      "//beatrate calc",
      "avgbr=beatb*(avgbr*.99+(time-lbt)*.01)+(1-beatb)*(avgbr+(3-avgbr)*.00001); // avg beat rate",
      "avgbr2=beatb2*(avgbr2*.99+(time-lbt2)*.01)+(1-beatb2)*(avgbr2+(3-avgbr2)*.00001);",
      "",
      "lbt=time*beatb+(1-beatb)*lbt; //last beat time",
      "lbt2=time*beatb2+(1-beatb2)*lbt2;",
      "",
      "",
      "ph=(time-lbt)*(60/avgbr)*const;",
      "phase=max(min( ph, 1 ),0);",
      "const=const*(1-beatb)+beatb*( const+ (.002*bool) );",
      "bool=below(phase,.98)*(.98-ph)-above(phase,.98)*(ph*.5);",
      "",
      "ph2=(time-lbt2)*(60/avgbr2)*const2;",
      "phase2=max(min( ph2, 1 ),0);",
      "const2=const2*(1-beatb2)+beatb2*( const2+ (.002*bool2) );",
      "bool2=below(phase2,.98)*(.98-ph2)-above(phase2,.98)*(ph2*.5);",
      "",
      "",
      "",
      "bc=bc+beatb;",
      "bc2=bc2+beatb2;",
      "//vol=(rawbeatb*abs(db)*.001);",
      "//avgvol=avgvol*.999+vol*.01;",
      "",
      "mtime=mtime+( (avgdb*avgbr)*.1 )*(1/fps);",
      "mtime2=mtime2+( (avgdt*avgbr2)*.1 )*(1/fps);",
      "q1=1-phase;",
      "q2=1-phase2;",
      "q3=bc;",
      "q4=bc2;",
      "",
      "",
      "",
      "q5=mtime;",
      "q6=mtime2;",
      "q7=sin(mtime)*.5+.5;",
      "q8=sin(mtime2)*.5+.5;",
      "q9=sin(mtime*.01)*.5+.5;",
      "q10=sin(mtime2*.01)*.5+.5;",
      "q11=avgdb;",
      "q12=avgdt;",
      "",
      "q14=60/avgbr;",
      "q15=60/avgbr2;",
      "q20=beatb;",
      "q21=beatb2;",
      "q22=bc%4;",
      "q23=bc2%4;",
      "monitor=q1;",
      "decay=1;",
      "//warp=0;",
      "wrap=1;",
      "",
      "// FLAMES EDITION //",
      "q1 = (bass_att + mid_att + treb_att) /3;",
      "q2 = time + 1000;",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.4)*0.95+1.4);",
      "treb_thresh = above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.5)*0.85+1.2);",
      "bass_on = above(bass_thresh,1.9);",
      "treb_on = above(treb_thresh,1.9);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "dy = -0.1*(q1-1)*log(2-(abs(y*2 - 1.8)));",
      "dy = below(dy,0.02)*dy - 0.02;",
      "dy = dy + 0.01*(sin((x*q2*0.483) + (y*q2*1.238)) + sin((x*q2*1.612) + (y*q2*0.648)));"
    ],
