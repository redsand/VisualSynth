  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "//zoom = 1;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "vol = (bass_att + treb_att + mid_att)*.333333;",
      "",
      "ra = 1/tic*.25;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "",
      "ra = 1/tic*.05;",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav*.2;",
      "toc = 1;",
      "",
      "zoom = 1 - vav*.03;",
      "sy = 1 - vav*.05;",
      "",
      "q1 = bt*.4;",
      "q2 = mt*.4;",
      "q3 = tt*.4;",
      "",
      "q4 = vav*.3;",
      "",
      "monitor = vav;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "num = 8;",
      "pi = 3.141592654;",
      "radi = (y-.5)*.75;",
      "radi = (y-.5);",
      "radi = pow(radi*radi + (x-.5)*(x-.5),.5);",
      "",
      "an = ang + pi + time;",
      "an = an - pi*2*int(an/(pi*2));",
      "",
      "mod = .1;",
      "",
      "seg = ang + pi;",
      "seg = seg/(pi*2)*num;",
      "seg = int(seg);",
      "seg = seg - equal(seg,num);",
      "",
      "anga = (ang + pi) - (pi*2/num)*seg;",
      "anga = if(equal(seg%2,0),(pi*2/num) - anga,anga);",
      "//anga = anga + pi/6; // num = 6",
      "anga = anga + pi/4; // num = 8",
      "//anga = anga + .85; // num = 10",
      "",
      "",
      "ox = .5 - radi*sin(anga);",
      "oy = .5 + radi*cos(anga);",
      "",
      "",
      "dx = equal(seg,3)*(x-ox);",
      "dy = equal(seg,3)*(y-oy);",
      "",
      "dx = above(seg,0)*(x-ox);",
      "dy = above(seg,0)*(y-oy);",
      "",
      "//dx = equal(seg,1)*(x - .5)*2;",
      "",
      "//zoom = zoom + equal(seg,0)*below(int(rand(100)),q4*3)*12;"
    ],
