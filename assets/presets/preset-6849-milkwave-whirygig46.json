      "zoom=1;",
      "cx=.5;",
      "cy=.5;",
      "warp=0;/////////////////////////////////////////////////////",
      "",
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "zoom = zoom + 0.01;",
      "zoom = zoom + (0.05 + 0.04*sin(time))*(0.2*sin(ang*time));",
      "rot = rot + 0.01*(0.5*cos(ang*5*bass*time));",
      "",
      "dx = dx + 0.1*above(rad,0.25)*dx_r;",
      "dy = dy + 0.1*above(rad,0.25)*dy_r;",
      "rot=0.1*pow(-ang,3)-1.18*sin(ang);",
      "zoom=1.45*sin(-rad)+1.3+ sin(rad);",
      "dx = dx + 0.09*sin(q8*0.785);",
      "dy = dy + 0.09*sin(q8*0.675);",
      "//zoom = zoom +q7;",
      "",
      "",
      "zoom = zoom + (0.2*(2.1*cos(6*bass_att*sin(2*bass_att)",
      "*cos((4*rad*bass)+cos(9*bass))*0.5-rad)))*(0.5-rad);",
      "zoom = zoom  - 0.02*(2.1*tan(6*mid_att*sin(2*mid_att)",
      "*cos((4*rad*treb)+cos(9*treb))*0.5-rad))*(1.8-rad);",
      "///////////////////////////////////////",
      "cr1=(int(sin(mid*1)/2+.5+.041));",
      "cr2=cr1;",
      "crx=cr2-cr1;",
      "ci=rad;",
      "cb=.25  ;",
      "crs=2;",
      "cr=pow(sin(ci*6.3-(cb*6.3))/2+.5,crs)*crx+cr1;",
      "cqr=if( above (ci,.25+cb),cr,crx+cr1);crr=if( below(ci,1.5),cqr,crx+cr1);",
      "jx1=crr;",
      "kx1=1-crr;",
      "",
      "ojdx=dx;",
      "ojdy=dy;",
      "ojsx=sx;",
      "ojsy=sy;",
      "ojrt=rot;",
      "ojzm=zoom;",
      "ojcx=cx;",
      "ojcy=cy;",
      "ojwp=warp;",
      "",
      "dx=(jx1*ojdx+kx1*okdx);",
      "dy=(jx1*ojdy+kx1*okdy);",
      "sx=(jx1*ojsx+kx1*oksx);",
      "sy=(jx1*ojsy+kx1*oksy);",
      "rot=(jx1*ojrt+kx1*okrt);",
      "zoom=(jx1*ojzm+kx1*okzm);",
      "cx=(jx1*ojcx+kx1*okcx);",
      "cy=(jx1*ojcy+kx1*okcy);",
      "warp=(jx1*ojwp+kx1*okwp);////////////////////////////////////////////////////"
