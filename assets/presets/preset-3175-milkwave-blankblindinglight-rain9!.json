      "q13=.4+sin(atime*.00598593455)*.4;",
      "monitor=q13;",
      "q4=sin(atime*.03);",
      "q5=cos(atime*.030383824);",
      "q6=tan(atime*.029384834);",
      "dec_med = pow (0.7, 30/fps);",
      "dec_slow = pow (0.99, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "",
      "beat = bass+mid+treb;",
      "beat = beat*beat;",
      "",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, 1.2*avg+peak) * above (time, t0+.2);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %8;",
      "indexa = (indexa + is_beat) %5;",
      "index2 = (index2 + is_beat*bnot(index))%2;",
      "",
      "q20 = avg;",
      "q21 = beat;",
      "q22 = peak;",
      "q23 = index;",
      "q24 = is_beat;",
      "q26 = bass_att + mid_att + treb_att + 1;",
      "q27 = index + 1;",
      "q28 = -index2 + indexa/5;",
      "q29 = index2;",
      "monitor = q29;",
      "k1 =  is_",
      "beat*equal(index%2,0);",
      "p1 =  k1*(p1+1) + (1-k1)*p1;",
      "p2 = dec_med * p2+ (1-dec_med)*p1;",
      "rott = p2 * 3.1416/4;",
      "",
      "q1 = cos(rott);",
      "q2 = sin(rott);",
      "q3 = -q2;",
      "q4 = q1;",
      "",
      "ds = ds*dec_med + q24*(1-dec_med);",
      "q25 = q24;",
      "//q25 = above(ds,.5);",
      "",
      "q10 = above (q2,.5);",
      "",
      "t_rel = time*8;",
      "//q25 = below((t_rel)-int(t_rel),.2);",
      "",
      "",
      "p3 = p3*dec_med + (1-dec_med) * (100*index + .0*q26);",
      "q30 = p3 ;",
      "",
      "p4 = dec_med*p4 + (1-dec_med)*q27;",
      "q31 = p4;",
      "",
      "zoom = 1.0;",
      "warp = 0;",
