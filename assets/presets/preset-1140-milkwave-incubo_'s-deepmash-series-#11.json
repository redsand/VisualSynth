  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    vUv = 0.05 + 0.9*vUv;\n\n    // equivalent of a laplacian: [center*4 - each of the 4 neighbors*1]\n    ret = 0;\n    ret += texture(sampler_main, vUv ).xyz;\n    ret += .25*GetBlur1(vUv);\n\n    vec2 uv_echo;\n    uv_echo.x = (vUv.y - 0.5)*(-1) + 0.5;\n    uv_echo.y = vUv.x;\n\n    vec3 ret2;\n    ret2 = texture(sampler_main, uv_echo ).xyz;\n    ret2 += .25*GetBlur1(uv_echo);\n\n    vec2 uv_echo2;\n    uv_echo2.y = (vUv.x - 0.5)*(-1) + 0.5;\n    uv_echo2.x = vUv.y;\n\n    vec3 ret3;\n    ret3 = texture(sampler_main, uv_echo2 ).xyz;\n    ret3 += .25* GetBlur1(uv_echo2);\n\n    vec2 uv_echo3;\n    uv_echo3 = (vUv - 0.5)*vec2(-1,-1) + 0.5;\n\n    vec3 ret4;\n    ret4 = texture(sampler_main, uv_echo3 ).xyz;\n    ret4 += .25*GetBlur1(uv_echo3);\n\n\n    ret = mix(0.5*mix(ret3,ret4,.5),0.5*mix(ret,ret2,.5),.5);\n\n\n    // little bit of noise:\n    ret *= 1 + 0.05*(texture(sampler_noise_lq, rand_frame.xy\n           + vUv*uTexSize.xy*texsize_noise_lq.zw).xxx*2-1);\n\n    // palettize:\n    ret = pow(ret, vec3(0.5, 0.5, 0.7));\n\n    ret = (ret-0.1)*2;\nret *= ret;\nret *= 7.2575654;\nret = pow(ret,1-ret);\n    //ret.xyz *= 2; // a little bit of overbright\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "dec_m = pow (0.85, 30/fps); dec_s = pow (0.95, 30/fps);",
      "",
      "beat = bass+mid+treb;",
      "avg = avg*dec_s + beat*(1-dec_s);",
      "is_beat = above(beat, .4+avg+peak) * above (time, t0+.2);",
      "t0a = if(bnot(is_beat),t0a,t0);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_m;",
      "index = (index + is_beat) %32;",
      "index2 = (index2 + is_beat*bnot(index))%8;",
      "",
      "q20 = avg;",
      "q22 = peak;",
      "q24 = is_beat;",
      "q27 = index +1;",
      "q28 = index2;",
      "ZDist =  .25 + .5*pow(sin(zang_/2),2) ; //zoom ;",
      "q29 = .08/ZDist ;",
      "q31 = ZDist;",
      "trig = q24 * bnot(index%8);",
      "sw0 = if (bnot(trig),sw0,1-above(int(rand(100)),90));",
      "",
      "",
      "trig = q24 * bnot(index%4);",
      "sw1 = if (bnot(trig), sw1, int(rand(5)-2)*3.1416/2);",
      "sw2 = if (bnot(trig), sw2, int(rand(8))-4);",
      "",
      "trig = q24 * above (abs(beat-avg), 2) * bnot(index%4);",
      "//speed = .2 * sw2 * ZDist * pow(xang,2) + .1;",
      "fps_ = fps_ * dec_s + (1-dec_s) * min(fps/30,2);",
      "speed = (.4 + (index2%2)*.3)*ZDist;",
      "dir = dir + min(max(sw1-dir,-.5),.5)/fps*16;",
      "monitor = speed;",
      "",
      "movx = movx + cos(dir)/fps*speed ;",
      "movy = movy + sin(dir)/fps*speed ;",
      "q5 = movx; q6 = movy;;",
      "",
      "trig = q24 * bnot((index+8)%20);",
      "sw4 = if (bnot(trig), sw4, sin(int(rand(100)))*.7);",
      "xang = xang + min(max(sw4-xang,-.2),.2)/fps*4;",
      "",
      "trig = q24 * bnot(index%12);",
      "sw3 = if (bnot(trig), sw3, sw3+int(rand(4)-2)*3.1416/2);",
      "pulse = q27 * bnot((2+index2)%4)*3.1416/2*0;",
      "zang_ = zang_ + max(min(sw3-zang_,.1),-.1)/fps*16;",
      "//pulse = q27*1.57*bnot(index2%3);",
      "zang = zang_ + cos((movx-movy)/3)*2;",
      "yang = (.8-abs(xang))*sin(movy+movx);",
      "",
      "ox = -0; oy = .0; oz = ZDist;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;oz = mz;",
      "q11=ox; q12 = oy; q13 = oz; //Position",
      "",
      "//Vektor x nach rechts",
      "ox = 1; oy = 0; oz = 0;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;oz = mz;",
      "q14=ox; q15 = oy; q16 = oz;",
      "",
      "",
      "//Vektor z nach hinten",
      "ox = 0; oy = 0; oz = 1;;",
      "",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;",
      "oz = mz;",
      "q17=ox; q18 = oy; q19 = oz;"
    ],
