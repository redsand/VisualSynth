  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "basstime = basstime + bass*0.03;",
      "q1 = basstime*2;",
      "",
      "basstime = basstime + bass_att*0.03;",
      "vol = pow(bass+mid+treb,2);",
      "vol = vol*above(vol,0.1);",
      "",
      "basssum = vol;",
      "",
      "stickybit = time%2;",
      "",
      "//avg vol",
      "//buffer 1",
      "volAvg = volAvg + vol*equal(stickybit,1);",
      "//number of samples 1 or framerate",
      "sample1 = sample1 + equal(stickybit,1);",
      "//buffer 2",
      "volAvg2 = volAvg2 + vol*equal(stickybit,0);",
      "//number of samples 2",
      "sample2 = sample2 + equal(stickybit,0);",
      "",
      "//transision",
      "edge = bnot(equal(bit2,stickybit));",
      "",
      "volAvg = volAvg - volAvg*edge*stickybit;",
      "volAvg2 = volAvg2 - volAvg2*edge*equal(stickybit,0);",
      "",
      "sample1 = sample1  - sample1*edge*stickybit;",
      "sample2 = sample2  - sample2*edge*equal(stickybit,0);",
      "",
      "//test vol against avg buffer lvl",
      "diff = if(equal(stickybit,1), (basssum/(volAvg2/sample2)) , 0);",
      "diff = if(equal(stickybit,0), (basssum/(volAvg/sample1)), diff);",
      "",
      "q3 = diff;",
      "",
      "bit2 = time%2;",
      "",
      "difftime = difftime + diff*0.03;",
      "q2 = difftime;",
      "",
      "//fix a strange error",
      "difftime = if(above(difftime,2000),0, difftime);",
      "",
      "state = state + above(diff,3);",
      "state = if(above(state,7),1,state);",
      "",
      "q4 = state;",
      "",
      "//custom shape tex size",
      "tex_saw = tex_saw -0.002*q3*bnot(equal(lock,1));// - equal(lock,0)*0.0001;",
      "flag = below(tex_saw,0.1);",
      "state_echo = state_echo + flag;",
      "tex_saw = if(below(tex_saw,0.1),0.35,tex_saw);",
      "q6 = tex_saw;",
      "",
      "//obtain lock while zooming out",
      "lock = if(equal(lock,0),bnot(equal(flag, prev_edge)),1);",
      "",
      "//gradient zoom out",
      "lock = if(equal(state_echo,0),0,lock);",
      "lock = if(equal(state_echo,1),0,lock);",
      "lock = if(equal(state_echo,2)*(below(zoomy,0.3505)),0,lock);",
      "lock = if(equal(state_echo,3)*(below(zoomy,0.205)),0,lock);",
      "",
      "zoomy = zoomy - zoomy*0.02*lock;",
      "",
      "zoomy = equal(state_echo,4)*1.05 + bnot(equal(state_echo,4))*zoomy;",
      "echo_zoom = zoomy;",
      "",
      "monitor  = tex_saw;",
      "",
      "state_echo = if(above(state_echo,3),0,state_echo);",
      "//for edge detection",
      "prev_edge = flag;"
    ],
    "perFrameInitCode": [
      "flag = 0;",
      "zoomy = 1;",
      "lock = 1;",
      "edge =0;"
    ],
    "perPixelCode": [
      "saw_r = saw_r + 0.0001*bass;",
      "saw_r =  if(above(saw_r,1),0,saw_r);",
      "",
      "saw_g = saw_g + 0.00012*bass;",
      "saw_g =  if(above(saw_g,1),0,saw_g);",
      "",
      "saw_b = saw_b + 0.00011*bass;",
      "saw_b =  if(above(saw_b,1),0,saw_b);",
      "",
      "",
      "decay_r = 2 - y*saw_r;",
      "decay_g = 2 - y*saw_g;",
      "decay_b = 2 - y*saw_b;",
      "",
      "",
      "dx = -0.025*q4;",
      "",
      "rot = ang;",
      "zoom = 1;"
    ],
