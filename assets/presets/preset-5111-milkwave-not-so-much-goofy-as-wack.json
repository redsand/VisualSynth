  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// Credit should go to whoever wrote \"Spiral Graph Fun\" for AVS because I got a lot of inspiration for the wave's code from that",
      "warp = 0;",
      "ob_r=.4+.4*sin(slowtime*2.157+q6);",
      "ob_b=.8+.2*sin(slowtime*1.689+q5);",
      "ob_g=.6+.4*sin(slowtime*.413+q4);",
      "ib_r=.5+.5*cos(slowtime*1.2+q1*.1);",
      "ib_b=.4+.4*cos(slowtime*2.811+q2*.1);",
      "ib_g=.4+.4*cos(slowtime*1.666+q3*.1);",
      "ib_size=.05+.03*q2;",
      "ob_size=.03+.02*sin(slowtime*2.321+q2*.2);",
      "ob_a=.6+.4*q3;",
      "ib_a=.9+.1*sin(q2*.3+q4+q1*.5);",
      "mv_r=mv_r+.5*sin(q4+slowtime*.678);",
      "mv_b=mv_b+.5*sin(q4+slowtime*.789);",
      "mv_g=mv_g+.5*sin(q5+slowtime*.456);",
      "mv_a=.2+.2*sin(slowtime*1.178+q5*1.14);",
      "rot=0;",
      "zoom=1+.7*sin(slowtime*1.51);",
      "q1 = 0.57*( 0.60*sin(0.374*q5) + 0.40*sin(0.294*q5) );",
      "q2 = 0.57*( 0.60*sin(0.393*q5) + 0.40*sin(0.223*q5) );",
      "q3 = 0.57*( 0.60*sin(0.412*q5) + 0.40*sin(0.364*q5) );",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "q9 = .01*(abs(sin(vol_mean)));",
      "beat = if(above(vol_now,1.1*vol_mean),1,0);",
      "slowtime = slowtime+beat*time;",
      "q4 = if(redneg,sin(slowtime),lastq4);",
      "lastq4 = q4;",
      "q5 = slowtime;",
      "myr = cos(slowtime);",
      "myg = cos(slowtime)*sign(cos(slowtime));",
      "myb = sin(time) ;",
      "redneg = if(below(myr,0),1,0);",
      "greenneg = if(below(myg,0),1,0);",
      "blueneg = if(below(myb,0),1,0);",
      "q6 = if(redneg,if(bor(greenneg , blueneg),abs(myr),1+myr),myr);",
      "q7 = if(greenneg,if(equal(greenneg + blueneg,2),abs(myg),1+myg),myg);",
      "q8 = if(blueneg,-1*myb,myb);",
      "q6 = if(above(q6+q7+q8,1),abs(q6-.5),q6);",
      "q7 = if(above(q6+q7+q8,1),abs(q7-.5),q7);",
      "q8 = if(above(q6+q7+q8,1),abs(q8-.5),q8);",
      "monitor = q4;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "rot=if(above(q4,0),rad*.2*q5,sin(rad*(q4+q3)));",
      "zoom=if(above(q2,0),zoom+(1-zoom)*rot*cos(rad*3.14*q2),if(above(q3,0)*above(x,.5+.5*q5),zoom+(1-zoom)*sin(q1*rot*3.14),zoom+(1-zoom)*cos(rad*10*q6)));",
      "dx=above(q1,0)*sin(rad*.5*q2);",
      "dy=above(q3,0)*sin(rad*.5*q3);"
    ],
