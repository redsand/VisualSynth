    "perFrameCode": [
      "warp=0;",
      "q8 =oldq8+ 0.0003*(pow(1+1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "oldq8 = q8;",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),(time*1.30),lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above((time*1.30) - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below((time*1.30)-lastbeat,2*beatrate),0.1*(beatrate*9 + (time*1.30) - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above((time*1.30) - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,(time*1.30),lastbeat);",
      "countertime = if(beat,time,countertime);",
      "counter =-1*pow(min((time-countertime-1.5),0),9);",
      "",
      "",
      "",
      "",
      "q7 = if(beat,0.001+0.0001*int(rand(40)),oldq7);",
      "oldq7=q7;",
      "q6 = if(beat,0.001+0.0001*int(rand(40)),oldq6);",
      "oldq6=q6;",
      "q5= if(beat,0.001+0.0001*int(rand(40)),oldq5);",
      "oldq5=q5;",
      "q4 = if(beat,0.001+0.0001*int(rand(40)),oldq4);",
      "oldq4=q4;",
      "q1 = if(beat,12,0);",
      "",
      "dec= (dec-.01)*(1-(beat*(1-beat2)));",
      "beat2 = beat2+beat*(1-beat2);",
      "monitor=dec;",
      "decay=decay+dec*beat2*.5;",
      "beat2=if(below(dec,-.15),0,beat2);",
      "",
      "//ib_r=wave_r;",
