  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "db=(bass-lbass)*fps*.1;",
      "lbass=bass;",
      "avgdb=avgdb*.99+abs(db)*.01;",
      "",
      "dt=(treb-ltreb)*fps*.06;",
      "ltreb=treb;",
      "avgdt=avgdt*.99+abs(dt)*.01;",
      "",
      "",
      "pitch=(sin(avgdt)+cos(avgdb))*.5+.5;",
      "",
      "",
      "",
      "",
      "fc=40/fps;",
      "bb=above(abs(db),avgdb*6);",
      "bt=above(abs(dt),avgdt*6);",
      "",
      "t1=t1+(avgdb*.1*(1.5-pitch)+bb*db)*fc;",
      "t2=t2+(avgdt*.1*pitch+bt*dt)*fc;",
      "t3=t3+abs(db)*.1*fc;",
      "t4=t4+abs(dt)*.1*fc;",
      "",
      "",
      "",
      "wave_r = 0.5 + 0.5*sin(t1-t4);",
      "wave_g = 0.4 + 0.4*sin(t2-t3);",
      "wave_b = -1 + (1-wave_r + 1-wave_g);",
      "warp = 0;",
      "wave_x = wave_x + 0.1*cos(1.2*t2)*sin(1.1*t1)-0.1*sin(0.61*3);",
      "wave_y = wave_y + 0.1*sin(1.2*t1)*cos(4.1*t4)-0.11*cos(1.1*t3);",
      "",
      "ob_r = 1-abs(wave_g);",
      "ob_b = .5-abs(wave_r);",
      "ob_g = .5-abs(wave_b);",
      "ib_a=.5;",
      "",
      "",
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "dx_r = equal(thresh,2)*0.015*sin(.1*t2)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(.1*t1)+(1-equal(thresh,2))*dy_r;",
      "",
      "",
      "q1=dx_r;",
      "q2=dy_r;",
      "",
      "q3=t1;",
      "q4=t2;",
      "q5=t3;",
      "q6=t4;",
      "",
      "wrap=1;",
      "",
      "decay=1;"
    ],
    "perFrameInitCode": [
      "t1=100+bass*100;",
      "t2=100+treb*100;",
      "t3=100+bass_att*100;",
      "t4=100+treb_att*100;"
    ],
    "perPixelCode": [
      "dx_r=q1;",
      "dy_r=q2;",
      "",
      "",
      "xbar = above(sin(q3),0)*abs(1.4-x*sin(1.4*cos(y*q4*.1))) +",
      "below(sin(q3),0)*sin((0.5-y)*sin(3*cos(dx_r*y*q3*.1)));",
      "ybar = above(cos(q4),0)*abs(1.4-y*sin(1.4*cos(x*q4*.1))) +",
      "below(cos(q4),0)*sin((0.5-x)*sin(3*cos(dy_r*x*q3*.1)));",
      "",
      "",
      "//c2=0;",
      "c1=above(sin(y*3.14-rad)-.5 ,.5+sin(q5*.1-q3*.25)*.5);",
      "c2=below(abs(sin(x*sin((q5-q4)*.0346)-y*sin((q3-q6)*.023))*1 )+.7,.5+sin(q4*.21-q5*.1)*.5);",
      "c3=above(sin(y*4+q3*.23-q4*.27+ang),.5+sin(q6*.0012-q4*.33)*.5);",
      "c4=below(1-sin(y*3.14-q4*.2)+sin(q5*.1+x),.5+sin(q3*.27-q6*.1)*.5);",
      "",
      "",
      "dx1 =  dx_r*cos(6.28*xbar);",
      "dy1 =  dy_r*cos(6.28*ybar);",
      "",
      "",
      "c=sin(q5*.1);",
      "cc=sin(q3*.1);",
      "ccc=sin(q4*.1);",
      "cx1=.5+ccc*.3;",
      "cy1=.5+cc*.4;",
      "",
      "myx=(cx1-x);",
      "myy=(cy1-(1-y));",
      "mrad=pow( myx*myx + myy*myy , .5);",
      "mang=asin( abs(myy)/(mrad) );",
      "",
      "ax=mang;",
      "ay=mang;",
      "",
      "mrot=.1*(1-mrad)*sin(q4*.01+q6*.1);",
      "",
      "dx2= sign(myy)*sin(ax)*mrot;",
      "dy2= sign(myx)*(cos(ay)*mrot);",
      "",
      "",
      "",
      "cx2=.5+cc*.3;",
      "cy2=.5+c*.25+ccc*.25;",
      "",
      "myx=(cx2-x);",
      "myy=(cy2-(1-y));",
      "mrad=pow( myx*myx + myy*myy , .5);",
      "mang=asin( abs(myy)/(mrad) );",
      "",
      "ax=mang;",
      "ay=mang;",
      "",
      "mrot=.1*(1-mrad)*sin(q3*.02+q5*.3);",
      "",
      "dx3= sign(myy)*sin(ax)*mrot;",
      "dy3=  sign(myx)*(cos(ay)*mrot);",
      "",
      "",
      "zoom=1+c1*.051+c2*.031-c3*.024-c4*.028;",
      "//zoom = zoom - 0.01;",
      "",
      "dx=dx1*(c1-c3*2)+dx2*(c4)+dx3*(c2);",
      "dy=dy1*(c1-c3*2)+dy2*(c4)+dy3*(c2);",
      "",
      "",
      "sx=1-2*c4;",
      "sy=1-2*c3;"
