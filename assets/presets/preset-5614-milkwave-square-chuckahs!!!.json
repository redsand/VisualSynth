    "perFrameCode": [
      "warp = 0;",
      "decay = 1;",
      "",
      "//Lets throw Krash's beatd etection code here for kicks!",
      "",
      "volume = 0.3*(bass+mid+att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "beatcounter = if(above(beat,0),beatcounter +1, beatcounter);",
      "beatcounter = if(above(beatcounter,101), 0, beatcounter);",
      "beateven=beatcounter%2;",
      "",
      "//Code happy time",
      "",
      "wave_x = centerx;",
      "wave_y = centery;",
      "wave_r = red;",
      "wave_g = green;",
      "wave_b = blue;",
      "",
      "//Blocking my code",
      "",
      "centerx = if(equal(beat,1),int(rand(100))*.01,centerx);",
      "centery= if(equal(beat,1),int(rand(100))*.01,centery);",
      "red = if(equal(beat,1),int(rand(100))*.01,red);",
      "green = if(equal(beat,1),int(rand(100))*.01,green);",
      "blue = if(equal(beat,1),int(rand(100))*.01,blue);",
      "decay = decay - (equal(beat,1))*.1;",
      "dimx = if(equal(beat,1),int(rand(25))*.01,dimx);",
      "dimy = if(equal(beat,1),int(rand(25))*.01,dimy);",
      "",
      "//blocking",
      "",
      "q1 = beat;",
      "q2 = centerx;",
      "q3 = centery;",
      "q4 = dimx;",
      "q5 = dimy;"
    ],
    "perFrameInitCode": [
      "centerx = int(rand(100))*.01;",
      "centery = int(rand(100))*.01;",
      "red = int(rand(100))*.01;",
      "green = int(rand(100))*.01;",
