      "dimy = int(rand(25))*.01;"
    ],
    "perPixelCode": [
      "testx = if(above(x,q2-q4),if(below(x,q2+q4),if(above(y,abs(q3-1)-q5),if(below(y,abs(q3-1)+q5),.005,0),0),0),0);",
      "testy = if(above(x,q2-q4),if(below(x,q2+q4),if(above(y,abs(q3-1)-q5),if(below(y,abs(q3-1)+q5),.005,0),0),0),0);",
      "",
      "dx = if(below(x,q2),-1*testx,testx);",
      "dy = if(below(y,abs(q3-1)),-1*testy,testy);"
    ],
