  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "vol = (bass_att + treb_att + mid_att)*.333333;",
      "",
      "ra = 1/tic*.25;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav*.2;",
      "toc = 1;",
      "",
      "",
      "q1 = vt; // shift along waveform",
      "//q1 = 0;",
      "q2 = .1 + min(bass_avg*.1,.4); // displacement of shape echo;",
      "q3 = .5; // shape tex_zoom",
      "",
      "bend = (mid_avg + treb_avg)*.5*.1;",
      "",
      "tri = if(above(time - tr,.1),below(bend,.05),0);",
      "sw = if(tri,1-sw,sw);",
      "tr = if(tri,time,tr);",
      "bend = max(0,bend - .05);",
      "",
      "q4 = bend*(1-2*sw)*2; // shape tex_ang",
      "",
      "cou = treb - treb_avg;",
      "",
      "monitor = q4;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "my = y*6.2832 + q1;",
      "mod = max(0,sin(my)*bass);",
      "mod = mod + max(0,sin(my + 2.0944)*mid);",
      "mod = mod + max(0,sin(my + 4.1888)*treb);",
      "",
      "",
      "sx = 1 - mod*.05;",
      "",
      "my = (1-y)*6.2832 + q1;",
      "mod = max(0,sin(my)*bass);",
      "mod = mod + max(0,sin(my + 2.0944)*mid);",
      "mod = mod + max(0,sin(my + 4.1888)*treb);",
      "",
      "",
      "sx = if(above(x,.5),sx,1 - mod*.05);",
      "",
      "",
      "dis = pow((x-.5)*(x-.5)*2 + .1*(y-.5)*(y-.5),.5);",
      "//mod = 1 - min(1,dis);",
      "mod = pow(mod,2);",
      "mod = min(3,mod);",
      "zoom = 1 - mod*.2;"
    ],
