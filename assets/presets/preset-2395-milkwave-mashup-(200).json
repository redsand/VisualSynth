ct.yx;\n\n    dist = 1-fract(n/anz+t_rel); //evtl sqrt !\n\n    inten =  4*dist*(1-dist*dist);\n    uv3 = 3*uv2*dist + 0.5+.1*vec2(q1,q2);\n    crisp = GetPixel(uv3);\n    blur = GetBlur1(fract(uv3)) * vec3 (.8,.9,1);\n    ret1 = max(ret1,(crisp+blur)*inten);\nn++;\n}\n\n\nvec3 ret1 = ret1 ;\n//ret1 = GetPixel(.5+vUvOriginal*uAspect.yx*1.2);\n\n\nret = ret1-.1;\nret=1-ret;\n\n  fragColor = ret;\n}",
