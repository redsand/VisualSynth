    "comp": null,
    "perFrameCode": [
      "wave_r = 0.7+0.3*sin(time*1.125) + 0.1*sin(time*0.145) + 0.1*tan(frame);",
      "wave_y = wave_y + 0.1*sin(20*time);",
      "sx = 1.0006;",
      "LifeSign = if(above(bass+bass_att,2),1,0);",
      "xwave_mode = if(LifeSign,0,wave_mode);",
      "wave_mystery = if(LifeSign,-0.5,wave_mystery);",
      "wave_y = if(LifeSIgn,0.9,wave_y);",
      "wave_x = if(LifeSIgn,0.5-abs((0.5*(-bass))),wave_x);",
      "wave_r = if(LifeSign,0,wave_r);",
      "wave_b = if(LifeSign,0.2+0.2*sin(time*0.245),wave_b);",
      "wave_g = if(LifeSign,0.8+0.2*sin(time*0.865),wave_g);",
      "montior = wave_mode;",
      "ib_a = if(LifeSign,0.7,0.4);",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "monitor =beateven;",
      "aib_a = beat;",
      "beatcounter = if(above(progress,0.01),if(above(beat,0),beatcounter +1, beatcounter),0);",
      "beatcounter = if(above(beatcounter,7), 0, beatcounter);",
      "beateven = beatcounter%2;",
      "monitor = beatcounter;",
      "wave_r= if(beat,0,wave_r);",
      "wave_b= if(beat,0,wave_b);",
      "wave_g= if(beat,0,wave_g);",
      "wave_mode = if(beat,7,wave_mode);",
      "ib_a = if(beat,1,ib_a);",
      "ib_r = if(beat,1,ib_r);",
      "ib_g = if(beat,0,ib_g);",
      "ib_b = if(beat,0,ib_b);",
      "mv_a = if(beat,1,1);",
      "mv_x = 1.5;",
      "mv_y = 1.2;",
      "mv_dx = 0.05*sin(time*7);",
      "mv_dy = 0.05*sin(time*6);",
      "mv_r = 0.8+0.2*sin(time);",
      "mv_g = 0.2+0.2*sin(time*0.865);",
      "mv_b = 0.8+0.2*cos(time*4.65);",
      "mv_r = if(beat,1,mv_r);",
      "mv_g = if(beat,1,mv_g);",
      "mv_b = if(beat,0,mv_b);",
      "warp=0;"
