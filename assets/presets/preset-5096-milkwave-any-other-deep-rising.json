  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "slowtime = slowtime+beat*time;",
      "ying = if(below(ying,1),1,ying);",
      "ying = if (beat,ying + bnot((time*10)%3),ying);",
      "yin = ying%2;",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "beat = if(above(vol_now,1.5*vol_mean),1,0);",
      "beatcount = if(bnot(time%5000),0,beatcount);",
      "beatcount = beatcount +.05*beat;",
      "yang = bnot(beatcount%2);",
      "ib_r = 0;",
      "ib_g = pow(abs(sign(sin(slowtime))),2)*sin(slowtime);",
      "ib_b= cos(slowtime)*sign(cos(slowtime))*pow(abs(sign(sin(slowtime))),2);",
      "mv_g = sin(slowtime)*(sign(sin(slowtime))-1)*(sign(sin(slowtime)));",
      "mv_b = -1*abs(cos(slowtime))+1;",
      "mv_r = .8;",
      "redneg = if(below(ib_r,0),1,0);",
      "greenneg = if(below(ib_g,0),1,0);",
      "blueneg = if(below(ib_b,0),1,0);",
      "wave_r = if(redneg,if(bor(greenneg , blueneg),1,1+ib_r),ib_r);",
      "wave_g = if(greenneg,if(equal(greenneg + blueneg,2),1,1+ib_g),ib_g);",
      "wave_b = if(blueneg,1 + ib_b, ib_b);",
      "q1 = if(yin,sin(slowtime),q1);",
      "q2 = if(yin,cos(slowtime),0);",
      "q3 = sin(beatcount);",
      "dx = if(yin,.01*sin(slowtime),if(equal(yin,yang),0,dx));",
      "dy = if(yin,.01*cos(slowtime),0);",
      "q5 = if(bnot(yin),abs(cos(time)),dx);",
      "wave_mystery=wave_mystery-1*sin(time*.65*sin(q3));",
      "wave_mode=int(rand(slowtime%12));"
    ],
    "perFrameInitCode": [
      "warp = 0;",
      "beatcount = 0;"
    ],
    "perPixelCode": [
      "solipsist = if(equal(q3,0),0,.01*( rad - q3*x + pow(q3,4)*y));",
      "rot = rot + sin(rad)-5*solipsist-1.5*q5;",
      "sy = if(equal(q3,0),sy,1-solipsist);",
      "new_x=rad*.05-x;",
      "new_y=rad*.05-y;",
      "zoom=zoom+.01*sin(ang-rad*3.14*sin(if(Above(q2,q1),.5,-.5)*sin(new_X*new_y)))*sin(if(Above(q3,q1),.5,-.5))-.03*sin(Ang*5-rad*sin(if(Above(q3,q2),.5,-.5)));"
