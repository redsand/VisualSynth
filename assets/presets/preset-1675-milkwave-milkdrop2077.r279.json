      "wave_r = wave_r + 0.4*( 0.60*sin(0.514*time) + 0.40*sin(1.211*time) );",
      "wave_b = wave_b + 0.4*( 0.60*sin(0.714*time) + 0.40*sin(q2) );",
      "wave_g = wave_g + 0.4*( 0.60*sin(10*q1) + 0.40*sin(10*q2) );",
      "zoom = 1;",
