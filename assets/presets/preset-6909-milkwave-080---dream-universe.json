      "rot_f2=pow(1-sqrt(sqr(x2)+(sqr(y2))),q7);",
      "dx=dx+ q5*(x1*sin(q6) - (y1)*cos(q6))*rot_f1;",
      "dy=dy+ q5*(x1*cos(q6) +(y1)*sin(q6))*rot_f1;",
      "dx=dx+q5*(x2*sin(q6)-(y2)*cos(q6))*rot_f2;",
