      "wave_x=if(above(f,1),q1,q3);",
      "wave_y=if(above(f,1),1-q2,1-q4);",
      "wave_r=if(equal(f%2,0),1,0);",
      "wave_b=if(equal(f,0),1,.4+.6*abs(sin(time)));",
      "wave_g=if(equal(f%2,0),1,0);",
      "wave_r=if(equal(f,3),.4+.6*abs(sin(time)),wave_g);",
      "stars=if(equal(frame%8,5),1,0);",
      "stars=if(equal(frame%8,7),1,stars);",
      "wave_r=if(equal(stars,1),.5,wave_r);",
      "wave_g=if(equal(stars,1),.5,wave_g);",
      "wave_b=if(equal(stars,1),.5,wave_b);",
      "decay=if(above(dist,.55),.995,.993);",
      "zoom=1+.005*sin(time*1.5+1.354);"
