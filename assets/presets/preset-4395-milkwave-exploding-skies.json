    "perFrameCode": [
      "dx = dx + dx_residual;",
      "dy = dy + dy_residual;",
      "mv_l = 70;",
      "mv_r = 0.499 * sin(time * 0.333);",
      "mv_b =  0.590 * sin (time * 0.545);",
      "mv_g = 0.333 * sin (time * 0.833);",
      "bass_effect = max(max(bass,bass_att)-1.3,0);",
      "vol_now = 4* bass_effect;",
      "beat_max = if(equal(frame%50,0),vol_now,max(beat_max, vol_now));",
      "beat_min = if(equal(frame%50,0),vol_now,min(beat_min,vol_now));",
      "beat_rate = if(equal(frame%50,0),0,beat_rate+beat);",
      "last_beat_rate = if(equal(frame%50,49),if(above(beat_rate,10),if(below(beat_rate,30),beat_rate,last_beat_rate),last_beat_rate),last_beat_rate);",
      "last_beat_rate = max(last_beat_rate,10*beat_min);",
      "beat = if(above(vol_now,.035*last_beat_rate*(beat_max-beat_min)),1,0);",
      "sin_beat = sin(beat_max-vol_now);",
      "mysign = if(above(sin_beat,0.1),1,-1);",
      "myframe=if(above(.2,sin_beat),frame,0);",
      "myframe=if(above(myendframe,frame),0,myframe);",
      "myendframe = if(above(.2,sin_beat),myframe + 100,myendframe);",
      "long_beat = mysign*10*sin(myendframe-myframe);",
      "cycle = if(equal(long_beat,0),(long_beat + 1.57),long_beat);",
      "decay = if(above(bass_effect,0),0.96,0.996);",
      "wave_x = 0.6+0.3*sin(long_beat*0.724);",
      "wave_b = wave_b + 0.5*sin(long_beat);",
      "wave_r = wave_r + cycle;",
      "wave_g = wave_g + sin_beat;",
      "q1 = progress * cycle;",
      "monitor = progress;",
      "ib_b = 20*sin(progress);",
      "ib_g = cos(progress);",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "dx_residual = equal(bass_thresh,2)*0.016*sin(time*7) + (1-equal(bass_thresh,2))*dx_residual;",
      "dy_residual = equal(bass_thresh,2)*0.012*sin(time*9) + (1-equal(bass_thresh,2))*dy_residual;"
    ],
