  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "ob_size=0;",
      "decay = .9; zoom=1;",
      "// -------------------------------- beat detection code ----------------------------------",
      "// - one time init",
      "sure=if(equal(sure,0),.75,sure);",
      "interval=if(equal(interval,0),.7,interval);",
      "avginterval=if(equal(avginterval,0),.7,avginterval);",
      "lockinterval=if(equal(lockinterval,0),.7,lockinterval );",
      "lastbeat=if(equal(lastbeat,0),time,lastbeat);",
      "// - do main calcs",
      "atreb=atreb*.999+treb*.001;",
      "dtreb=treb-ptreb;",
      "dmid=mid-pmid;",
      "db=bass-pbass;",
      "ptreb=treb;",
      "pmid=mid;",
      "dbass=db;",
      "",
      "",
      "//dbass=bass-bass_att;",
      "",
      "",
      "beat=below(dbass*phase-treb_att*.1,avgdbass)*above(pdbass*phase-treb_att*.1,avgdbass)*above(bass,avgbass)",
      "*above(time-lastbeat,lockinterval*.9);",
      "",
      "sure=if(beat*below(abs(time-(interval+lastbeat)),bpm*.2),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9999);",
      "sure=max(.5,sure);",
      "// - value decay and clipping",
      "avgdbass=.99*avgdbass+.01*dbass;",
      "avgbass=.99*avgbass+.01*bass;",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=min(200,maxdbass);",
      "maxdbass=max(.02,maxdbass);",
      "// - update vars",
      "interval=beat*(time-lastbeat)+(1-beat)*interval;",
      "lastbeat=if(beat+equal(lastbeat+interval,time),time,lastbeat);",
      "avginterval=if(beat,.9*avginterval+.1*interval, avginterval);",
      "lockinterval=if(beat,.9*lockinterval+.1*avginterval,lockinterval);",
      "pbass=bass;",
      "pdbass=dbass;",
      "bpm=60/(lockinterval*(1-sure)+interval*sure);",
      "phase=min( (time-lastbeat)*bpm*.02, 1 );",
      "",
      "monitor=phase;",
      "// - clip frame intervals",
      "//interval=min(interval,.7*FPS);",
      "//avginterval=min(avginterval,.7*FPS);",
      "//lockinterval=min(lockinterval,.7*FPS);",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "//////////////////////////////////////////////////",
      "// Turn the variable monitor on to watch the BPM     (and wait to get it right!)",
      "//////////////////////////////////////////////////",
      "//monitor=bpm;",
      "//monitor=phase;",
      "",
      "q1=phase;",
      "q8=above(time-lastbeat,3*interval)* min( (time-lastbeat)/interval-2,1 );",
      "myq8=above(time-lastbeat,1.2*interval)* min( (time-lastbeat)/interval-1,1 );",
      "mytime=mytime+1/lockinterval*.01*(1-q8);",
      "q2=mytime;",
      "dir=-1+2*(int(mytime*.2)%2);",
      "totalbeats=totalbeats+beat;",
      "q4=totalbeats*1.666;",
      "p2=mytime*.2-int(mytime*.2);",
      "q5=if( equal(dir,1), p2, 1-p2 );",
      "p2=(mytime+1)*.2-int((mytime+1)*.2);",
      "dir=-1+2*(int((mytime+1)*.2)%2);",
      "q3=if( equal(dir,1), p2, 1-p2 );",
      "q6=.15+avgbass*.1*sin(q1*3.1415);",
      "ob_size=beat;"
    ],
