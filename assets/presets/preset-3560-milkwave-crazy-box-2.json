      "",
      "r = 0.3;",
      "x1 = if(above(x,1-r),-abs(x1),x1);",
      "x1 = if(below(x,r),abs(x1),x1);",
      "x = if(above(x,1-r),1-r,x);",
      "x = if(below(x,r),r,x);",
      "y1 = if(below(y,r),abs(t2),t2);",
      "y = if(below(y,r),r,y);",
