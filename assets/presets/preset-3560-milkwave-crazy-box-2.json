      "v = 10 +bass*0.5;",
      "X2 = x-0.5;",
      "Y2 = y-0.5;",
      "X1 = sin(w)*X2 -cos(w)*Y2;",
      "Y1 = cos(w)*X2 +sin(w)*Y2;",
      "x = X1;",
      "y = Y1;",
      "dx1 = 0.01*(cos((-x+y)*n+t) + sin((x+y)*n+t));//*bass;",
      "dy1 = 0.01*(cos((x-y)*n-t) + sin((-x-y)*n-t));//*bass;",
      "dx2 = sin(-w)*dx1 - cos(-w)*dy1;",
      "dy2 = cos(-w)*dx1 + sin(-w)*dy1;",
      "dx = v*dx2;",
      "dy = v*dy2;"
