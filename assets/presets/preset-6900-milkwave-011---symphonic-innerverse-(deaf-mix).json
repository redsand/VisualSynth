  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "q1=.01; //general speed;",
      "q2=.5;   // main twirl's x",
      "q3=.5;   // main twirl's y",
      "q4=4;    // # of children twirls per twirl",
      "q5=.008;   // main twirl's speed;",
      "q6=q5/0.03;    // main twirl's range;",
      "q7=bass_att+mid_att+treb_att; //volume",
      "q8=10;   // max # of children twirls per axis",
      "InvertInterval = 1200;    // invert colors every ...#frames",
      "InvertDuration = 600;",
      "zoomexp=1.2;",
      "zoom=zoom+bass/70;",
      "wave_x=q2;",
      "wave_y=q3;",
      "bInvert = if( below( (frame+InvertInterval)%InvertInterval,InvertDuration),1,0);",
      "wave_r=sin(q1*time*25 + .167)/2+.5;",
      "wave_g=sin(q1*time*50 + .333)/2+.5;",
      "wave_b=sin(q1*time*75+ .667)/2+.5;",
      "wave_r=wave_r+bInvert*(1-2*wave_r);",
      "wave_g=wave_g+bInvert*(1-2*wave_g);",
      "wave_b=wave_b+bInvert*(1-2*wave_b);",
      "wave_mystery=-0.1+2*sin(3*abs(cos(time))*time);",
      "rot = rot +(q7/4)*.04*pow((sin(time/2 + .6)),11);",
      "decay=min(1,.975+.035*bass_att/3);",
      "monitor = decay;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "// center twirl",
      "twirlX=q2;",
      "twirlY=1-q3;",
      "Distance = sqrt(sqr(x-q2)+sqr(y-q3));",
      "RelAngle=atan2(x-twirlX,y-twirlY);",
      "TwirlMult = sin(time*50*q1)*q5/(Distance+q6);",
      "dx = dx+TwirlMult*sin(RelAngle+1.5);",
      "dy=dy+TwirlMult*cos(RelAngle+1.5);",
      "zoom = zoom + .0001*log(Distance);",
      "",
      "// mini twirls",
      "NumSwirlsX=q8-(abs(x-.5)*2*q8)%1;",
      "NumSwirlsY =q8-(abs(y-.5)*2*q8)%1;",
      "blockX=(x*10*NumSwirlsX)%NumSwirlsX;",
      "blockY=(y*10*NumSwirlsY)%NumSwirlsY;",
      "CenX= .1*blockX+(1/NumSwirlsX)*.5;",
      "CenY= .1*blockY+(1/NumSwirlsY)*.5;",
      "CurX=1-x-CenX;",
      "CurY=1-y-CenY;",
      "CurDist = sqrt( sqr(CurX)+sqr(CurY) );",
      "CurAngle=atan2(CurX,CurY);",
      "TwirlDir=if( above( (blockX+blockY)%4,2 ) , 1, -1 );",
      "CurMult = (q7/5)*sin(time/2 + 1.566)/(pow(CurDist,33)+100);",
      "dx=dx+CurMult*sin(CurAngle +rad/5+ 1.5);",
      "dy=dy+CurMult*cos(CurAngle+rad/5+1.5);",
      "zoom = zoom -2*abs(CurMult);",
      ""
    ],
