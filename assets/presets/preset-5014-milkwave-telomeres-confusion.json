  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "volume = 0.3*(bass+mid);",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beat = above(volume,0.8)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.95 + (1-above(time - lastbeat, 2*beatrate))*0.995);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "beatframe = if(beat,frame,beatframe);",
      "band1 = 0.5+0.4*sin(time*0.9);",
      "band1w = 0.03 + 0.025*cos(time*0.9);",
      "band2 = 0.5+0.4*sin((time+2.3)*0.9);",
      "band2w = 0.03 + 0.025*cos((time+2.3)*0.9);",
      "infront = if(above(sin(time*0.9),0),1,0);",
      "q1 = if(below(abs(band1-band2),0.05),if(infront,band1,-1),band1);",
      "q2 = if(below(abs(band1-band2),0.05),if(1-infront,band2,-1),band2);",
      "q3 = band1w;",
      "q4 = band2w;",
      "q5 = frame%2;",
      "q6 = (above(q1,0)+above(q2,0))*0.5*if(equal(q1,q2),2,1);",
      "q7 = max((beatframe-frame+2),0)*above(q1*q2,0);",
      "q8 = beat;",
      "ob_r = q5*(0.5+0.25*(0.5*sin(time*0.042)+0.5*sin(time*0.053)))+q7*(band1-0.5);",
      "ob_g = (1-q5)*(0.5+0.25*(0.5*sin(time*0.057)+0.5*sin(time*0.051)))+q7*(band2-0.5);",
      "ob_b = max(0.2+(0.2*sin(time*0.05)+0.3*sin(time*0.06)),0)+q7*0.05*int(rand(10));",
      "wave_a = beat;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "band1 = below(x,0.05)*above(y,q1-q3)*below(y,q1+q3);",
      "band2 = below(x,0.05)*above(y,q2-q4)*below(y,q2+q4);",
      "bases = below(x,0.02)*if(above(q1,q2),above(y,q2)*below(y,q1),above(y,q1)*below(y,q2));",
      "bandmove = 0.009*(q5*band1 + (1-q5)*band2);",
      "basemove = 0.02*bases;",
      "dx = 0.0015*max(bass_att*2,1) + if(above(q7,0),basemove,bandmove);",
      "newx = 0.7+0.3*(q3*20)-x;",
      "newy = 0.7+0.3*(q4*20)-y;",
      "newrad = sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2;",
      "newzoom = pow(1.05 + 0.03*newrad, pow(0.01+sin(newrad*newrad), newrad*2-1));",
      "dx =dx+ (newx)*newzoom - newx;",
      "dy =dy+ (newy)*newzoom - newy;",
      "dx =dx*0.1;",
      "dy=dy*0.1;",
      "rot = 0.1*q8;"
    ],
