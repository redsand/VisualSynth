  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "zoom = 1.003;  warp =0.075; decay = 0.993; vol = 0.3*(bass+mid+treb);",
      "b1x = if( equal( b1x, 0 ), .1, b1x );",
      "b1y = if( equal( b1y, 0 ), .5, b1y );",
      "b1vx = if( equal( b1vx, 0 ), 0*(int(rand(50))/100), b1vx );",
      "b1vy = if( equal( b1vy, 0 ), 0.006, b1vy );",
      "b2x = if( equal( b2x, 0 ), .9, b2x );",
      "b2y = if( equal( b2y, 0 ), .5, b2y );",
      "b2vx = if( equal( b2vx, 0 ), 0*(-int(rand(50))/100), b2vx );",
      "b2vy = if( equal( b2vy, 0 ), -0.006, b2vy );",
      "q3=.5*(1+.8*cos(time/7+.23+sin(time*.232+.983)));",
      "q4=.5*(1+.8*cos(time/5+2.69+sin(time*.157+3)));",
      "",
      "// o Resolve forces",
      "distX = ( b1x -b2x ); distY = ( b1y - b2y ); fAngle = atan2( distY, distX );",
      "dist = sqrt(sqr(distX)+sqr(distY));",
      "k = 1/sqr(dist);",
      "k = if( above( k, .005) , 0.005, k );",
      "k = if(above(fCrashPhase,0),0,k);",
      "b1vx=b1vx+k*cos(fAngle-3.14)/FPS;",
      "b1vy=b1vy+k*sin(fAngle-3.14)/FPS;",
      "b2vx=b2vx+k*cos(fAngle)/FPS;",
      "b2vy=b2vy+k*sin(fAngle)/FPS;",
      "q5 = atan2(b1y-q4,b1x-q3); k= 1.5/sqrt(sqr(b1x-q3)+sqr(b1y-q4));",
      "k=if(above(k,.008),.008,k);",
      "b1vx=b1vx-k*cos(q5)/FPS;",
      "b1vy=b1vy-k*sin(q5)/FPS;",
      "q5 = atan2(b2y-q4,b2x-q3); k= 1.5/sqrt(sqr(b2x-q3)+sqr(b2y-q4));",
      "k=if(above(k,.008),.008,k);",
      "b2vx=b2vx-k*cos(q5)/FPS;",
      "b2vy=b2vy-k*sin(q5)/FPS;",
      "Blue=if( above(sqrt(sqr(b2vx)+sqr(b2vy)),sqrt(sqr(b1vx)+sqr(b1vy))),1, 0);",
      "",
      "// o Apply motion",
      "iIndex = (frame%5);",
      "fScale = if( above(iIndex,1), (1+.5*mid)*30/FPS, (1+.5*bass)*30/FPS);",
      "b1x = b1x + b1vx*fScale;      b1y = b1y + b1vy*fScale;",
      "b2x = b2x + b2vx*fScale;      b2y = b2y + b2vy*fScale;",
      "",
      "// o Collision and \"keep-in-screen\" check",
      "q1 = if( below(sqr(b1x-q3) +sqr(b1y-q4), .005), 1, 0);",
      "q2 = if( below(sqr(b2x-q3) +sqr(b2y-q4), .005), 1, 0);",
      "b1x=if(equal(q1,1),int(rand(100))/100,b1x);",
      "b1y=if(equal(q1,1),int(rand(100))/100,b1y);",
      "b2x=if(equal(q2,1),int(rand(100))/100,b2x);",
      "b2y=if(equal(q2,1),int(rand(100))/100,b2y);",
      "distX = ( b1x -b2x ); distY = ( b1y - b2y ); fAngle = atan2( distY, distX );",
      "DotProd1= (.75+int(rand(50))/100)*sqrt( sqr(b1vx)+sqr(b1vy) );",
      "DotProd2= (.75+int(rand(50))/100)*sqrt( sqr(b2vx)+sqr(b2vy) );",
      "b1vx=if(equal(q1,1), DotProd1*cos(fAngle-3.14),b1vx);",
      "b1vy=if(equal(q1,1), DotProd1*sin(fAngle-3.14),b1vy);",
      "b2vx=if(equal(q2,1), DotProd2*cos(fAngle),b2vx);",
      "b2vy=if(equal(q2,1), DotProd2*sin(fAngle),b2vy);",
      "",
      "b1vx = if( above( b1x, 1 ), -b1vx, b1vx );",
      "b1vx = if( below( b1x, 0 ), -b1vx, b1vx );",
      "b1vy = if( above( b1y, 1 ), -b1vy, b1vy );",
      "b1vy = if( below( b1y, 0 ), -b1vy, b1vy );",
      "b2vx = if( above( b2x, 1 ), -b2vx, b2vx );",
      "b2vx = if( below( b2x, 0 ), -b2vx, b2vx );",
      "b2vy = if( above( b2y, 1 ), -b2vy, b2vy );",
      "b2vy = if( below( b2y, 0 ), -b2vy, b2vy );",
      "bCrash = if( below(dist, 0.075), 1, 0);bCrash = if( above( frame, NoCheckUntil) ,bCrash, 0 );",
      "ob_size = bCrash;ob_a=bCrash*.4;",
      "kavb1vx = b1vx;     kavb1vy = b1vy;",
      "kavb2vx = b2vx;     kavb2vy = b2vy;",
      "DotProd1 = cos(fAngle-3.14)*kavb2vx + sin(fAngle-3.14)*kavb2vy;",
      "DotProd2 = cos(fAngle)*kavb1vx + sin(fAngle)*kavb1vy;",
      "b1vx=if( equal( bCrash,1), -cos(fAngle-3.14)*DotProd1 + kavb2vx, b1vx );",
      "b1vy=if( equal( bCrash,1), -cos(fAngle-3.14)*DotProd1 + kavb2vy, b1vy );",
      "b2vx=if( equal( bCrash,1), -cos(fAngle)*DotProd2 + kavb1vx, b2vx );",
      "b2vy=if( equal( bCrash,1), -sin(fAngle)*DotProd2 + kavb1vy, b2vy );",
      "NoCheckUntil = if(equal(bCrash,1),frame + 30,NoCheckUntil );",
      "NoCheckUntil = if( equal( frame-2,NoCheckUntil+60 ), 0, NoCheckUntil );",
      "",
      "// o Determine what to draw",
      "fCrashPhase = if( above(NoCheckUntil,0),(60 + NoCheckUntil - frame)/90, 0);",
      "decay = if( above( fCrashPhase,0), .993 + fCrashPhase*0.006,decay);",
      "wave_x = if( below( iIndex,2), b1x, wave_x);",
      "wave_y = if( below( iIndex,2), b1y, wave_y);",
      "wave_x = if( above( iIndex,1), b2x, wave_x);",
      "wave_y = if( above( iIndex,1), b2y, wave_y);",
      "wave_r = 1.0; wave_g = 1.0; wave_b = 1.0;",
      "wave_x=if(equal(iIndex,4),q3,wave_x);",
      "wave_y=if(equal(iIndex,4),q4,wave_y);",
      "wave_b=if(equal(iIndex,4),0,wave_b);",
      "wave_mystery=if(equal(iIndex,4),-.35,wave_mystery);",
      "wave_r = if( equal( iIndex,1 ), 1.0, wave_r );",
      "wave_g = if( equal( iIndex,1 ), 0.1, wave_g );",
      "wave_b = if( equal( iIndex,1 ), 0.1, wave_b );",
      "wave_r = if( equal( iIndex,3 ), 0.1, wave_r );",
      "wave_g = if( equal( iIndex,3 ), 0.1, wave_g );",
      "wave_b = if( equal( iIndex,3 ), 1.0, wave_b );",
      "wave_mystery = if( equal( iIndex%2,1) , -.55-(bass+prevBass)/60 , wave_mystery);",
      "warp = if( above(fCrashPhase,.96),warp+5*(totalv/0.03)*(1 - 4*(fCrashPhase-.96)),warp);",
      "wave_size = if( equal( iIndex%2, 0) ,  1, 0 );",
      "wave_a = if( equal( iIndex%2, 0 ), .75, 1.0 );",
      "totalv = if( equal(fCrashPhase,0),sqrt(sqr(b1vx)+sqr(b1vy))+sqrt(sqr(b2vx)+sqr(b2vy)),totalv);",
      "totalv= if(above(totalv,0.04),0.04,totalv);",
      "wave_mystery = if( below(iIndex,4)*above(fCrashPhase,.93), -7*(fCrashPhase-.93)*.45, wave_mystery);",
      "wave_r=if( below(iIndex,4)*above( fCrashPhase, .9 ), 1, wave_r );",
      "wave_g=if( below(iIndex,4)*above( fCrashPhase, .9 ), 1, wave_g );",
      "wave_b=if( below(iIndex,4)*above( fCrashPhase, .9 ), 1, wave_b );",
      "ob_r=0;ob_b=0;",
      "ob_r=if(above(Blue,0),0,1);",
      "ob_b=if(above(Blue,0),1,0);",
      "prevBass = if(equal( iIndex%2, 0 ), bass, 0 );"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "q6=(x-q3)*(x-q3)+(1-y-q4)*(1-y-q4);",
      "zoom=if(below(q6,0.002),.1,zoom);"
    ],
