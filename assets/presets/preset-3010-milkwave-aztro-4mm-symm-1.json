  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    float small_rad =0.01;\n    vec3 color = GetBlur1(vUv);\n       mat2 rot = { q10 + small_rad + color.x, q11,\n                -q11  + color.y, q10};\n    rot*=q13;\n    vec2 uv_echo = (vUv - 0.5)*vec2(-1,1) + 0.5;\n    ret = mix( texture(sampler_main, (vUv-0.5)*0.98 + 0.5).xyz,\n                texture(sampler_main, (uv_echo-0.5)*0.98 + 0.5).xyz,\n                0.5\n              )\n + GetBlur1(vUv)*0.2 + GetBlur1(uv_echo)*0.2\n + GetBlur1(vUv)*0.4 + GetBlur1(uv_echo)*0.4;\n\n    ret =  ret*(1 - ret)*ret*3; //brighten\n  ret *= 2;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "dec_med = pow (.4, 30/fps);",
      "dec_slow = pow (0.95, 30/fps);",
      "//dec_xlow = pow (0.999, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, -.2+avg+peak) * above (time, t0+.1);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %32;",
      "index2 = (index2 + is_beat*bnot(index))%4;",
      "index3 = (index2 +index3 + is_beat*bnot(index))%4;",
      "",
      "is_beat2 = above (time, t1+.1);",
      "t1 = is_beat*time + (1-is_beat)*t1;",
      "q22 = peak;",
      "q24 = is_beat;",
      "q26 = bass_att + mid_att + treb_att;",
      "vol = vol*dec_med + (1-dec_med)*q26;",
      "q27 = index + 1.5;",
      "q28 = index2 +1;",
      "",
      "p2 = .3*sin(time) + .3*cos(time/3);",
      "//*****tunnel tilting",
      "q1 = cos(p2 * 3.1416/4);",
      "q2 = sin(p2 * 3.1416/4);",
      "q3 = -q2;",
      "q4 = q1;",
      "",
      "//****tunnel viewpoint x,y",
      "vtrig = is_beat * bnot(index%2);",
      "vx = vx * bnot(vtrig) + vtrig * (int(rand(100))/100-.5);",
      "vy = vy * bnot(vtrig) + vtrig * (int(rand(100))/100-.5);",
      "vz = vz * bnot(vtrig) + vtrig * (int(rand(100))/100-.5);",
      "",
      "vx = vx* below(index%32,24); //###",
      "vy = vy* above(index%32,16);",
      "q5 = vx*5;",
      "q6 = vy*5;",
      "",
      "//***tunnel width",
      "q21 = (1+sin(time))/4+.05;",
      "",
      "//**floor proximity",
      "prox = prox - above(vy,.3)*prox*2;",
      "q32 = .5 + .2*prox;",
      "monitor = prox;",
      "",
      "//****tunnel rotation",
      "rota = rota +.02*below(index%16,8)/fps*30;",
      "rota1 = rota1*dec_med + (1-dec_med)*rota;",
      "q7 = rota1;",
      "",
      "//****tunnel speed",
      "movez = movez + .8/(1+abs(vx)+abs(vy))/fps;",
      "q8 = movez * (1+q21/400);",
      "//dyn. Aenderung von q21 bewirkt auch Richt.wechsel",
      "",
      "q15 = -1+8*above(index,26);",
      "//***********************",
      "vxs = vxs * dec_med + (1-dec_med)*vx*20;",
      "vys = vys * dec_med + (1-dec_med)*vy*20;",
      "vzs = vzs * dec_med + (1-dec_med)*vz*20;",
      "",
      "z0 = 20+vzs;",
      "",
      "p1z = z0;",
      "q9 = vxs/(p1z);",
      "q10 = vys/(p1z);",
      "q11 = p1z;",
      "",
      "q12 = below (index,24);",
      "q13 = above (index,16);",
      ""
    ],
    "perFrameInitCode": [
      "prox = 1;"
    ],
