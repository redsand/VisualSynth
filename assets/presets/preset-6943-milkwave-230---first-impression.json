    "comp": null,
    "perFrameCode": [
      "// -------------------------------- Beat Detective v0.07 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "gsync=.9*(75/FPS); warp=0;",
      "pw=if(equal(pw,0),.5,pw);",
      "contVol=(bass_att+mid_att+treb_att)*.0033+.99*contVol;",
      "wave_r=if(equal(beat,1),.3+.7*int(rand(100))/100,pr);",
      "wave_g=if(equal(beat,1),.3+.7*int(rand(100))/100,pg);",
      "wave_b=if(equal(beat,1),.3+.7*int(rand(100))/100,pb);",
      "tb=tb+above(int(rand(10)),1)*beat;",
      "dir=beat*(1-2*(tb%2))+(1-beat)*dir;",
      "s=beat*(2+int(rand(5)))/1000+(1-beat)*s;",
      "bc=10*(frame-lastbeat)/interval;",
      "wave_x=pw+s*dir*gsync*sqrt(10-bc);",
      "decay=min(.96+.004*bc,1);",
      "z=below(wave_x,.15)*equal(dir,-1);",
      "wave_x=z*.16+(1-z)*wave_x;",
      "dir=z+(1-z)*dir;",
      "z=above(wave_x,.85)*equal(dir,1);",
      "wave_x=z*.84+(1-z)*wave_x;",
      "dir=z+(1-z)*dir;",
      "pw=wave_x;",
      "pr=wave_r;",
      "pg=wave_g;",
      "pb=wave_b;",
      "q1=wave_x;",
      "q2=dir;",
      "q3=s;",
      "q4=bc/10;",
      "sy=-beat+(1-beat);",
      "monitor=decay;"
    ],
    "perFrameInitCode": [
