  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "volume = 0.3*(bass+mid+att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.5*(beatrate + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "q1=beat;",
      "wave_y = 1.39176798*int(-0.68471563*int(1.67088366*sign(peakbass_att * dy)));",
      "wave_x = beat * ib_r;",
      "wave_g = 0.02662969*abs(bor(min(ib_r * wave_y , ib_a * wave_mystery) , rot * dx));",
      "warp = 1.72149348*int(volume * ib_b);",
      "wave_mystery = min(0.97296047*int(mv_b - sx) , decay + mv_b);",
      "wave_b = 0.89972925*log10(0.64274526*sqrt(ib_a + sx));",
      "cx = beatrate + wave_x;",
      "warp=if(below(warp,0.01), 0.01, warp);",
      "warp=if(above(warp,100.0), 100.0, warp);",
      "cx=if(below(cx,-1.0), -1.0, cx);",
      "cx=if(above(cx,2.0), 2.0, cx);",
      "wave_b=if(below(wave_b,0.0), 0.0, wave_b);",
      "wave_b=if(above(wave_b,1.0), 1.0, wave_b);",
      "wave_g=if(below(wave_g,0.0), 0.0, wave_g);",
      "wave_g=if(above(wave_g,1.0), 1.0, wave_g);",
      "wave_x=if(below(wave_x,0.0), 0.0, wave_x);",
      "wave_x=if(above(wave_x,1.0), 1.0, wave_x);",
      "wave_y=if(below(wave_y,0.0), 0.0, wave_y);",
      "wave_y=if(above(wave_y,1.0), 1.0, wave_y);",
      "wave_mystery=if(below(wave_mystery,-1.0), -1.0, wave_mystery);",
      "wave_mystery=if(above(wave_mystery,1.0), 1.0, wave_mystery);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "rot=if(above(bnot(1*bass),bnot(1*treb)),rot*sin(rad*sin(time)),-rot*sin(rad*cos(time)));",
      "cy = sigmoid(x * q2 , q3 - x);",
      "rot = bor(sigmoid(rot * q1 , x * x) , rot * q3);",
      "rot=if(below(rot,-1.0), -1.0, rot);",
      "rot=if(above(rot,1.0), 1.0, rot);",
      "cy=if(below(cy,-1.0), -1.0, cy);",
      "cy=if(above(cy,2.0), 2.0, cy);"
