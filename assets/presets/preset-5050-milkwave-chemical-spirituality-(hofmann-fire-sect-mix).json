      "mv_x_range = 0.05;",
      "mv_y_range = 0.151;",
      "mv_x = 1.25;",
      "mv_y = 1.25;",
      "mv_dx = mv_x_range*sin(mv_x_speed*ypos+(sin(time*0.964)-0.5*cos(time*0.256)));",
