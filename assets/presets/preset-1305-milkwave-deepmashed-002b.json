      "//    sum = sqrt(colr*colr + colb*colb + colg*colg) +.1;",
      "  //  colr /= sum; colg /= sum; colb/= sum; ,0);",
      "  while (exec2 (",
      "    self = (head_ptr%obj_num)*obj_size;",
      "    if (gmegabuf(self+12) <= 0,",
      "      // for rad.sym use theta = 1.5, phi = 0..6",
