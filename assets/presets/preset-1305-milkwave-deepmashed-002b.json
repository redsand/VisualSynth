      "  age = gmegabuf(self+12);",
      "  if (age > 0,",
      "    if (age > mage2, age = 0, age +=dt2);",
      "    v2 = pow(gmegabuf(self+3),2)+pow(gmegabuf(self+4),2)+pow(gmegabuf(self+5),2);",
      "    brake = max(0.1,1-300*dt*cw*v2);",
