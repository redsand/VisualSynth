      "//How it works",
      "//The camera tries to follow the head of the firework and look into its direction",
      "//Camera speed and rotational speed is limited, camera lags behind",
      "//Camera angle is forced back into horizontal position",
      "",
      "//-------------- BEGIN USER ADJUSTABLE PART ---------------",
      "//SPEEDS",
      "gSpeed = 1;   //global speed, affects all other speeds",
      "hSpeed = .03;  //head speed",
      "pSpeed = .08;   //speed of primary particles",
      "tSpeed = hspeed*4;  //speed of tail particles",
      "",
      "//CAMERA",
      "CamDist  = .01; //camera tries to keep this distance",
      "CamSpeed = .4; //camera follower speed",
      "CamLock = 8;   //how fast does camera angle lock on firework",
      "HLock = .1;    //force camera angle back into horizontal view",
      "",
      "//OTHER PARAMS",
      "sharp = 140;    //sharpness of bass/treb triggered head direction changes",
      "g0 = .04;      //gravitation",
      "cw = 10;       //air drag",
