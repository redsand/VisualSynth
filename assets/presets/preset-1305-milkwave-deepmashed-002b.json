      "x0 = (rand(10)-5)*.05; y0 = (rand(10)-5)*.05; z0 = (rand(10)-5)*.05;;",
      "xcam = 0; ycam = .0; zcam = -0;",
      "//Obj Structure - Index",
      "//0..2: x,y,z  3..5: vx,vy,vz  6..8: fx,fy,fz",
      "//9..11: rgb     12: age         13: size;",
      "",
      "",
      "//camera coordinate system",
      "  c1 = cos(0); c2 = cos(0); c3 = cos(0);",
      "  s1 = sin(0); s2 = sin(0); s3 = sin(0);",
      "",
      "  reg30 = c2*c1;            reg31 = c2*s1;            reg32 = -s2;",
      "  reg33 = s3*s2*c1 - c3*s1; reg34 = s3*s2*s1 + c3*c1; reg35 = s3*c2;",
      "  reg36 = c3*s2*c1 + s3*s1; reg37 = c3*s2*s1 - s3*c1; reg38 = c3*c2;",
      "",
      "",
      "//head coordinate system",
      "  reg50 = c2*c1;            reg51 = c2*s1;            reg52 = -s2;",
      "  reg53 = s3*s2*c1 - c3*s1; reg54 = s3*s2*s1 + c3*c1; reg55 = s3*c2;",
      "  reg56 = c3*s2*c1 + s3*s1; reg57 = c3*s2*s1 - s3*c1; reg58 = c3*c2;",
