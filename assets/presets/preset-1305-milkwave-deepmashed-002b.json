      "            gmegabuf(self2+3) = gmegabuf(self+3)+pSpeed*(rand(100)/100-.5)*1*bass;//#Streuung variieren",
      "            gmegabuf(self2+4) = gmegabuf(self+4)+pSpeed*(rand(100)/100-.5)*1*bass;",
      "            gmegabuf(self2+5) = gmegabuf(self+5)+pSpeed*(rand(100)/100-.5)*1*bass;",
      "            gmegabuf(self2+9) = pow(gmegabuf(self+9),2);",
      "            gmegabuf(self2+10) =pow(gmegabuf(self+10),2);",
      "            gmegabuf(self2+11) =pow(gmegabuf(self+11),2);",
      "            gmegabuf(self2+12) = dt2;",
      "            gmegabuf(self2+13) = rand(100)/200+.5;//size",
      "            new -=1; free2 -= 1;",
      "          ,0;);",
      "        ptr2 = (ptr2 + 1)%num2;, new > 0));",
      "      ,gmegabuf(self+14) = 0);      //#nochmal pruefen !",
      "      v2 = pow(gmegabuf(self+3),2)+pow(gmegabuf(self+4),2)+pow(gmegabuf(self+5),2);",
      "      brake = max(0.5,1-dt/(1+gmegabuf(self+14))*cw*v2);",
      "      gmegabuf(self)   += gmegabuf(self+3)*dt;",
      "      gmegabuf(self+1) += gmegabuf(self+4)*dt;",
      "      gmegabuf(self+2) += gmegabuf(self+5)*dt;",
