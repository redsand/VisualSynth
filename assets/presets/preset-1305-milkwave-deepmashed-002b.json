      "//ROTATE VIEPOINT",
      "x1 = (x0-XCam)*reg30 + (y0-yCam) *reg31 + (z0-zCam)*reg32;",
      "y1 = (x0-XCam)*reg33 + (y0-YCam) *reg34 + (z0-zCam)*reg35;",
      "dist = sqrt(pow(x0-xcam,2) + pow(y0-ycam,2) + pow(z0-zcam,2));",
      "k1 = dt/max(dist,.06)*CamLock;",
      "v1 =  -k1*(y1); v2 = k1*(x1); v3 = -reg31*k1*HLock;",
      "",
      "c1 = cos(v1); c2 = cos(v2); c3 = cos(v3);",
      "s1 = sin(v1); s2 = sin(v2); s3 = sin(v3);",
      "reg40 = c2*c3; reg41 = c2*s3; reg42 = -s2;",
      "reg43 = s1*s2*c3 - c1*s3; reg44 = s1*s2*s3 + c1*c3; reg45 = s1*c2;",
      "reg46 = c1*s2*c3 + s1*s3; reg47 = c1*s2*s3 - s1*c3; reg48 = c1*c2;",
      "",
      "q20 = reg40*reg30 + reg41*reg33 + reg42*reg36;",
      "q21 = reg40*reg31 + reg41*reg34 + reg42*reg37;",
      "q22 = reg40*reg32 + reg41*reg35 + reg42*reg38;",
      "q23 = reg43*reg30 + reg44*reg33 + reg45*reg36;",
      "q24 = reg43*reg31 + reg44*reg34 + reg45*reg37;",
      "q25 = reg43*reg32 + reg44*reg35 + reg45*reg38;",
      "q26 = reg46*reg30 + reg47*reg33 + reg48*reg36;",
      "q27 = reg46*reg31 + reg47*reg34 + reg48*reg37;",
      "q28 = reg46*reg32 + reg47*reg35 + reg48*reg38;",
      "reg30 =q20; reg31 =q21; reg32 =q22;",
      "reg33 =q23; reg34 =q24; reg35 =q25;",
      "reg36 =q26; reg37 =q27; reg38 =q28;",
      "",
      "//Fake altitude",
      "q10 = (1.5-ycam);",
      "",
      "//TEXTURE GND MOVEMENT",
      "posx += dxcam; posz += dzcam;",
      "q18 = posz*2;",
      "q19 = posx*2;",
      "",
      "//CLOUDS MOVEMENT",
      "crot = crot + v3;",
      "cfwd = cfwd + (dxcam*reg36 + dycam*reg37 + dzcam*reg38);",
      "",
      "q1 = cos(crot);q2 = sin(crot); q3 = - q2; q4 = q1;",
      "cmovx += -v1 * q1 + v2 * q2;",
      "cmovy += -v1 * q3 + v2 * q4;",
      "q5 = cmovx*.1;",
      "q6 = cmovy*.1;",
      "q7 = cfwd*8;",
      "q8 = v3;",
      "q9 = (dxcam*reg36 + dycam*reg37 + dzcam*reg38);",
      "",
      "",
      "q30 = dt2;",
      "q31 = aspectx;",
      "q32 = aspecty;",
      "",
      "q17 = int(colr*10) + int(colg*10)*10 + int(colb*10)*100;",
      "",
      "gg = .5;",
      "dx = -v2*gg; dy = v1*gg;",
      "",
      "zoom = 1+(dxcam*reg36 + dycam*reg37 + dzcam*reg38)*0;",
      "monitor = free;",
      "",
