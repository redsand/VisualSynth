    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n    // sample previous uFrame\n    ret.xyz = texture( sampler_main, vUv ).xyz;\n\n      // take the difference between the crisp and blurred images,\n      // then add it back into the image.  Creates spots and stripes over uTime.\n      ret.xyz += (ret - GetBlur3(vUv))*0.35;\n      ret.xyz -= 0.004;\n\n      // add noise:\n      vec2 dither_uv = vUvOriginal*uTexSize.xy*texsize_noise_lq.zw * 0.4 + rand_frame.xy;\n      ret.xyz += (texture(sampler_noise_lq, dither_uv).xyz-0.5)*0.18;\n\n      // desaturate over uTime, to keep the globs white\n      ret.xyz = mix(ret.xyz, lum(ret.xyz), 0.2);\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n\n    vec2 d = uTexSize.zw*12;\n    vec3 dx = ( GetBlur1(vUv + vec2(1,0)*d) - GetBlur1(vUv-vec2(1,0)*d) );\n    vec3 dy = ( GetBlur1(vUv + vec2(0,1)*d) - GetBlur1(vUv-vec2(0,1)*d) );\n    vec2 my_uv = vUv + vec2(dx.y,dy.y)*0.1;\n\nvec3 re;\n\n//vUv = vUv + 0.02*vec2(cos(vUv.y*27),sin(vUv.x*39));\nvec2 m = vec2(1-q4,q8);\nvec2 bg_uv = m + (vUv-m)*0.992; // subtle 3D shadow drop\nvec2 mid_uv = m + (vUv-m)*0.996;\nret = mix( vec3(0,0,0.2), vec3(0.3,0,1),texture( sampler_fw_main, bg_uv).y);\nret = mix(ret, vec3(1,1,0), max(GetBlur1(bg_uv).z*1.5,texture( sampler_main, mid_uv).z)); // if that isn't a cool glow effect?\nret *= 1-GetBlur1(bg_uv).x*2; // drop shadow\nret = mix( ret, vec3(1,0.01,0.4),texture( sampler_fw_main, vUv).x);\n//ret = texture(sampler_main, vUv);\nre = texture( sampler_MilkDrop3_004, my_uv);\nre = mix( texture(sampler_MilkDrop3_002b,my_uv), re, ret.x);\nret = mix( re, 1-re, ret.y);\n\nret /= vec3(-2.9,3.0,1.8);\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "dt = gSpeed/fps;",
      "dec_s = 1-.015*30/fps; dec_m = pow(.95, 30/fps); dec_f = pow(.8, 30/fps);",
      "dt2 = dt ; //# unabhaengig machen ?",
      "vol_att = (bass + mid + treb)/3;",
      "avg = avg*dec_s + (1-dec_s)*vol_att*(1.2-.2/cal);",
      "",
      "is_beat = above(vol_att, 1.5*peak) * above (time, t0+.2);",
      "t0 = if(is_beat,time,t0);",
      "peak = peak*dec_m  + (1-dec_m)*vol_att;",
      "index = (index + is_beat) %16;",
      "index2 = (index2 + is_beat*bnot(index))%12;",
      "",
      "//HEAD MOVEMENT x0,y0,z0 based on z-move in HEAD Coords",
      "right = pow(bass_att-avg,1) * (bass_att > avg) *sharp*n1*sin(time*3)/cal;",
      "up =  pow(treb_att-avg,1) * (treb_att > avg) * sharp*n2*cos(time*1)/cal;",
      "right = pow(bass_att,3)*2;",
      "up = pow(treb_att,3)*2;",
      "cal = cal*dec_s + (1-dec_s)*sqrt(up*up+right*right)/4;",
      "cal = max(cal,.3);",
      "",
      "if ((index%2==0)*is_beat,",
      "  if((bass_att < avg+11), n1 = rand(100)/100-.5,0);",
      "  if((treb_att < avg+11), n2 = rand(100)/100-.5,0),0);",
      "",
      "sp0 = (.5+sqrt(vol_att*2))*hSpeed;",
      "sp0 = .1;",
      "dec = if(sp0 > speed,dec_f,dec_m); //checken",
      "speed =  speed*dec + (1-dec)*sp0;;",
      "",
      "//HEAD COORD SYS",
      "c1 = cos(up*dt); c2 = cos(right*dt); c3 = 1;",
      "s1 = sin(up*dt); s2 = sin(right*dt); s3 = 0;",
      "reg40 = c2*c3;            reg41 = c2*s3;            reg42 = -s2;",
      "reg43 = s1*s2*c3 - c1*s3; reg44 = s1*s2*s3 + c1*c3; reg45 = s1*c2;",
      "reg46 = c1*s2*c3 + s1*s3; reg47 = c1*s2*s3 - s1*c3; reg48 = c1*c2;",
      "",
      "q20 = reg40*reg50 + reg41*reg53 + reg42*reg56;",
      "q21 = reg40*reg51 + reg41*reg54 + reg42*reg57;",
      "q22 = reg40*reg52 + reg41*reg55 + reg42*reg58;",
      "q23 = reg43*reg50 + reg44*reg53 + reg45*reg56;",
      "q24 = reg43*reg51 + reg44*reg54 + reg45*reg57;",
      "q25 = reg43*reg52 + reg44*reg55 + reg45*reg58;",
      "q26 = reg46*reg50 + reg47*reg53 + reg48*reg56;",
      "q27 = reg46*reg51 + reg47*reg54 + reg48*reg57;",
      "q28 = reg46*reg52 + reg47*reg55 + reg48*reg58;",
      "",
      "reg50 = q20; reg51 = q21; reg52 = q22;",
      "reg53 = q23; reg54 = q24; reg55 = q25;",
      "reg56 = q26; reg57 = q27; reg58 = q28;",
      "vx0 = reg56*speed;",
      "vy0 = reg57*speed;",
      "vz0 = reg58*speed;",
      "x0 = x0 + vx0*dt ;          reg04 = x0;",
      "y0 = max(-.5,min(0.5,y0 + vy0*dt)) ; reg05 = y0;",
      "z0 = z0 + vz0*dt ;          reg06 = z0;",
      "",
      "style = n1 > 0;",
      "//SPARK QUEUE - insert new objects",
      "if (style ==0, new = max(0,min(32*(mid>1.2),free)),0);",
      "if (style ==1, new = max(0,min(250*(vol_att*200 > 200+obj_num-free),free)),0);",
      "if (new < 8, new = 0, 0);",
      "",
      "n = 0; m = new;",
      "dec = if (new > 0,0.2,dec_f);",
      "new_ = new_*dec + (1-dec)*new;",
      "q29 = new_;",
      "if (new > 0,",
      "  if (index%4==0,",
      "    csum = sqrt(bass_att*bass_att + mid_att*mid_att + treb_att*treb_att) ;",
      "    colr = bass_att/csum;",
      "    colb = mid_att/csum;",
