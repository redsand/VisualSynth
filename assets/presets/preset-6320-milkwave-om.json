    "perFrameCode": [
      "// This preset has most of the values already present, many are either set to mimic a blank canvas, or deactivated.",
      "// Any text on any line that comes after \"//\" is a comment, and does not affect your equations.",
      "// They mostly tell you how to use the different variables.",
      "// Many of the variables themselves are commented out. Simply remove the // at the beginning of the line to use the variable.",
      "",
      "// 0 < x > 1 defines the horizontal coordinates",
      "// 0 < y > 1 defines the vertical coordinates",
      "",
      "// !!IMPORTANT!!",
      "// Any equation that is not commented out must end with a semi-colon \";\"",
      "// !!IMPORTANT!!",
      "",
      "// Custom Variables",
      "avol=(bass+mid+treb)/3;",
      "avol_att=(bass_att+mid_att+treb_att)/3; // attenuated inputs are an average over a short time, so they don't change as quickly as the raw inputs",
      "q1=avol;",
      "q2=avol_att;",
      "",
      "// Color Coordination",
      "red1=if(above(avol,.25),if(above(avol,1.2),if(above(avol,2),.3 ,.06),1),0);",
      "green1=if(above(avol,.5),if(above(avol,1),if(above(avol,1.8),0,.2),.8+(.1*cos(time))),0);",
      "blue1=if(above(avol,.3),if(above(avol,.8),if(above(avol,1.6),.3,.9),.32),1);",
      "",
      "// General Variables",
      "zoom=1; // 1 for no zoom, slightly higher for zoom in, slightly lower for zoom out",
      "warp=0; // WARP!",
      "//rot=0.01*(cos(time*.74)+sin(time*avol_att)); // rotation amount between frames",
      "decay=.97; // 1 keeps things on the screen forever, 0 makes everything disappear immediately",
      "",
      "//darken_center=1; // 0=off 1=on",
      "//wrap=1 // 0=off 1=on",
      "//invert=1; // 0=off 1=on",
      "//brighten=1; // 0=off 1=on",
      "//darken=1; // 0=off 1=on",
      "//solarize=1; // 0=off 1=on",
      "//gamma=2; // Default 2, sliding scale, less is darker, more is brighter",
      "",
      "// Screen Mirroring",
      "echo_zoom=1; // Default 1 (not the same as regular zoom)",
      "echo_alpha=.5; // .5 for equally visible (usually what you want) 1 or 0 for all the way on/off",
      "echo_orient=1; // Integers 1-4 to determine which direction the mirroring is facing",
      "",
      "// From here down, a lot of the variables fall into very specific groups.",
      "// There are waveform equations, inner border equations, outer border equations, and more.",
      "// Many of the variables in each section follow the same pattern. They will start with the",
      "// name of the object, followed by an underscore, then the property of the object.",
      "// [object]_r, [object]_g, and [object]_b control the red, green, and blue levels of the object. 1 is max, 0 is minimum.",
      "// [object]_a controls how opaque the object is, 1 is fully visible, 0 is completely transparent.",
      "// [object]_x and [object]_y control where on the screen the object is, 1 is max, 0 is min.",
      "// x=0 is the far left, x=1 is the far right. y=0 is the bottom, y=1 is the top.",
      "",
      "// Waveform",
      "// Preconfigured just to keep the blank preset from being boring :D",
      "wave_a=if(above(q2,1),1,0);",
      "wave_r=1-red1;",
      "wave_g=1-green1;",
      "wave_b=1-blue1;",
      "wave_x=.5;",
      "wave_y=.5+.3*cos(time*avol_att);",
      "wave_mode=2; // 0=Round, 1=Orbiting, 2=Scribble, 3=Also a scribble.., 4=Horizontal Scribble, 5=Rotating Scribble, 6=Line Wave, 7=2 Line Waves",
      "//wave_mystery=",
      "wave_usedots=1;",
      "wave_thick=1;",
      "wave_additive=1;",
      "wave_brighten=1;",
      "",
      "// Inner Border",
      "ib_a=1;",
      "ib_r=0;",
      "ib_g=0;",
      "ib_b=0;",
      "ib_size=if(above(cos(avol*time),0),.04,0);",
      "",
      "// Outer Border",
      "ob_a=1;",
      "ob_r=red1;",
      "ob_g=green1;",
      "ob_b=blue1;",
      "ob_size=if(above(avol,3),0,.06+.05*cos(time/avol_att));",
      "",
      "// Motion Vectors",
      "mv_a=if(above(q1,1),1,0);",
      "mv_r=1-red1;",
      "mv_g=1-green1;",
      "mv_b=1-blue1;",
      "// How many movion vectors in the x direction",
      "mv_x=100;",
      "// How many movion vectors in the y direction",
      "mv_y=100;",
      "// Length of the motion vectors (.01 for dot, .1+ for lines)",
      "mv_l=.5+.5*cos(avol_att);",
      "//mv_dx",
      "//mv_dy",
      "",
      "// These ones can be really weird, but also have very powerful potential. Play at your own risk.",
      "",
      "// Horizontal / Vertical Motion Fine Tuning",
      "//controls amount of constant horizontal motion",
      "dx=0+.01*cos(time);",
      "//controls amount of constant vertical motion",
      "dy=0+.01*cos(time*1.57);",
      "",
      "// Rotational / Stretching Center",
      "cx=.5+.2*cos(time+avol_att);",
      "cy=.5+.2*cos(abs(tan(avol_att)));",
      "",
      "// Horizontal / Vertical Stretching Fine Tuning",
      "//Controls amount of constant horizontal stretching",
      "sx=.95+.02*cos(time+avol_att);",
      "//Controls amount of constant vertical stretching",
      "sy=.95+.02*cos(time+avol);",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "// Watch a variable",
      "//  Set monitor equal to the variable you wish to watch",
      "// then press \"n\" while outside of the text editor, the",
      "// variable will show in the top right corner as \"pf monitor\"",
      "monitor=cy;"
    ],
