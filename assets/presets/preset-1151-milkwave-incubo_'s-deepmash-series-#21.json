  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvec2 uv1 = vec2(vUv.x-0.5,vUv.y-0.5)*uAspect.xy;\n\n\nvec3 noiseVal =lum (texture(sampler_noise_lq,vUv+ rand_frame))-.5;\n\nvec2 k1 = vec2((vUv.x), (vUv.y));\n\nvec3 ret1 = GetBlur1(vUv) ;\n\nvec2 zz = vUv.xy * uTexSize.xy *.02 ;\nfloat h1 = (cos(zz.y) * sin(-zz.y));\nfloat h2 = (sin(zz.x) * cos(zz.y));\n\nvUv.xy += q28*vec2(h1,h2)*uTexSize.zw * 64;\n\nvec3 crisp = texture(sampler_main,vUv) + noiseVal/20;\n\n\nvec2 uv6 = .3*sin(42*vUv);\nfloat dots = .001/length(uv6.x);\n\ncrisp += dots*roam_cos*0;\ncrisp = mix(crisp.zxy, crisp, 0.1*lum(crisp));\n\nret = (q24)*(crisp*.99 -.01) + (1-q24)*GetPixel(vUv)*.99;\n\n  fragColor = ret;\n}",
