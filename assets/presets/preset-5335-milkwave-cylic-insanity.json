      "net_effect = if(above(state,2),treb_effect,0)+if(above(state,1),bass_effect,0)*if(equal(bass_effect,4),.5,1);",
      "net_effect = if(equal(net_effect,0),1,net_effect);",
      "zoom = net_effect;",
      "ib_a = bass_att*.1*state;",
      "ib_r = wave_g;",
      "ib_g = wave_b;",
      "ib_b = wave_r;",
