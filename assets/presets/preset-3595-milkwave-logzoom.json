  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvec2 c =vec2(vUv.x-0.5,vUv.y-0.5)*uAspect.xy;\nfloat rad_hq = log(length(c))*q26;\nfloat ang_hq = -atan(c.x,c.y)*q27 + rad_hq*q24 + q23;\nvec2 polar =vec2(ang_hq/asin(1)*2, rad_hq-q25);\n//polar = 0.5 + (1.0 - abs( fract( polar * 0.5 ) * 2 - 1.0 )-0.5);\nvUv = polar.yx;\n\nret = GetPixel(fract(vUv));\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "// high saturation color cycler //",
      "bb = bb*0.98 + bass*0.02;",
      "mm = mm*0.98 + mid*0.02;",
      "tt = tt*0.98 + treb*0.02;",
      "",
      "zoom = 0.999;",
      "",
      "mx = max(max(bb,mm),tt);",
      "mn = min(min(bb,mm),tt);",
      "ob_r  = (bb-mn)/(mx-mn);",
      "ob_g = (mm-mn)/(mx-mn);",
      "ob_b = (tt-mn)/(mx-mn);",
      "",
      "v = 0.2/fps;",
      "bm = bm + (ob_r-ob_g)*v;",
      "mt = mt + (ob_g-ob_b)*v;",
      "",
      "q18 = bm-mt;",
      "",
      "",
      "bbb = bbb*0.99 + bass_att*0.01;",
      "mmm = mmm*0.99 + mid_att*0.01;",
      "ttt = ttt*0.99 + treb_att*0.01;",
      "mx = max(max(bbb,mmm),ttt);",
      "mn = min(min(bbb,mmm),ttt);",
      "t1 = (bbb-mn)/(mx-mn);",
      "t2 = (mmm-mn)/(mx-mn);",
      "t3 = (ttt-mn)/(mx-mn);",
      "",
      "v = 0.2/fps;",
      "b1 = b1 + (t1-0.5)*v;",
      "m1 = m1 + (t2-0.5)*v;",
      "tt1 = tt1 + (t3-0.5)*v;",
      "q23 = (m1-b1)*3;",
      "q24 = -(t1-t2)*0.5;",
      "q25 = (b1-tt1)*2;",
      "q26 = 0.25-(t1-t2)*0.1;",
      "q27 = 0.25;"
    ],
    "perFrameInitCode": [
      "x1 = 0;",
      "y1 = 0;",
      "q11 = 0.5/asin(1);"
    ],
    "perPixelCode": [
      "",
      "// have a nice warp effect? - rotate it like a shape!",
      "",
      "  angle = q18*2;",
      "",
      "/////////////////////////////////////////////////////////",
      "X1 = (x-0.5)*aspectx; // center",
      "Y1 = (y-0.5)*aspecty;",
      "x = cos(-angle)*X1 -sin(-angle)*Y1; // rotate the x/y pane",
      "y = sin(-angle)*X1 +cos(-angle)*Y1;",
      "/////////////////////////////////////////////////////////",
      "",
      "  // place your original code here",
      "",
      "  t = time*2;",
      "  v = 0.002;",
      "  n = 16;",
      "",
      "  dx = v*(cos((-x+y)*n+t) + sin((x+y)*n+t)); // these are the 2 lines for my mushroom-movement ;-)",
      "  dy = v*(cos((x-y)*n-t) + sin((-x-y)*n-t)); // insert here your dx/dy-code-to-rotate (but remember the shifting: center is @ 0,0)",
      "",
      "",
      "",
      "/////////////////////////////////////////////////////////",
      "dx1 = cos(angle)*dx - sin(angle)*dy; // and finally the dx/dy pane is rotated to match the x/y pane",
      "dy1 = sin(angle)*dx + cos(angle)*dy;",
      "dx = dx1*aspectx;",
      "dy = dy1*aspecty;",
      "/////////////////////////////////////////////////////////"
    ],
