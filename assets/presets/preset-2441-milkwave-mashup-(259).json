  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    float rad_lq = vRadius * length(uTexSize.xy)*0.5;\n    float ang_lq = vAngle;\n    vec2 uv_temp1 = (vUv - 0.5) * uTexSize.xy;\n    float rad_hq = length(uv_temp1);\n    float ang_hq = atan(-uv_temp1.y, uv_temp1.x);\n\n    vec2 uv2 = (vUv - 0.5);\n    float rad2 = rad_lq*0.8;\n    float ang2 = ang_lq * M_INV_PI_2 + rad_lq*0.000 + uTime*0.00;\n\n\n        // FIN TYPE\n        float fins = 6;\n        ang2 = fract(ang2*fins)/fins;\n              // ENABLE THIS TO MAKE THE FINS ALTERNATE: (seamless!)\n              ang2 = abs(ang2 - 0.5/fins);\n\n\n    ang2 *= M_PI_2;\n    vUv = 0.5 + rad2*vec2(cos(ang2),sin(ang2))*uTexSize.zw;\n\n    ret = 1.4*pow(clamp01(GetBlur1(vUv))*((texture(sampler_pc_main,vUv)-GetBlur3(vUv))),0.5); //invert\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "warp = 0;",
      "//zoom = 1;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "vol = (bass_att + treb_att + mid_att)*.333333;",
      "",
      "ra = 1/tic*.25;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "q1 = tt*3;// wave morph speeds",
      "q2 = mt*3;",
      "q3 = bt*3;",
      "",
      "q4 = vt; // wave colour cycle",
      "",
      "rb = if(rb,rb,.2 + rand(1001)*.001*.6);",
      "rc = if(rc,rc,.2 + rand(1001)*.001*.6);",
      "rd = if(rd,rd,.2 + rand(1001)*.001*.6);",
      "re = if(re,re,.2 + rand(1001)*.001*.6);",
      "",
      "rot = .26;",
      "cx = .3 + .1*sin(vt*re) + .1*cos(vt*rc);",
      "cy = .5 + .2*sin(vt*rb) + .1*cos(vt*rd);",
      "",
      "",
      "q5 = min(1,.5*treb_avg)*.035;",
      "q6 = min(1,.5*mid_avg)*.035;",
      "q7 = min(1,.5*bass_avg)*.035;",
      "",
      ""
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "num = 8;",
      "pi = 3.141592654;",
      "radi = (y-.5)*.75;",
      "radi = (y-.5);",
      "radi = pow(radi*radi + (x-.5)*(x-.5),.5);",
      "",
      "an = ang + pi + time;",
      "an = an - pi*2*int(an/(pi*2));",
      "",
      "mod = .1;",
      "",
      "seg = ang + pi;",
      "seg = seg/(pi*2)*num;",
      "seg = int(seg);",
      "seg = seg - equal(seg,num);",
      "",
      "anga = (ang + pi) - (pi*2/num)*seg;",
      "anga = if(equal(seg%2,0),(pi*2/num) - anga,anga);",
      "//anga = anga + pi/6; // num = 6",
      "anga = anga + pi/4; // num = 8",
      "//anga = anga + .85; // num = 10",
      "",
      "",
      "ox = .5 - radi*sin(anga);",
      "oy = .5 + radi*cos(anga);",
      "",
      "//rot = if(equal(seg,0),rot,0);",
      "",
      "dx = equal(seg,3)*(x-ox);",
      "dy = equal(seg,3)*(y-oy);",
      "",
      "dx = above(seg,0)*(x-ox);",
      "dy = above(seg,0)*(y-oy);",
      "",
      "//dx = equal(seg,1)*(x - .5)*2;"
    ],
