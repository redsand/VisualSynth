  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp =0.1;",
      "vol_now =  .7*bass + 0.2 * (bass_att + treb + mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean - 0.5 * (vol_mean-vol_now),0.1 * (vol_mean * 9 + vol_now));",
      "beat = if(above(vol_now,vol_mean),1,0);",
      "ying = if(below(ying,1),1,ying);",
      "ying = if (beat,ying + bnot(time*10%3),ying);",
      "yin = ying%2;",
      "mytime = beat*ying;",
      "ib_size = 0.02;",
      "ib_g = if(bnot(ying%11),ib_r,ib_b);",
      "//ib_g = if(bnot(ying%11),1,0);",
      "ib_r = if(bnot(ying%11),ying%3,ob_g);",
      "ib_b = if(bnot(ying%11),ying%4,1);",
      "mv_a = yin;",
      "mv_b = sin(mytime) + abs(sin(mytime));",
      "mv_r = cos(mytime);",
      "mv_g = -.8*sign(sin(mytime))*abs(sin(mytime));",
      "ob_b = cos(ying)  + abs(cos(ying));",
      "ob_g = abs(sin(ying)) ;",
      "ob_r = (-1 * cos(ying))  + abs(-1 * cos(ying)) + 0.2 * (cos(sin(ying))+(abs(cos(sin(ying)))+cos(sin(ying))));",
      "q3 = if(beat,(10*abs(sin(mytime)))%3-1,0);",
      "dx = if(yin,dx -0.005*sin(mytime*0.23),if(equal(yin,yang),0,if(below(abs(dx),.05),dx-(q3*0.001),dx)));",
      "dy = if(yin,dy - 0.005*sin(mytime*0.2),if(equal(yin,yang),0,if(below(abs(dy),.05),dy-(q3*0.001),dy)));",
      "zerocount = zerocount + bnot(dx);",
      "yin = if(equal(zerocount,15),1,yin);",
      "zerocount = if(equal(zerocount,15),0,zerocount);",
      "volume = vol_now-vol_mean;",
      "xamptarg = if(equal(frame%15,0),min(0.5*volume*bass_att,0.5),xamptarg);",
      "xamp = xamp + 0.5*(xamptarg-xamp);",
      "xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));",
      "xaccel = xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xpos = xpos + 0.001*xspeed;",
      "q2 = xpos;",
      "yamptarg = if(equal(frame%15,0),min(0.3*volume*treb_att,0.5),yamptarg);",
      "yamp = yamp + 0.5*(yamptarg-yamp);",
      "ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));",
      "yaccel = ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "yspeed = yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "ypos = ypos + 0.001*yspeed;",
      "q4 = ypos;",
      "q5 = max(sin(mytime)-.3,0);",
      "mv_y = if(yin,9,sin(ying)*ying);",
      "yang = bnot(yin);",
      "q6 = yin;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "box =0.5+0.8*((2*x)%2+(2*y)%2);",
      "q1 = 2*q5+7.7+0.3*(sin(pow(x,3)+0.137*time)-cos(pow(y,3)+0.213*time));",
      "axis = if(q3,x,y);",
      "zoom = if(q6,if(above(box,1),q1*.1,zoom),zoom+.05*axis);",
      "rot = if(q6,if(above(box,1),0.5*sin(0.5*rad+0.385*time),rot),0);",
      "cx = cx - 0.5*sin(rad+2*q4);",
      "cy = cy + 0.11*sin((sqrt(2)-rad)-18*q2);"
    ],
