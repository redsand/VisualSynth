  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// timed sidon sensor",
      "// le = signal level; desired average value = 2",
      "le=1.4*bass_att+.1*bass+.5*treb;",
      "pulse=above(le,th);",
      "// pulsefreq = running average of interval between last 5 pulses",
      "pulsefreq=if(equal(pulsefreq,0),2,",
      "if(pulse,.8*pulsefreq+.2*(time-lastpulse),pulsefreq));",
      "lastpulse=if(pulse,time,lastpulse);",
      "// bt = relative time; 0 = prev beat; 1 = expected beat",
      "bt=(time-lastbeat)/(.5*beatfreq+.5*pulsefreq);",
      "// hccp = handcicap for th driven by bt",
      "hccp=(.03/(bt+.2))+.5*if(band(above(bt,.8),below(bt,1.2)),",
      "(pow(sin((bt-1)*7.854),4)-1),0);",
      "beat=band(above(le,th+hccp),btblock);",
      "btblock=1-above(le,th+hccp);",
      "lastbeat=if(beat,time,lastbeat);",
      "beatfreq=if(equal(beatfreq,0),2,",
      "if(beat,.8*beatfreq+.2*(time-lastbeat),beatfreq));",
      "// th = threshold",
      "th=if(above(le,th),le+114/(le+10)-7.407,",
      "th+th*.07/(th-12)+below(th,2.7)*.1*(2.7-th));",
      "th=if(above(th,6),6,th);",
      "",
      "wave_r=.5*sqr(sin(time*3.7))+.5*sin(37*ccl+.01*leccl);",
      "wave_g=.5*sqr(sin(time*2.8))+.5*sin(38*ccl+.01*leccl);",
      "wave_b=.5*sqr(sin(time*3.2))+.5*sin(36*ccl+.01*leccl);",
      "wave_x=.5+.1*sin(leccl+frame);",
      "wave_y=.5+.1*sin(1.2*leccl+frame+1.17);",
      "",
      "ccl=ccl+beat;",
      "q1=ccl;",
      "leccl=leccl+bass+treb;",
      "q2=.001*leccl;",
      "q3=th;",
      "",
      "ob_r=wave_R;",
      "ob_b=wave_b;",
      "ob_g=wave_G;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "sector=(ang+rot+x+y)*5000+q1+10*sin(q2);",
      "orient=sector%4;",
      "spd=.005*q3;",
      "quadrant=above(x,.5)*2+above(y,.5-x);",
      "",
      "// variant movement",
      "dx=dx+equal(quadrant,q1%4)*if(below(orient,2),-spd,spd);",
      "dy=dx+equal(quadrant,q1%4)*if(orient%2,-spd,spd);",
      "",
      "// pulsed zoom",
      "zoom = 1+equal(quadrant,(q1+1)%4-x*5*sin(100*q2+10*sign(sin(20*q1))));",
      "",
      "",
      "//ccl driven stretch fx",
      "sx=1+equal(quadrant,(q1+2)%4)*.1*sin(53*q1+10*q2+4*ang);",
      "sy=1+equal(quadrant,(q1+2)%4)*.1*sin(32*q1+10*q2+4*ang);",
      "",
      "//structures",
      "structure=equal(quadrant,(21.7*q1)%4)*above(sector%6,2)-q1;",
      "",
      "dx=if(structure,5*-dx,dx);",
      "dy=if(structure,5*-dy,dy);;",
      "rot=if(above(q1,q3),if(above(no_effect,5),rot*Sin(-ang+ang-.4*q1)-rot*sin(ang+-ang*q3)*rad*Sin(q1-rad)-x*.05*sin(q4)-y*.05",
      "*sin(q2-x+y*rad)-rot*sin(equal(q1,q2)),.1*rad),0);",
      "zoom=if(above(no_effect,5),zoom+raD*.03*sin(q2+q3)-x*.05*sin(q1+q3)+y*.10*.25*sin(q1-q2)",
      ",1+.10*sin(rad)",
      ");",
      "no_effect=q3-.2;"
    ],
