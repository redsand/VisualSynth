  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "basstime = basstime + bass*0.03;",
      "q1 = basstime*4;",
      "",
      "//start in most active range",
      "basstime = if(below(basstime,1000),1000,basstime);",
      "//basstime = if(above(basstime,495),450,basstime);",
      "",
      "basstime = basstime + bass_att*0.03;",
      "vol = pow(bass+mid+treb,2);",
      "basssum = vol;",
      "",
      "stickybit = time%2;",
      "",
      "//avg vol",
      "//buffer 1",
      "volAvg = volAvg + vol*equal(stickybit,1);",
      "//number of samples 1 or framerate",
      "sample1 = sample1 + equal(stickybit,1);",
      "//buffer 2",
      "volAvg2 = volAvg2 + vol*equal(stickybit,0);",
      "//number of samples 2",
      "sample2 = sample2 + equal(stickybit,0);",
      "",
      "//transision",
      "edge = bnot(equal(bit2,stickybit));",
      "",
      "volAvg = volAvg - volAvg*edge*stickybit;",
      "volAvg2 = volAvg2 - volAvg2*edge*equal(stickybit,0);",
      "",
      "sample1 = sample1  - sample1*edge*stickybit;",
      "sample2 = sample2  - sample2*edge*equal(stickybit,0);",
      "",
      "//test vol against avg buffer lvl",
      "diff = if(equal(stickybit,1), (basssum/(volAvg2/sample2)) , 0);",
      "diff = if(equal(stickybit,0), (basssum/(volAvg/sample1)), diff);",
      "",
      "q3 = diff;",
      "",
      "bit2 = time%2;",
      "",
      "difftime = difftime + diff*0.03;",
      "q2 = difftime;",
      "",
      "//fix a strange error",
      "difftime = if(above(difftime,2000),0, difftime);",
      "",
      "monitor = q3;",
      "",
      "//////////  SHAPECODE CONTROL //////////",
      "////////// Starting from the beginning //////////",
      "",
      "// SHAPECODE PART 1//",
      "vol = 0.167*(bass+mid);",
      "xamptarg = if(equal(frame%15,0),min(0.5*vol*bass_att,0.5),xamptarg);",
      "xamp = xamp + 0.5*(xamptarg-xamp);",
      "xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));",
      "xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xpos = xpos + 0.003*xspeed;",
      "",
      "yamptarg = if(equal(frame%15,0),min(0.3*vol*treb_att,0.5),yamptarg);",
      "yamp = yamp + 0.5*(yamptarg-yamp);",
      "ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));",
      "yspeed = yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "ypos = ypos + 0.003*yspeed;",
      "",
      "q4=1.1*xpos +0.25*ypos + 0.5;",
      "q5=1.1*ypos +0.25*xpos + 0.5;",
      "",
      "// SHAPECODE PART 2//",
      "vol_2 = 0.167*(bass+mid);",
      "xamptarg_2 = if(equal(frame%15,0),min(0.5*vol_2*bass_att,0.5),xamptarg_2);",
      "xamp_2 = xamp_2 + 0.5*(xamptarg_2-xamp_2);",
      "xdir_2 = if(above(abs(xpos_2),xamp_2),-sign(xpos_2),if(below(abs(xspeed_2),0.1),2*above(xpos_2,0)-1,xdir_2));",
      "xspeed_2 = xspeed_2 + xdir_2*xamp_2 - xpos_2 - xspeed_2*0.055*below(abs(xpos_2),xamp_2);",
      "xpos_2 = xpos_2 + 0.013*xspeed_2;",
      "",
      "yamptarg_2 = if(equal(frame%15,0),min(0.3*vol_2*treb_att,0.5),yamptarg_2);",
      "yamp_2 = yamp_2 + 0.5*(yamptarg_2-yamp_2);",
      "ydir_2 = if(above(abs(ypos_2),yamp_2),-sign(ypos_2),if(below(abs(yspeed_2),0.1),2*above(ypos_2,0)-1,ydir_2));",
      "yspeed_2 = yspeed_2 + ydir_2*yamp_2 - ypos_2 - yspeed_2*0.055*below(abs(ypos_2),yamp_2);",
      "ypos_2 = ypos_2 + 0.013*yspeed_2;",
      "",
      "q7=1.1*xpos_2 +0.15*ypos_2 + 0.5;",
      "q8=1.1*ypos_2 +0.15*xpos_2 + 0.5;",
      "",
      "// ZOOM SHAPE CONTROL //",
      "q6= 0.05*(pow(1+1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "// END //",
      "",
      ""
    ],
