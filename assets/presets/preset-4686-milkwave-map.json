    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvec2 p0 = -.0*vec2(q6,q6);\nvUv = multiply(vUv,mat2(_qb));\nfloat corr = uTexSize.xy*texsize_noise_lq.zw;\nvec2 uv1 = (vUv-.5+p0 );\nfloat h1 = .4;\nfloat z = +h1/abs(uv1.y);\nrs.x = uv1.x * z;\nrs.y = z + q30;\nnoise = texture(sampler_pw_noise_lq,rs/32);\nnoise *= (noise >= .9);\nnoise *= 1+.5*(lum(texture(sampler_noise_hq,16*rs))-.5);\nvec4 noise2 = texture3D(sampler_noisevol_hq,\n                      ((rs.xyy*2.4\n                       )*uTexSize.xyy*texsize_noisevol_hq.zww\n                      ).xyz*\n                      vec3(1,1,0)*0.05 +\n                      uTime*vec3(0,0,1)*0.2\n                     );\nif (noise.x+noise.y+noise.z > .01) noise += (noise2)*.8;\nret1 = noise;\n\nz = 3*h1/abs(uv1.y);\nrs.x = uv1.x * z;\nrs.y = z + q30;\nnoise = texture(sampler_pw_noise_lq,rs/32);\nnoise *= (noise >= .9);\nif (noise.x+noise.y+noise.z > .01) noise += (noise2)*.8;\nret1 += noise;\n\nz = h1/abs(uv1.x);\nrs.y = uv1.y * z;\nrs.x = z + q30;\nnoise = texture(sampler_pw_noise_lq,rs/32);\nnoise *= (noise >= .9);\nnoise *= 1+.5*(lum(texture(sampler_noise_hq,16*rs))-.5);\nif (noise.x+noise.y+noise.z > .01) noise += (noise2)*.8;\nret1 += noise;\n\nz = 3*h1/abs(uv1.x);\nrs.y = uv1.y * z;\nrs.x = z + q30;\nnoise = texture(sampler_pw_noise_lq,rs/32);\nnoise *= (noise >= .9);\nif (noise.x+noise.y+noise.z > .01) noise += (noise2)*.8;\nret1 += noise;\n\nret = ret1;\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  uv0 = vUv;\nscreen3 = vec3 ((vUv-.5)*uAspect.xy,1) * (1+.0*texture(sampler_noise_hq,vUv+uTime*.1));//wirkt wie zoom / Tele ###\n\ndist = .5; lav_gnd = 0; tower = 1;\nfor (int m=1; m <= quality; m++) {\n  rsl = project (dist)+vec3 (mov,0);\n  lprof =  (texture(sampler_pw_noise_lq,rsl.xy*.1).r <=.7);\n  uv2 = rsl.xy*.4*64;\n  tile = clamp01(2-3*max(abs(fract(uv2.x)-.5),abs(fract(uv2.y)-.5)))*.25+.75;\n  lprof = 1-clamp01(1-lprof)*tile;\n  lprof *= texture(sampler_pw_noise_lq,rsl.xy*.1/16+tower+q30).r;\n  lav_gnd -= lprof/quality*depth/rsl.z;\n  tower -= lprof/quality/2;\n  rsl3 = rsl;\n}\nrsl = project (dist)+vec3 (mov,0);\nfloat step = int(uTime*8)%14+q24;\nfloat mask =         texture(sampler_pw_noise_lq,rsl.xy+step/128).r >= .9;\nmask *=              texture(sampler_pw_noise_lq,rsl.xy + 1.0/8*int(tower*8)).r >= .9;\nvec3 windows = pow(texture(sampler_pw_noise_lq,rsl.xy),2).r* !mask;\n\n\nuv2 = rsl.xy*4*64;\n\ntile = clamp01(1-2*max(abs(fract(uv2.x)-.5),abs(fract(uv2.y)-.5)));\nwindows *= 2*tile*GetPixel(fract(rsl.xy*2));\n\nlav_gnd = 0;\nrsl2 = project(dist) + vec3 (mov,0);\nvec3 light = GetPixel(fract(rsl2*2));\nret1 =  mix(8*light*clamp01(1-tower),2*windows *(tower*2-1),clamp01(2*tower-1.1)) ;\n\nuv4 = vec2(fract(rsl.x),fract(rsl.y));\nret1 *= 1+pow(sin(4*(uv4.x/uv4.y)+8*uTime),24) *(q28%2)* roam_sin ;;\n\nret = 1-exp(-ret1*2);\n//ret = GetPixel(vUv);\nret-=roam_sin*roam_cos.zxy;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "dec_med = pow (0.7, 30/fps);",
      "dec_slow = pow (0.9, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, avg+peak) * above (time, t0+.1);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %16;",
      "index2 = (index2 + is_beat*bnot(index))%4;",
      "",
      "q20 = avg;",
      "q21 = beat;",
      "q22 = peak;",
      "q23 = index;",
      "q24 = is_beat;",
      "q26 = bass + mid + treb;",
      "q29 = 2 * (index2%2-.5);",
      "q25 = min(1,q22/2);",
      "",
      "k1 =  is_beat*equal(index%4,0);",
      "p1 =  k1*(p1+1) + (1-k1)*p1;",
      "p2 = dec_med * p2+ (1-dec_med)*p1;",
      "rott = p2 * 3.1416/4;",
      "q1 = cos(rott);",
      "q2 = sin(rott);",
      "q3 = -q2;",
      "q4 = q1;",
      "",
      "",
      "q27 = index;",
      "q28 = index2;",
      "",
      "mov = mov*dec_med + (1-dec_med)*above(index%8,2);",
      "movez = movez + 1/fps*mov;",
      "q30 = movez;",
      "//**************************",
      "",
      "q8 = movex; q9 = movey;",
      "",
      "trel1 = trel1 + (q1*q22*3)/fps;",
      "trel2 = trel2 + (q2*q22*2)/fps;",
      "trel3 = trel3 + 4*(1-mov)/fps;",
      "trel4 = trel4 + 1 * mov/fps;",
      "",
      "q11 = .3*sin(trel1);",
      "q12 = .1*cos(trel2);",
      "q13 = 8 + 6*sin(trel3);",
      "",
      "q14 = .3*sin(trel2);",
      "q15 = .2*cos(trel3) ;",
      "q16 = 6 + 3*sin(trel1);",
      "",
      "q17 = .3*sin(trel4);",
      "q18 = .3*cos(trel2);",
      "q19 = 3 + sin(trel3);",
      "",
      "trot = trel1/2;",
      "trot = index2*6.28/4;",
      "q5 = cos(trot);",
      "q6 = sin(trot);",
      "q7 = -q6;",
      "q8 = q5;",
      "",
      "",
