  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "basstime = basstime + bass_att*0.03;",
      "vol = pow(bass+mid+treb,2);",
      "basssum = vol;",
      "",
      "stickybit = time%2;",
      "",
      "//avg vol",
      "//buffer 1",
      "volAvg = volAvg + vol*equal(stickybit,1);",
      "//buffer 2",
      "volAvg2 = volAvg2 + vol*equal(stickybit,0);",
      "",
      "//transision",
      "edge = bnot(equal(bit2,stickybit));",
      "",
      "volAvg = volAvg - volAvg*edge*stickybit;",
      "volAvg2 = volAvg2 - volAvg2*edge*equal(stickybit,0);",
      "",
      "",
      "diff = if(equal(stickybit,1), basssum/volAvg2 , 0);",
      "diff = if(equal(stickybit,0), basssum/volAvg, diff);",
      "",
      "bit2 = time%2;",
      "",
      "q1 = diff;",
      "",
      "ob_r = 0.5 + 0.5*sin(basstime*4.5);",
      "ob_g = 0.5 + 0.5*sin(basstime*5);",
      "ob_b = 0.5 + 0.5*sin(basstime*3.8);",
      "",
      "q2 = basstime;",
      "",
      "//rottating ceneter",
      "state = state + above(bass_att,1.3);",
      "state = if(above(state,1),0 , state);",
      "",
      "//need to init",
      "xs = if(below(xs, 1),5 ,xs);",
      "ys = if(below(xs, 1),5 ,ys);",
      "",
      "",
      "xs = xs + equal(state,0)*cos(basstime*1.2)*diff",
      "+ equal(state,1)*sin(basstime*1.5 + 1)*diff;",
      "",
      "ys = xs + equal(state,0)*cos(basstime*1.45 + 0.3)*diff",
      "+ equal(state,1)*sin(basstime*1.05)*diff;",
      "",
      "//project and publish",
      "q3 = 0.5 + 0.5*sin(xs*2);",
      "q4 = 0.5 + 0.5*sin(ys*2.1);",
      "",
      "echo_orient = 3;",
      "monitor = basstime;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "rot = y*x*q1*5;",
      "//zoom = 1 - q1;",
      "sx = 1-q1;",
      "sy = 1-q1;",
      "cx = q3;",
      "cy = q4;"
    ],
