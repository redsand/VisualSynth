  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "zoom = 1;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "vol = (bass_att + treb_att + mid_att)*.333333;",
      "",
      "ra = 1/tic*.25;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav*.2;",
      "toc = 1;",
      "",
      "q1 = vt; // rotation",
      "",
      "q2 = pow(1 + vav,2) - 1; // zoom strength",
      "",
      "q3 = .8; // triyle xius",
      "q4 = .8; // triyle tex_zoom",
      "q5 = q1 + 4.7124 + .7851; // triyle tex_y",
      "",
      "sw = 1-sw;",
      "q6 = -sw; // triyle additive value",
      "",
      "monitor = slide;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "",
      "zoom = zoom + 0.2*abs(0.3*cos(4*rad))*cos(12*ang);",
      "sx = sx - 11*dx_r*sin(2*sin(6*rad)*2*cos(6*rad));",
      "//sy = sy - 13*dy_r*sin(2*cos(6*rad)*2*sin(6*rad));",
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.999+1.31);",
      "//dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "//dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "",
      "",
      "tg1 = abs(sin(time));",
      "tg2 = 12*above(tg1,0.8) + 4*below(tg1,0.2) +",
      "6*above(tg1,0.2)*below(tg1,0.4) + 8*above(tg1,0.4)*below(tg1,0.6) +",
      "10*above(tg1,0.6)*below(tg1,0.8);",
      "tg3 = if(equal(thresh,2),tg2,tg3);",
      "zoom = zoom + 0.6-(1.5*abs( 25*dx_r*cos(tg3*ang) - sin(22*dy_r*rad)*0.2-rad));",
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "",
      "dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "zoom = zoom + 0.01;",
      "zoom = zoom + (0.05 + 0.04*sin(time))*(0.2*sin(ang*time));",
      "rot = rot + 0.01*(0.5*cos(ang*5*bass*time));",
      "",
      "dx = dx + 0.1*above(rad,0.25)*dx_r;",
      "dy = dy + 0.1*above(rad,0.25)*dy_r;",
      "rot=0.1*pow(-ang,3)-1.18*sin(ang);",
      "zoom=1.45*sin(-rad)+1.3+ sin(rad);",
      "dx = dx + 0.09*sin(q8*0.785);",
      "dy = dy + 0.09*sin(q8*0.675);",
      "//zoom = zoom +q7;",
      "",
      "rd=sqrt( sqr( (x-0.5)*2) + sqr( (y-0.5)*1.5 ) );",
      "",
      "backside=(rd-0.645)*5;",
      "backside=min(backside,1);",
      "dx=dx*backside;",
      "dy=dy*backside;",
      "warp=warp*backside;",
      "zoom=1 + 8.291 * pow(min(backside*0.2,1) , 2 )",
      "",
      ""
