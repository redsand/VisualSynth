  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// timed sidon sensor",
      "// le = signal level; desired average value = 2",
      "le=1.4*bass_att+.1*bass+.5*treb;",
      "pulse=above(le,th);",
      "// pulsefreq = running average of interval between last 5 pulses",
      "pulsefreq=if(equal(pulsefreq,0),2,",
      "if(pulse,.8*pulsefreq+.2*(time-lastpulse),pulsefreq));",
      "lastpulse=if(pulse,time,lastpulse);",
      "// bt = relative time; 0 = prev beat; 1 = expected beat",
      "bt=(time-lastbeat)/(.5*beatfreq+.5*pulsefreq);",
      "// hccp = handcicap for th driven by bt",
      "hccp=(.03/(bt+.2))+.5*if(band(above(bt,.8),below(bt,1.2)),",
      "(pow(sin((bt-1)*7.854),4)-1),0);",
      "beat=band(above(le,th+hccp),btblock);",
      "btblock=1-above(le,th+hccp);",
      "lastbeat=if(beat,time,lastbeat);",
      "beatfreq=if(equal(beatfreq,0),2,",
      "if(beat,.8*beatfreq+.2*(time-lastbeat),beatfreq));",
      "// th = threshold",
      "th=if(above(le,th),le+114/(le+10)-7.407,",
      "th+th*.07/(th-12)+below(th,2.7)*.1*(2.7-th));",
      "th=if(above(th,6),6,th);",
      "thccl=thccl+(th-2.5144);",
      "",
      "bccl=bccl+beat;",
      "q1=thccl;",
      "q2=bccl;",
      "",
      "wave_r=sqr(sin(.016*thccl+bccl+frame%2));",
      "wave_g=sqr(sin(.018*thccl+bccl+frame%2));",
      "wave_b=sqr(sin(.017*thccl+bccl+frame%2));",
      "wave_x=if(frame%2,.501,.5);",
      "wave_y=if(frame%2,.99,.5);",
      "wave_mode=if(frame%2,7,0);",
      "wave_mystery=if(frame%2,0,-.6);",
      "",
      "ob_a=if(above(sin(.005*thccl+bccl),.9),.05*(1+sin(time)),0);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "//middle part",
      "zoom=1+above(sin(1.7*q2),-.5)*.1*sin(2*q2+.027*q1+4*(1+sin(.7*time+q2))*sin(.05*q2+time)*rad);",
      "rot=.1*sin(q2)*sin(2.3*q2+.027*q1+2*sin(.07*q1+1.2*time)*(rad+sin(time+above(sin(q2),0)*4*sin(q2)*ang)));",
      "rot=above(sin(1.2*q2+1.3),-.5)*rot;",
      "",
      "//borders",
      "brdr=bor(below(y,.15),above(y,.85));",
      "dy=if(below(y,.15),y,0)+if(above(y,.85),-1+y,0)+if(brdr,0,dy);",
      "dx=if(brdr,.01*sin(.02*q1+x+3*ang+10*y),dx);",
      "rot=if(brdr,0,rot);",
      "zoom=if(brdr,1,zoom);",
      "sx=if(brdr,1,sx);",
      "sy=if(brdr,1,sy);"
    ],
