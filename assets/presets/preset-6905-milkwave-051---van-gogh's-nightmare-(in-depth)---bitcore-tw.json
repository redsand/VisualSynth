  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "wave_g = abs(cos(time*1.4+.89 + sin(time*2.1+.73)));",
      "wave_b= abs(cos(time*.7+.64));",
      "wave_r = abs(sin(time*1.526 + .321 ));",
      "wave_x=abs(sin(time*2+.368));",
      "warp=0;",
      "diakPos=if( below(frame%500,200),1,1);",
      "diakRot=if(below(frame%500,100),0,1);",
      "diakRot=if(above(frame%500,400),0,diakRot);",
      "q1=.125;",
      "q6=diakRot*sin(time/3+1.783+cos(time+2.814)); //rotation",
      "q8=sign( sin(2.356*time+.385+2*cos(.6*time+2.9)));",
      "q7=.375*(1+diakPos*sin( cos(time*2.31+1.972)+time*1.34+1.69));  // row1 x y coords",
      "q5=.5+(diakPos*.1*sin(time+cos(time*3+.256)));",
      "q4=.625+diakPos*2*q1*(sin( cos(time*.67+.711)+time*2.1+1.314)); // row2 x y cords",
      "",
      "q2=.875-diakPos*3*q1*(abs(sin( cos(2*time+1.23)+.8*time+1.72)));",
      "q3=.18+(mid_att+treb_att+bass_att)/11;",
      "monitor = mid+treb+bass;",
      "v=rand(200);",
      "sx=if( equal(v,9),-1,sx);",
      "sy=if( equal(v,8),-1,sy);",
      "zoom=if( equal(v,7),.5,1);"
    ],
    "perFrameInitCode": [
      "frame=-100;"
    ],
    "perPixelCode": [
      "IsRow1=if( below( abs(  (q6*(x-.5)+(1-q6)*(y-q7)))/(sqr(q6)+sqr(1-q6)),q1),1,0);",
      "IsRow2=if( below( abs( ((1-q6)*(x-q5)+(q6)*(y-q4)))/(sqr(q6)+sqr(1-q6)),q1),1,0);",
      "q6=q6*1.5;",
      "Row3dist=( (-q6*(x-.5)+(1-q6)*(y-q2) )/(sqr(q6)+sqr(1-q6)));",
      "IsRow3=if( below( abs(Row3dist),q1),1,0);",
      "scroll=sign(sin(time/4+2.312));",
      "dy=dy+.01*(1-IsRow1)*(1-IsRow2)*(1-IsRow3)*scroll*q3;",
      "",
      "//row1",
      "moveX=IsRow1*.006*(sin(38*(x-.5)+time*3) + sin(26*(y-q7)+time*1));",
      "moveY=IsRow1*.006*(sin(23*(x-.5)+time*2)+sin(40*(y-q7)+time*6));",
      "dx=dx+q3*moveX;",
      "dy=dy+q3*moveY;",
      "zoom=zoom+5*q3*(moveX+moveY);",
      "",
      "//row2",
      "row2ang=-atan2(x-q5,y-q4);",
      "row2dist=sqrt( sqr(x-q5)+sqr(y-q4) );",
      "moveX=IsRow2*.03*cos(row2ang)*q8;",
      "moveY=IsRow2*.03*sin(row2ang)*q8;",
      "dx=dx+q3*moveX;",
      "dy=dy+q3*moveY;",
      "zoom=zoom+IsRow2*.05*(1+.2*q3*pow((-1+row2dist),3));",
      "",
      "//row3",
      "moveX=.007*sin(time*100);",
      "dx=dx+IsRow3*q3*moveX;",
      "zoom=zoom+.1*IsRow3*( Row3dist/q1)*sin(time*3)*q3;"
    ],
