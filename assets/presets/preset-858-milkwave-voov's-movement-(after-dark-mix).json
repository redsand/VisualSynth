    "perFrameCode": [
      "warp=0;",
      "framehalf = frame%2;",
      "volume = 0.3*(bass+mid);",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beat = above(volume,0.8)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.99 + (1-above(time - lastbeat, 2*beatrate))*0.998);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "mode = if(beat,abs(mode-1),mode);",
      "q8 = oldq8 +0.003*(((pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps) + (pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,5)/fps) + (pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,4)/fps) + (pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,3)/fps) + (pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,2)/fps) +(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att)/fps)) + 1/(fps*5);",
      "oldq8 = q8;",
      "q1 = 0.5 + 0.15*sin(0.416*q8) + 0.15*sin(0.832*q8) + 0.1*sin(1.324*q8);",
      "q2 = 0.5 + 0.15*sin(0.341*q8) + 0.15*sin(0.768*q8) + 0.1*sin(1.523*q8);",
      "q6 = 0.5 + 0.15*sin(0.287*q8) + 0.15*sin(0.913*q8) + 0.1*sin(1.142*q8);",
      "q7 = 0.5 + 0.15*sin(0.531*q8) + 0.15*sin(0.671*q8) + 0.1*sin(1.442*q8);",
      "ob_size = beat*0.05;",
      "ob_r = sin(20*(q1+q2));",
      "ob_g = sin(25*(q6+q7));",
      "q4 = (8 + 0.2*sin(q8*0.385) + 0.2*sin(q8*0.641) + 0.2*sin(q8*0.846));",
      "q5 = (12 + 0.2*sin(q8*0.385) + 0.2*sin(q8*0.641) + 0.2*sin(q8*0.846));",
      "q3 = mode;",
      "wave_a =0.4;",
      "wave_r = if(framehalf,0.5 + 0.15*sin(0.512*time) + 0.15*sin(0.943*time) + 0.1*sin(1.024*time),0.5 + 0.15*sin(0.483*time) + 0.15*sin(0.879*time) + 0.1*sin(1.423*time));",
      "wave_g = if(framehalf,0.5 + 0.15*sin(0.248*time) + 0.15*sin(0.829*time) + 0.1*sin(1.623*time),0.5 + 0.15*sin(0.461*time) + 0.15*sin(0.699*time) + 0.1*sin(1.254*time));",
      "wave_b = if(framehalf,0.5 + 0.15*sin(0.211*time) + 0.15*sin(0.652*time) + 0.1*sin(1.865*time),0.5 + 0.15*sin(0.333*time) + 0.15*sin(0.978*time) + 0.1*sin(1.359*time));"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "newx = x - q1;",
      "newy = y - q6;",
      "newrad = min(sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2,sqrt(2));",
      "newang = atan2(newx,newy);",
      "newzoom = pow(0.995 + 0.05*sin((q4)*(newang+q3)), pow(sin(newrad*newrad), newrad));",
      "dx = (newx)*newzoom - newx;",
      "dy = (newy)*newzoom - newy;",
      "newx = x - q2;",
      "newy = y - q7;",
      "newrad = min(sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2,sqrt(2));",
      "newang = atan2(newx,newy);",
      "newzoom = pow(0.995 + 0.05*sin((q5)*(newang)), pow(sin(newrad*newrad), newrad));",
      "dx = dx + (newx)*newzoom - newx;",
      "dy = dy + (newy)*newzoom - newy;",
      "newx = x - (0.33*(q1+q2+q6));",
      "newy = y - (0.33*(3-q2-q6-q7));",
      "newrad = min(sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2,sqrt(2));",
      "newang = atan2(newx,newy);",
      "newzoom = pow(1.04 + 0.05*sin(0.5*(q4+q5)*(newang)), pow(sin(newrad*newrad), newrad));",
      "dx = dx + (newx)*newzoom - newx;",
      "dy = dy + (newy)*newzoom - newy;"
