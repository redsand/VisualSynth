      "bass_f = bass_f*0.90 + bass_s*0.10;",
      "mid_f  = mid_f *0.92 + mid_s *0.08;",
      "treb_f = treb_f*0.94 + treb_s*0.06;",
      "idle = 0.02;                      // try 0.008-0.02",
      "mid_f = max(mid_f, idle + 0.004*sin(time*0.7));",
      "bass_f = max(bass_f, idle + 0.004*cos(time*0.6));",
      "treb_f = max(treb_f, idle + 0.004*sin(time*0.9));",
      "bass_outer_c = bass_f * 0.6 / (1 + bass_f * 0.6);",
      "bass_outer   = min(bass_outer_c * 0.0025, 0.0015);",
      "wave_mystery = -.15 + .15*mid_f;",
      "energy = max(bass_s + mid_s + treb_s, 0.001);",
