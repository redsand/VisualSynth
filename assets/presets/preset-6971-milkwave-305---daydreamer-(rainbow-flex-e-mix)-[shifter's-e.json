  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvec2 pixelsize = uTexSize.zw;\nvec2 uvm = vUvOriginal;\n\nvec2 noise_uv = vUvOriginal*uTexSize.xy*texsize_noise_lq.zw + rand_frame.xy;\nvec4 noiseVal = texture(sampler_noise_hq, fract(noise_uv*8));\n\nret.xyz = clamp01(texture( sampler_pw_main,uvm).xyz*vec3(1,1,.97) - vec3(.0,.0,.001));\n\n\nvec3 rsamp = texture(sampler_pw_main,uvm + (noiseVal.xy-.5)*6*pixelsize).xyz;\nif (length(ret.xy - uvm) > length(rsamp.xy - uvm)) {\nret.xy = rsamp.xy;ret.z = rsamp.z;}\n\n//rsamp = texture(sampler_pw_main,uvm + (noiseVal.zw-.5)*2*pixelsize).xyz;\n//if (length(ret.xy - uvm) > length(rsamp.xy - uvm)) {\n//ret.xy = rsamp.xy;ret.z = rsamp.z;}\n\n\nret.xy *= pow(ret.z,.01);\n\n\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "// -------------------------------- beat detection code ----------------------------------",
      "sure=if(equal(sure,0),.75,sure);",
      "interval=if(equal(interval,0),.7*FPS,interval);",
      "avginterval=if(equal(avginterval,0),.7*FPS,avginterval);",
      "lockinterval=if(equal(lockinterval,0),.7*FPS,lockinterval );",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)*FPS;",
      "beat=below(dbass,0)*above(pdbass,0)*above(bass,.95*avgbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "avgbass=.995*avgbass+.005*bass;",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=min(200,maxdbass);",
      "maxdbass=max(.02,maxdbass);",
      "interval=if(beat*below(frame-lastbeat,1.8*interval), ((frame-lastbeat)*.25+.75*interval),interval);",
      "lastbeat=if((1-force)*beat+equal(lastbeat+interval,frame),frame,lastbeat);",
      "avginterval=if(beat,.9*avginterval+.1*interval, avginterval);",
      "lockinterval=if(beat,.9*lockinterval+.1*avginterval,lockinterval);",
      "pbass=bass;",
      "pdbass=dbass;",
      "bpm=60*FPS*.3333*( ((2*(1-sure))/interval)+((2*sure)/avginterval)+(1/lockinterval) );",
      "phase=min( (frame-lastbeat)/(.333*(2*sure*avginterval+2*(1-sure)*interval+lockinterval)), 1 );",
      "beat=if(equal(phase,0),1,beat);",
      "interval=min(interval,.7*FPS);",
      "avginterval=min(avginterval,.7*FPS);",
      "lockinterval=min(lockinterval,.7*FPS);",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "zoom=1;",
      "warp=0;",
      "ib_size=0;",
      "ib_a=0;",
      "ob_size=1;",
      "ob_a=.01+.02*(FPS/100);",
      "vol=min(.99*vol+.01*(bass+mid+treb),3);",
      "c1=.333*(vol+1)*time+3.34;",
      "c2=.87*time+2.97;",
      "ob_r=abs(cos(c1+sin(c2)));",
      "ob_g=abs(sin(c1+cos(c2)));",
      "ob_b=abs(sin(c1+sin(c2)));",
      "",
      "q1=.18*cos(.354*time+.54+cos(.521*time+1.432));  // spiral bend",
      "q3=sqrt(.995*(.5*time-int(.5*time)));            // glow phase",
      "c1=.1/FPS;",
      "contbass=(1-c1)*contbass+c1*bass;",
      "q8=min(contbass,1.15);",
      "",
      "totalbeats=totalbeats+beat;",
      "changerot=equal(totalbeats%5,0);",
      "dir=changerot*(-dir)+(1-changerot)*dir;",
      "myangstep=changerot*(.01*dir*rand(1000)*.001)+(1-changerot)*myangstep;",
      "q7=myangstep;",
      "totalbeats=changerot*1+(1-changerot)*totalbeats;",
      "monitor=q8;"
    ],
    "perFrameInitCode": [
      "contbass=.75;",
      "totalbeats=1;",
      "dir=1;"
    ],
    "perPixelCode": [
      "zoom=zoom+below(rad,.45)*sqr(1-rad/.45)*5;",
      "warp=above(abs(y-.5)+abs(x-.5),.707)*2*q8;"
    ],
