  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "high_bass = above(bass_att,2);",
      "high_treb = above(treb, 2);",
      "",
      "wave_b = if(high_treb,0,1);",
      "",
      "//mv_rr = if(high_bass,.5 ,mv_rr*.9);",
      "//mv_r = mv_rr;",
      "//mv_b = if(high_treb*high_bass,0,1);",
      "//mv_g = if(high_treb*high_bass,0,.1*sin(time*.302)+.1);",
      "//mv_a = if(above(bass_att,1.5),.6,mv_a);",
      "//mv_x = bits *3;",
      "//mv_y = mv_x *.8;",
      "",
      "ob_r = sin(time*.3)/2+.5;",
      "ob_g= sin(time*.34)/2+.5;",
      "ob_b = sin(time*.3714)/2+.5;",
      "",
      "boomnow = if(high_bass,time,boomnow);",
      "brightness = min(sqr(time-boomnow-.866)+.25,1);",
      "av_bass=if(high_bass,av_bass*.8+.2*bass,av_bass);",
      "count=count+above(bass,av_bass*1.2);",
      "",
      "ob_r = ob_r*brightness;",
      "ob_g = ob_g*brightness;",
      "ob_b = ob_b*brightness;",
      "",
      "w_dx = (above((w_y*bits)%2,0)*.01-.005)*sin(time);",
      "w_dy = (above((w_x*bits)%2,0)*.01-.005)*cos(time);",
      "",
      "w_x = w_x+w_dx;",
      "w_y = w_y +w_dy;",
      "monitor = bits;",
      "q1 = bits;",
      "w_x = if(above(abs(w_x-.5),.5),int(rand(10))/10,w_x);",
      "w_y = if(above(abs(w_y-.5),.5),int(rand(10))/10,w_y);",
      "",
      "wave_x = w_x;",
      "wave_y = w_y;",
      "",
      "monitor = brightness;",
      "monitor = av_bass;",
      "monitor = count;"
    ],
    "perFrameInitCode": [
      "bits = rand(7)+7;"
    ],
    "perPixelCode": [
      "//---- Rotation Angle",
      "v_ang=time*.2*(x+y)*(.005+.003*(sin(time*.1)+cos(time*.14)));",
      "",
      "v_ang = time+sin(x*(sin(time*.32)*3+4)+y*(sin(time*.42)*3+4));",
      "",
      "//---- Initialisation: X, Y, ANG, CX, CY, DX, DY, SX, SY",
      "//---- to these: VX, VY, VANG, CVX, CVY, DVX, DVY, SVX, SVY",
      "vx = (x-.5)*cos(v_ang) - (y-.5)*sin(v_ang)+.5;",
      "vy = (x-.5)*sin(v_ang) +(y-.5)*cos(v_ang)+.5;",
      "vang=atan((vy-.5)/(vx+.000001-.5))+below(vx,.5)*sign(vy-.5)*3.14159;",
      "cvx = (cx-.5)*cos(v_ang) - (cy-.5)*sin(v_ang)+.5;",
      "cvy = (cx-.5)*sin(v_ang) +(cy-.5)*cos(v_ang)+.5;",
      "svx=sx; svy=sy; dvx=dx; dvy=dy;",
      "cang=atan((vy-cvy)/(vx+.000001-cvx))",
      "+below(vx,cvx)*sign(vy-cvy)*3.14159; //Bonus var: angle about (cvx,cvy)",
      "",
      "//---- Preset Code",
      "",
      "dx=above(vx,sin(time*.5)*.7+.5)*1.0002;",
      "dy = above(vy,(cos(time*.5)*.6+.5));",
      "",
      "//---- Realisation of virtual variables",
      "cx = (cvx-.5)*cos(-v_ang) - (cvy-.5)*sin(-v_ang)+.5;",
      "cy = (cvx-.5)*sin(-v_ang) +(cvy-.5)*cos(-v_ang)+.5;",
      "dvx = dvx + (vx-cvx)*(svx-1);",
      "dvy = dvy - (vy-cvy)*(svy-1);",
      "//dx = dvx*cos(v_ang) - dvy*sin(v_ang);",
      "//dy = -dvx*sin(v_ang) - dvy*cos(v_ang);",
      "//---- End Virtual Axis Code"
    ],
