  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n//vUv = vUvOriginal;\nfloat corr = uTexSize.xy*texsize_noise_lq.zw;\nvec2 uv1 = vec2(vUv.x-0.5,vUv.y-0.5)*uAspect.xy;\n\nvec2 tmp = uv1;\ntmp.x = vAngle*3; tmp.y = vRadius;\nuv1 = tmp;\n\nvec3 noise = (texture(sampler_noise_lq,corr*vUv/2+q23)+1);\n\nvec3 ret1 = GetBlur1 (vUv)-.3;\nvec3 crisp = texture(sampler_main, vUv+ret1*.01 ) + noise*0.1;\nvec3 blur = GetBlur1 (vUv/4+.4*vec2(.3*ret1.x,ret1.y)) - noise*.1;\n\nret = -.4*blur + crisp;\n\n ret *= 0.98 * pow(1-.01*q28*q28*vRadius,2);\n  ret -= 0.04;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.9+.1*sin(pulse);",
      "entropy=if(equal(pulse,-20),1+bass_flop+treb_flop+mid_flop+int(rand(2)),entropy);",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*chaos+1.3);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*chaos+1.3);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.3)*chaos+1.3);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),20),-20,pulse+(bass_thresh+mid_thresh+treb_thresh)*.032);",
      "q1=mid_residual;",
      "q2=bass_residual;",
      "q3=treb_residual;",
      "q4=sin(pulse);",
      "q5=cos(pulse/2+q1);",
      "q6=sin(q1*3.14+q2*3.14+q3*3.14);",
      "q7=above(q1,0)+above(q2,0)+above(q3,0)+above(q3,0)*treb_flop+above(q2,0)*bass_flop+above(q1,0)*mid_flop;",
      "q8=entropy;",
      "wave_r=.5+.5*sin(q1+abs(q4*2.14));",
      "wave_b=.5+.5*sin(q2+abs(q5*2.14));",
      "wave_g=.5+.5*sin(q3+abs(q6*2.14));",
      "ob_r=ob_r+ob_r*sin(q1+q2*2.14);",
      "ob_b=ob_b+ob_b*sin(q2+q3*2.14);",
      "ob_g=ob_g+ob_g*sin(q3+q1*2.14);",
      "ib_r=ib_r+ib_r*cos(q5+q1*2.14);",
      "ib_b=ib_b+ib_*cos(q5+q2*2.14);",
      "ib_g=ib_g+ib_g*cos(q5+q3*2.14);",
      "ob_a=.25+.25*sin(q2+q3*2.14);",
      "ib_a=.25+.25*sin(q2*2.14+q3);",
      "ob_size=.1+.1*sin(q3*3+q1);",
      "ib_size=.15+.05*sin(q1*3+q3);",
      "mv_r=mv_r+.5*sin(q4+q5*6*q1);",
      "mv_b=mv_b+.5*sin(q4+q5*6*q2);",
      "mv_g=mv_g+.5*sin(q5+q5*6*q3);",
      "mv_a=mv_a+mv_a*sin(q2+q3+q5*1.14);",
      "mv_l=.1*q8;",
      "mv_x=q8*q7;",
      "mv_y=q8*q7;",
      "wave_mystery=wave_mystery+.25*sin(time*q4);",
      "echo_zoom=1+.2*q1+.2*q5+.3*q4;",
      "echo_orientation=q7%3;"
    ],
