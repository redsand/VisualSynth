  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "",
      "wave_r = .3+.3*sin(time);",
      "wave_g = .3+.3*sin(.5*time);",
      "wave_b = .3*.3*sin(1.5*time);",
      "",
      "count = count+1;",
      "bc = bc+bass;",
      "tc = tc+treb;",
      "mc = mc+mid;",
      "bb = .5*bd+.5*bass_att;",
      "bt = .5*bt+.5*treb_att;",
      "mt = .5*mt+.5*mid_att;",
      "bimp = if(above(3*bass,bass+treb+mid),1,0);",
      "timp = if(above(3*treb,bass+treb+mid),1,0);",
      "mimp = if(above(3*mid,bass+treb+mid),1,0);",
      "is_beat = if(above(bb*.7,bc/count),1*bimp,if(above(bt*.7,tc/count),1*timp,if(above(mt*.7,mc/count),1*mimp,0)));",
      "is_beat = if(above(reha,0),0,is_beat);",
      "reha = if(is_beat,fps*.5,if(below(reha,1),0,reha-1));",
      "",
      "r1 = if(is_beat,rand(2)-1,r1);",
      "r2 = if(is_beat,rand(2)-1,r2);",
      "r3 = if(is_beat,rand(2)-1,r3);",
      "r4 = if(is_beat,if(below(rand(4),2),r4*(-1),r4),r4);",
      "",
      "rot = rot*r4;",
      "",
      "q1 = r1;",
      "q2 = r2;",
      "q3 = r3;",
      "q4 = r4;"
    ],
    "perFrameInitCode": [
      "r1 = rand(2)-1;",
      "r2 = rand(2)-1;",
      "r3 = rand(2)-1;",
      "r4 = 1;"
    ],
    "perPixelCode": [
      "cross = q1*(1.5*above(x,.45)*below(x,.55)+1.5*above(y,.45)*below(y,.55));",
      "rect = q2*(above(x,.3)*below(x,.7)*below(y,.7)*above(y,.3));",
      "ring = q3*(above(rad,.35)*below(rad,.65));",
      "",
      "box = -cross-rect+ring;",
      "",
      "rot = rot-.05*ring*q4;",
      "",
      "//zoom = 1.05*(1-box)+.0*box;",
      "sx = 1+.025*box;",
      "sy = 1+.025*box;"
    ],
