    "perFrameCode": [
      "warp = 0;",
      "vol_now =  .4 * bass + 0.1 * (bass_att + treb + mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean - 0.5 * (vol_mean-vol_now),0.1 * (vol_mean * 9 + vol_now));",
      "beat = if(above(vol_now,1.2+sin(time) * vol_mean),1,0);",
      "ying = if(below(ying,1),1,ying);",
      "ying = ying + beat;",
      "yin = ying%2;",
      "ob_g = if(yin,time%2,0);",
      "ob_r = if(yin,time%3,0);",
      "ob_b = if(yin,time%4,0);",
      "mv_b = sin(time) + abs(sin(time));",
      "mv_r = cos(time);",
      "mv_g = -.8*sign(sin(time))*abs(sin(time));",
      "dx = if(yin,.3* sin(time),if(equal(yin,yang),0,if(below(abs(dx),.05),dx-0.005,dx)));",
      "dy = if(yin,.3*cos(3*time),0);",
      "mv_y = if(yin,9,sin(time)*ying);",
      "yang = bnot(yin);",
      "q1 = yin;",
      "monitor = yin;"
    ],
