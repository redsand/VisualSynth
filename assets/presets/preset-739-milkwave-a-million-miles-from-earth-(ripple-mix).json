    "perFrameCode": [
      "warp = 0;",
      "wave_r = 0.5 + 0.3*sin(time*0.894);",
      "wave_g = 0.53 + 0.33*sin(time*1.14);",
      "wave_b = 0.4 + 0.1*(1-bass);",
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "test = equal(thresh,2);",
      "dx_r = test*0.002*sin(5*time)+(1-test)*dx_r;",
      "dy_r = test*0.002*sin(6*time)+(1-test)*dy_r;",
      "zoom = zoom -0.01*thresh;",
      "dx = 1.1* dx_r;",
      "dy = 1.1* dy_r;",
      "dx = dx + if (above(bass,1.3), 21*dx_r, 0);",
      "mv_x = if(test,2,64);",
      "mv_y = if(test,64,2);",
      "mv_dx = if(test,-0.1,0);",
      "mv_dy = if(test,0,-0.1);",
      "mv_a = if(test,1,0.5);",
      "xpos = xpos + 0.05*(80*dx_r - xpos);",
      "ypos = ypos + 0.05*(80*dy_r - ypos);",
      "wave_x = 0.5 - xpos + 0.1*sin(2*time);",
      "wave_y = 0.5 - ypos + 0.1*cos(2*time);",
      "q1 = wave_x;",
      "q2 = 1 - wave_y;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "newx = x - q1;",
      "newy = y - q2;",
      "newrad = sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2;",
      "newzoom = pow(1.03, pow(0.01+sin(newrad*newrad), newrad*2-1));",
      "dx = min(5*newrad,1)*dx + max(-newrad*5+1,0)*((newx)*newzoom - newx);",
      "dy = min(5*newrad,1)*dy + max(-newrad*5+1,0)*((newy)*newzoom - newy);"
    ],
