      "music_time = music_time + vol*0.4375;",
      "cx = .5+sin(music_time/9.5)/17.5;",
      "cy = .5+cos(music_time/9.5)/17.5;",
      "",
      "mv_x = rez_mv_x;",
      "mv_y = rez_mv_y;",
      "mv_r = rez_col_r3;",
      "mv_g = rez_col_g3;",
