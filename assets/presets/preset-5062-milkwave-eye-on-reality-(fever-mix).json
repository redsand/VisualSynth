  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "wave_r = wave_r + .15*sin(time*.222);",
      "wave_g = wave_g + .15*sin(time*.333);",
      "wave_b = wave_b + .15*sin(time*.444);",
      "//zoom = zoom+.01 - bass_att*.01;",
      "volume = 0.3*(bass+mid);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "beatcounter = if(above(beat,0),beatcounter +1, beatcounter);",
      "beatcounter = if(above(beatcounter,5), 0, beatcounter);",
      "beateven = beatcounter%2;",
      "mycounter = if(beateven,if(beat,if(above(mycounter,4),0,mycounter+1),mycounter),mycounter);",
      "q5 = if(beat,if(beateven,2,mycounter+3),oldq5);",
      "oldq5 = q5;",
      "ib_r = ib_r + 0.25*sin(time*0.965);",
      "ib_g = ib_g +0.25*sin(time*1.123);",
      "ib_b = ib_b + 0.25*sin(time*1.046);",
      "ob_r = ob_r + 0.15*sin(time*0.865);",
      "ob_g = ob_g +0.15*sin(time*1.103);",
      "ob_b = ob_b + 0.15*sin(time*1.086);",
      "",
      "q6 =oldq6+ 0.005*(pow(1+1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "oldq6 = q6;",
      "",
      "zoom = zoom + 0.01*( 0.60*sin(0.339*time) + 0.40*sin(0.276*time) );",
      "//rot = rot + 0.010*( 0.60*sin(0.381*time) + 0.40*sin(0.579*time) );",
      "//decay = decay - 0.01*equal(frame%6,0);",
      "left = 0.5 + 0.25*(sin(0.555*q6) + sin(1.111*q6));",
      "right = 0.5 + 0.25*(sin(0.333*time) + sin(1.222*time));",
      "centrex = (left+right)/2;",
      "distx = 0.1 + (abs(centrex-left)+abs(centrex-right))/2;",
      "q1 = centrex + distx;",
      "q2 = centrex - distx;",
      "wave_x = centrex;",
      "top = 0.5 + 0.25*(sin(0.888*time) + sin(0.999*time));",
      "bottom = 0.5 + 0.25*(sin(0.444*time) + sin(1.333*time));",
      "centrey = (top+bottom)/2;",
      "disty = 0.1 + (abs(centrey-top)+abs(centrey-bottom))/2;",
      "q3 = centrey + disty;",
      "q4 = centrey - disty;",
      "wave_y = 1-centrey;",
      "warp=0;",
      "monitor = zoom;",
      "zoom = 1;",
      "q7 = centrex;",
      "q8 = centrey;",
      "monitor = q6;",
      "wave_a = 0;",
      "dx = 0;",
      "dy =0;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "newx = x-q7;",
      "newy = y-q8;",
      "newrad = min(sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2,sqrt(2));",
      "newang = atan2(newx,newy);",
      "newzoom = pow(0.999 + 0.05*sin((q4)*(newang+q3)), pow(sin(newrad*newrad),newrad));",
      "//dx = (newx)*newzoom - newx;",
      "//dy = (newy)*newzoom - newy;",
      "rot = .3*tan(.1*sin(pow(newrad,4)*20+q6)+sin(q6*.222)*.1);",
      "zoom = zoom + .1*sin((newang)*q5+q6);"
    ],
