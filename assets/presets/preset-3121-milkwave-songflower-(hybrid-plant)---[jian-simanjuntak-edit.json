  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    vec2 uv_k = vUv * 2.0 - 1.0;\n    float angle = atan(uv_k.y, uv_k.x);\n    float segments = 6.0;\n    angle = floor(angle * segments / 6.283) * (6.283 / segments);\n    uv_k = vec2(cos(angle), sin(angle)) * length(uv_k);\n    uv_k = (uv_k + 1.0) * 0.5;\n    ret = texture(sampler_main, uv_k).xyz;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "wave_r = 0.5 + 0.5*sin(1.6*time);",
      "wave_g = 0.5 + 0.5*sin(4.1*time);",
      "wave_b = -1 + (1-wave_r + 1-wave_g);",
      "warp = 0;",
      "pfthresh = above(bass_att,pfthresh)*3+(1-above(bass_att,pfthresh))*((pfthresh-1.3)*0.96+1.3);",
      "pfdx_r = equal(pfthresh,3)*0.015*sin(5*time)+(1-equal(pfthresh,3))*pfdx_r;",
      "pfdy_r = equal(pfthresh,3)*0.015*sin(6*time)+(1-equal(pfthresh,3))*pfdy_r;",
      "q1 = wave_r;",
      "q2 = wave_g;",
      "q3 = wave_b;",
      "",
      "ob_r = 1-abs(q1)*0.75;",
      "ob_g = 1-abs(q2)*0.75;",
      "ob_b = 1-abs(q3)*0.75;",
      "echo_zoom = echo_zoom - min(max(0.75,50*pfdx_r),1);",
      "",
      "echo_orient = echo_orient + 16*pfdy_r;",
      "",
      "dx = dx + 12.1*pfdx_r;",
      "dy = dy + 12.1*pfdy_r;",
      "//ib_a = ib_a + min(0.5,0.5-abs(dx+dy));",
      "",
      "cog = ocog+0.005*(bass+bass_att+(bass*bass_att)-2);",
      "ocog = below(cog,30000)*cog;",
      "q4 = cog;",
      "ob_r = q2;",
      "ob_g = q3;",
      "ob_b = q1;",
      "rcog = orcog + 0.5*(rand(100)*0.01);",
      "orcog = below(rcog,20000)*rcog;",
      "q5 = rcog;",
      "//ib_size = ib_size + 0.009*treb_att*tan(q4);",
      "//ob_size = ob_size + 0.009*bass_att*cos(q4);",
      "//ob_a = ob_a + min(0.5,0.5-abs(q4-q5));",
      "ib_r = 1-abs(q1)*sin(q4);",
      "ib_g = 0.75*cos(q4);",
      "ib_b = 1-abs(q3)*cos(q5);"
    ],
    "perFrameInitCode": [
      "leafset = 3;"
    ],
    "perPixelCode": [
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "tg1 = abs(sin(time));",
      "tg2 = 4*dy_r*above(tg1,0.5) + 4*dx_r*below(tg1,0.5);",
      "tg3 = if(equal(thresh,2),tg2,tg3);",
      "",
      "ladder = abs(sin(1*time));",
      "leaf = 5*below(ladder,0.2) + 8*above(ladder,0.2)*below(ladder,0.4) +",
      "12*above(ladder,0.4)*below(ladder,0.6) + 18*above(ladder,0.6)*below(ladder,0.8) +",
      "24*above(ladder,0.8);",
      "leafset = if(equal(thresh,2), leaf, leafset);",
      "",
      "zoom = zoom + 0.05*(0.75-sin(leafset*5))*(1-rad);",
      "zoom = zoom - abs(0.05*(0.75-cos(4*ang)));",
      "",
      "zoom = zoom + tg3*tan(4*q4)*below(zoom,0.22)*above(zoom,-0.22);",
      "",
      "zoom = zoom + 0.0095*(sin(10*ang) + sin(sin(time*2*sin(time)*rad))*0.3 - cos(rad)*0.1);",
      "rot = rot + 0.08*abs(0.746-rad)*sin(2.2*(0.5-rad)+5.7*sin(0.1*time));",
      "sx = sx + 0.01*(0.99*1-rad)*sin(0.733*time)*below(sin(time),0);",
      "sy = sy + 0.01*(0.99*1-rad)*cos(0.953*time)*above(sin(time),0);",
      "zoom = zoom - 0.015*(0.5*abs(3)-rad)*below(rad,1.5);"
    ],
