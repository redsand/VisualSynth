  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.9+.1*sin(beat);",
      "entropy=if(bnot(entropy),2,if(equal(pulse,-3.14),1+int(rand(3)),entropy));",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*chaos+1.3);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*chaos+1.3);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.3)*chaos+1.3);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse*.1*entropy) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*.1*entropy) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*.1*entropy) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),3.14),-3.14,pulse+(bass_thresh+mid_thresh+treb_thresh)*.052);",
      "beat=if(above(abs(beat),3.14),-3.14,beat+(bass+treb+mid)*.01);",
      "q1=mid_residual;",
      "q2=bass_residual;",
      "q3=treb_residual;",
      "q4=sin(pulse);",
      "q5=sin(beat);",
      "wave_r=wave_r+.5*bass_residual;",
      "wave_g=wave_g+.5*mid_residual;",
      "wave_b=wave_b+.5*treb_residual;",
      "ob_r=if(bass_flop,treb_changed,wave_r);",
      "ob_b=if(treb_flop,mid_changed,wave_b);",
      "ob_g=if(mid_flop,bass_changed,wave_g);",
      "ob_a=.05+.05*cos(wave_r+pulse*.03);",
      "ob_size=.2+.2*treb_residual;",
      "ib_r=if(bass_flop,ob_b,ob_g);",
      "ib_b=if(treb_flop,ob_g,ob_r);",
      "ib_g=if(mid_flop,ob_r,ob_b);",
      "ib_size=ob_size*cos(wave_g+pulse*0.4)*.5;",
      "mv_a=1-(ob_a+ib_a)*chaos*.5;",
      "mv_x=abs(beat*10)*entropy;",
      "mv_y=mv_x;",
      "mv_r=wave_b;",
      "mv_b=wave_g;",
      "mv_g=wave_r;",
      "wave_x = 0.5+sin(2*time)/8;",
      "wave_y = 0.5-cos(3*time)/6;",
      "wave_mystery=q5;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "shift=q3*.1*mid_att;",
      "checkx=bor(above(abs(q1),x)*below(abs(q2),x),above(abs(q2),x)*below(abs(q1),x));",
      "checky=bor(above(abs(q1),y)*below(abs(q2),y),above(abs(q2),y)*below(abs(q1),y));",
      "dx=if(checkx,shift*q4,dx);",
      "dy=if(checky,shift*q5,dy);",
      "rot=if(checkx*checky,0,shift);",
      "bend = cos(   x*3.14*q2*above(q1,q2) + (rad*3.14*q2-3.14*q3)*above(q2,q3)+(y*3.14*q4)*above(q3,q1));",
      "zoom = zoom+bend*.05*above(q4+q5,.8);",
      "grid=(x*10)%(above(q1,q4)+above(q2,q5)+above(q3,q4)) + (y*10)%(above(q1,q5)+above(q2,q4)+above(q3,q5));",
      "sx=sx-if(bnot(grid),q3*y,.03);",
      "sy=sy-if(bnot(grid),q2*x,.03);"
    ],
