    "perFrameCode": [
      "ob_size = 1;",
      "// -------------------------------- Beat Detective 007 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "ob_a=0.2*beat;",
      "wave_g=(bass_att+mid_att+treb_att)/15;",
      "wave_r=wave_g;",
      "q1=beat;",
      "wave_r=if(equal(q1,1),1,wave_r);",
      "wave_g=if(equal(q1,1),1,wave_g);",
      "wave_b=if(equal(q1,1),1,wave_b);",
      "wave_mystery = if(equal(q1,1),-1,wave_mystery);",
      "wave_x=if(equal(q1,1),int(rand(60))/100+.2,wave_x);",
      "",
      "q2=if(below(frame,lastBeat+interval),(frame-lastBeat)/interval,-1);",
      "last_x=if(equal(q1,1),wave_x,last_x);",
      "q3=last_x;",
      "monitor=q2;",
      "wave_mode=if(below(q2,.3)*above(q2,0),0,wave_mode);",
      "wave_x=if(equal(wave_mode,0),q3,wave_x);",
      "wave_y=if(equal(wave_mode,0),.1,wave_y);",
      "wave_mystery=if(equal(wave_mode,0),-.45+.5*q2,wave_mystery);",
      "wave_r=if(equal(wave_mode,0),1,wave_r);",
      "wave_g=if(equal(wave_mode,0),1,wave_g);",
      "wave_b=if(equal(wave_mode,0),1,wave_b);",
      "monitor=sure"
