  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.4)*0.85+1.4);",
      "treb_thresh = above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.5)*0.75+1.5);",
      "mid_thrsh=above(mid_att,mid_thresh)*2+",
      "(1-above(mid_att,mid_thresh))*((mid_thresh-1.5)*.75+1.5);",
      "bass_on = above(bass_thresh,1.8);",
      "treb_on = above(treb_thresh,1.9);",
      "beat_on=above(beat,1);",
      "swapcolour = beat_on-treb_on-.2*q1;",
      "red_aim = if(equal(swapcolour,1),1,if(equal(swapcolour,0),1,0));",
      "green_aim = if(equal(swapcolour,1),0,if(equal(swapcolour,0),0.5,0.25));",
      "blue_aim = if(equal(swapcolour,1),0,if(equal(swapcolour,0),0,1));",
      "red = red + (red_aim - red)*if(equal(swapcolour,1),0.65,0.45);",
      "green = green + (green_aim - green)*0.5;",
      "blue = blue + (blue_aim - blue)*if(equal(swapcolour,1),0.45,0.65);",
      "wave_r = red;",
      "wave_g = green;",
      "wave_b = blue",
      ";;",
      "volume = 0.3*(bass+mid+bass_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.5*(beatrate + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "",
      "q1=beat;",
      "q2=bass_thresh;",
      "q3=mid_thresh;",
      "q4=treb_thresh;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "my2=((frame%50)/50)*0.4;",
      "dx=0.01*q2*bass;",
      "dx=if(below(y,-0.3+my2),-dx,dx)*rad;",
      "dx=if(below(y,-0.1+my2),-dx,dx);",
      "dx=if(below(y,0.1+my2),-dx,dx);",
      "dx=if(below(y,0.3+my2),-dx,dx);",
      "dx=if(below(y,0.5+my2),-dx,dx);",
      "dx=if(below(y,0.7+my2),-dx,dx);",
      "dx=if(below(y,0.9+my2),-dx,dx);",
      "dx=if(below(y,1.1+my2),-dx,dx);",
      "dx=if(below(y,1.3+my2),-dx,dx);",
      "dx=-.02;",
      "dy=0.01*q2*bass;",
      "dy=if(below(x,-0.3+my2),-dy,dy)*rad;",
      "dy=if(below(x,-0.1+my2),-dy,dy);",
      "dy=if(below(x,0.1+my2),-dy,dy);",
      "dy=if(below(x,0.3+my2),-dy,dy);",
      "dy=if(below(x,0.5+my2),-dy,dy);",
      "dy=if(below(x,0.7+my2),-dy,dy);",
      "dy=if(below(x,0.9+my2),-dy,dy);",
      "dy=if(below(x,1.1+my2),-dy,dy);",
      "dy=if(below(x,1.3+my2),-dy,dy);",
      "//Borrowed from Techno and Rovastar's Bass Mantas modded some."
    ],
