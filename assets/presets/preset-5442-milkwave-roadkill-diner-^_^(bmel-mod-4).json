  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.9+.1*sin(pulse);",
      "entropy=if(bnot(entropy),2,if(equal(pulse,-20),1+.001*int(rand(time)),entropy));",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*chaos+1.3);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*chaos+1.3);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.3)*chaos+1.3);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse*bass_thresh*sin(beat*entropy)) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*treb_thresh*sin(beat*entropy)) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*mid_thresh*sin(beat*entropy)) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),20),-20,pulse+(mid_thresh+bass_thresh+treb_thresh)*.03);",
      "beat=if(above(abs(beat),20),-20,beat+.1*bor(bor(bass_changed,mid_changed),treb_changed));",
      "sound_check=above(bass_residual+treb_residual,.25*-entropy);",
      "q1=mid_residual+sin(beat)*sound_check;",
      "q2=bass_residual+sin(beat-pulse)*sound_check;",
      "q3=treb_residual+sin(pulse)*sound_check;",
      "q4=sin(pulse)+bnot(sound_check)*beat;",
      "q5=sin(beat)+bnot(sound_check)*pulse;",
      "wave_r=if(sound_check,wave_r+.5*bass_residual,1);",
      "wave_g=sound_check*(wave_g+.5*mid_residual);",
      "wave_b=sound_check*(wave_b+.5*treb_residual);",
      "ib_r=if(bass_flop,treb_flop,wave_r)*.2;",
      "ib_b=if(treb_flop,mid_flop,wave_b)*.2;",
      "ib_g=if(mid_flop,bass_flop,wave_g)*.2;",
      "ib_a=sound_check*(.03+.002*wave_r);",
      "ib_size=.05+.04*treb_residual;",
      "wave_x=wave_x+.05*q4;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "dy = if(below(abs(x-q1),0.15), if(below(y,0.35), -0.006, if(below(y,0.5), 0.00, if(below(y,0.65), -0.00, 0.006))), 0);",
      "dy = dy - if(below(y, 0.65), if(above(y, 0.35), 0.1*(y-0.5) + 0.01*sin(x*30+sign(x-0.5)*time*4), 0), q4*.02);",
      "dx = if(below(abs(y-q2),0.15), if(below(x,0.35), -0.006, if(below(x,0.5), 0.00, if(below(x,0.65), -0.00, 0.006))), 0);",
      "dx = dx - if(below(x, 0.65), if(above(x, 0.35), 0.1*(x-0.5) + 0.01*sin(y*30+sign(y-0.5)*time*4), 0), q5*.02);",
      "zoom = if(below(abs(x-y),(mid* .05)), mid, if(below(abs(1 - (x+y)), (treb*.05)), treb, zoom));"
    ],
