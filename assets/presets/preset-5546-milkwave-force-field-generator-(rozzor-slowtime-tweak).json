  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "slowtime = slowtime+beat;",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "beat = if(above(vol_now,1.5*vol_mean),1,0);",
      "beatcount = beatcount + beat;",
      "wave_b = 1- (cos(time)  + abs(cos(time)));",
      "wave_g = 1-abs(sin(time)) ;",
      "wave_r = 1-(-1 * cos(time))  + abs(-1 * cos(time)) + 0.2 * (cos(sin(time))+(abs(cos(sin(time)))+cos(sin(time))));",
      "q1 = abs(sin(slowtime)/3)-.2;",
      "",
      "warp = 0;",
      "wave_mode = 6;",
      "wave_mystery = if(below(frame%2,1),0,1)+slowtime*q1;",
      "monitor = q1;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "zoom = zoom - q1*rad;",
      "dx = .5;",
      "dy = .5;"
