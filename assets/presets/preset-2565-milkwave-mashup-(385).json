  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n//Geiss's Motion Blur\n\n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).xyz;\n\n    // this vector points exactly one pixel, in the direction of motion\n    vec2 v = normalize(vUv-vUvOriginal)*uTexSize.zw;\n\n    vec3 s;\n    ret = max(ret, texture(sampler_main, vUv+v)*0.97);\n    ret = max(ret, texture(sampler_main, vUv-v)*0.97);\n    ret = max(ret, texture(sampler_main, vUv+v*2)*0.90);\n    ret = max(ret, texture(sampler_main, vUv-v*2)*0.90);\n\n    // darken over uTime\n    ret *= 0.95;\n\n    // add noise\n    //vec2 uv_noise = vUv*texsize_noise_lq.zw*uTexSize.xy + rand_frame.xy;\n    //ret += (texture(sampler_noise_lq, uv_noise)*2-1)*0.02;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "dec_med = pow (0.8, 30/fps); dec_slow = pow (0.95, 30/fps);",
      "vol = (bass+med+treb)/1.5; vol_ = vol_*dec_slow + (1-dec_slow)*vol;",
      "",
      "is_beat = above(vol, vol_+2*peak) * above (time, t0+spb_*.45);",
      "t0a  = if(is_beat,t0,t0a); t0 = if(is_beat,time,t0);",
      "peak = if(is_beat,vol,peak*dec_med);",
      "index = (index + is_beat) %128;",
      "",
      "spb = min(t0-t0a + .01,2);",
      "spb_ = if(is_beat,spb_ *.9 +.1*spb, spb_);",
      "",
      "",
      "q20 = vol_;",
      "q21 = above(vol,2.7*vol_);",
      "q22 = max(0,peak-.0)+.01;",
      "hpeak = hpeak*dec_med + (1-dec_med)*q21;",
      "q23 = hpeak * (1+rand(8));",
      "q24 = is_beat;",
      "q25 = q22*(1+rand(8))/8;",
      "",
      "mindev = min(min(abs(spb-spb_),abs(spb*2-spb_)),abs(spb-spb_*2));",
      "sdev = if(is_beat,sdev * .8 + .2*pow(mindev+.02,2),sdev);",
      "",
      "speed = 1/fps/spb_;",
      "trel = trel + speed;",
      "q10 = trel;",
      "",
      "wamp =  min(.001/sdev,.15);",
      "wamp_ = wamp_*dec_slow + (1-dec_slow)*wamp;",
      "q11 = sin(trel/2)*wamp_;",
      "q12 = wamp_/2;",
      "",
      "rota = 2*wamp_*sin(trel/3);",
      "//rota = .2*sin(wamp_*32);",
      "q5 = cos(rota);",
      "q6 = sin(rota);",
      "q7 = -q6;",
      "q8 = q5;",
      "",
      "q15 = -sin(trel*.5)*.05;",
      "q16 = cos(trel)*wamp_/2;",
      "",
      "q19 = .1*sin(trel/12);",
      "",
      "//ODD PLANET MOVEMENT",
      "trig1 = bnot(vis)*bnot(rand(100*fps));",
      "vis = if (trig1,1,vis*below(mov1,1));",
      "//q30 = vis;",
      "q30=(abs(bass-bass_att)+abs(treb-treb_att)+abs(mid-mid_att))*3;",
      "mov1 = if (vis,mov1+2*speed/fps,-1);",
      "dir = if(trig1,rand(100),dir);",
      "q31 = .5+.5*cos(dir)*mov1;",
      "q32 = .5+.5*sin(dir)*mov1;",
      "",
      "q29 = (2+sin(time/17)); //reflection water",
      "",
      "//monitor = wamp;",
      "q3=pixelsx;",
      "q4=pixelsy;",
      "monitor = q30;"
    ],
    "perFrameInitCode": [
      "t0a = time; t0 = time+.5;",
      "spb_ = .5; ;",
      "volb = .5; volx = .5;",
      "vol_= 1; index = 0; mov1 = 0;",
      "sdev = .1; wamp_ = .1;",
      ""
    ],
    "perPixelCode": [
      "zoom = 1+.02*rad*q20;",
      "dy = -.00;",
      "warp =.1; dx = .0;"
    ],
