  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_fc_main, vUv ).xyz;\n\n    // darken (decay) over uTime\n    ret *= 1.00; //or try: ret -= 0.004;\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    float rad_lq = vRadius * length(uTexSize.xy)*0.5;\n    float ang_lq = vAngle;\n    vec2 uv_temp1 = (vUv - 0.5) * uTexSize.xy;\n    float rad_hq = length(uv_temp1);\n    float ang_hq = atan(-uv_temp1.y, uv_temp1.x);\n\n    vec2 uv2 = (vUv - 0.5);\n    float rad2 = rad_lq*0.8;\n    float ang2 = ang_lq * M_INV_PI_2 + rad_lq*0.000 + uTime*0.00;\n\n\n        // FIN TYPE\n        float fins = 6;\n        ang2 = fract(ang2*fins)/fins;\n              // ENABLE THIS TO MAKE THE FINS ALTERNATE: (seamless!)\n              ang2 = abs(ang2 - 0.5/fins);\n\n\n    ang2 *= M_PI_2;\n    vUv = 0.5 + rad2*vec2(cos(ang2),sin(ang2))*uTexSize.zw;\n\n    ret = 1.4*pow(clamp01(GetBlur1(vUv))*((texture(sampler_pc_main,vUv)-GetBlur3(vUv))),0.5); //invert\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "decay = 1;",
      "xx1 = xx1*0.9 + (bass)*0.01;",
      "xx2 = xx2*0.9 + (treb)*0.01;",
      "yy1 = yy1*0.94 + (treb+bass)*0.0075;",
      "",
      "x1 = 0.5 + (xx1-xx2);",
      "y1 = 0.85 + yy1*.3;",
      "",
      "//x2 = 0;y2 = 0;x3 = 0;y3 = 0;x4 = 0;y4 = 0;",
      "",
      "spring = 100;",
      "grav = 11;",
      "resist = 0.2;",
      "bounce = 0.8;",
      "dt = 0.0001;",
      "",
      "vx2 = vx2*(1-resist*dt) + dt*((x1+x3-2*x2)*spring);",
      "vy2 = vy2*(1-resist*dt) + dt*((y1+y3-2*y2)*spring-grav);",
      "vx3 = vx3*(1-resist*dt) + dt*((x2+x4-2*x3)*spring);",
      "vy3 = vy3*(1-resist*dt) + dt*((y2+y4-2*y3)*spring-grav);",
      "vx4 = vx4*(1-resist*dt) + dt*((x3-x4)*spring);",
      "vy4 = vy4*(1-resist*dt) + dt*((y3-y4)*spring-grav);",
      "",
      "x2 = x2 + vx2;",
      "y2 = y2 + vy2;",
      "x3 = x3 + vx3;",
      "y3 = y3 + vy3;",
      "x4 = x4 + vx4;",
      "y4 = y4 + vy4;",
      "",
      "vx2 = if(above(x2,0),vx2,abs(vx2)*bounce);",
      "vx2 = if(below(x2,1),vx2,-abs(vx2)*bounce);",
      "vx3 = if(above(x3,0),vx3,abs(vx3)*bounce);",
      "vx3 = if(below(x3,1),vx3,-abs(vx3)*bounce);",
      "vx4 = if(above(x4,0),vx4,abs(vx4)*bounce);",
      "vx4 = if(below(x4,1),vx4,-abs(vx4)*bounce);",
      "",
      "vy2 = if(above(y2,0),vy2,abs(vy2)*bounce);",
      "vy2 = if(below(y2,1),vy2,-abs(vy2)*bounce);",
      "vy3 = if(above(y3,0),vy3,abs(vy3)*bounce);",
      "vy3 = if(below(y3,1),vy3,-abs(vy3)*bounce);",
      "vy4 = if(above(y4,0),vy4,abs(vy4)*bounce);",
      "vy4 = if(below(y4,1),vy4,-abs(vy4)*bounce);",
      "q3 = x4;",
      "q4 = x2;",
      "q7 = y4;",
      "q8 = y2;",
      "q9 = x1;",
      "q10 = y1;",
      "q11 = x3;",
      "q12 = y3;",
      "",
      "zoom = 1;",
      "bb = bb*0.99 + bass*0.02;",
      "mm = mm*0.99 + mid*0.02;",
      "tt = tt*0.99 + treb*0.02;",
      "",
      "mx = max(max(bb,mm),tt);",
      "mn = min(min(bb,mm),tt);",
      "",
      "ob_r = (bb-mn)/(mx-mn);",
      "ob_b = (mm-mn)/(mx-mn);",
      "ob_g = (tt-mn)/(mx-mn);",
      "",
      "q2 = atan2(vx4,vy4);",
      "q13 = atan2(vx3,vy3);",
      "q1 = sqrt(vx4*vx4 + vy4*vy4);",
      "q14 = sqrt(vx3*vx3 + vy3*vy3);",
      "q6 = atan2(vx2,vy2);",
      "q5 = sqrt(vx2*vx2 + vy2*vy2);",
      "",
      "",
      "a = a*0.95 + q5;",
      "",
      "monitor = q7;"
    ],
