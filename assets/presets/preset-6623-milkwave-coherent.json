  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "",
      "",
      "tic = min(time - tin,.1);",
      "tin = time;",
      "",
      "ra = 10;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb_avg*2;",
      "mt = mt + tic*mid_avg*2;",
      "bt = bt + tic*bass_avg*2;",
      "vt = vt + tic*(treb_avg+mid_avg+bass_avg)*.33333;",
      "",
      "st = .8;",
      "",
      "sw = above(tim,.067);",
      "tim = if(sw,tim-.067,tim);",
      "tim = tim + tic;",
      "",
      "q1 = (.5 + (.35*sin(vt*.789) + .35*sin(vt*.879))*st)*sw;",
      "q2 = (.5 + (.35*sin(vt*.385) + .35*sin(vt*.187))*st)*sw;",
      "q3 = (.5 + (.35*sin(tt*.629) + .35*sin(tt*.107))*st)*sw;",
      "q4 = (.5 + (.35*sin(tt*.987) + .35*sin(tt*.456))*st)*sw;",
      "q5 = (.5 + (.35*sin(mt*.747) + .35*sin(mt*.285))*st)*sw;",
      "q6 = (.5 + (.35*sin(mt*.358) + .35*sin(mt*.897))*st)*sw;",
      "q7 = (.5 + (.35*sin(bt*.465) + .35*sin(bt*.546))*st)*sw;",
      "q8 = (.5 + (.35*sin(bt*.132) + .35*sin(bt*.632))*st)*sw;",
      ""
    ],
