    "perPixelCode": [
      "vol = (mid + bass + treb)*.33333;",
      "st = .25;",
      "",
      "xd = q1-x;",
      "yd = q2-y;",
      "",
      "dis = pow(xd*xd+yd*yd,.5);",
      "an = acos(abs(yd)/dis);",
      "",
      "dx = sign(xd)*vol*st*cos(an)*(1.414-dis);",
      "dy = sign(yd)*-vol*st*sin(an)*(1.414-dis);",
      "",
      "xd = q3-x;",
      "yd = q4-y;",
      "",
