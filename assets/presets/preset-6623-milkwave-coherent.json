      "",
      "xd = q5-x;",
      "yd = q6-y;",
      "",
      "dis = pow(xd*xd+yd*yd,.5);",
      "an = acos(abs(yd)/dis);",
      "",
      "dx = dx + sign(xd)*mid*st*cos(an)*(1.414-dis);",
      "dy = dy + sign(yd)*-mid*st*sin(an)*(1.414-dis);",
      "",
      "xd = q7-x;",
      "yd = q8-y;",
      "",
      "dis = pow(xd*xd+yd*yd,.5);",
      "an = acos(abs(yd)/dis);",
      "",
      "dx = dx + sign(xd)*-bass*st*cos(an)*(1.414-dis);",
      "dy = dy + sign(yd)*bass*st*sin(an)*(1.414-dis);",
      "",
      "dx = dx*(1-equal(q1+q2+q3+q4+q5+q6+q7+q8,0));",
