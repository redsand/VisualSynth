    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.97+.03*sin(beat);",
      "entropy=if(bnot(entropy),1,if(equal(pulse,-3.14),entropy+sin(beat),entropy));",
      "bass_thresh = above(bass,bass_thresh)*2 + (1-above(bass,bass_thresh))*((bass_thresh-1.3)*chaos+1.3);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb,treb_thresh)*2 + (1-above(treb,treb_thresh))*((treb_thresh-1.3)*chaos+1.3);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid,mid_thresh)*2 + (1-above(mid,mid_thresh))*((mid_thresh-1.3)*chaos+1.3);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse*.1*entropy) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*.1*entropy) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*.1*entropy) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),3.14),-3.14,pulse+(bass_thresh+mid_thresh+treb_thresh)*.016);",
      "beat=if(above(abs(beat),3.14),-3.14,beat+(bass+treb+mid)*.01);",
      "q1=mid_residual;",
      "q2=bass_residual;",
      "q3=treb_residual;",
      "q4=sin(pulse);",
      "q5=sin(beat);",
      "mv_r=mv_r+.5*bass_residual;",
      "mv_g=mv_g+.5*mid_residual;",
      "mv_b=mv_b+.5*treb_residual;",
      "mv_a=1-(ob_a+ib_a)*chaos*.5;",
      "mv_x=int(rand(30));",
      "mv_y=int(rand(30));",
      "mv_l=5*(q4-q5);",
      "state=(1+1*above(q1,0))*(1+2*above(q2,0))*(1+4*mid_changed*above(q2,0))*(1+6*above(q3,0))*(1+10*bass_changed*above(q3,0))*(1+12*above(q4,0))*(1+16*treb_changed*above(q4,0));",
      "wave_r=.5+.2*bnot(state%2)-.2*bnot(state%3)+.3*q3*bnot(state%13);",
      "wave_g=.5+.2*bnot(state%5)-.2*bnot(state%13)+.3*q4*bnot(state%7);",
      "wave_b=if(bnot(state%6),.8+.2*q5,.5+.5*q2);",
      "ob_r=ob_r+.2*q2+.3*bnot(state%13)*q3;",
      "ob_b=ob_b-.1*bnot(state%105)-.4*q2;",
      "ob_g=ob_g+.5*sin(pulse*entropy);",
      "ob_a=.07+.05*q3;",
      "ob_size=.01*entropy*bnot(state%6);",
      "ib_r=ib_r+.2*q1-.3*bnot(state%3)*q4;",
      "ib_b=ib_b-.2*bnot(state%17)-.3*q2+.2*bnot(state%11);",
      "ib_g=ib_g+.5*q5;",
      "ib_a=.07+.05*q3*q4;",
      "ib_size=.005+.005*q3;",
      "zoom=zoom-.01*bnot(state%2)+.01*bnot(state%3)-.01*bnot(state%5)-.01*bnot(state%7)+.01*bnot(state%11)-.01*bnot(state%13)+.01*bnot(state%17);",
      "rot_fade=if(bnot(state%7),rot_fade-(rot_fade-.1*q3)/2-.03*bnot(state%13),rot_fade-.02*bnot(state%11)+.02*bnot(state%3)+.03*bnot(state%35));",
      "rot=rot_fade;",
      "cx=cx+.1*bnot(state%39)+.07*bnot(state%13)*q3-.2*bnot(state%55)*q4;",
      "wave_x=wave_x+.1*q3+.2*q4*bnot(state%2);",
      "wave_mystery=wave_x-.5;",
      "sy=sy+.07*bnot(state%22)-.09*bnot(state%17)+.07*q3*bnot(state%65);",
      "warp=if(bnot(state%187),2+2*q2,0);",
      "q5=state;"
    ],
