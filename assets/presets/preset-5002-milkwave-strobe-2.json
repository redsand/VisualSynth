  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "q1 = above(bass_att,beat_q1*1.15);",
      "//check for hard beat",
      "q2 = above(mid_att*1.15,beat_q2);",
      "//check for soft beat",
      "",
      "beat_q1 = q1*5 + ((1-q1)*(beat_q1-1.2)*0.9 + 1.2);",
      "beat_q2 = q2*3 + ((1-q2)*(beat_q2-1.2)*0.8 + 1.2);",
      "//monitor = beat_t2;",
      "//beat_threshold algorithm from Geiss - Shift",
      "",
      "wave_r = abs(wave_r + 0.35*sin(0.984*time) + 0.1*sin(12.43*time));",
      "wave_g = wave_g + 0.33*sin(0.764*time) + 0.1*sin(13.13*time);",
      "wave_b = wave_b + 0.25*sin(0.881*time) + 0.1*sin(11.43*time);",
      "//normal wave change",
      "rot = (1-q2)*old_rot + q2*0.2*sin(412*time);",
      "",
      "old_rot = rot*0.98;",
      "ob_a = if(q1,1,0);",
      "ob_size = if(q1,2,0);",
      "ob_r = if(q1,wave_r,0);",
      "ob_g = if(q1,wave_g,0);",
      "ob_b = if(q1,wave_b,0);",
      "d = t*-0.5 + ((1-t)*(d-0.92)*0.7 + 0.92);",
      "decay = d;",
      "t = q1;",
      "",
      "dy = (1-q2)*dy_old + q2*0.03*sin(4.33*time);",
      "dx = (1-q2)*dx_old + q2*0.03*sin(2.35*time);",
      "dy_old = dy*0.88;",
      "dx_old = dx*0.88;",
      "",
      "zoom = min(max(0.96,bass_att),1.5);"
    ],
    "perFrameInitCode": [
      "old_rot = 0.001;"
    ],
    "perPixelCode": [
      "rot = rot*(0.5-rad)*2;"
