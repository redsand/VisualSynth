      "ib_r = wave_g;",
      "ib_g = 1-wave_r;",
      "ib_b = wave_b;",
      "ob_r = 1-wave_b;",
      "ob_g = wave_r;",
      "ob_b = 1-wave_g;",
      "ib_size = 0.02*bass_effect;",
      "ok_to_change = if(above(time,beat_time+5),1,0);",
      "bass_effect = max(bass, bass_att)-1;",
      "beat_time = if(above(bass_effect,0.5), if(ok_to_change,time,beat_time),beat_time);",
      "effect = if(equal(time,beat_time),abs(effect-1),effect);",
      "q1=cos((0.91*time) + sin(time*0.324));",
      "q2=time + 0.3*sin((time*0.47) - cos(time*0.216));",
      "q3 =effect;"
