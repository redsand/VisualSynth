  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "wave_r = min(1,max(0,0.3*bass));",
      "wave_g = min(1,max(0,0.3*mid));",
      "wave_b = min(1,max(0,0.3*treb));",
      "",
      "//Thanks to Zylot for rainbow generator",
      "counter1 = if(equal(counter2,1),if(equal(counter1,1),0,counter1+.2),1);",
      "counter2 = if(equal(counter1,1),if(equal(counter2,1),0,counter2+.2),1);",
      "cdelay1 = if(equal(cdelay2,1),1,if(equal(colorcounter%2,1),if(equal(counter1,1),2 ,0), if(equal(counter2,1),2,0)));",
      "cdelay2 = if(equal(cdelay1,2),1,0);",
      "colorcounter = if(above(colorcounter,7),0,if(equal(cdelay1,1),colorcounter+1,colorcounter));",
      "ob_r = if(equal(colorcounter,1),1, if(equal(colorcounter,2),1, if(equal(colorcounter,3),1, if(equal(colorcounter,4),sin(counter2+2.1), if(equal(colorcounter,5),0, if(equal(colorcounter,6),0,sin(counter1)))))));",
      "ob_g = if(equal(colorcounter,1),0, if(equal(colorcounter,2),sin(counter2*.5), if(equal(colorcounter,3),sin((counter1+1.75)*.4), if(equal(colorcounter,4),1, if(equal(colorcounter,5),1, if(equal(colorcounter,6),sin(counter2+2),0))))));",
      "ob_b = if(equal(colorcounter,1),sin(counter1+2.1), if(equal(colorcounter,2),0, if(equal(colorcounter,3),0, if(equal(colorcounter,4),0, if(equal(colorcounter,5),sin(counter1), if(equal(colorcounter,6),1,1))))));",
      "",
      "mbass=max(bass_att,3);",
      "xmovn = 0.1*int(rand(10))*mbass*0.015*(1-2*above(int(rand(10)),5));",
      "ymovn = pow(pow(mbass*0.015,2)-pow(xmovn,2),1/2)*(1-2*above(int(rand(10)),5));",
      "//ymovn=.05;",
      "xmov = if(beat,xmovn,xmov*.9);",
      "ymov = if(beat,ymovn,ymov*.9);",
      "q1=oldx;",
      "q2=oldy;",
      "out_x = bor(above(q1+xmov,.9),below(q1+xmov,.1));",
      "out_y = bor(above(q2+ymov,.9),below(q2+ymov,.1));",
      "xmov = xmov + (-2*xmov*out_x);",
      "ymov = ymov + (-2*ymov*out_y);",
      "wave_x =  q1+xmov ;",
      "wave_y = q2+ymov;",
      "q1=wave_x;",
      "q2=wave_y;",
      "oldx = q1;",
      "oldy = q2;",
      "",
      "decay = decay - 0.91*(treble);",
      "",
      "//Thanks to krash for beat detection (modified)",
      "volume = 0.3*bass+mid;",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "runmeanbass =(runmeanbass*2 + bass_att)/3;",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beat = above(volume,0.8)*above(bass_att,runmeanbass*1.1)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.95 + (1-above(time - lastbeat, 2*beatrate))*0.995);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "q3=volume+treb;",
      "monitor =meanbass_att;"
    ],
    "perFrameInitCode": [
      "oldx=.5;",
      "oldy=.5;"
    ],
    "perPixelCode": [
      "mx= x-q1;",
      "my = y-(1-q2);",
      "mrad = pow(pow(mx,2)+pow(my,2),0.5)*pow(2,0.5);",
      "cx = q1;",
      "cy = 1-q2;",
      "rot= rot + below(mrad-0.18,0)*0.5*sin(mrad*40)*(mrad-0.1)*40- above(mrad-0.18,0)*0.3*sin(mrad*2)*(mrad-0.1)*sin((cx-0.5)*(cy-0.5)*6.28)*q3;",
      "zoom= zoom - above(mrad-0.18,0)*0.05*mrad*q3;",
      "dx = dx +below(mrad-0.18,0)*0.015*(mx/mrad);",
      "dy = dy +below(mrad-0.18,0)*0.015*(my/mrad);"
    ],
