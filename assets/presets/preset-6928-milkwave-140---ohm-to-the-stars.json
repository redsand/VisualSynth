  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// -------------------------------- Beat Detective 007 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "wave_r = .8*abs(cos( .07*time+.532 + sin( .125*time+.789) ));",
      "wave_g = .8*abs(cos( .092*time+2.1 + sin( .045*time+1.52) ));",
      "wave_b = .8*abs(cos( .1*time+1.452 + sin( .112*time+2.98) ));",
      "q1=beat;",
      "ib_a=beat;",
      "ib_r=1-wave_r;ib_g=1-wave_g;ib_b=1-wave_b;",
      "wave_mystery = 1-1.5*min(((frame-lastBeat)/interval),1);",
      "wave_a=if(above((frame-lastBeat)/interval,1),0,1);",
      "phase=if(equal(frame%interval,0),phase+1,phase);",
      "phase=if(equal(phase%18,17),0,phase);",
      "midphase=min((frame-lastBeat)/interval,1);",
      "sx=if(equal(phase,15)*equal(frame%interval,0),-1,sx);",
      "sy=if(equal(phase,26)*equal(frame%interval,0),-1,sy);",
      "phase = if(equal(frame%interval,0)*below(cos(time/6), -.5), (phase+rand(13))%14+1,phase);",
      "q2=phase;",
      "q3=midphase;",
      ""
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "zoom =1+.01*sin(13.28*rad);",
      "//zoom right",
      "zoom=zoom+equal(q2,1)*q3*.1*(x-.5);",
      "// zoom left",
      "zoom=zoom+equal(q2,2)*q3*.1*(.5-x);",
      "// zoom top",
      "zoom=zoom+equal(q2,5)*q3*.1*(.5-y);",
      "// zoom bottom",
      "zoom=zoom+equal(q2,4)*q3*.1*(y-.5);",
      "// rotate left",
      "rot=rot+equal(q2,3)*q3*.3;",
      "// rotate right",
      "rot=rot-equal(q2,6)*q3*.3;",
      "// scale x",
      "sx=sx+equal(q2,7)*q3*.2;",
      "// squash y",
      "sy=sy-equal(q2,8)*q3*.2;",
      "// squash x",
      "sx=sx-equal(q2,9)*q3*.2;",
      "// scale y;",
      "sy=sy+equal(q2,10)*q3*.2;",
      "// transpose+ vertical",
      "dy=dy+equal(q2,11)*abs(.5-x)*sign(.5-x)*q3*.2;",
      "// transpose+ horiz",
      "dx=dx+equal(q2,12)*abs(.5-y)*sign(.5-y)*q3*.2;",
      "// transpose- horiz",
      "dx=dx-equal(q2,14)*abs(.5-y)*sign(.5-y)*q3*.2;",
      "// transpose- vertical",
      "dy=dy-equal(q2,13)*abs(.5-x)*sign(.5-x)*q3*.2;"
