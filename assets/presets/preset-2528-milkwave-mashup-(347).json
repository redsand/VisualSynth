  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n   dither_uv = vUvOriginal*uTexSize.xy*texsize_noise_lq.zw * 1 + rand_frame.xy;\n   rand = texture(sampler_noise_lq, dither_uv)-0.5;\n\n   d = uTexSize.zw*4;\n   d_uv = vUvOriginal + rand*uTexSize.zw*0;\n   dx = GetBlur1(d_uv + vec2(1,0)*d) - GetBlur1(d_uv - vec2(1,0)*d);\n   dy = GetBlur1(d_uv + vec2(0,1)*d) - GetBlur1(d_uv - vec2(0,1)*d);\n   d_uv += vec2(dx.x,dy.x)*uTexSize.zw*4;\n\n\nret.x = GetPixel(d_uv).x;\nret.x += -(GetBlur1(d_uv).x-ret.x)*0.04 - 0.006 + rand*0.01;\n//ret.x = 0;\n\nvec2 uv_y = vUv-(vec2(0,-1.2) + vec2(dx.y,dy.y)*8+vec2(dx.x,dy.x)*4)*uTexSize.zw;\nret.y = max(GetPixel(uv_y).x, GetPixel(uv_y).y-0.0012) + rand*0.08;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "wave_a = 0;",
      "",
      "tic = time-tin;",
      "tic = tic;",
      "tin = time;",
      "",
      "v = tic*((bass_att + med_att + treb_att)*.3333*2 + (1/tic - 2)*v);",
      "sb = tic*(bass*4 + (1/tic - 4)*sb);",
      "su = tic*(med*.5+treb*.5*4 + (1/tic - 4)*su);",
      "",
      "tb = (tb + tic*sb)*below(tb,100000);",
      "tu = (tu + tic*su)*below(tu,100000);",
      "",
      "monitor = tu;",
      "",
      "q1 = v*.2 + .25;",
      "q2 = tb;",
      "q3 = tu;",
      "",
      "q4 = (5*sin(time*.145) + 3*cos(time*.115))*.1;",
      "",
      "q5 = pow(v*.5,2);",
      "q5 = .15;",
      "",
      "zoom = -.98;",
      "",
      "q6 = 40;",
      "",
      "h = time*.05;",
      "h = h - int(h);",
      "l = 1;",
      "s = 1;",
      "tmpb = if(below(l,0.5),l*(1+s),(l+s)-(s*l));",
      "tmpa = 2*l - tmpb;",
      "hvr = h + .333333;",
      "hvr = if(below(hvr,0),hvr+1,if(above(hvr,1),hvr-1,hvr));",
      "hvg = h;",
      "hvg = if(below(hvg,0),hvg+1,if(above(hvg,1),hvg-1,hvg));",
      "hvb = h - .333333;",
      "hvb = if(below(hvb,0),hvb+1,if(above(hvb,1),hvb-1,hvb));",
      "ob_r = if(below(6*hvr,1),tmpa+(tmpb-tmpa)*6*hvr, if(below(2*hvr,1),tmpb, if(below(hvr*3,2),tmpa+(tmpb-tmpa)*(.666666-hvr)*6,tmpa)));",
      "ob_g = if(below(6*hvg,1),tmpa+(tmpb-tmpa)*6*hvg, if(below(2*hvg,1),tmpb, if(below(hvg*3,2),tmpa+(tmpb-tmpa)*(.666666-hvg)*6,tmpa)));",
      "ob_b = if(below(6*hvb,1),tmpa+(tmpb-tmpa)*6*hvb, if(below(2*hvb,1),tmpb, if(below(hvb*3,2),tmpa+(tmpb-tmpa)*(.666666-hvb)*6,tmpa)));",
