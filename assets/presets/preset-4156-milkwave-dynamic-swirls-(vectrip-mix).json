  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "wave_r = wave_r + 0.350*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );",
      "wave_g = wave_g + 0.350*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );",
      "wave_b = wave_b + 0.350*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );",
      "q1 = (cx*2-1) + 0.62*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );",
      "q2 = (cy*2-1) + 0.62*( 0.60*sin(0.393*time) + 0.40*sin(0.223*time) );",
      "q3 = (cx*2-1) + 0.62*( 0.60*sin(0.174*-time) + 0.40*sin(0.364*time) );",
      "q4 = (cy*2-1) + 0.62*( 0.60*sin(0.234*time) + 0.40*sin(0.271*-time) );",
      "decay = decay - 0.01*equal(frame%5,0);",
      "vol = (bass+mid+att)/6;",
      "xamptarg = if(equal(frame%15,0),min(0.5*vol*bass_att,0.5),xamptarg);",
      "xamp = xamp + 0.5*(xamptarg-xamp);",
      "xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));",
      "xaccel = xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xpos = xpos + 0.001*xspeed;",
      "yamptarg = if(equal(frame%15,0),min(0.3*vol*treb_att,0.5),yamptarg);",
      "yamp = yamp + 0.5*(yamptarg-yamp);",
      "ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));",
      "yaccel = ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "yspeed = yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "ypos = ypos + 0.001*yspeed;",
      "mv_x_speed = 32;",
      "mv_y_speed = 24;",
      "mv_x_range = 0.499;",
      "mv_y_range = 0.499;",
      "mv_x_default = 4;",
      "mv_y_default = 2;",
      "mv_x = mv_x_default +mv_x_range + mv_x_range*sin(mv_x_speed*ypos+(sin(time*0.964)-0.5*cos(time*0.256)));",
      "mv_y = mv_y_default + mv_y_range+ mv_y_range*sin(mv_y_speed*xpos-(cos(time*1.345)-0.5*cos(time*0.331)));",
      "mv_b = mv_b - 0.3*sin(time*1.711);",
      "mv_r = mv_r + 0.25*cos(time*1.091);",
      "mv_g = mv_g + 0.09*cos(time*0.621);",
      "mv_l = 6 + 5*min(bass*0.5+bass_att*0.5,2);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "du = x*2-1 - q1;",
      "dv = y*2-1 - q2;",
      "dist = sqrt(du*du+dv*dv);",
      "ang2 = atan2(du,dv);",
      "mult = 0.008/(dist+0.4);",
      "dx = mult*sin(ang2-1.5);",
      "dy = mult*cos(ang2-1.5);",
      "du = x*2-1 - q3;",
      "dv = y*2-1 - q4;",
      "dist = sqrt(du*du+dv*dv);",
      "ang2 = atan2(du,dv);",
      "mult = 0.008/(dist+0.4);",
      "dx = dx + mult*sin(ang2+1.5);",
      "dy = dy + mult*cos(ang2+1.5);"
    ],
