      "q1=ib_r;",
      "",
      "//--fed's detection 1.3--",
      "boom = bass-oldbass;",
      "tick = treb-oldtreb;",
      "beep = mid-oldmid;",
      "",
      "crash = (boom*1.2+beep*0.7+tick*1.9)*0.3;",
      "beat = beat*0.5+(crash-oldcrash)*0.5;",
      "beat2 = beat2*0.5+beat*0.5;",
      "monitor = abs(beat2);",
      "",
      "out=abs(beat2);",
      "//-----------------------",
