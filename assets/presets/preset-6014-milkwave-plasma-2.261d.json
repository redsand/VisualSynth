      "//ob_size=out*0.4;",
      "rot = rot+beat2*0.01;",
      "//-----------------------",
      "q2=out;",
      "q4=beat2;",
      "oldbass = bass;",
      "oldmid = mid;",
      "oldtreb = treb;",
      "oldcrash = crash;"
    ],
