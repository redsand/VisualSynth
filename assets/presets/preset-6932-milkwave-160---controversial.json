      "curang=.97*curang- (q1*(.4+max(bass,1.5)*rand(20)/100)*(-1+2*(aa%2)))*q8;",
      "cursc=1+.97*curscale+q8*.3*beat;",
      "sx=cursc;",
      "sy=1-(cursc-1);",
      "decay=1-.2*beat;",
      "ob_a=.2*beat;",
      "ib_a=.3*beat;",
      "q6=below(aa%4,2)*if(equal(aa%2,0),1,-1);",
