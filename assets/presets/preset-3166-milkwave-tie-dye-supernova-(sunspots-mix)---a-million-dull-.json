      "ranpt = if (rand(10)/7<vol_att,((head_ptr+obj_num-int(rand(obj_num/4)))%obj_num)*obj_size, ranpt);",
      "point = ranpt;",
      "x0_ = gmegabuf(point)-reg07; y0_ = gmegabuf(point+1)-reg08; z0_ = gmegabuf(point+2)-reg09;",
      "x1 = x0_*reg30 + y0_*reg31 + z0_*reg32;",
      "y1 = x0_*reg33 + y0_*reg34 + z0_*reg35;",
