      "",
      "//TAIL QUEUE - calc movement",
      "n = 0; t_free = 0;",
      "loop (t_num,",
      "  self = n*obj_size + tbase;",
      "  age = gmegabuf(self+12);",
      "  if (age > 0,",
      "    if (age > t_age, age = 0, age +=dt2);",
      "    v2 = pow(gmegabuf(self+3),2)+pow(gmegabuf(self+4),2)+pow(gmegabuf(self+5),2);",
      "    brake = max(0.5,1-dt*cw*v2);",
      "    gmegabuf(self)   += gmegabuf(self+3)*dt;",
      "    gmegabuf(self+1) += gmegabuf(self+4)*dt;",
      "    gmegabuf(self+2) += gmegabuf(self+5)*dt;",
      "    gmegabuf(self+3) *= brake;",
      "    gmegabuf(self+4) *= brake;",
      "    gmegabuf(self+5) *= brake;",
      "    gmegabuf(self+4) += g0*dt; //Gravitation",
      "  ,t_free += 1); //otherwise",
      "  gmegabuf(self+12) = age;",
      "  n += 1;",
      ");",
      "",
      "//SPARK and HEAD COORD for use in comp shader",
