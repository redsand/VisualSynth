      "",
      "x0_ = x0-reg07; y0_ = y0-reg08; z0_ = z0-reg09;",
      "x1 = x0_*reg30 + y0_*reg31 + z0_*reg32;",
      "y1 = x0_*reg33 + y0_*reg34 + z0_*reg35;",
      "z1 = x0_*reg36 + y0_*reg37 + z0_*reg38;",
      "q14 = .5 + x1/z1*fac;",
      "q15 = .5 + y1/z1*fac;",
      "q16 = if (z1>0, 1/z1,0) * q29/4+20 + 20*vol_att;",
      "q16 = max(0,q16/4);",
      "",
      "",
      "//FOLLOW WITH CAMERA",
      "dxcam = (x0-xcam)*dt*CamSpeed; dycam = (y0-ycam-.0)*dt*CamSpeed; dzcam = (z0-zcam-CamDist)*dt*CamSpeed;",
      "xcam = xcam +dxcam; ycam = ycam +dycam; zcam = zcam +dzcam;",
      "reg07 = xcam; reg08 = ycam; reg09 = zcam;",
      "",
      "//ROTATE VIEPOINT",
      "x1 = (x0-XCam)*reg30 + (y0-yCam) *reg31 + (z0-zCam)*reg32;",
      "y1 = (x0-XCam)*reg33 + (y0-YCam) *reg34 + (z0-zCam)*reg35;",
      "dist = sqrt(pow(x0-xcam,2) + pow(y0-ycam,2) + pow(z0-zcam,2));",
      "k1 = dt/max(dist,.04)*CamLock;",
      "v1 =  -k1*(y1); v2 = k1*(x1); v3 = -reg31*k1*HLock;",
      "",
      "c1 = cos(v1); c2 = cos(v2); c3 = cos(v3);",
      "s1 = sin(v1); s2 = sin(v2); s3 = sin(v3);",
