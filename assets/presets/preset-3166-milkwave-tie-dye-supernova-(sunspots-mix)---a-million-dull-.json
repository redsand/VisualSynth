    "perFrameInitCode": [
      "//The camera tries to follow the head of the firework and look into its direction",
      "//Camera speed and rotational speed is limited, camera lags behind",
      "//Camera angle is forced back into horizontal position",
      "",
      "//-------------- BEGIN MAIN PARAMS ---------------",
      "//SPEEDS",
      "gSpeed = .6;   //global speed, affects all other speeds incl. particle lifetimes",
      "hSpeed = .03;  //firework head speed",
      "pSpeed = .07;   //speed of primary particles",
      "tSpeed = hspeed*3.5;  //speed of tail particles",
      "",
      "//CAMERA",
      "CamDist  = .02; //distance camera tries to stay behind firework",
      "CamSpeed = .35;  //camera follower speed",
      "CamLock = 8;    //how fast does camera angle lock on firework",
