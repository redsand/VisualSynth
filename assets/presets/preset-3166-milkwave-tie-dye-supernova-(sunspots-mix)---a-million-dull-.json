      "      vx = vx1; vy = vy1; vz = vz1; ran = -v0*dt*rand(100)/100;",
      "      gmegabuf(self)   = x0 + ran*reg56;",
      "      gmegabuf(self+1) = y0 + ran*reg57;",
      "      gmegabuf(self+2) = z0 + ran*reg58;",
      "      gmegabuf(self+3) = vx+vx0;",
      "      gmegabuf(self+4) = vy+vy0;",
      "      gmegabuf(self+5) = vz+vz0;",
      "      gmegabuf(self+12) = dt2;",
      "      gmegabuf(self+13) = .5 + rand(100)/150;//size",
      "      new -= 1;",
      "   ,0;);",
      "  t_ptr = (t_ptr+1)%t_num;, new > 0))",
      ",0);",
