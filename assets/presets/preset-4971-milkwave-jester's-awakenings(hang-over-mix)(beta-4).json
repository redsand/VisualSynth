  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "",
      "",
      "db=((w1+w2)-lbass)*fps;",
      "dt=((w4+w3)-ltreb)*fps;",
      "",
      "ltreb=w4+w3;",
      "lbass=w1+w2;",
      "",
      "avgdb=avgdb*.9+abs(db)*.1;",
      "avgdt=avgdt*.9+abs(dt)*.1;",
      "",
      "//beatdection",
      "rawbeatb=above(time-lbbtime,avgbbeatrate*.75);",
      "beatb=rawbeatb*above(abs(dt),avgdt*3);",
      "beatb2=rawbeatb*above(abs(db),avgdb*3);",
      "beat=max(beatb2,beatb);",
      "",
      "//beatrate calc",
      "//avgbbeatrate=beatb2*(avgbbeatrate*.9+(time-lbbtime2)*.1)+(1-beatb2)*(avgbbeatrate+(3-avgbbeatrate)*.001);",
      "//avgbbeatrate=beatb*(avgbbeatrate*.99+(time-lbbtime)*.01)+(1-beatb)*(avgbbeatrate+(3-avgbbeatrate)*.00001);",
      "avgbbeatrate=beat*(avgbbeatrate*.99+(time-lbbtime)*.01)+(1-beat)*(avgbbeatrate);//+(3-avgbbeatrate)*.00001);",
      "//lbbtime2=time*beatb2+(1-beatb2)*lbbtime2;",
      "lbbtime=time*beat+(1-beat)*lbbtime;",
      "",
      "ph=(time-lbbtime)*(60/avgbbeatrate)*const;",
      "phase=max(min( ph, 1 ),0);",
      "const=const*(1-beatb2)+beatb2*( const+ (.001*bool) );",
      "bool=below(phase,.98)*(.99-ph)-above(phase,.98)*(ph*.5);",
      "",
      "",
      "bc=bc+beatb;",
      "zoom=1+below(w1,0);",
      "vol=(beatb*(w1+w4+w2+w3)*.1);",
      "avgvol=avgvol*.999+vol*.01;",
      "monitor=avgvol;",
      "mtime=mtime+(min(avgdt*.05,.5)+avgvol)*(1/fps);",
      "mtime2=mtime2+(min(avgdb*.05,.5)+avgvol)*(1/fps);",
      "mtime3=mtime3+(beatb)*db*(1/fps);",
      "mtime4=mtime4+(beatb2)*dt*(1/fps);",
      "monitor=mtime4;",
      "beat=beat2;",
      "",
      "warp=0;",
      "vol = 0.167*(bass+mid);",
      "xamptarg = if(equal(frame%15,0),min(0.5*vol*bass_att,0.5),xamptarg);",
      "xamp = xamp + 0.5*(xamptarg-xamp);",
      "xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));",
      "xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xpos = xpos + 0.001*xspeed;",
      "yamptarg = if(equal(frame%15,0),min(0.3*vol*treb_att,0.5),yamptarg);",
      "yamp = yamp + 0.5*(yamptarg-yamp);",
      "ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));",
      "yspeed = yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "ypos = ypos + 0.001*yspeed;",
      "ib_r = ib_r + 2.3*sin(time*4.132)*xpos;",
      "ib_g = ib_g + 2.3*sin(time*3.547)*ypos;",
      "ib_b = ib_b + 0.499*sin(time*0.731);",
      "ob_g = beat*treb*0.5;",
      "ob_a = 0.5 + 0.5*beat;",
      "ob_size = ob_size + 0.01*beat;",
      "mv_dx =0.15* xpos;",
      "mv_dy = 0.15*ypos;",
      "mv_l = 0.15;",
      "mv_r = 1 - ib_g;",
      "mv_b = ib_r;",
      "mv_g = 1-ib_b;",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "Eff_test = if(below(Eff_size*200,500),1,0);",
      "Eff_size = if(beat,2.5*Eff_test+ 0.0025*int(rand(500)),Old_Eff_size);",
      "Old_Eff_size =Eff_size;",
      "q5 = Eff_size;",
      "mv_l = if(Eff_test,q5*3,mv_l);",
      "q6 = 3*xpos;",
      "q4 = 3*ypos;",
      "decay = decay + if(Eff_test,0,0.07);",
      "wave_r = 1-ib_g;",
      "wave_g = 1-ib_b;",
      "wave_b = 1-ib_b;",
      "monitor=beatrate;",
      "",
      "w5=mtime;",
      "w6=mtime2;",
      "w7=mtime3;",
      "w8=mtime4;",
      "ib_a=0;",
      "ob_a=0;"
    ],
    "perFrameInitCode": [
