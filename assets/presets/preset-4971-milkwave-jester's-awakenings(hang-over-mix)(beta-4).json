    "perPixelCode": [
      "q1 = 0.8*((sqrt(2)*0.5)-rad);",
      "q3  = below(rad,0.1*q5+ sin((w5-w8)*.01)*.2+.2);",
      "q7 =if(q3,0,12 + int(3*(rad)));",
      "q8 =if(q3,0,10 + int(1*(rad)));",
      "cx =if(q3,0.5,(-1&(x*q7-q1+0.5))*(1/q7)+0.1*q1);",
      "cy =if(q3,0.5,(-1&(y*q8-0.3*rad+0.5))*(1/(q8-0.3*rad))+0.1*(0.3*rad));",
      "rot = if(q3,2*q6*rad,0.1*(0.5*sqrt(2)-rad)- 0.1*bass_att-0.02*cx*cy);",
      "zoomexp = if(q3,0.2+0.2*(1-rad)+0.1*q5+ 0.3*q4+sin((w8-w7)*.1)*.1,zoomexp);",
      "zoom = zoomexp-0.005*(rad);",
      "dx = if(q3,0,-0.0015);",
      "sx = 1.05 + if(q3,0,0.05*q4);",
      "sy = 1.05 + if(q3,0,0.05*q4);",
      "",
      "md=.8;",
      "decay_r=sin(q8+rad)*(1-md)+md;",
      "decay_g=sin(q7-y*w1)*(1-md)+md;",
      "decay_b=sin(q5+x*w4)*(1-md)+md;"
    ],
