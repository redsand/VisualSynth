    "perFrameCode": [
      "wave_a = 0;",
      "",
      "tic = min(time - tin,1);",
      "tin = time;",
      "",
      "ra = 10;",
      "",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "",
      "rb = 1;",
      "vav = tic*(vav*(1/tic - rb) + rb*(bass+treb+mid)*.33333);",
      "q1 = treb_avg;",
      "q2 = mid_avg;",
      "q3 = bass_avg;",
      "",
      "db = bass - bass_avg;",
      "",
      "it = (it + tic)*below(it,1);",
      "",
      "rb = .5*(1/tic);",
      "bvb = tic*(bass*rb + (1/tic-rb)*bvb);",
      "bd = bass - bvb;",
      "",
      "vm = vm - tic + swi;",
      "swi = above(bd - vm,0);",
      "",
      "q4 = 1-swi;",
      "",
      "cm = if(above(iter,30) + equal(time,0),int(rand(3)) + 1,cm);",
      "iter = (iter + tic)*(1-above(iter,30));",
      "q5 = if(equal(cm,0),3,cm);",
      "",
      "cma = if(above(itar,5) + equal(time,0),int(vav*5),cma);",
      "itar = (itar + tic)*(1-above(itar,5));",
      "",
      "q6 = int(vav*5);",
      "",
      "monitor = q6;",
      "",
      "decay = 1;"
