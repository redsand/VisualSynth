    "comp": null,
    "perFrameCode": [
      "wave_mode = cy - ob_r;",
      "wave_y = sigmoid(wave_y + mv_g , ib_size * dy);",
      "ob_size = min(ib_a * mv_r , ib_a + mv_l);",
      "mv_y = if(above(ob_r * wave_g , wave_mode * ob_r) , ob_b - ob_g , zoomexp * wave_mode);",
      "ib_b = 0.94505525*sqr(zoom * sy);",
      "wave_y=if(below(wave_y,0.0), 0.0, wave_y);",
      "wave_y=if(above(wave_y,1.0), 1.0, wave_y);",
      "wave_mode=if(below(wave_mode,0), 0, wave_mode);",
      "wave_mode=if(above(wave_mode,7.0), 7.0, wave_mode);",
      "ob_size=if(below(ob_size,0.0), 0.0, ob_size);",
      "ob_size=if(above(ob_size,0.5), 0.5, ob_size);",
      "ib_b=if(below(ib_b,0.0), 0.0, ib_b);",
      "ib_b=if(above(ib_b,1.0), 1.0, ib_b);",
      "mv_y=if(below(mv_y,0.0), 0.0, mv_y);",
      "mv_y=if(above(mv_y,48.0), 48.0, mv_y);",
      "q1 = int(slowtime)%2;",
      "slowtime = slowtime+beat*time;",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "beat = if(above(vol_now,1.5*vol_mean),1,0);",
      "beatcount = beatcount+beat;",
      "q2=sin(slowtime);",
      "wave_b = cos(slowtime)  + abs(cos(slowtime));",
      "wave_g = abs(sin(slowtime)) ;",
      "wave_r = (-1 * cos(slowtime))  + abs(-1 * cos(slowtime)) + 0.2 * (cos(sin(slowtime))+(abs(cos(sin(slowtime)))+cos(sin(slowtime))));",
      "ib_g = if(above(wave_g,1),1,if(above(wave_g,0), abs(wave_g),0));",
      "ib_b = if(above(wave_b,1),1,if(above(wave_b,0), abs(wave_b),0));",
      ""
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "rot=if(above(bnot(1*bass),bnot(1*treb)),rot*sin(rad*sin(time)),-rot*sin(rad*cos(time)));",
      "sy = if (q1,sy , x + x);",
      "zoomexp = if(q1,q2*zoomexp,ang - ang);",
      "cx = if(q1,abs(q2)*cx,y * x);",
      "zoomexp=if(below(zoomexp,0.025), 0.025, zoomexp);",
      "zoomexp=if(above(zoomexp,100.0), 100.0, zoomexp);",
      "cx=if(below(cx,-1.0), -1.0, cx);",
      "cx=if(above(cx,2.0), 2.0, cx);",
      "sy=if(below(sy,0.01), 0.01, sy);",
      "sy=if(above(sy,100.0), 100.0, sy);"
