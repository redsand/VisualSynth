  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "//begin beat code",
      "volume = 0.3*(bass+mid);",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.05*(meanbass_att*19 + bass_att);",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beat = above(volume,0.8)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "//Adjust responsiveness: To increase responsiveness, set the \"0.96 and \"0.996\" on the next line to slightly lower values. Higher values decrease responsiveness.",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.96 + (1-above(time - lastbeat, 2*beatrate))*0.996);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "//end beat code",
      "",
      "tim = if(beat,time,tim);",
      "q5 = below(time - tim,.1);",
      "",
      "warp = 0;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "ra = 1/tic*.25;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "q1 = treb_avg;",
      "q2 = mid_avg;",
      "q3 = bass_avg;",
      "",
      "monitor = q5;",
      "",
      "mx = if(beat,int(rand(1001))*.001*.5 + int(rand(1001))*.001*.5,mx);",
      "my = if(beat,int(rand(1001))*.001*.5 + int(rand(1001))*.001*.5,my);",
      "cx = mx;",
      "cy = my;",
      "",
      "mox = mx - .5;",
      "moy = my - .5;",
      "an = atan(moy/mox) + if(above(mox,0),above(moy,0)*6.2832,3.1416);",
      "dis = pow(mox*mox + moy*moy,.5);",
      "dis = max(.17,dis);",
      "",
      "q7 = .5 + dis*cos(an);",
      "q8 = .5 + dis*sin(an);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "mx = x - q7;",
      "my = y - q8;",
      "",
      "an = ang;",
      "//zoom = 1 + pow(sin(an*5 - time),1)*.02*bass*bass;",
      "",
      "ra = pow(mx*mx + my*my,.5);",
      "rot = .02*sin(ra*6.2832*2 - time*4)*(mid + treb)*(mid + treb)*.5;"
    ],
