  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n   d = uTexSize.zw*4;\n   d_uv = vUv;\n   dx = GetBlur1(d_uv + vec2(1,0)*d) - GetBlur1(d_uv - vec2(1,0)*d);\n   dy = GetBlur1(d_uv + vec2(0,1)*d) - GetBlur1(d_uv - vec2(0,1)*d);\n   d_uv += vec2(dx.x,dy.x)*0.03;\n\nret = mix(GetBlur2(d_uv),GetPixel(d_uv),0.4);\nret = (ret.y-ret.x*0.5)*mix(vec3(1.5,0.6,0),1,ret.x)*1.4;\n\nret = mix(ret,0,GetBlur1(d_uv-vec2(1,1)*uTexSize.zw*32).z*0.6);\nret = mix(ret,2,GetPixel(vUv).z*0.36);\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "warp = 0;",
      "decay=.999;",
      "//q1 = .1*tan(time);",
      "//q1 = min(0.5,max(0.0,q1));",
      "//q1 = q1+0.5;",
      "",
      "q1=sin(time);",
      "q1sgn = sign(q1);",
      "q1=abs(q1);",
      "q1=pow(q1,6);",
      "q1=q1*q1sgn;",
      "q1=q1*0.4 + 0.5;",
      "",
      "",
      "",
      "q2 = .5 + .1*sin(time*.548);",
      "",
      "tic = min(time - tin,.1);",
      "tin = time;",
      "",
      "ra = 1;",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "",
      "rb = 1;",
      "vav = tic*(vav*(1/tic - rb) + rb*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb_avg;",
      "mt = mt + tic*mid_avg;",
      "bt = bt + tic*bass_avg;",
      "vt = vt + tic*(treb_avg+mid_avg+bass_avg)*.33333;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav;",
      "toc = 1;",
      "",
      "q3 = (treb + bass + mid)*.3333;",
      "q3 = q3*q3*0.5 + 0.1;",
      "q3 = min(q3,1.0);",
      "//q3=1.25;",
      "monitor = int(q3*4)/4;",
      "",
      "q4 = mt;",
      "q5 = bt;",
      "",
      "cx = q1;",
      "cy = q2;",
      "",
      "rmod = ((treb_avg + mid_avg)*.5 - bass_avg*0.5)*.01;",
      "rmod = 0.02 * pow(rmod/0.02 , 2)*7;",
      "rmod = min(0.001 , max(rmod, -0.001));",
      "rmod=rmod*pow(sin(time)*1.1,2);",
      "rot = 0.02 * pow(rmod/0.02 , 2) *40;",
      "",
      "q6 = rmod;",
      "",
      "q7 = slide - below(q3,.5)*(6 + 2*sin(time*24))*pow(min(1,(.5 - q3)*2),5);",
      "",
      "q8=if( above(sin(time*0.5),0) , -1 , 1);",
      "",
      "//echo_zoom=1+(above(treb,.8)+treb);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "tm=time/rad;",
      "a = q1;",
      "b = q2;",
      "",
      "//testcode",
      "//a=0.0;b=0.5;",
      "",
      "mx = x-a;",
      "my = y-b;",
      "zm = -.45;",
      "zm= if( above(sin(time*2.1),0.95) , 0.45 * max(1-q3*.5,0) , zm);",
      "",
      "//test code",
      "//zm= -0.5;",
      "",
      "dis = pow(mx*mx + my*my,.5)*.70710678;",
      "",
      "rot = rot*(1-dis);",
      "rot=rot*20*q8 ;",
      "",
      "//testcode",
      "//q3=3.1;",
      "",
      "limit=0.05;",
      "",
      "dx = zm*mx*dis*cos(my*3.14)*q3;",
      "dsign=sign(dx);",
      "dx = dx -  ( max(abs(dx)-limit,0) )*dsign;",
      "",
      "dy = zm*my*dis*cos(mx*3.14)*q3;",
      "dsign=sign(dy);",
      "dy = dy -  ( max(abs(dy)-limit,0) )*dsign;",
      ""
