  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "mv_r = mv_r + 0.350*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );",
      "mv_g = mv_g + 0.350*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );",
      "mv_b = mv_b + 0.350*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );",
      "q8 =oldq8+ 0.005*(pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "oldq8 = q8;",
      "q1 = 0.62*( 0.60*sin(0.374*q8) + 0.40*sin(0.294*q8) );",
      "q2 = 0.62*( 0.60*sin(0.393*q8) + 0.40*sin(0.223*q8) );",
      "q3 = 0.62*( 0.60*sin(0.174*-q8) + 0.40*sin(0.364*q8) );",
      "q4 = 0.62*( 0.60*sin(0.234*q8) + 0.40*sin(0.271*-q8) );",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "ob_a = bnot(beat);",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "q5_residual = equal(bass_thresh,2)*0.016*sin(time*7) + (1-equal(bass_thresh,2))*q5_residual;",
      "q6_residual = equal(bass_thresh,2)*0.012*sin(time*9) + (1-equal(bass_thresh,2))*q6_residual;",
      "",
      "",
      "",
      "q5 = 1-abs(4*q5_residual);",
      "q6 =  1-abs(4*q5_residual);",
      "wave_a =0;",
      "zoom = 1000;",
      "monitor = q8;",
      "q7= 0.05*(pow(1+1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "dx = 0.5;",
      "dy =0.5;"
    ],
    "perFrameInitCode": [
      "oldq8 =0;",
      "q8=0;"
    ],
    "perPixelCode": [
      "du = x*2-1 - q1;",
      "dv = y*2-1 - q2;",
      "dist = sqrt(du*du+dv*dv);",
      "ang2 = atan2(du,dv);",
      "mult = q5/(dist+0.4);",
      "dx = dx+mult*sin(ang2-1.5);",
      "dy = dy+mult*cos(ang2-1.5);",
      "du = x*2-1 - q3;",
      "dv = y*2-1 - q4;",
      "dist = sqrt(du*du+dv*dv);",
      "ang2 = atan2(du,dv);",
      "mult = q6/(dist+0.4);",
      "dx = dx + mult*sin(ang2+1.5);",
      "dy = dy + mult*cos(ang2+1.5);",
      "rot = -0.1*rad*q7;",
