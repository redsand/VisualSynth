  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_fc_main, vUv ).xyz;\n    //ret = mix(GetBlur1(vUv)*1,ret,ret);\n    // darken (decay) over uTime\n    if (ret.x+ret.y+ret.z < (0+((audioMid+audioLow+audioHigh)/3)*.3)){\n       ret.x = ret.x+.6;\n       ret.y = ret.y+.6;\n       ret.z = ret.z+.6;\n       }else{\n       ret = (ret - .005)*0.99; //or try: ret -= 0.004;\n    }\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "// timed sidon sensor",
      "// le = signal level; desired average value = 2",
      "le=1.4*bass_att+.1*bass+.5*treb;",
      "pulse=above(le,th);",
      "// pulsefreq = running average of interval between last 5 pulses",
      "pulsefreq=if(equal(pulsefreq,0),2,",
      "if(pulse,.8*pulsefreq+.2*(time-lastpulse),pulsefreq));",
      "lastpulse=if(pulse,time,lastpulse);",
      "// bt = relative time; 0 = prev beat; 1 = expected beat",
      "bt=(time-lastbeat)/(.5*beatfreq+.5*pulsefreq);",
      "// hccp = handcicap for th driven by bt",
      "hccp=(.03/(bt+.2))+.5*if(band(above(bt,.8),below(bt,1.2)),",
      "(pow(sin((bt-1)*7.854),4)-1),0);",
      "beat=band(above(le,th+hccp),btblock);",
      "btblock=1-above(le,th+hccp);",
      "lastbeat=if(beat,time,lastbeat);",
      "beatfreq=if(equal(beatfreq,0),2,",
      "if(beat,.8*beatfreq+.2*(time-lastbeat),beatfreq));",
      "// th = threshold",
      "th=if(above(le,th),le+114/(le+10)-7.407,",
      "th+th*.07/(th-12)+below(th,2.7)*.1*(2.7-th));",
      "th=if(above(th,6),6,th);",
      "thccl=thccl+(th-2.5144);",
      "",
      "q1=le;",
      "q2=thccl+.2*leccl;",
      "leccl=leccl+dle*le;",
      "dle=if(beat,-dle,dle);",
      "bccl=bccl+beat;",
      "",
      "wave_r=.1+.8*sqr(sin(.011*thccl))+.1*sin(leccl*.061);",
      "wave_g=.1+.8*sqr(sin(.013*thccl))+.1*cos(leccl*.067);",
      "wave_b=.1+.8*sqr(cos(.017*thccl))+.1*sin(leccl*.065);",
      "",
      "ib_r=ib_r+.1*sin(1.3*time+.012*leccl);",
      "ib_g=ib_g+.1*sin(1.7*time+.019*leccl);",
      "ib_b=ib_b+.1*sin(1.9*time+.017*leccl);",
      "mv_r=.5*(ib_r+wave_r);mv_g=.5*(ib_g+wave_g);mv_b=.5*(ib_b+wave_b);",
      "mv_a=.5*sqr(sin(.01*leccl+bccl));",
      "",
      "echo_alpha=.5+.2*cos(.07*leccl+.02*thccl);",
      "eo=if(band(equal(bccl%3,0),beat),int(rand(4)),eo);",
      "q3=(equal(eo,2)+equal(eo,1))*equal(bccl%2,0);",
      "q4=(equal(eo,0)+equal(eo,3))*equal(bccl%2,0);",
      "echo_orient=eo;"
    ],
    "perFrameInitCode": [
      "dle=1;"
    ],
    "perPixelCode": [
      "dqv=above(x,.5)-above(y,.5);",
      "rot=sin(sin(rad*(13+5*sin(.01*q2))+.06*q2)*q1*.01);",
      "zoom=1+if(q3,dqv,1)*.1*sin(7*ang+.03*q2);",
      "zoom=if(q4,if(below(rad,.8*sqr(sin(.016*q2))),.75+.4*cos(.021*q2),zoom),zoom);"
    ],
