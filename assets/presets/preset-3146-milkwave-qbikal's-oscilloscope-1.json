  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "q1=aspecty;     bt=bt+bass/fps;      tt=tt+treb/fps;",
      "",
      "",
      "////  propagation of 2 disturbances",
      "",
      "i=0;    loop(ni,     oldc=gmegabuf(ni+i);",
      "",
      "c = ( gmegabuf(i-1)  + gmegabuf(i+1)  + gmegabuf(i-33) + gmegabuf(i-32)       //// average of the 8 neighbour points",
      "     +gmegabuf(i-31) + gmegabuf(i+31) + gmegabuf(i+32) + gmegabuf(i+33) ) / 8;",
      "",
      "x1=.5+.45*sin(.4*bt);   y1=.5+.45*sin(.5*tt);    i1=32*int(32*x1)+int(32*y1);    //// disturbances path",
      "x2= 1-x1;               y2= 1-y1;                i2=32*int(32*x2)+int(32*y2);",
      "",
      "p=  equal(i,i1)* bass_att +  equal(i,i2)* treb_att;      //// disturbances (2 single points)",
      "",
      "z = p + 1.4*c-.415*oldc;                 //// disturbances + propagation",
      "",
      "gmegabuf(i)=z;     gmegabuf(ni+i)=c;",
      "",
      "i=i+1 ;);",
      "",
      ""
    ],
    "perFrameInitCode": [
      "ni=1024;    i=0;   loop(2*ni,",
      "gmegabuf(i)= 0;     i=i+1;);"
    ],
