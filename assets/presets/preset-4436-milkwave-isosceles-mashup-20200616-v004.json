  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\nvec2 uv1 = vec2(vUv.x,vUv.y+uTexSize.w*3);\nret = GetPixel(uv1);\nret = 0;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "xlen = 44; ylen = 44; flen = 10; reg00 = xlen*ylen/4; reg01=reg00/4;",
      "dec_med = pow (0.94, 30/fps); dec_slow = pow (0.98, 30/fps);",
      "dec_f = pow (0.8, 30/fps); monitor = smooth;",
      "q30 = dec_s;",
      "smooth = max(1,pow(6,fps/30)-2); // >= 0; Ausbreitungsgeschwindigkeit",
      "",
      "//Gleichanteil entfernen und normalisieren",
      "ind = 0; sum = 0; amp = 0.01;",
      "loop (reg01,",
      "  sum = sum + gmegabuf(ind+30000)/(reg01);",
      "  amp = amp + pow(gmegabuf(ind+30000),2);",
      "  ind = ind+1;",
      ");",
      "ind = 0; amp_= amp_*dec_med + (1-dec_med)*sqrt(amp)/reg01*600;",
      "loop (reg01,",
      "  megabuf(ind+30000)= (gmegabuf(ind+30000)-sum)/amp_;",
      "  ind = ind+1;",
      ");",
      "",
      "// Spectrum of spectrum  !",
      "index2 = 0;",
      "loop(flen, //Frequency step",
      "  index=0; real= 0; imag = 0;",
      "  loop (flen,",
      "    real = real + cos(index/flen*6.28*index2)*megabuf(index*reg01/8+30002);",
      "    imag = imag + sin(index/flen*6.28*index2)*megabuf(index*reg01/8+30002);",
      "    index=index+1;",
      "  );",
      "  megabuf(10000+index2)= megabuf(10000+index2) * dec_f + real;",
      "  megabuf(15000+index2)= megabuf(15000+index2) * dec_f + imag;",
      "  index2 = index2+1;",
      " );",
      "",
      "//Anregung",
      "ind = 1;",
      "loop (flen/2,",
      "  cx = megabuf(10000+ind);",
      "  cy = megabuf(15000+ind);",
      "  yind = -1;",
      "  loop (3,",
      "    xind = -1;",
      "    loop (3,",
      "      ox = ((cx+.5)*xlen+xind)%xlen;",
      "      oy = ((cy+.5)*ylen+yind)%ylen;",
      "      amp = (cx*cx+cy*cy);",
      "      megabuf (oy*ylen+ox) = megabuf (oy*ylen+ox)",
      "                           - 2*30/fps*sqrt(amp)*above(amp,.02)/(1+xind*xind+yind*yind);",
      "      xind = xind+1;",
      "    );",
      "    yind = yind+1;",
      "  );",
      "  ind = ind+1;",
      ");",
      "",
      "//Simulation",
      "yind = 0;",
      "loop (ylen,",
      "  xind = 0;",
      "  loop (xlen,",
      "    megabuf(yind*ylen+xind+5000) = //megabuf ab 5000 ist nur Zwischenspeicher",
      "    dec_med*((gmegabuf(yind*ylen+(xind+1)%xlen) +",
      "    gmegabuf(yind*ylen+(xlen+xind-1)%xlen) +",
      "    gmegabuf(((yind+1)%ylen)*ylen+xind) +",
      "    gmegabuf(((yind+ylen-1)%ylen)*ylen+xind)",
      "    +gmegabuf(yind*ylen+xind)*smooth*4)/(2+2*smooth) - megabuf(yind*ylen+xind));",
      "    xind = xind+1;",
      "  );",
      "  yind = yind+1;",
      ");",
      "",
      "//Projektionsparameter",
      " zang = -0.2*sin(time/9); xang = -.5 -.2*sin(time/6) ; yang = time/4;",
      "q1 = cos(xang);",
      "q2 = sin(xang);",
      "q3 = cos(yang);",
      "q4 = sin(yang);",
      "q5 = cos(zang);",
      "q6 = sin(zang);",
      "fov = .8;",
      "",
      "//Umkopieren und Projektion",
      "yind = 0;",
      "loop (ylen,",
      "  xind = 0;",
      "  loop (xlen,",
      "    ind = yind*ylen+xind;",
      "    megabuf(ind) = gmegabuf(ind);",
      "    gmegabuf(ind) = megabuf(ind+5000);",
      "    oz = yind - ylen/2+sin(time*2)*0; //#",
      "    ox = if(bnot(yind%2),xind,xlen-xind-1);",
      "    oy = gmegabuf(yind*ylen+ox); oy0 = oy;",
      "    ox = ox - xlen/2;",
      "    mx = ox*q5 - oy*q6;  my = ox*q6 + oy*q5;",
      "    ox = mx; oy = my;",
      "    mx = ox*q3 + oz*q4;  mz = - ox*q4 + oz*q3;",
      "    ox = mx; oz = mz;",
      "    my = oy*q1 - oz*q2;  mz = oy*q2 + oz*q1;",
      "    oy = my; oz = mz;",
      "    gmegabuf(10000+ind) = fov*ox/(oz+60*fov)+.5;",
      "    gmegabuf(15000+ind) = fov*oy/(oz+60*fov)+.6;",
      "    gmegabuf(20000+ind) = max(min(.5+oy0/4,1),0)*1;",
      "    gmegabuf(25000+ind) = oy0/16+.5;;",
      "    xind = xind+1;",
      "  );",
      "  yind = yind+1;",
      ");",
      "",
      "q32 = aspecty;",
      ""
    ],
