  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*0.96+1.3);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.3)*0.96+1.3);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "pulse=if(above(abs(pulse),500),-500,pulse+.1*bor(bor(bass_changed*bnot(treb_changed),treb_changed*bnot(bass_changed))*bnot(mid_changed),mid_changed))+(bass+mid+treb)*.025;",
      "effect_1=1+1*bor(bass_changed,mid_changed);",
      "effect_2=1+2*mid_flop*bnot(treb_changed);",
      "effect_3=1+4*above(sin(pulse),0);",
      "effect_4=1+6*bor(treb_changed,mid_changed);",
      "effect_5=1+10*bor(treb_flop,bass_flop)*bnot(mid_changed)*above(sin(pulse),0);",
      "q1=effect_1*effect_2*effect_3*effect_4*effect_5;",
      "q2=sin(pulse*.2);",
      "q3=sin(pulse*.4);",
      "q4=sin(pulse*.8);",
      "q5=sin(pulse);",
      "wave_b=if(treb_changed,1,if(mid_changed,.45,-.45))*q4;",
      "wave_g=if(bass_changed,.1,bass_flop);",
      "wave_r=if(mid_flop,1,.5*q2*treb_flop);",
      "wave_mystery=q5/2;",
      "wave_x=wave_x+.25*q4*bor(bor(mid_changed,treb_changed),bass_changed);",
      "wave_y=wave_y+.3*q5;",
      "zoom=zoom+.1*bnot(q1%2)*q5;",
      "rot=treb_flop*(pulse%q1)*-.01;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "brick_dx =sin(pow(x,2))*.1;",
      "brick_dy =sin(pow(y,2))*.1;",
      "radical=sin(ang*6)*.04;",
      "bend = cos((x*10)*q2-(rad*10)*q4*bnot(q1%2));",
      "zoom = zoom+bend*.2*q5*bnot(q1%7);",
      "dx=if(bnot(q1%5),if(bnot(q1%5),radical,brick_dx),dx);",
      "dy=if(bnot(q1%5),if(bnot(q1%3),radical,brick_dy),dy);",
      "grid=(x*10)%2 + (y*10)%2;",
      "grid_shift=bnot(q1%11)*grid*.15;",
      "sx=sx-above(q4,0)*grid_shift;",
      "sy=sy-below(q4,0)*grid_shift;"
