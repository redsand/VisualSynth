      "xx=above(y,.5+.5*q2)*x*q1-.5+.03*q5+.1*y*q6+.1*sin(time*.322);",
      "yy=above(x,.5+.5*q3)*y*q1-.5+.03*q6+.1*x*q5+.1*sin(time*.427);",
      "rot=sin(rad*(1.4+.7*q4+.7*q5+.7*q6));",
      "grid=bnot(sin(xx*yy)%q8);",
      "grid_shift=grid*sin((yy-.5)*6.3*q4);",
      "dx=if(above(q4,0)*above(abs(x-.5),.25+.25*q1),below(q7,4)*grid_shift,sin(xx*3.14*above(q3,0)));",
