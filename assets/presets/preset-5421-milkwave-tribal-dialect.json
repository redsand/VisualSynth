      "wave_b = wave_b + if(above(treb_att,1.4),0,.49*sin(time));",
      "bass_flux=if(equal(abs(bass_flux),1),bass_flux,1)*if(above(abs(timing),.97),-1,if(above(bass_att,1.3),-1,1));",
      "treb_flux=if(equal(abs(treb_flux),1),treb_flux,1)*if(above(treb_att,1.3),-1,1);",
