      "q1=timing;",
      "q2=-timing*bass_flux;",
      "q3=timing*treb_flux;",
      "rot=if(above(q1,0),if(above(q2,0),.1,-.1),0);",
      "zoom=zoom+.05*q2+.05*q1;",
      "wave_mystery=wave_mystery+.7*q1+.3*q2;",
      "wave_size=wave_size+0.5*q3;",
      "cx=cx+.2*q1;",
      "cy=cy+.2*q3;"
    ],
