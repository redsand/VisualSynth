  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.1+.1*sin(pulse);",
      "bass_thresh =if(above(bass_att,bass_thresh),3,bass_thresh-chaos);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,3));",
      "treb_thresh=if(above(treb_att,treb_thresh),3,treb_thresh-chaos);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,3));",
      "mid_thresh=if(above(mid_att,mid_thresh),3,mid_thresh-chaos);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,3));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse*3) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*3) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*3) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),3.14),-3.14,pulse+(bass_thresh+mid_thresh+treb_thresh)*.0071);",
      "entropy=if(equal(pulse,-3.14),bass_flop+mid_flop+treb_flop+int(rand(5)),entropy);",
      "q1=mid_residual;",
      "q2=bass_residual;",
      "q3=treb_residual;",
      "q4=sin(pulse);",
      "q5=cos(pulse*(.5+.1*entropy));",
      "q6=sin(pulse*(.5+pow(.25,entropy)));",
      "q7=above(q1,0)+above(q2,0)+above(q3,0)+above(q3,0)*treb_flop+above(q2,0)*bass_flop+above(q1,0)*mid_flop;",
      "q8=entropy;",
      "ib_r=.5+.5*cos(time*1.2+q1*.1);",
      "ib_b=.5+.5*cos(time*2.811+q2*.1);",
      "ib_g=.5+.5*cos(time*1.666+q3*.1);",
      "rot=0;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "grid=pow((sin(ang*10*q1)+x*y*q4)*2,1+q8*q7%11)%2;",
      "snee=(.3+.2*q6)*q3;",
      "rot=bnot(grid)*above(x,.5+snee)*above(y,.5-snee) -",
      "ang*cos(5+(3.14*q6))*below(x,.5+snee)*below(y,.5-snee)*.05;",
      "sx=sx+sin((q8%4+q7%5)*x*3.14)*bnot(rot)*.004;",
      "sy=sy+sin((q8%5+q7%4)*y*3.14)*bnot(rot)*.004;",
      "zoom=zoom+.1*cos(rad*q8*q7);"
    ],
