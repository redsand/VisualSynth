      "zoom = if(below(bass,0.05),0,zoom);",
      "rot = if(below(bass,0.05),0,sin(0.2));",
      "cy = cy + 0.25*sin(time)*22*dy_r;",
      "cx = cx + 0.25*cos(2.5*time)*22*dx_r;"
