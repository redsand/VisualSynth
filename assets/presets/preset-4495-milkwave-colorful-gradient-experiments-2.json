  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "dec_med = pow (0.7, 30/fps);",
      "dec_slow = pow (0.99, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "",
      "beat = bass+mid+treb;",
      "beat = beat*beat;",
      "",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, .2*avg+peak) * above (time, t0+.2);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %8;",
      "index2 = (index2 + is_beat*bnot(index))%2;",
      "",
      "q20 = avg;",
      "q21 = beat;",
      "q22 = peak;",
      "q23 = index;",
      "q24 = is_beat;",
      "q26 = bass_att + mid_att + treb_att + 3;",
      "q27 = index + 1;",
      "q28 = index2;",
      "q29 = index2;",
      "monitor = q29;",
      "",
      "warp=0;",
      "",
      "beatcounter = if(beat,beatcounter +1, beatcounter);",
      "beatcounter = if(above(beatcounter,7), 0, beatcounter);",
      "beateven = beatcounter%2;",
      "q5 = beateven;",
      "q8 =oldq8+ 0.005*(pow(1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "oldq8 = q8;",
      "q9 = 0.0125*(q8 + time);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "grid=abs(x*18+3*q5)%2 + abs(y*18+3*q5)%2;",
      "cx = grid;",
      "cy = grid;",
      "zoom=1+0.5*if(bnot(grid),cos(rad*10*sin(q8))*.07,cos(x*10*sin(q8))*.07);",
      "rot = 0.01*(1-rad);",
      "dx=0.4*grid*(0.008*sin((y*2-1)*48)+0.008*sin((y*2-1)*64));",
