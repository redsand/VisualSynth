      "// Appended Code From C:\\Program Files\\Winamp\\Plugins\\MilkDrop\\Self\\Turbulence.milk",
      "wave_y = if(below(wave_r - bass , mid * frame) , bass * bass , mid + time);",
      "wave_r = max(bass + wave_r , treb + wave_g);",
      "mv_l = 0.055 + wave_y * wave_x;",
      "wave_r = if(below(wave_r * wave_y , treb * treb) , bass * zoom , bass * warp);",
      "ob_r = min(mid * bass , treb + treb);",
      "ib_b = if(below(bass_att * wave_b , wave_g * wave_x) , if(below(warp * mid , bass - wave_y) , bass_att * wave_r , treb * wave_g) , wave_r + wave_g);",
      "mv_b = min(wave_r + bass , mid * wave_b);",
