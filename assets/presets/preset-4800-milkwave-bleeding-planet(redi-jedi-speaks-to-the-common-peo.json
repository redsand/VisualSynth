    "perPixelCode": [
      "center_x = q1;",
      "center_y = q2;",
      "radius = q3;",
      "angle = q4;",
      "",
      "",
      "d_x = (x - center_x)/radius*4/3;",
      "d_y = (y - center_y)/radius;",
      "",
      "r = below (d_x * d_x + d_y * d_y, 1); // je uvnitr koule?",
      "posun = sqrt(1 - d_x * d_x - d_y * d_y); // jak moc se tam posune?",
      "",
      "amount = 0.01 + 0.015*bass_att;",
      "",
      "dx = r * posun * amount * cos(angle);",
      "dy = r * posun * amount * sin(angle);"
