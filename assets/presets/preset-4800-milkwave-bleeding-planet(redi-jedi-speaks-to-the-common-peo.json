    "perFrameCode": [
      "dx=0; dy=0;",
      "",
      "// ddx=ddx+ddx*0.01*cos(time);",
      "// ddy=ddy+ddy*0.01*sin(time);",
      "",
      "mtime=mtime+bass*bass;",
      "mtime2=mtime2+treb*treb;",
      "radius=.2+.05*sin(mtime*.1);",
      "",
      "",
      "",
      "b_right = above(xpos,1-radius)*above(sign(ddx),0);",
      "b_left = below(xpos,radius)*below(sign(ddx),0);",
      "b_bottom = above(ypos,1-radius)*above(sign(ddy),0);",
      "b_top = below(ypos,radius)*below(sign(ddy),0);",
      "ddx=ddx*if(b_right,-1,1);",
      "ddx=ddx*if(b_left,-1,1);",
      "ddy=ddy*if(b_bottom,-1,1);",
      "ddy=ddy*if(b_top,-1,1);",
      "",
      "xpos=xpos+ddx;",
      "ypos=ypos+ddy;",
      "",
      "angle = atan2(ddy,ddx * 4/3);",
      "//angle = 3.1415926;",
      "angle=sin(mtime2*.1)*6.28;",
      "",
      "q1 = xpos;",
      "q2 = ypos;",
      "q3 = radius;",
      "q4 = angle;",
      "",
      "monitor = angle;"
    ],
    "perFrameInitCode": [
