  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    ret = texture( sampler_main, (vUv-0.5)*1.00 + 0.5 );\n    ret /= ret.x+ret.y+ret.z;\n    float zoom = dot(ret, vec3(1,0.975,0.95));\n\n    ret.xyz = texture( sampler_main, (vUv-0.5)*zoom + 0.5 );\n\n    // .x = fastest layer, .z = slowest\n    float r = 0.02;\n    vec3 xfer = clamp01((ret - 0.05)*99);\n    xfer.yz *= clamp01((0.1-ret.xy)*99);\n    ret += xfer.xxx*vec3(-1,1,0)*r*0.7;\n    ret += xfer.yyy*vec3(0,-1,1)*r*4;\n    ret += xfer.zzz*vec3(0,0,-1)*r;\n\n    // ERROR DIFFUSION DITHER - looks great\n    vec2 dither_uv = vUvOriginal*uTexSize.xy*texsize_noise_lq.zw + rand_frame.xy;\n    ret += (texture(sampler_noise_lq, dither_uv).xyz-0.5)/256.0*vec3(1,3,8)*5;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "treb_thresh=above(treb_att,treb_thresh)*2+",
      "(1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*0.96+1.3);",
      "mid_thresh=above(mid_att,mid_thresh)*2+",
      "(1-above(mid_mid_att,mid_thresh))*((mid_thresh-1.3)*0.96+1.3);",
      "vol_thresh= (pfthresh+treb_thresh+mid_thresh)/3;",
      "q6 = vol_thresh;",
      "q7 = treb_thresh;",
      "q8 = mid_thresh;",
      "q3 = 0.65 + 0.5*sin(time*1.13);",
      "q2 = 0.65 + 0.5*sin(time*1.23);",
      "q1 = 0.65 + 0.5*sin(time*1.33);",
      "",
      "wave_r = 0.5 + 0.5*sin(1.6*time);",
      "wave_g = 0.5 + 0.5*sin(4.1*time);",
      "wave_b = -1 + (1-wave_r + 1-wave_g);",
      "warp = 0;",
      "pfthresh = above(bass_att,pfthresh)*2+(1-above(bass_att,pfthresh))*((pfthresh-1.3)*0.96+1.3);",
      "pfdx_r = equal(pfthresh,2)*0.015*sin(5*time)+(1-equal(pfthresh,2))*pfdx_r;",
      "pfdy_r = equal(pfthresh,2)*0.015*sin(6*time)+(1-equal(pfthresh,2))*pfdy_r;",
      "rg1 = abs(sin(time));",
      "rg2 = 1*above(rg1,0.80) + 0.90*below(rg1,0.20) + 0.80*above(rg1,0.20)*below(rg1,0.40)+",
      "0.70*above(rg1,0.40)*below(rg1,0.60) + 0.60*above(rg1,0.6)*below(rg1,0.8);",
      "rg3 = if(equal(pfthresh,2),rg2,rg3);",
      "wave_a = 0;",
      "//wave_b = 0;",
      "//wave_r = 1;",
      "//wave_g = 0.66 - 0.3*sin(time);",
      "echo_zoom = rg3;",
      "cog = ocog+0.005*(bass+bass_att+(bass*bass_att)-2);",
      "ocog = below(cog,30000)*cog;",
      "q4 = cog;",
      "rcog = orcog + 0.5*(rand(100)*0.01);",
      "orcog = below(rcog,20000)*rcog;",
      "q5 = rcog;",
      "ib_r = 0.5*bass_att;",
      "ib_G = 0.5*treb_att;",
      "ib_b = 0.5*mid_att;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);",
      "dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;",
      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "tg1 = abs(sin(time));",
      "tg2 = 12*dx_r*above(tg1,0.5) + 12*dy_r*below(tg1,0.5);",
      "tg3 = if(equal(thresh,2),tg2,tg3);",
      "",
      "",
      "dx = dx + 0.1*tg3*sin(q4);",
      "dy = dy - 0.1*tg3*cos(q4);",
      "cx = cx + 0.31*cos(q4);",
      "cy = cy + 0.31*sin(q4);",
      "zoom = zoom - 0.4*(sin(q4));",
      "rot = rot + 1*sin(1-q4);"
    ],
