  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    ret = texture(sampler_main, vUv).xyz;\n    float L = lum(ret);\n    float bw = clamp01(cos(L*17 + 3 + vUv.x*30)*30 - 21);\n    float L2 = lum(GetBlur1(vUv));\n    float bw2 = clamp01(cos(L*17 + 3 + vUv.x*30)*3 - 2.7);\n\n    ret = vec3(1.1,0.8,0.7)*ret.x +\n          vec3(0.4,0.6,0.55)*ret.y +\n          vec3(1.7,0.6,0.3)*ret.z;\n    ret *= 0.4;\n\n    ret = ret*ret * (1 + bw2*4);\n\nret /= vec3(1.2,0.8,0.8);\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "wave_r = 0.85 + 0.35*sin(0.437*time+1) + 0.55*sin(0.197*time+4);",
      "wave_g = 0.85 + 0.35*sin(0.544*time+2) + 0.55*sin(0.143*time+5);",
      "wave_b = 0.85 + 0.35*sin(0.751*time+3) + 0.55*sin(0.117*time+6);",
      "wave_r = sqrt(wave_r);",
      "wave_g = sqrt(wave_g);",
      "wave_b = sqrt(wave_b);",
      "wave_x = int(rand(100))*0.01;",
      "wave_y = 0.25 + 0.5*int(rand(100))*0.01;",
      "rot = rot + 0.010*( 0.60*sin(0.381*time) + 0.40*sin(0.579*time) );",
      "cx = cx + 0.210*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );",
      "cy = cy + 0.210*( 0.60*sin(0.393*time) + 0.40*sin(0.223*time) );",
      "dx = dx + 0.003*( 0.60*sin(0.234*time) + 0.40*sin(0.277*time) );",
      "dy = dy + 0.003*( 0.60*sin(0.284*time) + 0.40*sin(0.247*time) );",
      "decay = decay - 0.01*equal(frame%6,0);",
      "dx = dx + dx_residual;",
      "dy = dy + dy_residual;",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "dx_residual = equal(bass_thresh,2.13)*0.016*sin(time*7) + (1-equal(bass_thresh,2.13))*dx_residual;",
      "dy_residual = equal(bass_thresh,2.13)*0.012*sin(time*9) + (1-equal(bass_thresh,2.13))*dy_residual;",
      "wave_x = wave_x - dx_residual*7;",
      "wave_y = wave_y - dy_residual*7;",
      "wave_mystery = time*0.03;"
    ],
