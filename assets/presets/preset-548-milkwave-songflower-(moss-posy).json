      "dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;",
      "",
      "ladder = abs(sin(1*time));",
      "leaf = 5*below(ladder,0.2) + 8*above(ladder,0.2)*below(ladder,0.4) +",
      "12*above(ladder,0.4)*below(ladder,0.6) + 18*above(ladder,0.6)*below(ladder,0.8) +",
      "24*above(ladder,0.8);",
      "leafset = if(equal(thresh,2), leaf, leafset);",
      "",
      "zoom = zoom + 0.05*(0.75-cos(leafset*rad))*(1-rad);",
      "zoom = zoom - abs(0.05*(0.75-cos(4*rad)));"
    ],
