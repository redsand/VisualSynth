      "ob_r = 1-abs(q1)*0.75;",
      "ob_g = 1-abs(q2)*0.75;",
      "ob_b = 1-abs(q3)*0.75;",
      "echo_zoom = echo_zoom + min(max(0.75,50*pfdx_r),1);",
      "",
      "echo_orient = echo_orient + 16*pfdy_r;",
      "",
