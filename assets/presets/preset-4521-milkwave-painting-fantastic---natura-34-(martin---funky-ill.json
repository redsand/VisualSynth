  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nscreen3 = vec3 ((vUv-.5)*uAspect.xy,1);//wirkt wie zoom\nneu = GetBlur1(vUv)/4;\n\n  pq  = project (sxy, vec3 (q10,q11,q12));\n  pq2 = project (sxz, vec3 (q10,q11,q12));\n  mask1 = (pq.x>=0)* (pq.x <=width);\n  mask2 = (pq2.x>=0)*(pq2.x <= depth);\n  if (mask1) {neu = mix(neu,wall(pq),blend);}\n  if (mask2) {neu = mix(neu,wall(pq2),blend);}\n\n  pq  = project (-sxy, vec3 (q13,q14,q15));\n  pq2 = project (sxz, vec3 (q13,q14,q15));\n  mask1 = (pq.x>=0)* (pq.x <=width);\n  mask2 = (pq2.x>=0)*(pq2.x <= depth);\n  if (mask1) {neu = mix(neu,wall(pq),blend);}\n  if (mask2) {neu = mix(neu,wall(pq2),blend);}\n\n  pq  = project (sxy, vec3 (q16,q17,q18));\n  pq2 = project (sxz, vec3 (q16,q17,q18));\n  mask1 = (pq.x>=0)* (pq.x <=width) * (dist2 >=0);\n  mask2 = (pq2.x>=0)*(pq2.x <= depth)* (dist2 >=0);\n  if (mask1) {neu = wall(pq);}\n  if (mask2) {neu = wall(pq2);}\n  musr = (q29%2)/length(abs(fract(pq2/2)-.5))*mask2;\n  musr += (q29%2)/length(abs(fract(pq/2)-.5))*mask1;\n\n  pq  = project (-sxy, vec3 (q19,q20,q21));\n  pq2 = project (sxz, vec3 (q19,q20,q21));\n  mask1 = (pq.x>=0)* (pq.x <=width) * (dist2 <=0);\n  mask2 = (pq2.x>=0)*(pq2.x <= depth)* (dist2 <=0);\n  if (mask1) {neu = wall(pq);}\n  if (mask2) {neu = wall(pq2);}\n  musl = ((q29+1)%2)/length(abs(fract(pq2/2)-.5))*mask2;\n  musl += ((q29+1)%2)/length(abs(fract(pq/2)-.5))*mask1;\n\nret = texture(sampler_main,vUv+neu/8)\n+neu*(1+roam_cos)*clamp01(audioLowSmooth*.04/length(vUv-.5))/2\n*(audioLowSmooth) + clamp01((musl*roam_sin+musr*roam_cos)/16)*audioMidSmooth;\n\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "dec_med = pow (0.8, 30/fps);",
      "dec_slow = pow (0.97, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, .2+avg+peak) * above (time, t0+.2);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %32;",
      "index2 = (index2 + is_beat*bnot(index))%2;",
      "index2_ = index2_*dec_med + (1-dec_med)*index2;",
      "",
      "q29 = index;",
      "q27 = is_beat * bnot(index%8);",
      "k1 =  is_beat*bnot(index%8);",
      "p1 =  k1*(p1+1) + (1-k1)*p1;",
      "p2 = dec_slow * p2+ (1-dec_slow)*p1;",
      "rott = rott*dec_slow + (1-dec_slow)*p2 * 3.1416/4;",
      "",
      "//Kamerapos.",
      "speed = speed*dec_slow + (1-dec_slow)*.03*(index+beat*18)*",
      "below(sin(time/13),.95);",
      "",
      "trel = trel + 1/fps*speed;",
      "",
      "xang = -.6*sin(rott) ;//###",
      "xang = if (below(index,23),xang,.5*cos(index)-.3);",
      "",
      "yang = .4*sin(trel)*cos(time*.2);",
      "yang =  if(above(index,8),yang,.6*sin(index));",
      "",
      "zang = zang *dec_slow + (1-dec_slow)*index2_*6.2832;",
      "",
      "zdist = 45; xdist =  4+ 3*sin(time/11);",
      "pos_x = sin(time/3)*xdist*.8;",
      "pos_y = pos_y - xang/fps*60*speed;",
      "cz = zdist*.5;",
      "",
      "q30 = cos(zang); q31 = sin(zang);",
      "q1 = trel*8;q2 = yang;q3 = xang;",
      "q24 = cos(yang); q25=sin(yang);",
      "q32 = (trel-int(trel)); //Blend in",
      "",
      "ox = -xdist-pos_x; oy = -pos_y;",
      "oz = (trel-int(trel))*zdist-cz-zdist;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;oz = mz;",
      "q10=ox; q11 = oy; q12 = oz;",
      "",
      "ox = xdist-pos_x; oy = -pos_y;",
      "oz = (trel-int(trel))*zdist-cz-zdist;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;",
      "oz = mz;",
      "q13=ox; q14 = oy; q15 = oz;",
      "",
      "ox = -xdist-pos_x; oy = -pos_y;",
      "oz = (trel-int(trel))*zdist-cz;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;oz = mz;",
      "q16=ox; q17 = oy; q18 = oz;",
      "",
      "ox = xdist-pos_x; oy = -pos_y; oz = (trel-int(trel))*zdist-cz;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;oz = mz;",
      "q19=ox; q20 = oy; q21 = oz;",
      "",
      "//Vektor x nach rechts",
      "ox = 1; oy = 0; oz = 0;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;oz = mz;",
      "q4=ox; q5 = oy; q6 = oz;",
      "",
      "",
      "//Vektor z nach hinten",
      "ox = 0; oy = 0; oz = 1;",
      "mx = ox*cos(zang) - oy*sin(zang);",
      "my = ox*sin(zang) + oy*cos(zang);",
      "ox = mx;oy = my;",
      "mx = ox*cos(yang) + oz*sin(yang);",
      "mz = - ox*sin(yang) + oz*cos(yang);",
      "ox = mx;oz = mz;",
      "my = oy*cos(xang) - oz*sin(xang);",
      "mz = oy*sin(xang) + oz*cos(xang);",
      "oy = my;",
      "oz = mz;",
      "q7=ox; q8 = oy; q9 = oz;",
      "",
      "q28 = 3+2*sin(time/15);",
      "q22 = (.5+sin(time/17))*.02;",
      "",
      "warp = 0;",
      "wave_a = 0;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "q2 = 1;",
      "",
      "q1=1;",
      "vol = vol + ((alt + bass + mid)/3-vol)*tic*1;",
      "q5 = vol*vol*vol*2;",
      "",
      "",
      "q8 = sin(time)*.5;",
      "q9 = sin(time*.75)*.5;",
      "",
      "sw = abs(sw - beat);",
      "an = an + tic*.5*(1-2*sw);",
      "",
      "",
      "q7 = 1+(pow(q8,2) + pow(q9,2))*1;",
      "q10 = sin(an);",
      "q11 = cos(an);",
      "",
      "sp = sp + tic*vol*vol*.5;",
      "",
      "q12 = sp;",
      "",
      "monitor = q12;",
