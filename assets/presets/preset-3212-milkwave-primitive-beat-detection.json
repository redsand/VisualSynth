    "perFrameCode": [
      "bass_pulse=band(above(bass,1),1-bass_block);",
      "bass_block=above(bass,1);",
      "treb_pulse=band(above(treb,1),1-treb_block);",
      "treb_reduce=if(treb_pulse,time,treb_lowered);",
      "treb_block=above(treb,1);",
      "treb_pulse=band(treb_pulse,above(time+.5,treb_reduce));",
      "mid_pulse=band(above(mid,1),1-mid_block);",
      "mid_block=above(mid,1);",
      "",
      "sfx=if(above(sfx,0),if(above(sfx,13),0,sfx+1),if(band(above(",
      "bass_pulse+mid_pulse+treb_pulse+.1*bass+.1*treb,3.4),",
      "above(time,scn+4.72)),1,0));",
      "scn=if(equal(sfx,1),time,scn);",
      "q1=equal(sfx,0);",
      "q2=sfx;",
      "",
      "zoom=1-q1*(.15*bass_pulse+",
      ".3*equal(bass_pulse+mid_pulse+treb_pulse,3));",
      "rot=q1*mid_pulse*(int(rand(11))-5);",
      "",
      "dx=q1*.02*treb_pulse*(int(rand(11))-5);",
      "dy=q1*.02*treb_pulse*(int(rand(11))-5);",
      "",
      "ib_a=q1;",
      "ib_r=.5+.3*sin(1.13*time)+.2*sin(3.57*time);",
      "ib_g=.5+.3*sin(1.14*time)+.2*sin(3.59*time);",
      "ib_b=.5+.3*sin(1.15*time)+.2*sin(3.61*time);",
      "wave_r=ib_r;",
      "wave_g=ib_g;",
      "wabe_b=ib_b;",
      "",
      "wave_cycle=(time+.5)%4;",
      "time_frag=.001*((time*1000)%1000);",
      "",
      "wave_x=if(wave_cycle%2,-.4*wave_cycle+1.3,",
      "if(equal(wave_cycle,2),.9-.8*time_frag,.1+.8*time_frag));",
      "wave_y=if((wave_cycle+1)%2,if(wave_cycle,.1,.9),",
      "if(equal(wave_cycle,1),.9-.8*time_frag,.1+.8*time_frag));",
      "echo_alpha=.5+.2*sin(time);"
    ],
