    "perFrameCode": [
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "q9 = .01*(abs(sin(vol_mean)));",
      "beat = if(above(vol_now,1.1*vol_mean),1,0);",
      "slowtime = slowtime+beat*time;",
      "q4 = sin(slowtime);",
      "climb = climb + q9 + abs(q4);",
      "q5 = climb;",
      "firstr = 0.57*( 0.60*sin(0.374*climb) + 0.40*sin(0.294*climb) );",
      "firstg = 0.57*( 0.60*sin(0.393*climb) + 0.40*sin(0.223*climb) );",
      "firsgb = 0.57*( 0.60*sin(0.412*climb) + 0.40*sin(0.364*climb) );",
      "q1 = firstr;",
      "q2 = firstg;",
      "q3 = firstb;",
      "myr = cos(slowtime);",
      "myg = cos(slowtime)*sign(cos(slowtime));",
      "myb = sin(time) ;",
      "redneg = if(below(myr,0),1,0);",
      "greenneg = if(below(myg,0),1,0);",
      "blueneg = if(below(myb,0),1,0);",
      "newred = if(redneg,if(bor(greenneg , blueneg),abs(myr),1+myr),myr);",
      "newgreen = if(greenneg,if(equal(greenneg + blueneg,2),abs(myg),1+myg),myg);",
      "newblue = if(blueneg,-1*myb,myb);",
      "finalred = if(above(finalred+finalgreen+finalblue,1),abs(finalred-.5),finalred);",
      "finalgreen = if(above(finalred+finalgreen+finalblue,1),abs(finalgreen-.5),finalgreen);",
      "finalblue = if(above(finalred+finalgreen+finalblue,1),abs(finalblue-.5),finalblue);",
      "q6 = finalred;",
      "q7 = finalgreen;",
      "q8 = finalbllue;",
      "monitor = q4;"
    ],
