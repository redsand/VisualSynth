  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "",
      "db=(bass-lbass)*fps;",
      "lbass=bass;",
      "avgdb=avgdb*.99+abs(db)*.01;",
      "",
      "//beatdection",
      "rawbeatb=above(abs(db),avgdb*2);",
      "beatb=rawbeatb*above(time-lbbtime,avgbbeatrate*.5);",
      "beatb2=beatb*above(abs(db),avgdb*3);",
      "beatbhard=beatb*(abs(db)-avgdb*5);",
      "//beatrate calc",
      "",
      "",
      "avgbbeatrate=beatb*(avgbbeatrate*.9+(time-lbbtime)*.1)+(1-beatb)*(avgbbeatrate+(3-avgbbeatrate)*.000001);",
      "lbbtime2=time*beatb2+(1-beatb2)*lbbtime2;",
      "lbbtime=time*beatb+(1-beatb)*lbbtime;",
      "",
      "ph=(time-lbbtime2)*(60/avgbbeatrate)*const;",
      "phase=max(min( ph, 1 ),0);",
      "const=const*(1-beatb2)+beatb2*( const+ (.0001*bool) );",
      "",
      "",
      "bool=below(phase,.98)*(.99-ph)-above(phase,.98)*(ph*.5);",
      "",
      "bc=bc+beatb;",
      "",
      "vol=(rawbeatb*abs(db)*.001);",
      "avgvol=avgvol*.999+vol*.01;",
      "",
      "mtime=mtime+(min(treb_att*.01,.25)-beatbhard*.01)*(1/fps);",
      "mtime2=mtime2+(min(avgdb*.01,.25)+beatbhard*.01)*(1/fps);",
      "wrap=0;",
      "warp=0;",
      "zoom=1;",
      "",
      "",
      "//gamma=1+abs(db*.01)+beatbhard;",
      "//invert=above(db,avgdb*4)*beatb;",
      "",
      "",
      "q1=rawbeatb;",
      "q2=beatbhard;",
      "q3=60/avgbbeatrate;",
      "q4=phase;",
      "q5=avgdb;",
      "q6=.01+sin((mtime-mtime2)*1)*.0001;",
      "q6=.01+.001*above(q3,100)+.001*above(q3,175)+.001*above(q3,250)+.001*above(q3,325);",
      "",
      "decay=1;",
      "q7=mtime;",
      "q8=mtime2;",
      "",
      "",
      "decay=.86+rawbeatb*.14;",
      "",
      "dt=1/FPS;",
      "contvol=max(.4, (1-.6*dt)*contvol+.2*dt*(bass+mid+treb) );",
      "",
      "monitor=q3;"
    ],
