    "comp": null,
    "perFrameCode": [
      "",
      "vol = (bass + treb + mid) * (bass_att + treb_att + mid_att);",
      "thump = if(above(thump_count, 1),0 , if(above(vol,3),1, 0));",
      "thump_count = if(equal(q1,1),0, (1 - 1 * sin(time + .25))); //My attempt at telling if \"thump\" just happened.",
      "no_thump = if(below(bass,2.5),1, 0); //When there is no \"thump\"",
      "re_thump = if(above(q2, 1), 1, 0); //If there was just a thump, this is 1",
      "",
      "wave_r = .2 + .6 * sin (thump);",
      "wave_b = .7 - .2 * sin (no_thump);",
      "wave_g = .5 + .3 * sin (re_thump);",
      "",
      "q1 = thump;",
      "q2 = no_thump;",
      "q3 = re_thump;",
      "q4 = if(equal(q3,0), .05 * time, 1 * time);",
      "q5 = vol;",
      "",
      "",
      "wave_usedots = thump;",
      "wave_thick = thump;",
      "wave_additive = thump;",
      "wave_brighten = thump;",
      "wrap = nothump;",
      "",
      "",
      "//Named after the tool song I was listening to. Check out Aenema to hear it.",
      "monitor = thump_count;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "zoom_1 = zoom + .1 * sin (ang * 3.14);",
      "zoom_2 = zoom -.1 * sin (rad * 3.14);",
      "rot_effect = if(equal(q2,0), rad * 3.14 + ang, rad * 3.14 - sin(rad/time));",
      "zoom = if(equal(q1,1), zoom_1, zoom_2) + .005;",
      "rot_effect2 = if(above(q2,1), rot - .004 * sin (rad * .24), rot - .04 * sin (rad * - .04)) + .005 * sin (rot_effect) + (q4 + (rad * 3.14)) + rad;",
      "dx = if(equal(q1,0),dx + 1 * (q1 * .05), dx + .02 * sin(rad * q3)) * (tan(x * rad));",
      "dy = if(equal(q1,1),dx + 1 * (q3 * .05), dy - .02 * sin(rad * q3)) * (tan(y * rad));",
      "rot = if(above(q5, 6), root_effect2, -rot_effect2);",
      "cx = cx - .005 * sin (thump * time/x*rad);",
      "cy = cy + .005 * sin (thump * time/y*rad);"
