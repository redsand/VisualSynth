    "perFrameCode": [
      "decay = 0;",
      "xx1 = xx1*0.9 + (bass)*0.01;",
      "xx2 = xx2*0.9 + (treb)*0.01;",
      "yy1 = yy1*0.94 + (treb+bass)*0.0075;",
      "",
      "x1 = 0.5 + (xx1-xx2)*3;",
      "y1 = 1 - yy1*0.75;",
      "",
      "spring = 20;",
      "grav = .65-0.25*yy1;",
      "resist = 0.03;",
      "bounce = 1;//0.5;",
      "dt = 0.0005;",
      "",
      "spx2 = (x1+x3-2*x2)*spring;",
      "spy2 = (y1+y3-2*y2)*spring;",
      "spx3 = (x2+x4-2*x3)*spring;",
      "spy3 = (y2+y4-2*y3)*spring;",
      "spx4 = (x3-x4)*spring;",
      "spy4 = (y3-y4)*spring;",
      "",
      "vx2 = vx2*(1-resist) + dt*(spx2);",
      "vy2 = vy2*(1-resist) + dt*(spy2-grav);",
      "vx3 = vx3*(1-resist) + dt*(spx3);",
      "vy3 = vy3*(1-resist) + dt*(spy3-grav*1.5);",
      "vx4 = vx4*(1-resist) + dt*(spx4);",
      "vy4 = vy4*(1-resist) + dt*(spy4-grav*4);",
      "",
      "x2 = x2 + vx2;",
      "y2 = y2 + vy2;",
      "x3 = x3 + vx3;",
      "y3 = y3 + vy3;",
      "x4 = x4 + vx4;",
      "y4 = y4 + vy4;",
      "",
      "vx2 = if(above(x2,0),vx2,abs(vx2)*bounce);",
      "vx2 = if(below(x2,1),vx2,-abs(vx2)*bounce);",
      "vx3 = if(above(x3,0),vx3,abs(vx3)*bounce);",
      "vx3 = if(below(x3,1),vx3,-abs(vx3)*bounce);",
      "vx4 = if(above(x4,0),vx4,abs(vx4)*bounce);",
      "vx4 = if(below(x4,1),vx4,-abs(vx4)*bounce);",
      "",
      "vy2 = if(above(y2,0),vy2,abs(vy2)*bounce);",
      "vy2 = if(below(y2,1),vy2,-abs(vy2)*bounce);",
      "vy3 = if(above(y3,0),vy3,abs(vy3)*bounce);",
      "vy3 = if(below(y3,1),vy3,-abs(vy3)*bounce);",
      "vy4 = if(above(y4,0),vy4,abs(vy4)*bounce);",
      "vy4 = if(below(y4,1),vy4,-abs(vy4)*bounce);",
      "",
      "",
      "q1 = x1;",
      "q2 = x2;",
      "q3 = x3;",
      "q4 = x4;",
      "",
      "q5 = y1;",
      "q6 = y2;",
      "q7 = y3;",
      "q8 = y4;",
      "q2 = sin(+atan2(x4-x3,y4-y3) - asin(1)*2)*0.2;",
