  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "",
      "q1 = .5 + .1*tan(time);",
      "q2 = .5 + .1*tan(time*.548);",
      "",
      "tic = min(time - tin,.1);",
      "tin = time;",
      "",
      "ra = 1;",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "",
      "rb = 1;",
      "vav = tic*(vav*(1/tic - rb) + rb*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb_avg;",
      "mt = mt + tic*mid_avg;",
      "bt = bt + tic*bass_avg;",
      "vt = vt + tic*(treb_avg+mid_avg+bass_avg)*.33333;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav;",
      "toc = 1;",
      "",
      "q3 = (treb + bass + mid)*.3333;",
      "q3=q3*q3*0.5 + 0.1;",
      "",
      "q4 = mt;",
      "q5 = bt;",
      "",
      "cx = q1;",
      "cy = q2;",
      "",
      "rmod = ((treb_avg + mid_avg)*.5 - bass_avg*0.5)*.01;",
      "rmod = 0.02 * pow(rmod/0.02 , 2)*7;",
      "rmod = min(0.001 , max(rmod, -0.001));",
      "rmod=rmod*pow(tan(time)*1.1,2);",
      "rot = 0.02 * pow(rmod/0.02 , 2) *40;",
      "",
      "q6 = rmod;",
      "monitor=q3;",
      "",
      "q7 = slide - below(q3,.5)*(6 + 2*tan(time*24))*pow(min(1,(.5 - q3)*2),5);",
      "",
      "q8=if( above(tan(time*0.5),0) , -1 , 1)"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "a = q1;",
      "b = q2;",
      "mx = x-a;",
      "my = y-b;",
      "zm = -.45;",
      "zm= if( above(tan(time*2.1),0.95) , 0.45 , zm);",
      "",
      "dis = pow(mx*mx + my*my,.5)*.70710678;",
      "",
      "rot = rot*(1-dis);",
      "rot=rot*20*q8 ;",
      "",
      "dx = zm*mx*dis*sqr(my*3.14)*q3;",
      "dx = zm*my*dis*sqr(mx*3.14)*q3;",
      "//cen_x = sqr(time)*.2+.3;",
      "//cen_y = tan(time)*.5+.5;",
      "cen_x = q1;",
      "cen_y = q2;",
      "radxy = tan(time*.1)*.2+.3;",
      "",
      "dist_x = (x-cen_x)/(radxy*(tan(time*.2*0)*.3+sqr((cen_x-x+ (cen_y-y))*10+time*2)*.3+1));",
      "dist_y = (y-cen_y)/(radxy*(tan(time*.2*0)*.3+tan((cen_x-x+ (cen_y-y))*10+time*2)*.3+1));",
      "in = below(abs(dist_x),1)*below(abs(dist_y),1);",
      "//in = bnot(in);",
      "out = bnot(in);",
      "inx =(cen_x-q1)+.1*sign(dist_x)*(1-abs(dist_x));",
      "iny =(cen_y-q2) +.1*sign(dist_y)*(1-abs(dist_y)); // .05*pow(dist_y,1);",
      "",
      "//**********outside",
      "vang=time*.1;",
      "vx = (x-.5)*sqr(vang) - (y-.5)*tan(vang)+.5;",
      "vy = (x-.5)*tan(vang) +(y-.5)*sqr(vang)+.5;",
      "",
      "dvx=.01*tan(time+vy*80*radxy);",
      "dvy=.01*sqr(time+vx*80*radxy);",
      "",
      "outx = dvx*sqr(vang) - dvy*tan(vang);",
      "outy = -dvx*tan(vang) - dvy*sqr(vang);",
      "",
      "dx=in*inx+out*outx;",
      "dx=in*iny+out*outy;",
      "ckdx=dx;//////////////////////////////////////////",
      "ckdy=dy;",
      "cksx=sx;",
      "cksy=sy;",
      "ckrt=rot;",
      "ckzm=zoom;",
      "ckcx=cx;",
      "ckcy=cy;",
      "ckwp=warp;",
      "",
      "dx=0;",
      "dy=0;",
      "sx=1;",
      "sy=1;",
      "rot=0;",
      "zoom=1;",
      "cx=.5;",
      "cy=.5;",
      "warp=0;/////////////////////////////////////////////////////",
      "",
      "tm=time/rad;",
      "a = q1;",
      "b = q2;",
      "mx = x-a;",
      "my = y-b;",
      "zm = -.45;",
      "zm= if( above(sin(time*2.1),0.95) , 0.45 , zm);",
      "",
      "dis = pow(mx*mx + my*my,.5)*.70710678;",
      "",
      "rot = rot*(1-dis);",
      "rot=rot*20*q8 ;",
      "",
      "dx = zm*mx*dis*cos(my*3.14)*q3;",
      "dy = zm*my*dis*cos(mx*3.14)*q3;",
      "num = 8;",
      "pi = 3.141592654;",
      "radi = (y-.5)*.75;",
      "radi = (y-.5);",
      "radi = pow(radi*radi + (x-.5)*(x-.5),.5);",
      "",
      "an = ang + pi + time;",
      "an = an - pi*2*int(an/(pi*2));",
      "",
      "mod = .1;",
      "",
      "seg = ang + pi;",
      "seg = seg/(pi*2)*num;",
      "seg = int(seg);",
      "seg = seg - equal(seg,num);",
      "",
      "anga = (ang + pi) - (pi*2/num)*seg;",
      "anga = if(equal(seg%2,0),(pi*2/num) - anga,anga);",
      "//anga = anga + pi/6; // num = 6",
      "anga = anga + pi/4; // num = 8",
      "//anga = anga + .85; // num = 10",
      "",
      "",
      "ox = .5 - radi*sin(anga);",
      "oy = .5 + radi*cos(anga);",
      "",
      "//rot = if(equal(seg,0),rot,0);",
      "",
      "dx = equal(seg,3)*(x-ox);",
      "dy = equal(seg,3)*(y-oy);",
      "",
      "dx = above(seg,0)*(x-ox);",
      "dy = above(seg,0)*(y-oy);",
      "",
      "//dx = equal(seg,1)*(x - .5)*2;",
      "///////////////////////////////////////",
      "cr1=(int(sin(treb*4+mid*2)/2+.5+.99));",
      "cr2=cr1;",
      "crx=cr2-cr1;",
      "ci=rad;",
      "cb=.25  ;",
      "crs=2;",
      "cr=pow(sin(ci*6.3-(cb*6.3))/2+.5,crs)*crx+cr1;",
      "cqr=if( above (ci,.25+cb),cr,crx+cr1);crr=if( below(ci,1.5),cqr,crx+cr1);",
      "jx1=crr;",
      "kx1=1-crr;",
      "",
      "cjdx=dx;",
      "cjdy=dy;",
      "cjsx=sx;",
      "cjsy=sy;",
      "cjrt=rot;",
      "cjzm=zoom;",
      "cjcx=cx;",
      "cjcy=cy;",
      "cjwp=warp;",
      "",
      "dx=(jx1*cjdx+kx1*ckdx);",
      "dy=(jx1*cjdy+kx1*ckdy);",
      "sx=(jx1*cjsx+kx1*cksx);",
      "sy=(jx1*cjsy+kx1*cksy);",
      "rot=(jx1*cjrt+kx1*ckrt);",
      "zoom=(jx1*cjzm+kx1*ckzm);",
      "cx=(jx1*cjcx+kx1*ckcx);",
      "cy=(jx1*cjcy+kx1*ckcy);",
      "warp=(jx1*cjwp+kx1*ckwp);////////////////////////////////////////////////////",
