    "perFrameCode": [
      "//Title - Back in the game",
      "//Author - idiot <ryan@vague.us>",
      "//Date - January 12, 2005",
      "//Made while listening too:",
      "//A Perfect Circle - Thirteenth Step",
      "//Placebo - Once More With Feeling",
      "",
      "//Bastard Warp",
      "warp = 0;",
      "",
      "//Beat Reaction (Borrowed From Geiss preset)",
      "bass_thresh = above(bass_att,bass_thresh)*2 +    (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "treb_thresh=above(treb_att,treb_thresh)*2+",
      "(1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*0.96+1.3);",
      "mid_thresh=above(mid_att,mid_thresh)*2+",
      "(1-above(mid_mid_att,mid_thresh))*((mid_thresh-1.3)*0.96+1.3);",
      "q1 = bass_thresh; q2 = treb_thresh; q3 = mid_thresh;",
      "",
      "//Motion Vectors",
      "mv_l = mv_l + 10 * sin(q1 * q2);",
      "mv_dx = mv_dx + 1 * sin(time / q1);",
      "mv_dy = mv_dy - 1 * sin(time / q2);",
      "",
      "",
      "//Vector Colours",
      "mv_r = 0 + .5 * sin(q1);",
      "mv_b = 1 - .5 * sin(q2);",
      "mv_g = .5 + .5 * sin(q2 * q1);",
      "",
      "//Gamma",
      "gamma = time & (q1 * q2);",
      ""
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "zoom = zoom + .1 * sin ((if(above(q1,q2),rad,ang)) * 3.14 / (q1 * q2) * (time * .01));",
      "rot = (zoom * ang/rad) * sin(time & ((q1 * .01) * (q2 * .01)));",
      "",
      "",
      ""
