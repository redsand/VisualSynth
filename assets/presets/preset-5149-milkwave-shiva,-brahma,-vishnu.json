      "//monitor=decay;",
      "",
      "vol=(bass+mid+treb)*0.33; vol=vol*vol;",
      "vol2=(bass_att+mid_att+treb_att)*0.33; vol2=vol2*vol2;",
      "",
      "volm=max(vol,volm); volm2=max(vol2,volm2);",
      "beat=above(vol2,vol);",
      "",
      "bhit=above(sqr(bass),sqr(bass_att));mhit=above(sqr(mid),sqr(mid_att));thit=above(sqr(treb),sqr(treb_att));",
      "",
      "",
      "tvar=(((time+vol2-vol)*2232)+bass_att+mid_att-treb_att)*.00005;",
