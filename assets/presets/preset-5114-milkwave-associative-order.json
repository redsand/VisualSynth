      "oldys = if(equal(colorcounter%2,1),if(equal(counter1,.95),rys,oldys),if(equal(counter2,.95),rys,oldys));",
      "rx = if(equal(cdelay1,1),(int(rand(100))*.01),rx);",
      "ry = if(equal(cdelay1,1),(int(rand(100))*.01),ry);",
      "rxs = if(equal(cdelay1,1),(int(rand(100))*.01),rxs);",
      "rys = if(equal(cdelay1,1),(int(rand(100))*.01),rys);",
      "xm = if(equal(cdelay1,1),(rx - oldx)*.05,xm);",
      "ym = if(equal(cdelay1,1),(ry - oldy)*.05,ym);",
      "xms = if(equal(cdelay1,1),(rxs - oldxs)*.05,xms);",
      "yms = if(equal(cdelay1,1),(rys - oldys)*.05,yms);",
      "monitor = colorcounter;",
