      "dx = if(above(dx * rot , x - q1) , q2 * x , q2 + y);",
      "zoom=if(below(zoom,0.01), 0.01, zoom);",
      "zoom=if(above(zoom,100), 100, zoom);",
      "rot=if(below(rot,-1.0), -1.0, rot);",
      "rot=if(above(rot,1.0), 1.0, rot);",
      "dx=if(below(dx,-1), -1, dx);",
