      "wave_g = treb*.4;",
      "",
      "wave_b = mid*.4;",
      "wave_a = bass;",
      "wave_mystery = -.5+bass*.1;",
      "wave_x = if(above(frame%2,0), if(equal(colorcounter%2,1),rx-(abs(counter1-1)*(xm*20)),rx-(abs(counter2-1)*(xm*20))), if(equal(colorcounter%2,1),rxs-(abs(counter1-1)*(xms*20)),rxs-(abs(counter2-1)*(xms*20))));",
      "wave_y = if(above(frame%2,0), if(equal(colorcounter%2,1),ry-(abs(counter1-1)*(ym*20)),ry-(abs(counter2-1)*(ym*20))), if(equal(colorcounter%2,1),rys-(abs(counter1-1)*(yms*20)),rys-(abs(counter2-1)*(yms*20))));",
      "zoom = .995;",
      "slowtime = slowtime+beat*time;",
      "ying = if(below(ying,1),1,ying);",
      "ying = if (beat,ying + bnot((time*10)%3),ying);",
      "yin = ying%2;",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "beat = if(above(vol_now,1.5*vol_mean),1,0);",
      "beatcount = if(bnot(time%5000),0,beatcount);",
      "beatcount = beatcount +.05*beat;",
      "yang = bnot(beatcount%2);",
      "ib_r = 0;",
      "ib_g = pow(abs(sign(sin(slowtime))),2)*sin(slowtime);",
      "ib_b= cos(slowtime)*sign(cos(slowtime))*pow(abs(sign(sin(slowtime))),2);",
      "mv_g = sin(slowtime)*(sign(sin(slowtime))-1)*(sign(sin(slowtime)));",
      "mv_b = -1*abs(cos(slowtime))+1;",
      "mv_r = .8;",
      "wave_b = if(above(ib_b,0),ib_b,mv_b);",
      "wave_g = if(above(ib_g,0),ib_g,mv_g);",
      "q1 = if(yin,sin(slowtime),q1);",
      "wave_r = .8*q1;",
      "q2 = if(yin,.01*cos(slowtime),0);",
      "q3 = sin(slowtime);",
      "dx = if(yang,q1,dx);",
      "dy = if(yang,q2,dy);",
      "q3 = if(yang,0,q1);",
      "q5 = if(bnot(yin),abs(cos(time)),dx);",
      "sy = bnot(q3 * sin(time));",
      "dx=if(below(dx,-1), -1, dx);",
      "dx=if(above(dx,1.0), 1.0, dx);",
      "dy=if(below(dy,-1), -1, dy);",
      "dy=if(above(dy,1.0), 1.0, dy);",
      "sy=if(below(sy,0.01), 0.01, sy);",
      "sy=if(above(sy,100.0), 100.0, sy);",
      "ib_a = sin(time);",
      "ob_a = cos(time);"
