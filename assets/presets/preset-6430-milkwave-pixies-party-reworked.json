      "    gmegabuf(self+2) += gmegabuf(self+5)*dt;",
      "    gmegabuf(self+3) *= brake;",
      "    gmegabuf(self+4) *= brake;",
      "    gmegabuf(self+5) *= brake;",
      "    gmegabuf(self+3) += sin(gmegabuf(self+1)*444)*dt*.04;",
      "    gmegabuf(self+4) += sin(gmegabuf(self+2)*444)*dt*.04;",
      "    gmegabuf(self+5) += sin(gmegabuf(self+0)*444)*dt*.04;",
      "",
      "    gmegabuf(self+4) += g0*dt; //Gravitation",
      "  ,t_free += 1); //otherwise",
      "  gmegabuf(self+12) = age;",
      "  n += 1;",
      ");",
      "",
      "//SPARK and HEAD COORD for use in comp shader",
      "",
      "ranpt = if (rand(10)/7<vol_att,((head_ptr+obj_num-int(rand(obj_num/2)))%obj_num)*obj_size, ranpt);",
      "point = ranpt;",
      "x0_ = gmegabuf(point)-reg07; y0_ = gmegabuf(point+1)-reg08; z0_ = gmegabuf(point+2)-reg09;",
      "x1 = x0_*reg30 + y0_*reg31 + z0_*reg32;",
      "y1 = x0_*reg33 + y0_*reg34 + z0_*reg35;",
      "z1 = x0_*reg36 + y0_*reg37 + z0_*reg38;",
      "q11 = .5 + x1/z1*fac;",
      "q12 = .5 + y1/z1*fac;",
      "age = gmegabuf(point+12);",
      "q13 = if (z1>0,1/z1,0) * (age > 0)*(1-age/max_age) * sqrt(treb)*.0008;",
      "q13 = max(0,q13*(.5+flim));",
      "",
      "x0_ = x0-reg07; y0_ = y0-reg08; z0_ = z0-reg09;",
      "x1 = x0_*reg30 + y0_*reg31 + z0_*reg32;",
      "y1 = x0_*reg33 + y0_*reg34 + z0_*reg35;",
      "z1 = x0_*reg36 + y0_*reg37 + z0_*reg38;",
      "q14 = .5 + x1/z1*fac;",
      "q15 = .5 + y1/z1*fac;",
      "q16 = if (z1>0, 1/z1* q29/3+20 + 40*vol_att,0) ;",
      "q16 = max(0,q16/4) ;",
      "",
      "",
      "//FOLLOW WITH CAMERA",
      "reg07 = xcam; reg08 = ycam; reg09 = zcam;",
      "dxcam = (x0-xcam)*dt*CamSpeed; dycam = (y0-ycam-.0)*dt*CamSpeed; dzcam = (z0-zcam-CamDist)*dt*CamSpeed;",
      "xcam += dxcam; ycam += dycam; zcam += dzcam;",
      "",
      "//ROTATE VIEPOINT",
      "x1 = (x0-XCam)*reg30 + (y0-yCam) *reg31 + (z0-zCam)*reg32;",
      "y1 = (x0-XCam)*reg33 + (y0-YCam) *reg34 + (z0-zCam)*reg35;",
      "dist = sqrt(pow(x0-xcam,2) + pow(y0-ycam,2) + pow(z0-zcam,2));",
      "k1 = dt/max(dist,.02)*CamLock;",
      "v1 =  -k1*(y1); v2 = k1*(x1); v3 = -reg31*k1*HLock;",
      "",
      "c1 = cos(v1); c2 = cos(v2); c3 = cos(v3);",
      "s1 = sin(v1); s2 = sin(v2); s3 = sin(v3);",
      "reg40 = c2*c3; reg41 = c2*s3; reg42 = -s2;",
      "reg43 = s1*s2*c3 - c1*s3; reg44 = s1*s2*s3 + c1*c3; reg45 = s1*c2;",
      "reg46 = c1*s2*c3 + s1*s3; reg47 = c1*s2*s3 - s1*c3; reg48 = c1*c2;",
      "",
      "q20 = reg40*reg30 + reg41*reg33 + reg42*reg36;",
      "q21 = reg40*reg31 + reg41*reg34 + reg42*reg37;",
      "q22 = reg40*reg32 + reg41*reg35 + reg42*reg38;",
      "q23 = reg43*reg30 + reg44*reg33 + reg45*reg36;",
      "q24 = reg43*reg31 + reg44*reg34 + reg45*reg37;",
      "q25 = reg43*reg32 + reg44*reg35 + reg45*reg38;",
      "q26 = reg46*reg30 + reg47*reg33 + reg48*reg36;",
      "q27 = reg46*reg31 + reg47*reg34 + reg48*reg37;",
      "q28 = reg46*reg32 + reg47*reg35 + reg48*reg38;",
      "reg30 =q20; reg31 =q21; reg32 =q22;",
      "reg33 =q23; reg34 =q24; reg35 =q25;",
      "reg36 =q26; reg37 =q27; reg38 =q28;",
      "",
      "//Fake altitude",
      "q10 = (1.3-ycam);",
      "",
      "//TEXTURE GND MOVEMENT",
      "q18 = zcam*4;",
      "q19 = -xcam*4;",
      "",
      "//CLOUDS MOVEMENT",
      "crot = crot + v3;",
      "cfwd = cfwd + (dxcam*reg36 + dycam*reg37 + dzcam*reg38);",
      "",
      "q1 = cos(crot);q2 = sin(crot);",
      "cmovx += -v1 * q1 + v2 * q2;",
      "cmovy +=  v1 * q2 + v2 * q1;",
      "q5 = cmovx*.1;",
      "q6 = cmovy*.1;",
      "q7 = cfwd*8;",
      "",
      "q30 = dt2;",
      "q31 = aspectx;",
      "q32 = aspecty;",
      "",
      "q17 = int(colr*10) + int(colg*10)*10 + int(colb*10)*100;",
      "dx = -v2*.5; dy = v1*.5;",
      "rot = v3;",
      "zoom = 1+(dxcam*reg36 + dycam*reg37 + dzcam*reg38);",
      "",
      "start = max(0,start-dt2);",
      "q3 = start;",
      "if (ltest > 2000, fail = 1, 0);",
      "monitor = q30;;",
      "",
      "",
      "//frei: q4, q8, q9"
    ],
    "perFrameInitCode": [
      "//The camera tries to follow the head of the firework and look into its direction",
      "//Camera speed and rotational speed is limited, camera lags behind",
      "//Camera angle is forced back into horizontal position",
      "",
      "//-------------- BEGIN MAIN PARAMS ---------------",
      "//SPEEDS",
      "gSpeed = .65;   //global speed, affects all other speeds incl. particle lifetimes",
      "hSpeed = .03;  //firework head speed",
      "pSpeed = .06;   //speed of primary particles",
      "tSpeed = hspeed*3.5;  //speed of tail particles",
      "",
      "//CAMERA",
      "CamDist  = .03; //distance camera tries to stay behind firework",
      "CamSpeed = .27;  //camera follower speed",
      "CamLock = 6;    //how fast does camera angle lock on firework",
