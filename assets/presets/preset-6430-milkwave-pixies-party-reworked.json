    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n//vUv = 0.5 + (1.0 - abs( fract( vUv * 0.5 ) * 2 - 1.0 )-.5); // Eo.S. mirror code\n\nret = mix(GetPixel(vUv), GetBlur1(vUv),0.2);\nvUv = (vUv+vUvOriginal)/2;\nret += mix(GetPixel(vUv), GetBlur1(vUv),0.2);\n\nret = ret * 0.1;\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nuv1 = (vUv-.5)*uAspect.xy+.5;\nscreen = vec3 ((vUv-vec2(.5,.5+.0*pow((vUv.x-.5),2)))*uAspect.xy,.6);\n\n//CLOUDS\nuv2 = multiply(uv1*vec2(1,1),mat2(q1,q2,-q2,q1));\nfloat anz = 3.0; float t_rel = q7;\ncloud = 0;\nfor (int n=1;n<=anz;n++) {\n    z = 1-fract(1.0*n/anz-1.0*fract(-t_rel/anz));\n    inten =  (1-z)*z*2;\n    uv2 = z*uv2*.2 + vec2(q6,q5); //?\n    tmp = sat(lum(texture(sampler_noise_hq,uv2 +.01*noise4(uv2*4))-.6));\n    cloud = cloud + tmp*inten;}\nncloud = 1-cloud;\nfcol = texture(sampler_test,(uv2)*.2)*1.6;\ncloud *= (.2+col);\n\n//SKY AND GROUND\nrs = project (q10); vec3 rs0 = rs;\nvec3 noise = texture(sampler_noise_hq,rs.xy*.1);\ngnd = .3*(noise.z-.5)/rs.z;\n\nforest = 0;\nfor (int m = 1; m <= 2; m++)\n{ rs = project(q10+gnd);\n  rs.xy += .015*(texture(sampler_noise_hq,vec2(rs.xy/2+uTime*.01))-.5);; //wind\n  rs1 = rs;\n  rs1.xy = 0.5 + (1.0 - abs( fract( rs.xy * 0.5 ) * 2 - 1.0 )-.5); // Eo.S. mirror code\n  back = texture(sampler_test,rs1.xy);;\n  lprof =  back.g;\n  tmp =  1-(clamp01(1.8*lprof-.3*(2-m)));\n  forest += back * clamp01(lprof*1)*.15 ;\n  gnd += tmp/pow(rs.z,2)*.3;\n}\nforest *= 1-noise.x+lprof;\nforest += (.2/length(abs(noise.xy-.2-forest.g/2)))/rs.z * (.5+slow_roam_sin)/4 ;\nback = forest/pow(rs.z,1) * (rs.z>0) * (rs.z < hlim);\n\nfloat k1 = clamp01(1-10/abs(pow(rs.z,1.8)));\nback = mix(back,.12*lavcol(k1), k1) ;;\n\nret1 = mix(texture(sampler_main,vUv),2*GetBlur1(vUv),.0) *3 * ncloud;\nret2 = (GetBlur2(vUv) + GetBlur3(vUv))*2.0;\nret1 = mix(ret1, ret2, 2*cloud);;\nret = back*ncloud + ret1 + cloud/3;\n\n\nuv2 = uv1-vec2(q11,q12);\nfloat flash = q13/(length(uv2));\nflash *= flash/(abs(fract(q12*32+min(6,int(1+audioHighSmooth))*aTan2(uv2.x,uv2.y))-.5)+.14);\n\nuv2 = uv1-vec2(q14,q15);\nfloat head = pow(.0001/(length(uv2)),.8)*q16;\nret += pow(head+flash,ncloud)*col;\n\nret += GetBlur3((vUv-.5)/2+.5)/pow(rs.z,2)*(rs.z>0)*lprof*2;\n\n\n\n  fragColor = ret;\n}",
    "perFrameCode": [
