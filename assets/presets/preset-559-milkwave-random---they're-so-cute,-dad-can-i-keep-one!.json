      "cy = q1 * warp;",
      "cy = cy * rad;",
      "cx = a * bass_att;",
      "dy = warp + time;",
      "zoomexp = bass_att + a;",
      "rot = a * bass_att;",
      "rot = rot * y;",
      "zoomexp=if(below(zoomexp,0.01), 0.01, zoomexp);",
      "zoomexp=if(above(zoomexp,100.0), 100.0, zoomexp);",
      "rot=if(below(rot,-1.0), -1.0, rot);",
      "rot=if(above(rot,1.0), 1.0, rot);",
      "cx=if(below(cx,-1.0), -1.0, cx);",
      "cx=if(above(cx,2.0), 2.0, cx);",
      "cy=if(below(cy,-1.0), -1.0, cy);",
      "cy=if(above(cy,2.0), 2.0, cy);",
      "dy=if(below(dy,-1), -1, dy);",
