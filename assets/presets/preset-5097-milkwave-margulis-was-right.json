  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "vol_now =  .4 * bass + 0.1 * (bass_att+treb+mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean-0.5*(vol_mean-vol_now),0.1*(vol_mean*9 + vol_now));",
      "beat = if(above(vol_now,1.15*vol_mean),1,0);",
      "xamptarg = if(equal(frame%15,0),min(0.25*vol_now*bass_att,0.5),xamptarg);",
      "xamp = xamp + 0.5*(xamptarg-xamp);",
      "xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));",
      "xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xpos = xpos + 0.001*xspeed;",
      "yamptarg = if(equal(frame%15,0),min(0.15*vol_now*treb_att,0.5),yamptarg);",
      "yamp = yamp + 0.5*(yamptarg-yamp);",
      "ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));",
      "yspeed = yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "ypos = ypos + 0.001*yspeed;",
      "mode = if(beat, (mode + 1 + int(rand(3)))%4, mode);",
      "wave_x = xpos + 0.5;",
      "wave_y = ypos + 0.5;",
      "q1 = wave_x;",
      "q2 = 1-wave_y;",
      "sx = 0.8+0.2*wave_y;",
      "sy = 0.8+0.2*wave_x;",
      "cx = wave_x;",
      "cy = 1-wave_y;",
      "ob_r = 0.5 + 0.5*sin(time*1.13);",
      "ob_g = 0.5 + 0.5*sin(time*1.23);",
      "ob_b = 0.5 + 0.5*sin(time*1.33);",
      "ib_size = 0.01;",
      "ob_size = .8+sin(100*q1);",
      "ib_r = ib_r + 0.5*sin(time);",
      "ib_g = ib_g + 0.5*sin(time*1.5);",
      "ib_b = ib_b + 0.5*sin(time*2.5);",
      "wasbeat = if(beat,time+0.15,wasbeat);",
      "wave_b = wave_b + 0.3*(0.6*sin(0.825*time) + 0.4*sin(1.157*time)) + above(wasbeat,time);",
      "wave_r = ib_b;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "newx = x - q1;",
      "newy = y - q2;",
      "newrad = sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2;",
      "newzoom = pow(1.03, pow(0.01+sin(newrad*newrad), newrad*2-1));",
      "dx = (newx)*newzoom - newx;",
      "dy = (newy)*newzoom - newy;",
      "rot = -0.1*newrad*(0.5*rad+0.1);",
      "zoom = 0.8 + .2*q1;"
