  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "q8 =oldq8+ 0.0003*(pow(1+1.2*bass+0.4*bass_att+0.1*treb+0.1*treb_att+0.1*mid+0.1*mid_att,6)/fps);",
      "oldq8 = q8;",
      "ib_a =bass;",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "countertime = if(beat,time,countertime);",
      "counter =-1*pow(min((time-countertime-1.5),0),9);",
      "q7 = if(beat,0.001+0.0001*int(rand(40)),oldq7);",
      "oldq7=q7;",
      "q6 = if(beat,0.001+0.0001*int(rand(40)),oldq6);",
      "oldq6=q6;",
      "q5= if(beat,0.001+0.0001*int(rand(40)),oldq5);",
      "oldq5=q5;",
      "q4 = if(beat,0.001+0.0001*int(rand(40)),oldq4);",
      "oldq4=q4;",
      "Flag = If(beat,if(int(Rand(2))-1,1,0),oldFlag);",
      "oldflag = flag;",
      "Ratio = If(Beat,50+int(rand(100)),oldRatio);",
      "OldRatio = Ratio;",
      "q1 = if(beat,if(flag,ratio,0.75*ratio),oldq1);",
      "oldq1=q1;",
      "q2 = if(beat,if(flag,0.75*ratio,ratio),oldq2);",
      "//q2 = if(beat, rand(2)+1,oldq2);",
      "oldq2=q2;",
      "//monitor = if(rand(2)-1,-1,1);",
      "temp_b = cos(time)  + abs(cos(time));",
      "temp_g = abs(sin(time)) ;",
      "temp_r = (-1 * cos(time))  + abs(-1 * cos(time)) + 0.2 * (cos(sin(time))+(abs(cos(sin(time)))+cos(sin(time))));",
      "ob_r = 1 - if(above(temp_r,1),1,if(above(temp_r,0), abs(temp_r),0));",
      "ob_g = 1 - if(above(temp_g,1),1,if(above(temp_g,0), abs(temp_g),0));",
      "ob_b = 1 - if(above(temp_b,1),1,if(above(temp_b,0), abs(temp_b),0));",
      "q3 = .5+.5*sin(q8);",
      "monitor = q3;"
    ],
    "perFrameInitCode": [
      "decay=0.1;"
    ],
    "perPixelCode": [
      "dx=q4*sin((y-0.5)*q1)+q5*sin((y-0.5)*q2);",
      "dy=q6*cos((x-0.5)*q2)+q7*cos((x-0.5)*q1);",
      "rot = 0.1*(rad+cos((5+5*sin(q8*1.211)*x)-0.5) -sin(((5+5*sin(q8*0.973))*y)-dx));",
      "cx = if(above(dy,-.5),1-rot * 2,rot*q8);"
