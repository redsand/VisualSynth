    "comp": null,
    "perFrameCode": [
      "// -------------------------------- beat detection code ----------------------------------",
      "// - one time init",
      "sure=if(equal(sure,0),.75,sure);",
      "interval=if(equal(interval,0),.7,interval);",
      "avginterval=if(equal(avginterval,0),.7,avginterval);",
      "lockinterval=if(equal(lockinterval,0),.7,lockinterval );",
      "lastbeat=if(equal(lastbeat,0),time-.7,lastbeat);",
      "// - do main calcs",
      "dbass=(bass-pbass)*FPS;",
      "beat=below(dbass,0)*above(pdbass,0)*above(bass,.95*avgbass)*above(time-lastbeat,.3333);",
      "sure=if(beat*below(abs(time-(interval+lastbeat)), .5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "// - value decay and clipping",
      "avgbass=.995*avgbass+.005*bass;",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=min(200,maxdbass);",
      "maxdbass=max(.02,maxdbass);",
      "// - update vars",
      "interval=if(beat*below(time-lastbeat,1.8*interval), ((time-lastbeat)*.25+.75*interval),interval);",
      "lastbeat=if((1-force)*beat+above(lastbeat+interval,time),time,lastbeat);",
      "avginterval=if(beat,.9*avginterval+.1*interval, avginterval);",
      "lockinterval=if(beat,.9*lockinterval+.1*avginterval,lockinterval);",
      "pbass=bass;",
      "pdbass=dbass;",
      "bpm   = 60/(.3333*( ((2*(1-sure))/interval)+((2*sure)/avginterval)+(1/lockinterval) ));",
      "phase = min( (time-lastbeat)/(.333*(2*sure*avginterval+2*(1-sure)*interval+lockinterval)), 1 );",
      "// - clip frame intervals",
      "interval=min(interval,.7);",
      "avginterval=min(avginterval,.7);",
      "lockinterval=min(lockinterval,.7);",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "st=if(equal(st,0),time-131,st);",
      "mytime=time-st;",
      "",
      "phi=if( beat, 6.2831*int(rand(1000))*.001, phi );",
      "theta=if( beat, 6.2831*int(rand(1000))*.001, theta );",
      "rho=if( beat, 6.2831*int(rand(1000))*.001, rho );",
      "",
      "",
      "q1=phi;",
      "q2=theta;",
      "q3=rho;",
      "",
      "ax=0; ay=0; az=-30;",
      "bx = ax;",
      "by = ay*cos(q1) - az*sin(q1);",
      "bz = ay*sin(q1) + az*cos(q1);",
      "",
      "ax = bx*cos(q2) - bz*sin(q2);",
      "ay = by;",
      "az = bx*sin(q2) + bz*cos(q2);",
      "",
      "bx = ax*cos(q3) - ay*sin(q3);",
      "by = ax*sin(q3) + ay*cos(q3);",
      "bz = az;",
      "vx=bx; vy=by; vz=bz;",
      "",
      "",
