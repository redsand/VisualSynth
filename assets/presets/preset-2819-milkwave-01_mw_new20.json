  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n//Geiss's Motion Blur\n\n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).xyz;\n\n    // this vector points exactly one pixel, in the direction of motion\n    vec2 v = normalize(vUv-vUvOriginal)*uTexSize.zw;\n\n    vec3 s;\n    ret = max(ret, texture(sampler_main, vUv+v)*0.97);\n    ret = max(ret, texture(sampler_main, vUv-v)*0.97);\n    ret = max(ret, texture(sampler_main, vUv+v*2)*0.90);\n    ret = max(ret, texture(sampler_main, vUv-v*2)*0.90);\n\n    // darken over uTime\n    ret *= 0.93; //orig 0.95\n\n    // add noise\n    //vec2 uv_noise = vUv*texsize_noise_lq.zw*uTexSize.xy + rand_frame.xy;\n    //ret += (texture(sampler_noise_lq, uv_noise)*2-1)*0.02;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "basstime = basstime + bass*0.06;",
      "q1 = basstime;",
      "",
      "basstime = if(below(basstime,1000),1000,basstime);",
      "",
      "vol = pow(bass+mid+treb,2);",
      "basssum = vol;",
      "",
      "stickybit = time%2;",
      "",
      "//avg vol",
      "//buffer 1",
      "volAvg = volAvg + vol*equal(stickybit,1);",
      "//number of samples 1 or framerate",
      "sample1 = sample1 + equal(stickybit,1);",
      "//buffer 2",
      "volAvg2 = volAvg2 + vol*equal(stickybit,0);",
      "//number of samples 2",
      "sample2 = sample2 + equal(stickybit,0);",
      "",
      "//transision",
      "edge = bnot(equal(bit2,stickybit));",
      "",
      "volAvg = volAvg - volAvg*edge*stickybit;",
      "volAvg2 = volAvg2 - volAvg2*edge*equal(stickybit,0);",
      "",
      "sample1 = sample1  - sample1*edge*stickybit;",
      "sample2 = sample2  - sample2*edge*equal(stickybit,0);",
      "",
      "//test vol against avg buffer lvl",
      "diff = if(equal(stickybit,1), (basssum/(volAvg2/sample2)) , 0);",
      "diff = if(equal(stickybit,0), (basssum/(volAvg/sample1)), diff);",
      "",
      "q3 = diff;",
      "",
      "bit2 = time%2;",
      "",
      "difftime = difftime + diff*0.03;",
      "q2 = difftime;",
      "",
      "//fix a strange error",
      "difftime = if(above(difftime,2000),0, difftime);",
      "",
      "",
      "monitor = q1;"
    ],
