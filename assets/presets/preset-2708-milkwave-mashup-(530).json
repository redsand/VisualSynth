    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n  vUv.x = .6;\n  vUv.y = vRadius*2-max(audioLowSmooth*.05,audioMidSmooth*.05);\n  ret = GetBlur1(vUv);\n  ret *= (1.5-vRadius);\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "chng=sin(time*.5);",
      "cthr=.9999;",
      "mq21=if(above(chng,cthr),rand(3),mq21);",
      "mq22=if(above(chng,cthr),rand(3),mq22);",
      "mq23=if(above(chng,cthr),rand(3),mq23);",
      "mq24=if(above(chng,cthr),rand(2),mq24);",
      "mq25=if(above(chng,cthr),rand(2),mq25);",
      "mq26=if(above(chng,cthr),rand(2),mq26);",
      "mq27=if(above(chng,cthr),rand(1),mq27);",
      "mq28=if(above(chng,cthr),rand(1),mq28);",
      "mq29=if(above(chng,cthr),rand(1)*.3,mq29);",
      "mq31=if(above(chng,cthr),rand(1)*.3,mq31);",
      "monitor=chng;",
      "q21=mq21;q22=mq22;q23=mq23;q24=mq24;q25=mq25;q26=mq26;",
      "q27=mq27;q28=mq28;q29=mq29;q31=mq31;",
      "",
      "monitor=mq1;",
      "vol=bass+treb+mid;",
      "atime=atime+vol;",
      "q1=.4+sin(atime*.006        )*.4;",
      "q2=.4+cos(atime*.00613828348)*.4;",
      "q3=.4+sin(atime*.00598593455)*.4;",
      "monitor=q3;",
      "",
      "dec_med = pow (0.96, 30/fps);",
      "dec_slow = pow (0.98, 30/fps);",
      "beat = max (max (bass, mid), treb);",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, .5+avg+peak) * above (time, t0+.2);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %8;",
      "index2 = (index2 + is_beat*bnot(index))%2;",
      "index3 = (index3 + is_beat*bnot(index) * bnot(index2))%2;",
      "",
      "q20 = avg;",
      "q21 = beat;",
      "q22 = peak;",
      "q23 = index;",
      "q24 = is_beat;",
      "",
      "vol = bass_att + treb_att;",
      "v2 = v2 * dec_slow + vol * (1-dec_slow) ;",
      "q26 = max(atan (vol - v2*.8),.3);",
      "",
      "q27 = index + 1;",
      "",
      "sw = sw*dec_med + (1-dec_med)*(index2%2);",
      "q28 = sw;",
      "",
      "k1 =  is_beat*bnot(index*20);",
      "k2 =  is_beat*bnot(index);",
      "",
      "p1 =  k1*(p1+1) + (1-k1)*p1;",
      "p2 = dec_slow * p2+ (1-dec_slow)*p1;",
      "rott = p2 * 3.1416/2;",
      "monitor = k1;",
      "q1 = cos(rott);",
      "q2 = sin(rott);",
      "q3 = -q2;",
      "q4 = q1;",
      "",
      "",
      "q5 = cos(time/6);",
      "q6 = -sin(time/6);",
      "q7 = -q6;",
      "q8 = q5;",
      "",
      "zoom = 1;",
      "rot = -0;",
      "",
      "movez = movez + .006*(q1+1.1)*30/fps;",
      "q29 = movez;",
      "rota = rota + .003*(2-q1)*30/fps;",
