    "comp": null,
    "perFrameCode": [
      "ib_size=.0333*(frame%30);",
      "ib_a=.1;",
      "red=if( equal(time%3,0),1,0);",
      "yellow=if( equal(time%3,1),1,0);",
      "green = if( equal(time%3,2),1,0);",
      "ib_r = (red+yellow);",
      "ib_g= green+yellow;",
      "q1=.03+.2*sin(time+cos(2*time+.324));   // motion speed",
      "q2=3*q1/2;  // rot speed",
      "q3=sin(time+cos(time*3+sin(time*.5)))*.2; //x offset",
      "q4=cos(time*2 +sin(time*.5+cos(time)))*.1; //y offset",
      "q5=if(below(frame%300,40),.25,0);   // zoom trigger"
