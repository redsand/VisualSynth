    "perFrameInitCode": [
      "q6 = frame;"
    ],
    "perPixelCode": [
      "x=x+q3;",
      "y=y+q4;",
      "newrad=sqrt( sqr( x-.5) +sqr(y-.5) );",
      "d1=abs(x-y);",
      "d2=abs(1-x-y);",
      "d3=abs(.5-x);",
      "IsInCircle = if(above(newrad,.35),1,0);",
      "IsInCircle = if(above(newrad,.5),0,IsInCircle);",
      "IsInVert = if( below( d3,.06),1,0);",
      "IsInVert = if( above( abs(.5-y),.4),0,IsInVert);",
      "v1 = if (below( d1,.1),1,0);",
      "v1 = if( below(y,.5),0,v1);",
      "v1= if( above( newrad, .4),0,v1);",
      "v2 = if( below( d2,.1),1,0);",
      "v2 = if (below(y,.5),0,v2);",
      "v2 = if( above( newrad, .4) ,0, v2);",
      "rotdir=IsInCircle*2-1;",
      "dx=rotdir*(1-IsInVert)*(1-v1)*(1-v2)*q2*(sin(.05)*(x+q3-.5)-cos(.05)*(y+q4-.5));",
      "dy=rotdir*(1-IsInVert)*(1-v1)*(1-v2)*q2*((x+q3-.5)*cos(.05)+(y+q4-.5)*sin(.05));",
      "dy=dy+IsInVert*q1*sign(y-.5);",
      "dx=dx+v1*q1*.707;",
      "dy=dy+v1*q1*.707;",
      "dx=dx-v2*q1*.707;",
      "dy=dy+v2*q1*.707;",
      "zoom = zoom  - (1-IsInVert)*(1-IsInCircle)*(1-v1)*(1-v2)*(q5+(.55 + .1*sin(.234+time/3+2*cos(time*3+.712)) ));",
      ""
