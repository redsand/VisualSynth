  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "q1=.01; //general speed;",
      "q2=.5;   // main twirl's x",
      "q3=.5;   // main twirl's y",
      "q4=3*( abs( 6*cos(time/5) )%6);     // the phase of the mini twirls",
      "q5=.008;   // main twirl's speed;",
      "q6=q5/0.03;    // main twirl's range;",
      "q7=bass_att+mid_att+treb_att; //volume",
      "q8=sqrt(2)/20;   // max dist from transformation center",
      "InvertInterval = 1200;    // invert colors every ...#frames",
      "InvertDuration = 600;",
      "zoomexp=1.2;",
      "zoom=zoom+bass/70;",
      "wave_x=q2;",
      "wave_y=q3;",
      "bInvert = if( below( (frame+InvertInterval)%InvertInterval, InvertDuration),1,0);",
      "wave_r=abs(sin(time*1.3+1.23+cos(time*2.87+2.145)));",
      "wave_g=abs(sin(time*2.165+2.89+cos(time*.74+.78)));",
      "wave_b=abs(sin(time*.845+1.23+cos(time*1.6+3)));",
      "",
      "",
      "wave_mystery=-0.1+2*sin(3*abs(cos(time))*time);",
      "rot = rot +(q7/4)*.04*pow((sin(time/2 + .6)),11);",
      "q4 = if( equal(q4,9),10,q4);",
      "q4 = if(equal(q4,12),13,q4);",
      "q4= if(equal(q4,15),18,q4);"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "// center twirl",
      "twirlX=q2;",
      "twirlY=1-q3;",
      "Distance = sqrt(sqr(x-q2)+sqr(y-q3));",
      "RelAngle=atan2(x-twirlX,y-twirlY);",
      "TwirlMult = sin(time*50*q1)*q5/(Distance+q6);",
      "dx = dx+TwirlMult*sin(RelAngle+1.5);",
      "dy=dy+TwirlMult*cos(RelAngle+1.5);",
      "zoom = zoom + .0001*log(Distance);",
      "",
      "// mini twirls",
      "x=x*(1-q4/20);",
      "y=y*(1-q4/20);",
      "CenX= ((100*x)%100)/100;",
      "CenY= ((100*y)%100)/100;",
      "CurX=x-CenX;",
      "CurY=y-CenY;",
      "",
      "factor = 1+.7*abs(cos(q1*time/50));",
      "dx=dx-(bass_att/factor)*abs(sin(3.14/2+time*50*q1))*.2*CurY/q8;",
      "dy=dy-(bass_att/factor)*abs(sin(3.14/2+time*50*q1))*.2*CurX/q8;",
      "",
      ""
    ],
