  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "//rt = realtime (for use with beat count)",
      "rt=time-start;",
      "",
      "",
      "//initialisation bug patch",
      "beatrate = if(below(beatcount,2),.1,beatrate);",
      "",
      "//beat = if(longer that 10 sec,1,above(bass, decaying threshold)*(can't be less that .4 of last beat length)",
      "beat =if(above(rt-lastbeat,10),1, above(bass,1.6+.2*(lastbeat-rt)/beatrate)* above((rt-lastbeat)/beatrate,max(.4,.95-abs(accuracy*2))));",
      "beat = if(beat,1, if(below(abs(accuracy),0.01)*above((lastbeat-rt)/beatrate,1),1,0));",
      "",
      "//Comparison of last beat duration to current. Best value is 0. -1 and 5 are pretty bad.",
      "accuracy =if(beat,(rt-nextbeat)/beatrate,accuracy);",
      "",
      "beatcount = beatcount + beat;",
      "",
      "//Preserve beat rate",
      "l_beatrate=if(beat,beatrate, l_beatrate);",
      "//Record new beatrate",
      "beatrate = if(beat,rt-lastbeat,beatrate);",
      "",
      "//Record most recent beat",
      "lastbeat=if(beat,rt,lastbeat);",
      "//Predict time of next beat",
      "nextbeat=if(beat,rt+beatrate,nextbeat);",
      "",
      "",
      "decay=max(bass_att*-.01+1,.99);",
      "//decay =if(below(decay,.97),300000,decay);",
      "decay =if(beat,300000,decay);",
      "//wave_r=if(above(bass+mid,3.5), .5+.5*sqr(sin(bass+mid)),sin(time)*.06125+.06125);",
      "wave_r=if(below(rt,lastbeat+beatrate*.5), .5+.5*sqr(sin(bass+mid)),sin(time)*.06125+.06125);",
      "wave_g=.5+max(.6-(bass+treb)*.15,0); //-wave_r;",
      "//decay = 300000;",
      "monitor = below(rt,lastbeat+beatrate*.5);",
      "q1=beat;"
    ],
    "perFrameInitCode": [
      "beat = 0;",
      "rt= 0;",
      "start = 0;",
      "beatcount = 0;"
    ],
    "perPixelCode": [
      "//dy=if(equal((x*7)%7,((time+10*fps) + 2*above(treb_att,2))%7),",
      "",
      "//dy=if(equal((x*7)%7,(time*.12*fps + q1)%7)*equal((y*2)%2,0),",
      "//cos((y-.5)*6.28)*(treb_att+bass_att)*.02*abs(y-.5)/(y-.5),",
      "//(y-.5)*mid*.003);",
      "",
      "",
      "",
      "dy=if(equal(((x*7+2*y%2*3))%7,(time*.12*fps + q1)%7),",
      "cos((y-.5)*6.28)*(treb_att+bass_att)*.1*abs(y-.5)/(y-.5),",
      "(y-.5)*mid*.015);"
    ],
