  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "bass_clip = above(bass_att,bass_clip)*2 + (1-above(bass_att,bass_clip))*((bass_clip-1.3)*0.96+1.3);",
      "basstime = basstime + (bass_att*0.03);",
      "",
      "",
      "time2 = time2 + (bass_att*0.09);",
      "",
      "//punlish",
      "q1 = state;",
      "q2 = basstime;",
      "q3 = bass_clip;",
      "q4 = time2;",
      "",
      "ob_r = ob_r + 0.5*sin(time*1.22);",
      "ob_g = ob_g + 0.5*sin(time*1.307);",
      "ob_b = ob_b + 0.5*sin(time*1.959);",
      "",
      "",
      "monitor = bass_clip;"
    ],
    "perFrameInitCode": [
      "state = 0;"
    ],
    "perPixelCode": [
      "//use simple fuzzy logic to model zooming",
      "",
      "//rules",
      "fuzzy1 = x*0.1*rad;",
      "fuzzy3 = (x-1)*0.1*rad;",
      "fuzzy2 = y*0.1*rad;",
      "fuzzy4 = (y-1)*0.1*rad;",
      "",
      "//activations approx sawtooth with sin curve",
      "f1 = sin(q4 - 1.5707);",
      "f2 = sin(q4);",
      "f3 = sin(q4 + 1.5707);",
      "f4 = sin(q4 + 3.14);",
      "",
      "//take only values above zero",
      "f1 = f1*above(f1,0);",
      "f2 = f2*above(f2,0);",
      "f3 = f3*above(f3,0);",
      "f4 = f4*above(f4,0);",
      "",
      "//sum rule ativations",
      "sum_fuzzy = fuzzy1*f1 + fuzzy2*f2 - fuzzy3*f3 - fuzzy4*f4;",
      "",
      "zoom = 0.975 - (rad- 0.5)*0.05 + sum_fuzzy*0.5;"
    ],
