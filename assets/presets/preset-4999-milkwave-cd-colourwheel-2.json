  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "vol = (base_att + mid_att + treb_att)/6;",
      "q2 = max(vol*0.9,0.4);",
      "t = t + vol*0.07;",
      "q5 = t;",
      "//my new volume based time... :) makes things go quicker with volume",
      "",
      "q1 = above(bass_att,beat_q1*1.15);",
      "beat_q1 = q1*5 + ((1-q1)*(beat_q1-1.1)*0.9 + 1.1);",
      "//beat_threshold algorithm from Geiss - Shift",
      "rt = if(q1,rt*-1,rt);",
      "q3 = rt;",
      "//Changes the direction of the rotation",
      "",
      "wave_x = 0.5 + 0.1*cos(t*3.14) + 0.05*cos(t*1.3);",
      "wave_y = 0.5 + 0.1*sin(t*2.14) + 0.03*sin(t*0.5);",
      "wave_a = vol;",
      "",
      "wave_r = wave_r + 0.5*sin(t*3.034);",
      "wave_g = wave_g + 0.5*sin(t*2.547);",
      "wave_b = wave_b - 0.5*sin(t*1.431);",
      "ob_size = min(0.95-vol/2,0.95);",
      "ib_size = max(0.01, vol/15);",
      "ib_a = (vol+0.2)*(vol+0.2)*(vol+0.2);",
      "ib_r = max(0.1 + 0.6*sin(t*1.747),0);",
      "ib_g = max(0.1- 0.3*sin(t*0.731),0);",
      "ib_b = max(0.4 + 0.5*cos(t*0.834),0);",
      "",
      "monitor = q3;"
    ],
    "perFrameInitCode": [
      "t = time;",
      "q3 = 1;",
      "rt = 1;"
    ],
    "perPixelCode": [
      "// q2 = volume, q3 = rotation direction, q5 = timer",
      "",
      "rot = q3*q2* ((0.5+1/(rad+0.1))) * 0.2 * max(sin(q5*1.31),0.3);",
      "zoom=0.85+0.1*sin(pow(rad,1.5)*25-q5*(q2-3.14)*1.5);"
    ],
