  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\nvec2 ac = vec2(q1,q2);\nvec2 mu = vec2(q3,q4);\nvec2 c = vec2(q5,q6);\nvec2 d = vec2(q7,q8);\n\nvec2 z = (vUv-0.5);\n\n// (c*z + d)\nvec2 czd = vec2(z.x*c.x-z.y*c.y,z.x*c.y-z.y*c.x)*uAspect.yx + d;\n// mu/(cz+d)\nvec2 moebius = vec2( mu.x*czd.x + mu.y*czd.y , mu.y*czd.x-mu.x*czd.y )/(czd.x*czd.x+czd.y*czd.y) + ac;\n\nmoebius = 0.5 + (1.0 - abs( fract( moebius * 0.5 ) * 2 - 1.0 )-0.5)*0.99;\n\nvUv = moebius;\n\n    d = uTexSize.zw*8;\n    vec3 dx = ( GetBlur1(vUv+vec2(1,0)*d)-GetBlur1(vUv-vec2(1,0)*d) );\n    vec3 dy = ( GetBlur1(vUv+vec2(0,1)*d)-GetBlur1(vUv-vec2(0,1)*d) );\n    vec2 uv_y = vUv-vec2(dx.y,dy.y)*0.4;\n\n    vec2 uv_dx = vUv - vec2(dx.x,dy.x)*1;\n    vec2 uv_dz = vUv + vec2(dx.z,dy.z)*uTexSize.zw*256;\n    vec2 uv_dy = vUv - vec2(dx.y,dy.y)*uTexSize.zw*80;\n\nret = GetPixel(vUv).y*0.2;\n//ret = mix(ret, vec3(0,1,0), length(vec2(dx.z,dy.z)));\nret = mix(vec3(0.2,0,0.1),vec3(0.8,0.6,0),GetPixel(uv_dz).y);\nret = mix(ret,1,GetPixel(vUv).z*1);\n\n//ret = mix(ret, vec3(0.8,0,1.5), length(vec2(dx.x,dy.x)));\n//ret = mix(ret,vec3(1,1,0),GetPixel(vUv).x*clamp01(1-GetBlur3(vUv).y*8));\n//ret = mix(ret,1,GetBlur1(uv_dx).z*GetBlur1(vUv).x*2*(1-GetBlur1(vUv).y*4));\n\n//ret = mix(clamp01(ret),0,GetPixel(vUv).x);\n\n//ret = GetPixel(vUv).y;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "wave_r = wave_r + 0.35*sin(1.14*time) + 0.16*sin(1.5*time);",
      "wave_g = wave_g + 0.36*sin(1.27*time) + 0.15*sin(1.11*time);",
      "wave_b = wave_b + 0.37*sin(1.284*time) + 0.15*sin(1.3*time);",
      "warp = 0;",
      "",
      "ob_r = wave_g;",
      "ob_b = wave_r;",
      "ob_g = wave_b;",
      "ib_r = wave_r;",
      "ib_b = wave_g;",
      "ib_g = wave_r;",
      "//before inversion",
      "scale = 1;",
      "angle = time*.2;",
      "translation_x = 0;",
      "translation_y = 0.12;",
      "",
      "//complex inverted",
      "iscale = 1;",
      "iangle = sin(time*0.1337)*0.3;",
      "itranslation_u = 0;",
      "itranslation_v = 0.2;",
      "",
      "",
      "// the m�bius transformation",
      "// z -> (az+b)/(cz-d); where a,b,c,d are complex numbers and z will be the uv-vector",
      "// (az+b)/(cz-d) = a/c + mu/(cz+d), with mu = (bc-ad)/c",
      "// so a/c and mu can be calculated outside of the shader",
      "",
      "a_r = cos(angle)*scale;",
      "a_i = sin(angle)*scale;",
      "b_r = translation_x;",
      "b_i = translation_y;",
      "",
      "c_r = -cos(iangle)*iscale;",
      "c_i = -sin(iangle)*iscale;",
      "d_r = itranslation_u;",
      "d_i = itranslation_v;",
      "",
      "// c^(-1)",
      "c_inv_r = c_r/(c_r*c_r+c_i*c_i);",
      "c_inv_i = c_i/(c_r*c_r+c_i*c_i);",
      "",
      "// a*c^(-1)",
      "ac_r = (a_r*c_inv_r - a_i*c_inv_i);",
      "ac_i = (a_r*c_inv_i - a_i*c_inv_r);",
      "",
      "// (bc-ad)",
      "bcad_r = (b_r*c_r - b_i*c_i)-(a_r*d_r-a_i*d_i);",
      "bcad_i = (b_r*c_i - b_i*c_r)-(a_r*d_i-a_i*d_r);",
      "",
      "// mu*c^(-1)",
      "mu_r = bcad_r*c_inv_r - bcad_i*c_inv_i;",
      "mu_i = bcad_r*c_inv_i - bcad_i*c_inv_r;",
      "",
      "q1 = ac_r;",
      "q2 = ac_i;",
      "q3 = mu_r;",
      "q4 = mu_i;",
      "",
      "q5 = c_r;",
      "q6 = c_i;",
      "q7 = d_r;",
      "q8 = d_i;"
    ],
