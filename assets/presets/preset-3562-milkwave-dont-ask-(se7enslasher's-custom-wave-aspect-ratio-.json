      "t = -time*0.2;",
      "pi3 = 3.1415*2/3;",
      "c = 5-pow(bass,5)*1;",
      "",
      "r = sin(t)*c;",
      "r = if(above(r,1),1,r);",
      "r = if(below(r,0),0,r);",
      "",
      "g = sin(t+pi3)*c;",
      "g = if(above(g,1),1,g);",
      "g = if(below(g,0),0,g);",
      "",
      "b = sin(t-pi3)*c;",
      "b = if(above(b,1),1,b);",
      "b = if(below(b,0),0,b);",
      "",
      "ib_r = r;//0.5+sin(time)*0.5;",
      "ib_g = g;//0.5+sin(time)*0.5;",
      "ib_b = b;//0.5-sin(time)*0.5;",
      "",
      "zoom = 1 - bass*0.0051;",
      "rot = sin(time)*0.001;",
      "",
      "q1 = 1/aspectx;",
