    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    // sample previous uFrame\n    ret = texture( sampler_main, vUv ).xyz;\n\n    // darken (decay) over uTime\n    ret *= 0.795; //or try: ret -= 0.004;\nret = tex2d(sampler_rand01,vUvOriginal).zzy;\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\nvec2 uv1 = vUv-.5;\n\nvec3 ret1 = texture(sampler_main, vUv) +texture(sampler_main, 1-vUv)*0;\n\n\nvec2 hor = vec2 (uTexSize.z,0);\nvec2 ver = vec2 (0,uTexSize.w);\nfloat dx = GetPixel (vUv-hor) - GetPixel (vUv+hor);\nfloat dy = GetPixel (vUv-ver) - GetPixel (vUv+ver);\nvec2 dz = vec2 (dx,dy);\n\nuv1 = .3*cos(uv1*2+1.7) -2*dz;;\nvec3 dots = clamp01(.03/length(uv1));\n\n\nret1 = (-ret1/4) + 6*dots*(-0.08+ret1);\n\nret = ret1;\n\n    vec2 texc = 0.4 + 0.6*ret.xy;\n    ret = texture(sampler_rand00, texc) * lum(ret) * 3;\n\n\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "q31 = .8; //Tele",
      "q32 = .2; //Verschiebung Y-Mitte ; pos-> Vogel nach oben",
      "size = .3* (1 + above(xang,0)*xang/3);",
      "dec_m = pow (0.85, 30/fps); dec_s = pow (0.98, 30/fps);",
      "beat = if(tic, mid_att*4, beat*dec_s);",
      "tic = above(mid_att, beat)*above(time,t0+1); t0 = if(tic,time,t0); count = count + tic;",
      "vol = (bass_att+mid_att+treb_att)/3;",
      "vol_ = vol_*dec_s + (1-dec_s) * vol;",
      "",
      "speed = dec_s*speed + (1-dec_s)*(vol_/4+.3)*size*4 ; //#",
      "",
      "//Kameraposition rel. zu Vogel",
      "reg00 = if(tic*bnot(count%4), rand(8)-4, reg00);",
      "reg01 = if(tic*bnot(count%6), (rand(8))/6+0, reg01);",
      "reg02 = if(tic*bnot(count%8), rand(10)-4, reg02);",
      "",
      "reg03 = reg03 + max(min((reg00-reg03),.1), -.1)/fps*20;",
      "reg04 = reg04 + max(min((reg01-reg04),.05), -.05)/fps*20;",
      "reg05 = reg05 + max(min((reg02-reg05),.1), -.1)/fps*20;",
      "dec_f = pow(.93,30/fps); //#",
      "",
      "//Kamera Richtung",
      "dxang = -asin((YVog-YCam)/dist);",
