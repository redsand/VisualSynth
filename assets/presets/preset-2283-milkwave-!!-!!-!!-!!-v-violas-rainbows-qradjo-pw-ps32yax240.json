      "power = dec_m * power + (1-dec_m)*min(max((reg41-reg44)*2 + vol_-.2,.1),1.6);",
      "XVog = XVog + sin(yangV)/fps*speed*(1-q5/16);",
      "ZVog = ZVog + cos(yangV)/fps*speed*(1-q5/16);",
      "YVog = dec_s * YVog + (1-dec_s)*max(min(reg44,8),.2);",
