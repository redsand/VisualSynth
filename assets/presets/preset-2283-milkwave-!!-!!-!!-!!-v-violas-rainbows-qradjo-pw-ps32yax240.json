      "",
      "yang1 = atan(-(XVog-XCam)/(ZVog-ZCam)) ;",
      "yang1 = if (below(ZVog-ZCam,0),if(above(XVog-XCam,0),yang1+3.1416,yang1-3.1416),yang1);",
      "per = if(below(yang1,yanga-6),per+1,per);",
      "per = if(above(yang1,yanga+6),per-1,per);",
      "yanga = yang1;",
      "yang = yang*dec_f + (1-dec_f)*(yang1+per*6.2832);",
      "yang_ = yang_*dec_f + (1-dec_f)*yang;",
      "zang = -atan((yang-yang_)*4)/2;",
      "",
      "//Kamera Position",
      "rvol = rvol*dec_s + (1-dec_s) * min(max(vol_,0),1);",
      "rvol = min(max(rvol,0),1);",
      "dec_f = pow(.98, 30/fps); //#separate fr ang und pos !",
      "dec_f = rvol*dec_f + (1-rvol);",
      "//dec_f = 1;",
      "XCam = XCam*dec_f + (1-dec_f)* (XVog-reg03) ;",
      "ZCam = ZCam*dec_f + (1-dec_f)* (ZVog-reg05); //# bei grosser YVog reduzieren",
      "YMin = 4*above(xang,0)*pow(xang/1.6,1.5);",
      "YCam1 = YCam1*dec_f + (1-dec_f)*reg04;",
      "YCam = YCam1 + YMin + .5;",
      "dist = sqrt(pow(XCam-XVog,2)+pow(YCam-YVog,2)+pow(ZCam-ZVog,2));",
      "",
      "//VOGEL",
      "reg12 = if(tic*bnot(count%3), (rand(100)-50)/50, reg12*bnot(count%3));",
      "reg15 = dec_s * reg15 + (1-dec_s)*(reg12+ (rand(10)-5)*(rand(10)-5)/2/fps); //# rand ?",
      "",
      "//Vogel Flugrichtung",
      "xangV = 0;",
      "yangV = yangV + -zangV/fps/2;",
