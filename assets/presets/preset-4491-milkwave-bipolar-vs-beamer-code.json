  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvUv *=2 ;\nvec2 m = floor(fract(vUv*0.5)*2);\nvUv = fract(vUv)*(1-m) + (m)*fract(1-vUv);\n\nvec2 uv1 = vUv-.5;\n\nvec3 ret1 = texture(sampler_main, vUv) +texture(sampler_main, 1-vUv)*0;\n\n\nvec2 hor = vec2 (uTexSize.z,0);\nvec2 ver = vec2 (0,uTexSize.w);\nfloat dx = GetPixel (vUv-hor) - GetPixel (vUv+hor);\nfloat dy = GetPixel (vUv-ver) - GetPixel (vUv+ver);\nvec2 dz = vec2 (dx,dy);\n\nuv1 = .3*cos(uv1*2+1.7) -2*dz;;\nvec3 dots = clamp01(.03/length(uv1));\n\n\nret1 = (-ret1/4) + 6*dots*(-0.08+ret1);\n\nret = lum(ret1)*rand_preset;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "decay = decay - 0.01*equal(frame%40,0);",
      "rot = rot + 0.01*sin(time*0.113);",
      "rot = rot + 0.01*sin(time*0.533);",
      "rot = rot + 0.02*sin(time*-0.323);",
      "dx = dx + dx_residual;",
      "dy = dy + dy_residual;",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "dx_residual = equal(bass_thresh,2)*0.0072*sin(time*7) + (1-equal(bass_thresh,2))*dx_residual;",
      "dy_residual = equal(bass_thresh,2)*0.0054*sin(time*9) + (1-equal(bass_thresh,2))*dy_residual;",
      "",
      "////  Beamer Code Edition  ////",
      "dec_med = 1- .3*30/fps;",
      "dec_slow = 1-.05*30/fps;",
      "",
      "beat = max (max (bass, mid), treb);",
      "avg = avg*dec_slow + beat*(1-dec_slow);",
      "is_beat = above(beat, .5*avg+peak) * above (time, t0+.03);",
      "t0 = is_beat*time + (1-is_beat)*t0;",
      "peak = is_beat * beat + (1-is_beat)*peak*dec_med;",
      "index = (index + is_beat) %16;",
      "index2 = if (bnot(index)*is_beat,index2+1,index2);",
      "",
      "q24 = is_beat;",
      "q27 = index;",
      "q28 = index2;",
      "q22 = peak;",
      "peak_ = dec_med*peak_ + (1-dec_med)*peak;",
      "q29 = peak_;",
      "trig = is_beat * bnot(index%4);",
      "count = count + trig;",
      "rott = rott*dec_med + (1-dec_med) * count*3.14/2;",
      "q1 = cos(rott);",
      "q2 = sin(rott);",
      "",
      "",
      "ma = ma + (peak_-0)/fps*4*above(peak_,0);",
      "mx=mx*dec_slow+(1-dec_slow)*cos(ma);",
      "my=my*dec_slow+(1-dec_slow)*sin(ma*q1);",
      "q15 = mx/2 ;",
      "q16 = my/2 ;",
      "q17 = ma;",
      "",
      "ang1 = ang1 + 8*bass*above(bass,1)/fps*q1;",
      "q18 = ang1;",
      "",
      "q32 = aspecty;",
      "monitor = index2;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "zoom=0.9615+rad*0.1;",
      "rot = rot * 3*(1-pow(rad*2-1,2));"
    ],
