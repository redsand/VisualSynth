    "perFrameCode": [
      "// sensor - alpha",
      "le=1.4*bass_att+.1*bass+.5*treb;",
      "pulse=band(above(le,th),above(le-th,block));",
      "block=le-th;",
      "th=if(above(le,th),le+114/(le+10)-7.407,",
      "th+th*.07/(th-12)+below(th,2.7)*.1*(2.7-th));",
      "th=if(above(th,5.2),4,th);",
      "",
      "q1=.12*th;",
      "ccl=if(pulse,ccl+1,ccl);",
      "q2=ccl;",
      "",
      "ob_r=ob_r + time*sin(bass);",
      "ob_b=ob_b + time*sin(treb+1);",
      "ob_g=ob_g + time*sin(mid/1.5);",
      "zoomexp = q1;",
      "myb = cos(time)  + abs(cos(time));",
      "myg = abs(sin(time)) ;",
      "myr = (-1 * cos(time))  + abs(-1 * cos(time)) + 0.2 * (cos(sin(time))+(abs(cos(sin(time)))+cos(sin(time))));",
      "avg = .9*avg+.1*le;",
      "wave_r = if(below(avg,1.8),myr,0);",
      "wave_b = if(below(avg,1.8),myb,0);",
      "wave_g = if(below(avg,1.8),myg,0);",
      "monitor = avg;"
    ],
