    "perPixelCode": [
      "grid=sign(pow(sin(ang*(q2)+x*y*q1)*2,1+q2%4)) -.5;",
      "snee=.5*sin(q2*q1);",
      "rot=bnot(grid%((q2%10)+2))*above(x,.5+snee)*above(y,.5-snee);",
      "sx=sx-sin((q2+.5)*x)*band(rot,snee)*.003;",
      "sy=sy-cos((q2+3.4)*y)*band(rot,snee)*.003;",
      "zoom=1+.1*sin((q1-q2)*3)+.2*cos(1.6*sin(time)+rad*6.28*q1)*below(x,.5+snee)*below(y,.5-snee);"
    ],
