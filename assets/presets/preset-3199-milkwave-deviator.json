  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// sensor - alpha",
      "// le = signal level; desired average value = 2",
      "// th = threshold",
      "le=1.4*bass_att+.1*bass+.5*treb;",
      "pulse=band(above(le,th),above(le-th,block));",
      "block=le-th;",
      "th=if(above(le,th),le+114/(le+10)-7.407,",
      "th+th*.07/(th-12)+below(th,2.7)*.1*(2.7-th));",
      "th=if(above(th,6),6,th);",
      "",
      "thr=thr+th;",
      "q1=.005*thr;",
      "pr=pr+pulse;",
      "q5=pr+(pr+1)%2;",
      "q6=pr+pr%2;",
      "q2=sin(37.12*pr)*(pr+13)%3+sin(time);",
      "",
      "wr=if(pulse,.001*int(rand(1000)),wr);",
      "wg=wr+.3*sin(time*1.17);",
      "wb=wg+.3*sin(time*1.18);",
      "wave_r=wr;wave_g=wg;wave_b=wb;",
      "ib_r=.6*wg+.2*sin(time*1.12);",
      "ib_g=wb+.2*sin(time*1.13);",
      "ib_b=.6*wr+.2*sin(time*1.14);",
      "ob_size=.3+.2*sin(pr);",
      "ibvisible=if(pulse,above(int(rand(3)),0),ibvisible);",
      "ib_a=ibvisible*.4+.3*sin(.5*time+.03*thr);"
    ],
    "perFrameInitCode": [
      "pr=int(rand(378));"
    ],
    "perPixelCode": [
      "left=above(x,.5);",
      "zone=below(rad,.6)*below(cos(rad*21+ang*12+q5),0);",
      "deviator=1+q2*cos(x*31.42+y*25.13+q1);",
      "sx=1+.05*deviator*if(zone,tan(26*q5),if(left,sin(27*q5),sin(28*q6)));",
      "sy=1+.05*deviator*if(zone,tan(25*q5),",
      "if(left,sin(26.1*q5),sin(29.5*q6)));",
      "zoom=1+if(zone,.13*sin(31*q5),",
      ".1*if(left,sin(13.7*q5),sin(21.6*q6)));",
      "rot=.07*sin((2.3+left)*q5+zone*q1);"
    ],
