    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "wave_r = wave_r + 0.45*(0.5*sin(time*0.701)+ 0.3*cos(time*0.438));",
      "wave_b = wave_b - 0.4*(0.5*sin(time*4.782)+0.5*cos(time*0.722));",
      "wave_g = wave_g + 0.4*sin(time*1.931);",
      "wave_r = 0.2125*wave_r + 0.7154*wave_g + 0.0721*wave_b;",
      "wave_g = wave_r;",
      "wave_b = wave_r;",
      "vol = 0.167*(bass+mid);",
      "xamptarg = if(equal(frame%15,0),min(0.5*vol*bass_att,0.5),xamptarg);",
      "xamp = xamp + 0.5*(xamptarg-xamp);",
      "xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));",
      "xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);",
      "xpos = xpos + 0.001*xspeed;",
      "wave_x = 1.25*xpos + 0.5;",
      "yamptarg = if(equal(frame%15,0),min(0.3*vol*treb_att,0.5),yamptarg);",
      "yamp = yamp + 0.5*(yamptarg-yamp);",
      "ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));",
      "yspeed = yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);",
      "ypos = ypos + 0.001*yspeed;",
      "wave_y = 1.25*ypos + 0.5;",
      "dx = dx + dx_residual;",
      "dy = dy + dy_residual;",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*0.96+1.3);",
      "dx_residual = equal(bass_thresh,2)*0.003*sin(time*7) + (1-equal(bass_thresh,2))*dx_residual;",
      "dy_residual = equal(bass_thresh,2)*0.001*sin(time*9) + (1-equal(bass_thresh,2))*dy_residual;",
      "rot = 0.1;",
      "",
      "vol=(bass+mid+treb)*0.25;",
      "vol=vol*vol;",
      "mtime=mtime + vol*0.01*(75/fps);",
      "q8=mtime;",
      "",
      "",
      "q1=sin(mtime) * sin(mtime*3) * 0.4 + 0.5;",
      "q2=cos(mtime*1.3) * sin(mtime*5.4) * 0.4 + 0.5;",
      "",
      "",
      "",
      "ib_r = tan(time);",
      "ib_r = min(1, max(ib_r,0));",
      "",
      "ib_g = tan(time+2.1);",
      "ib_g = min(1, max(ib_g,0));",
      "",
      "ib_b = tan(time+4.2);",
      "ib_b = min(1, max(ib_b,0));",
      "",
      "q3 = 10+8*(0.6*sin(0.223*time) + 0.4*sin(0.153*time));",
      "q4 = 1/q3;",
      "q5 = 0.5*sign(xpos);",
      "q6 = 0.5*sign(ypos);",
      "",
      "monitor=q4",
      "",
      ""
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "cx = ((-1&(x*q3-q5+0.5))+q5)*q4;",
      "cy = ((-1&(y*q3-q6+0.5))+q6)*q4;",
      "newx = q1-x;",
      "newy = q2-y;",
      "newrad = sqrt((newx)*(newx)+0.5625*(newy)*(newy))*2;",
      "newzoom = pow(1.05 + 0.03*newrad, pow(0.01+sin(newrad*newrad), newrad*2-1));",
      "dx = (newx)*newzoom - newx;",
      "dy = (newy)*newzoom - newy;",
      "dx =dx*0.1;",
      "dy=dy*0.1;",
      "rot = 2*newrad*(0.5*(0.5-rad)+0.1);",
      "rot=rot*sin(time)*0.2"
