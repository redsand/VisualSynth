      "treb_effect = max(max(treb,treb_att)-1.2,0);",
      "ib_a = if(above(bass_effect,0),0.05+0.02*bass_effect,0);",
      "ob_a =if(above(treb_effect,0),0.1+0.02*treb_effect,0.05);",
      "ob_r = ob_r + 0.3*bass_effect;",
      "ob_g = ob_g +0.3*treb_effect;"
    ],
