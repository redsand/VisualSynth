  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "volume = 0.3*(bass+mid+att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.5*(beatrate + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "q1=beat;",
      "wave_r = min(peakbass_att * mid , wave_r * time);",
      "rot = max(bass_att * wave_b , beat * wave_b);",
      "ob_r = -0.05474079*cos(time * cx);",
      "cy = max(wave_g - mid_att , wave_b + treb);",
      "ob_r = ob_r - time;",
      "ob_r = min(ob_r * bass , beatrate + wave_g);",
      "rot = -0.47323078*sin(max(rot * rot , treb_att * mid));",
      "cy = min(0.41730499*sin(cy + cy) , wave_b + beat);",
      "cy = 0.90379298*sin(min(cy - rot , beatrate * rot));",
      "rot = 0.59319639*cos(rot * wave_r);",
      "warp = 0.62598276*cos(max(wave_b * time , treb_att + mid_att));",
      "cx = -0.1809752*cos(cy * bass);",
      "ob_b = min(treb_att * wave_r , q1 * q1);",
      "wave_r = wave_r * time;",
      "ob_g = min(wave_b * wave_g , bass_att * wave_r);",
      "wave_b = min(max(wave_r * treb_att , bass_att - volume) , cx - time);",
      "wave_g = 0.52486885*sin(cx * bass_att);",
      "cx = max(cx + wave_b , cx + bass_att);",
      "cy = cy * q1;"
    ],
