      "",
      "q5=3.1415*cos(.05*time+.84+sin(time*.1+6.43)); // rot-y;",
      "q6=.2;//.6-.45*abs(sin(time*.15+2.43+cos(time*.09+1.87))); // rot-x;",
      "",
      "q5=0;q6=0;",
      "",
      "",
      "stime=if(equal(stime,0),time,stime );",
      "mytime=time-stime;",
      "phase = .1*mytime - int(.1*mytime);",
      "tilex=if(below(phase,.025),1 + int(rand(4)),tilex );",
      "tilez=if(below(phase,.025),1 + int(rand(4)),tilez );",
      "q7=tilex;",
      "",
      "contVol=((bass+mid+att)*.3333)*.02+contVol*.98;",
      "contVol=min(1,contVol);",
      "zoom=1.01+.05*contVol;",
      "",
      "darken=above(frame%3,0);",
      "",
      "c1=above(contvol,.7)*min(contvol-.7,.3);",
      "dx=c1*.001*(-10+int(rand(20)));",
      "dy=c1*.001*(-10+int(rand(20)));",
      "",
      "solarize=1;",
      "darken=frame%2;",
      "brighten=1-darken;",
      "//invert=beat;",
      "gamma=gamma+.5*sqrt(1-(frame-lastbeat)/interval);",
      "monitor=gamma;",
      "",
      "q8=min((frame-lastbeat)/interval,1);",
      "q1=.05*cos(1.943*time+2.43+sin(1.83*time+2.01) );",
      "",
      "sx=1-2*beat*above(contVol,.8);",
      "sy=1-2*beat*above(contVol,.8);",
      "invert=beat*above(contVol,.8);"
