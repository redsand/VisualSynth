  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nuv0 = vUv;\nuv2 = vec2(.2/vRadius+uTime/4,vAngle/3.14)*2;\nfloat mod = length(sin(uv2*3.141/2+uTime*.1));\nvec2 noise = texture(sampler_noise_hq,uv2+mod).rg;\nfloat mask = (noise.r <= sw2);\nvec2 rohr = sw1*vRadius * (noise-.5) /2*mask;\n\nuv1 = vec2(1-vUv.x,vUv.y);\nret =  GetPixel(vUv)+GetPixel(uv1);\n\nvec3 back = .2*(.5+(vUv.x-.5)*q1+(vUv.y-.5)*q2);\nvUv+= rohr * sw1;\n\nuv1 = vec2(1-vUv.x,vUv.y);\nret += (GetBlur2(vUv) + GetBlur2(uv1)) *min(.5+audioHighSmooth/4,2) *(1+1*sw1) * clamp01(1-lum(ret)/2);\nret += !sw1*back;\nret = mix(ret*(hue_shader*2-1),ret,lum(ret));;\n//ret = GetPixel(vUv);\nvec4 noise2 = texture3D(sampler_noisevol_hq,\n                      ((vUvOriginal.xyy+vec3(lum(roam_sin.xy),\n                                           lum(roam_cos.yx),\n                                           0)*0.5\n                       )*uTexSize.xyy*texsize_noisevol_hq.zww\n                      ).xyz*\n                      vec3(1,1,0)*0.05 +\n                      uTime*vec3(0,0,1)*0.2 );\nret *= (noise2)*1;\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "//krash's beat detection code",
      "volume = 0.3*(bass+mid+att);",
      "beatrate = equal(beatrate,0) + (1-equal(beatrate,0))*(below(volume,0.01) + (1-below(volume,0.01))*beatrate);",
      "lastbeat = lastbeat + equal(lastbeat,0)*time;",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = max(bass_att,peakbass_att);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = beat*bass_att + (1-beat)*peakbass_att*(above(time - lastbeat, 2*beatrate)*0.95 + (1-above(time - lastbeat, 2*beatrate))*0.995);",
      "lastbeat = beat*time + (1-beat)*lastbeat;",
      "peakbass_att = max(peakbass_att,1.1*meanbass_att);",
      "beat = above(volume,0.8)*below(peakbass_att - bass_att, 0.05*peakbass_att)*above(time - lastbeat, 0.1 + 0.5*(beatrate - 0.1));",
      "beatcounter = beatcounter + beat;",
      "mode = if(beat*equal(beatcounter%2,0),1-mode,mode);",
      "flip = 2*mode-1;",
      "monitor=flip;",
      "q8=flip;",
      "",
      "",
      "decay=1;",
      "//zoom=1.002;",
      "",
      "vol=(bass_att+mid_att+treb_att)*0.25;",
      "vol=vol*vol;",
      "mtime=mtime+vol*0.05*flip;",
      "",
      "q1=mtime*0.4;",
      "",
      "",
      "musictime=musictime+(mid*mid*mid*mid)*0.01*flip;",
      "",
      "xpos=sin(musictime*0.6)*0.3;",
      "ypos=sin(musictime*0.4)*0.3;",
      "q4=xpos;",
      "q5=ypos;",
      "",
      "warp=0.0"
    ],
