      "zoom = if(above(circle,1),q1*.1,1-0.4*log(sqrt(2)-rad));",
      "dx = if(above(circle,1),1.3*sin(rot+0.75*x+0.942*q3),0);",
      "dy= if(above(circle,1),1.3*sin(cx+0.75*y+1.081*q3),0);",
