    "comp": null,
    "perFrameCode": [
      "warp=0;",
      "chaos=.9+.1*sin(pulse);",
      "entropy=if(bnot(entropy),2,if(equal(pulse,-20),1+int(rand(3)),entropy));",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.3)*chaos+1.3);",
      "bass_changed=abs(bass_changed-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.3)*chaos+1.3);",
      "treb_changed=abs(bass_changed-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.3)*chaos+1.3);",
      "mid_changed=abs(bass_changed-equal(mid_thresh,2));",
      "bass_residual = bass_changed*sin(pulse*bass_thresh*.1*entropy) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*treb_thresh*.1*entropy) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*mid_thresh*.1*entropy) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),20),-20,pulse+.2*bor(bor(bass_changed*bnot(treb_changed),treb_changed*bnot(bass_changed))*bnot(mid_changed),mid_changed)+(mid+bass+treb)*.025);",
      "q2=mid_residual;",
      "q3=bass_residual;",
      "q4=treb_residual;",
      "q5=sin(pulse);",
      "q1=(1+1*above(q2,0))*(1+2*above(q3,0))*(1+4*above(q4,0))*(1+6*above(q5,0))*(1+10*treb_changed*above(q5,0))*(1+12*bass_changed*above(q3,0));",
      "wave_r=wave_r+.5*bass_residual;",
      "wave_r=wave_g+.5*mid_residual;",
      "wave_r=wave_b+.5*treb_residual;",
      "ob_r=if(bass_flop,treb_flop,wave_r);",
      "ob_b=if(treb_flop,mid_flop,wave_b);",
      "ob_g=if(mid_flop,bass_flop,wave_g);",
      "ob_a=.03+.02*wave_r;",
      "bob_size=.05+.04*treb_residual;",
      "ob_size=bnot(q1%102)*.1;",
      "ib_r=if(bass_flop,ob_b,ob_g);",
      "ib_b=if(treb_flop,ob_g,ob_r);",
      "ib_g=if(mid_flop,ob_r,ob_b);",
      "ib_a=.03+.02*wave_g;",
      "ib_size=.05+.04*bass_residual;",
      "wave_mystery=bnot(q1%2)*.5-bnot(q1%11)*.5+.5*q5;",
      "cx=cx+.5*q3;",
      "cy=cy+.5*q4;",
      "rot=rot+.1*bnot(q1%13)*q5;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "bend = cos(x*10*q2*bnot(q1%3)+(rad*10*q2-10*q5)*bnot(q1%7)+y*10*q4-10*q3*bnot(q1%11));",
      "zoom = zoom+bend*.05*bnot(q1%13)*q2+bend*.05*bnot(q1%6)*q3;",
      "zoom = if(above(bnot(q1%5)*sin(ang*10*q3),0),1+abs(1-zoom)*3*q3,zoom);",
