    "perFrameCode": [
      "warp=0;decay=.95;",
      "// -------------------------------- Beat Detective 007 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "",
      "",
      "nt = -(frame-(interval+lastBeat))/interval;",
      "nt=max(0,nt);nt=min(nt,1);",
      "dir=if(equal(beat,1),-dir,dir);",
      "wave_r=abs(sin(time*2.3+1.23+cos(time*3.87+2.145)));",
      "wave_g=abs(sin(time*3.165+2.89+cos(time*1.74+.78)));",
      "wave_b=abs(sin(time*1.845+1.23+cos(time*2.6+3)));",
      "",
      "ob_r = wave_r;",
      "ob_g = wave_g;",
      "ob_b = wave_b;",
      "ib_r=1-.25*ob_r;",
      "ib_g=1-.25*ob_g;",
      "ib_b=1-.25*ob_b;",
      "ob_a=beat;ib_a=beat;",
      "wave_a=above(nt,0)*below(nt,.3)*sqr((3.-nt)/.3);",
      "zoom = 1 + 100*above(nt,.7)*(.3-(1-nt));",
      "vol=(vol+(bass+mid+treb)/3)/2;",
      "contVol = contVol+(vol-ContVol)*.1;",
      "",
      "q1=beat;",
      "q2=nt;",
      "q3=dir;",
      "q4=min(pow(2.8*contVol,3),25);",
      "q5=abs(cos(time/1.5 + 1.564));"
    ],
