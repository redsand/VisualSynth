      "//q1 = q1+0.5;",
      "",
      "q1=sin(time);",
      "q1sgn = sign(q1);",
      "q1=abs(q1);",
      "q1=pow(q1,6);",
      "q1=q1*q1sgn;",
      "q1=q1*0.4 + 0.5;",
      "",
      "",
      "",
      "q2 = .5 + .1*sin(time*.548);",
      "",
      "tic = min(time - tin,.1);",
      "tin = time;",
      "",
      "ra = 1;",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "",
      "rb = 1;",
      "vav = tic*(vav*(1/tic - rb) + rb*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb_avg;",
      "mt = mt + tic*mid_avg;",
      "bt = bt + tic*bass_avg;",
      "vt = vt + tic*(treb_avg+mid_avg+bass_avg)*.33333;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav;",
      "toc = 1;",
      "",
      "q3 = (treb + bass + mid)*.3333;",
      "q3 = q3*q3*0.5 + 0.1;",
      "q3 = min(q3,1.0);",
      "//q3=1.25;",
      "monitor = int(q3*4)/4;",
      "",
      "q4 = mt;",
      "q5 = bt;",
      "",
      "cx = q1;",
      "cy = q2;",
      "",
      "rmod = ((treb_avg + mid_avg)*.5 - bass_avg*0.5)*.01;",
      "rmod = 0.02 * pow(rmod/0.02 , 2)*7;",
      "rmod = min(0.001 , max(rmod, -0.001));",
      "rmod=rmod*pow(sin(time)*1.1,2);",
      "rot = 0.02 * pow(rmod/0.02 , 2) *40;",
      "",
      "q6 = rmod;",
      "",
      "q7 = slide - below(q3,.5)*(6 + 2*sin(time*24))*pow(min(1,(.5 - q3)*2),5);",
      "",
      "q8=if( above(sin(time*0.5),0) , -1 , 1);",
      "",
      "//echo_zoom=1+(above(treb,.8)+treb);"
    ],
