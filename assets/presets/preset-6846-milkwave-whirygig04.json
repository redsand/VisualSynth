      "sy = sy + if (above(y, 0.49 + 0.38*sin(3*time/Volt)), if(below(y, 0.51 + 0.38*sin(3*time/Volt)), if(below(rad, 1), -0.03*sin(bass), 0), 0), 0);",
      "dy = (dy + if",
