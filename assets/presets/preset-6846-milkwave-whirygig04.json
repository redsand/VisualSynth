      "rot=if(above(bnot(1*bass),bnot(1*treb)),rot*sin(rad*sin(time)),-rot*sin(rad*cos(time)));",
      "cx = 0.5 + 2.62786984*pow(warp * q1 , q2 * q3);",
      "warp = 1.331 + rot - bass_att;",
      "q2 = q1 + sy;",
      "dx = 0 + 2.98454583*pow(sy + rot , warp + q3);",
      "dy = 0 + 2.33245909*pow(rad + warp , bass_att * time);",
      "warp=if(below(warp,0.01), 0.01, warp);",
      "warp=if(above(warp,100.0), 100.0, warp);",
      "cx=if(below(cx,-1.0), -1.0, cx);",
      "cx=if(above(cx,2.0), 2.0, cx);",
      "dx=if(below(dx,-1), -1, dx);",
      "dx=if(above(dx,1.0), 1.0, dx);",
      "dy=if(below(dy,-1), -1, dy);",
