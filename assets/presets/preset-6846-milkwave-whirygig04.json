      "rot = rot + 0.00006*(0.1*(time))+(0.5*(0.5-rad))+rad;",
      "rot = rot - 0.1*sqr(0.5*cos(ang*time)*bass_att);",
      "zoom = zoom - 0.09*(sin(1-rad)*0.25*(0.25*(5-rad)));",
