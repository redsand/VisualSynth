    "perFrameInitCode": [],
    "perPixelCode": [
      "rad_cycle=rad*rad*x*60*rad*sin(q1);",
      "rot=if(above(q2,q8),.06*sin(rad_cycle-3*Sin(Q3)-x*ang*q3)*equal(Rad,x+y)*sin(Q6)-.3*sin(Q7",
      "),.02*sin(Q3));",
      "zoom =if(above(q2,q8), 2*rot*rad + 1 - 0.01*q1*rad-(1-y-.3*sin(Q4))+(y*.25*sin(Q2)),1.10);;",
      "zoomexp = 1 - 0.1*rad;",
      "dx=if(above(q2,q8),equal(x,raD)*sin(Q3)/y*sin(Q1),.009*sin(q5)*x*rad+d*sin(q2));",
      "dy=if(above(q2,q8),equal(y,rad)*sin(q2)/x*sin(q5),.009*sin(Q3)*y*rad+r*sin(q1));",
