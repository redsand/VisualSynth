  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n    ret = texture(sampler_main, vUv).xyz;\n    ret = ret*1.5 - 0.1;\n\n    vec4 g;\n    vec3 d = vec3(uTexSize.zw * 4, 0);\n    g.x = lum(GetBlur1(vUv + d.xz));\n    g.y = lum(GetBlur1(vUv - d.xz));\n    g.z = lum(GetBlur1(vUv + d.zy));\n    g.w = lum(GetBlur1(vUv - d.zy));\n\n    ret *= 0.7;\n    ret.x += clamp01(g.x-g.y)*5;\n    ret.z += clamp01(g.y-g.x)*5;\n    //ret.xy += (g.xz-g.yw)*3;\n\nret.x = GetBlur1(vUv).x - 0.03;\nret.z = GetBlur2(vUv).z*1.5 - 0.05;\nret *= 2.3;\n\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "warp = 0;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "vol = (bass_att + treb_att + mid_att)*.333333;",
      "",
      "ra = 1/tic*.1;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav*.2;",
      "toc = 1;",
      "",
      "q1 = 0;",
      "",
      "q2 = bt*.5 + 5;",
      "q3 = mt*.5 + 3;",
      "q4 = tt*.5;",
      "q5 = .1 + (treb_avg + mid_avg)*.2;",
      "",
      "zoom = 1 - bass_avg*.2;",
      "",
      "monitor = q5;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "coy = (coy + below(y,oy))*above(q1,0);",
      "cox = (cox + 1)*above(q1,0)*equal(coy,ocoy);",
      "",
      "moy = max(coy,moy);",
      "mox = max(cox,mox);",
      "",
      "nu = 4;",
      "pox = ((cox/nu) - int(cox/nu))*nu;",
      "poy = ((coy/nu) - int(coy/nu))*nu;",
      "",
      "",
      "mod = (1-2*above(x,.5))*(1-2*above(y,.5));",
      "",
      "dx = if(equal(coy%2,0),-equal(pox,1) + equal(pox,2),equal(pox,0) - equal(pox,3))*.001;",
      "dy = if(equal(coy%2,0),-equal(pox,1) + equal(pox,2),equal(pox,0) - equal(pox,3))*.001*mod;",
      "",
      "dis = (x + (1-y));",
      "",
      "mod = if(above(dis,1),dis - 1,1-dis);",
      "mod = below(mod,.2) + (1-min(1,(mod-.2)*4))*above(mod,.2)*1;",
      "",
      "zm = q5;",
      "modx = if(above(dis,1),zm,-zm);",
      "mody = if(above(dis,1),-zm,zm);",
      "",
      "",
      "dx = dx*mod + (1-mod)*modx;",
      "dy = dy*mod + (1-mod)*mody;",
      "",
      "rot = .3*mod;",
      "",
      "",
      "oy = y;",
      "ocoy = coy;",
      "q1 = q1 + 1;"
    ],
