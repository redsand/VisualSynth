  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "db=(bass-lbass)*fps;",
      "lbass=bass;",
      "avgdb=avgdb*.99+abs(db)*.01;",
      "",
      "//beatdection",
      "rawbeatb=above(db,avgdb);",
      "beatb=rawbeatb*above(time-lbbtime,.5*avgbeatrate);",
      "",
      "//beatrate calc",
      "bbtime=time*beatb;",
      "beatrate=beatb*(bbtime-lbbtime)+(1-beatb)*beatrate;",
      "avgbeatrate=beatb*(avgbeatrate*.999+beatrate*.001)+(1-beatb)*avgbeatrate;",
      "lbbtime=time*beatb+(1-beatb)*lbbtime;",
      "",
      "bc=bc+rawbeatb*sign(db)*int(vol*5)-beatb*2;",
      "",
      "//to reset or not to reset, thats the question",
      "//maxdb=max(maxdb*.9999,abs(db));",
      "rs=bor(above(abs(db),avgdb*100),below(abs(db),avgdb*.01))*rawbeatb;",
      "drs=1-rs;",
      "//reset",
      "avgbeatrate=beatrate*rs+avgbeatrate*drs;",
      "beatrate=4*rs+beatrate*drs;",
      "bbtime=1*rs+bbtime*drs;",
      "lbbtime=1*rs+lbbtime*drs;",
      "avgdb=db*rs+avgdb*drs;",
      "bc=bc*drs+(bc-1)*rs;",
      "//",
      "",
      "",
      "//(rawbeatb*(db-(avgdb))*.01;",
      "vol=(rawbeatb*(db-(avgdb))*.01);",
      "//avgvol=avgvol*(1-rawbeatb)+rawbeatb*(avgvol*.9+vol*.1);",
      "avgvol=avgvol*.99+vol*.05;",
      "",
      "mtime=mtime+min(avgvol*.5,.25);",
      "",
      "",
      "",
      "",
      "wave_r = .8*abs(cos( bass*.07*time+.532 + sin( .125*time+.789) ));",
      "wave_g = .8*abs(cos( treb*.092*time+2.1 + sin( .045*time+1.52) ));",
      "wave_b = .8*abs(cos( mid*.1*time+1.452 + sin( .112*time+2.98) ));",
      "",
      "q1=rawbeatb;",
      "wave_mystery = 1-1.5*min(((time-lbbtime)*.05),1.3);",
      "wave_a=if(above((time-lbbtime),1),.5,1);",
      "",
      "bc=if(above(bc,17),0,if(below(bc,0),17,bc));",
      "",
      "sx=if(equal(bc,15)*equal(frame%avgbeatrate,0),-1,sx);",
      "sy=if(equal(bc,16)*equal(frame%avgbeatrate,0),-1,sy);",
      "",
      "mtime=mtime+vol*.01;",
      "q2=bc;",
      "q3=cos(mtime)*.5+.5;",
      "decay=1;"
    ],
    "perFrameInitCode": [
      "beatrate=5;",
      "avgbeatrate=1;",
      "bbtime=1;",
      "lbbtime=.5;",
      "avgdb=.5;",
      "vol=1;",
      "avgvol=.2;",
      ""
    ],
    "perPixelCode": [
      "zoom =1+.01*sin(13.28*rad);",
      "//zoom right",
      "zoom=zoom+equal(q2,1)*q3*.1*(x-.5);",
      "// zoom left",
      "zoom=zoom+equal(q2,2)*q3*.1*(.5-x);",
      "// zoom top",
      "zoom=zoom+equal(q2,5)*q3*.1*(.5-y);",
      "// zoom bottom",
      "zoom=zoom+equal(q2,4)*q3*.1*(y-.5);",
      "// rotate left",
      "rot=rot+equal(q2,3)*q3*.3;",
      "// rotate right",
      "rot=rot-equal(q2,6)*q3*.3;",
      "// scale x",
      "sx=sx+equal(q2,7)*q3*.2;",
      "// squash y",
      "sy=sy-equal(q2,8)*q3*.2;",
      "// squash x",
      "sx=sx-equal(q2,9)*q3*.2;",
      "// scale y;",
      "sy=sy+equal(q2,10)*q3*.2;",
      "// transpose+ vertical",
      "dy=dy+equal(q2,11)*abs(.5-x)*sign(.5-x)*q3*.2;",
      "// transpose+ horiz",
      "dx=dx+equal(q2,12)*abs(.5-y)*sign(.5-y)*q3*.2;",
      "// transpose- horiz",
      "dx=dx-equal(q2,14)*abs(.5-y)*sign(.5-y)*q3*.2;",
      "// transpose- vertical",
      "dy=dy-equal(q2,13)*abs(.5-x)*sign(.5-x)*q3*.2;"
    ],
