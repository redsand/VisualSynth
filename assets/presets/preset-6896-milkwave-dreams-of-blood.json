      "",
      "//ob_size=1;",
      "//ob_a=min(.005/(sqr(q7-.5)+sqr(q8-.5)),.8);",
      "monitor=mytime;",
      "",
      "vol=(bass+mid+treb)*0.25;",
      "vol=vol*vol;",
      "mtime=mtime+vol*0.03*(75/fps);",
      "q8=mtime;",
      "",
      "xa=sin(mtime*0.6)*0.2;",
      "ya=sin(mtime*0.7)*0.2;",
      "za=sin(mtime*0.5);",
      "q4=xa;",
      "q5=ya;",
      "q6=za;",
      "decay=0.99;",
      "dy=-ya*0.004;",
      "dx=xa*0.004;",
      "",
      "x=xa/abs(za-10)+.5;",
      "y=ya/abs(za-10)+.5;",
      "cx=x;cy=y;",
      "sx=1 + za*0.004;",
      "sy=sx;"
