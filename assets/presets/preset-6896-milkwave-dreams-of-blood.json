    "perFrameCode": [
      "st=if(equal(st,0),time-131,st);",
      "mytime=time-st;",
      "",
      "phi=6.2831*(mytime+4.564)*.02;",
      "theta=6.2831*(mytime*.03+1.54);",
      "rho=6.2831*abs(sin(mytime*0));",
      "",
      "q1=phi;",
      "q2=theta;",
      "q3=rho;",
      "",
      "ax=0; ay=0; az=-30;",
      "bx = ax;",
      "by = ay*cos(q1) - az*sin(q1);",
      "bz = ay*sin(q1) + az*cos(q1);",
      "",
      "ax = bx*cos(q2) - bz*sin(q2);",
      "ay = by;",
      "az = bx*sin(q2) + bz*cos(q2);",
      "",
      "bx = ax*cos(q3) - ay*sin(q3);",
      "by = ax*sin(q3) + ay*cos(q3);",
      "bz = az;",
      "vx=bx; vy=by; vz=bz;",
      "",
      "//q7=vx/abs(vz-10)+.5;",
      "vy=-vy+1;",
      "//q8=vy/abs(vz-10)+.5;",
      "//q7=if(1-below(vz,0), -100,q7);",
