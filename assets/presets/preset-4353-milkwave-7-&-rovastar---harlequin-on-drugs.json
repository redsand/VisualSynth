    "perFrameCode": [
      "ob_r = 0.7 - 0.3*(0.5*sin(time*0.701)+ 0.3*cos(time*0.438));",
      "ob_g = 0.5- 0.4*sin(time*5.924);",
      "ob_b = 0.45 - 0.3*cos(time*0.816);",
      "warp =0;",
      "volume = 0.15*(bass_att+bass+mid+mid_att);",
      "beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));",
      "lastbeat = if(equal(lastbeat,0),time,lastbeat);",
      "meanbass_att = 0.1*(meanbass_att*9 + bass_att);",
      "peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);",
      "beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);",
      "beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);",
      "peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);",
      "lastbeat = if(beat,time,lastbeat);",
      "peakbass_att = max(if(beat,bass_att,peakbass_att),1.1*meanbass_att);",
      "q5 = if(beat,0.1*int(rand(1000)),oldq5);",
      "oldq5 = q5;",
      "q3 = if(beat,0.1*int(rand(1000)),oldq3);",
      "oldq3 = q3;",
      "ib_size = 0.02;",
      "ib_r = ib_r + 0.5*sin(time*2.424);",
      "ib_g = ib_g + 0.5*sin(time*2.247);",
      "ib_b = ib_b - 0.5*sin(time*1.131);",
      "dx = dx -0.008*(0.6*sin(time*0.23)+0.5*cos(time*0.153));",
      "dy = dy - 0.008*(0.6*sin(time*0.21)+0.5*cos(time*0.142));"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "box=abs(x*2-0.4*sin(q3))%2 + abs(y*2+0.4*sin(q5))%2;",
      "q1 = 4.05+(sin(x+0.237*time)-cos(y+0.513*time));",
      "zoom = if(above(box,1),q1*.1,zoom);",
      "rot = if(above(box,1),sin(0.885*time),0);",
      "dx = if(above(box,1),sin(0.542*time),dx);",
      "dy= if(above(box,1),sin(0.581*time),dy);",
      "dx = dx + above((0.5+0.5*sin(0.4*time))*x,(0.5+0.5*sin(0.5*time))*y)*0.95*box;",
      "dy = dy + above((1+sin(0.482*time))*x+(q+sin(0.373*time))*y,1)*0.95*box;"
