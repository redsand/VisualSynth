  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "g = 0.006/fps;    d = 0.99;    rad= .06;",
      "",
      "i1=0;         loop(n,",
      "",
      "x1=gmegabuf(4*i1);  y1=gmegabuf(4*i1+1);  sx1=gmegabuf(4*i1+2);  sy1=gmegabuf(4*i1+3);",
      "",
      "x1  = x1 +  sx1;                         y1  = y1 + sy1;",
      "sx1 = if(below(x1,0), abs(sx1)*d,sx1);   sy1 = sy1 - g;",
      "sx1 = if(above(x1,1),-abs(sx1)*d,sx1);   sy1 = if(below(y1,0), abs(sy1)*d, sy1);",
      "",
      "i2=i1+1;      loop(n-i1-1,",
      "",
      "x2=gmegabuf(4*i2);  y2=gmegabuf(4*i2+1);  sx2=gmegabuf(4*i2+2);  sy2=gmegabuf(4*i2+3);",
      "",
      "d1=sqrt(sqr(x1-x2)+sqr(y1-y2));",
      "d2=x1-x2+sx1-sx2;",
      "d3=y1-y2+sy1-sy2;",
      "",
      "hit = below(d1,rad) * above(d1, d2 + sqr(d3) );",
      "",
      "ang=atan2(x2-x1, y2-y1) + asin(1);",
      "s1 = sqrt(sx1*sx1 + sy1*sy1);",
      "s2 = sqrt(sx2*sx2 + sy2*sy2);",
      "w1 = atan2(sx1, sy1);",
      "w2 = atan2(sx2, sy2);",
      "",
      "sx1= if( hit, sin(ang)*s1*cos(w1-ang) + cos(ang)*s2*sin(w2-ang), sx1);",
      "sy1= if( hit, cos(ang)*s1*cos(w1-ang) - sin(ang)*s2*sin(w2-ang), sy1);",
      "sx2= if( hit, sin(ang)*s2*cos(w2-ang) + cos(ang)*s1*sin(w1-ang), sx2);",
      "sy2= if( hit, cos(ang)*s2*cos(w2-ang) - sin(ang)*s1*sin(w1-ang), sy2);",
      "",
      "",
      "gmegabuf(4*i2)=x2;   gmegabuf(4*i2+1)=y2;   gmegabuf(4*i2+2)=sx2;   gmegabuf(4*i2+3)=sy2;",
      "i2=i2+1; );",
      "",
      "gmegabuf(4*i1)=x1;   gmegabuf(4*i1+1)=y1;   gmegabuf(4*i1+2)=sx1;   gmegabuf(4*i1+3)=sy1;",
      "i1=i1+1; );"
    ],
    "perFrameInitCode": [
      "n=25;  loop(n,  sample=i/n;",
      "",
      "gmegabuf(4*i)  =.5+.03*pow(-1,i);",
      "gmegabuf(4*i+1)=.8+4*sample;",
      "",
      "i=i+1;);"
    ],
