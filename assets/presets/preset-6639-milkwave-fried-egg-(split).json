  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "warp = 0;",
      "",
      "tic = min(time-tin,.1);",
      "tin = time;",
      "",
      "vol = (bass_att + treb_att + mid_att)*.333333;",
      "",
      "ra = 1/tic*.25;",
      "",
      "treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);",
      "mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);",
      "bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);",
      "vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);",
      "",
      "tt = tt + tic*treb;",
      "mt = mt + tic*mid;",
      "bt = bt + tic*bass;",
      "vt = vt + tic*vav;",
      "",
      "sp = abs(vav - slide)*.1;",
      "slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav*.2;",
      "toc = 1;",
      "",
      "q1 = vt*.1;",
      "q3 = vt*4; // speed of zoomrings",
      "",
      "// for artefact rings",
      "q2 = (mt + tt)*.5;",
      "q5 = (treb_avg + mid_avg)*.1;",
      "q6 = .5 + .2*sin(bt*.279) + .25*sin(bt*.972); // artefact ring 2",
      "q7 = .5 + .2*sin(bt*.785) + .25*sin(bt*.489);",
      "q8 = bass_avg*.2;",
      "",
      ""
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "",
      "mod = max(0,cos(rad*3)*.03);",
      "zoom = 1 + mod;",
      "",
      "ti = time*-.6;",
      "rot = if(mod,sin((rad+ti)*6.2832)*.01,0);",
      "",
      "",
      "",
      "// needs q2,q5,q6,q7,q8",
      "a = .5 + .2*sin(q2*.687) + .25*sin(q2*.248); // artefact ring 1",
      "b = .5 + .2*sin(q2*.354) + .25*sin(q2*.724);",
      "dis = pow((x-a)*(x-a) + (y-b)*(y-b)*.75,.5);",
      "sw = below(abs(dis - q5),.005) + below(abs(dis - (q5-.1)),.01) + below(abs(dis - (q5-.2)),.015);",
      "",
      "a = q6;",
      "b = q7;",
      "dis = pow((x-a)*(x-a) + (y-b)*(y-b)*.75,.5);",
      "sw = sw + below(abs(dis - q8),.005) + below(abs(dis - (q8-.1)),.01) + below(abs(dis - (q8-.2)),.015);",
      "",
      "sw = if(sw,int(rand(3)),below(int(rand(int(fps*5))),1));",
      "//sw = if(mod,0,sw);",
      "sw = sw*pow(rad,2);",
      "zoom = zoom + sw*1;",
      "rot = rot + sw*1;",
      "",
      "mid = max(0,sin(rad*6.2832 - q3));",
      "mid = if(mod,mid*pow(1-cos(rad*3),5),mid);",
      "zoom = zoom + mid;"
