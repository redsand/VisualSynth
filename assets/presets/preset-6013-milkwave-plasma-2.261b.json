  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \nvUv=vUvOriginal+(vUv-vUvOriginal)*0.7; //too hard 4 us..\nret=GetPixel(vUv);\nvec2 mo=vUv-vUvOriginal;\nret=GetPixel(vUvOriginal+mo*lum(ret));\nret=mix(ret,GetPixel(vUvOriginal+mo/2),0.6);\nret=mix(ret,GetPixel(vUvOriginal-mo/2),0.9);\nret=(pow(ret,ret+1)+ret)*0.55-0.007;\n\n  fragColor = ret;\n}",
    "comp": null,
    "perFrameCode": [
      "//zoom = zoom*9;",
      "ib_r = sin(time*1.25*4)*0.3+0.7;",
      "ib_g = sin(time*4)*0.3+0.3;",
      "ib_b = sin(time/3*4)*0.5+0.5;",
      "",
      "mv_r = 1-ib_r;",
      "mv_g = 1-ib_g;",
      "mv_b = 1-ib_g;",
      "",
      "wave_r = 1- ib_r;",
      "wave_g = 1- ib_g;",
      "wave_b = 1- ib_b;",
      "//wave_mystery = -1+bass/2;",
      "wave_x = 0.5+sin(time*3)*0.3;",
      "wave_y = 0.5+cos(time*2.187)*0.3;",
      "q1=ib_r;",
      "",
      "//--fed's detection 1.3--",
      "boom = bass-oldbass;",
      "tick = treb-oldtreb;",
      "beep = mid-oldmid;",
      "",
      "crash = (boom*1.2+beep*0.7+tick*1.9)*0.3;",
      "beat = beat*0.5+(crash-oldcrash)*0.5;",
      "beat2 = beat2*0.5+beat*0.5;",
      "monitor = abs(beat2);",
      "",
      "out=abs(beat2);",
      "//-----------------------",
      "//rot=rot+0.1*beat2; //[rot]?[-rot] swtch",
      "q3=out/beat2;",
      "//cy=cy+0.8*beat2;",
      "//zoom=zoom+abs(beat)*1;",
      "cx=cx+0.05*(sin(time*1.2)*1.3-cos(time*0.9)*1.5);",
      "//ob_size=out*0.4;",
      "rot = rot+beat2*0.01;",
      "//-----------------------",
      "q2=out;",
      "q4=beat2;",
      "oldbass = bass;",
      "oldmid = mid;",
      "oldtreb = treb;",
      "oldcrash = crash;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "frm = 1/(rad*3+1);",
      "sy = sy+sin(x*3.1416*(1+q4*10)+time)*q4*1*frm;",
      "dx = dx + if(above(sin(x*3.1416*16+q4*3),0),-0.12*q4,0.12*q4)*frm;",
      "dy = dy+abs(sin(y*3.1416*8)*q4*0.2)*frm; //L beat",
      "_sx = sin(y*3.1416*4)*cos(x*3.1416*4)*0.3*q2*frm;",
      "//dy = dy-abs(_sx*_sx)*100; //haha lol...",
      "sx = sx+_sx;"
