  "_shaderData": {
    "warp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\nvec3 blur = lum(GetBlur1(fract(vUv)))*crumple;\nvec2 hor = vec2 (uTexSize.z,0)*8*blur;\nvec2 ver = vec2 (0,uTexSize.w)*8*blur;\nfloat dx = lum(texture(sampler_main,vUv+hor) - texture(sampler_main,vUv-hor));\nfloat dy = lum(texture(sampler_main,vUv+ver) - texture(sampler_main,vUv-ver));\nvec2 dz = vec2 (dx + (vUv.x-.5)*.0,dy+.0);\n\nuv1 = vec2 (abs(vUv.x-.5),vUv.y-.5);\n//uv1 = vec2(8*uv1.x*uv1.x,uv1.y*uv1.y*8);\n\nfloat teeth = sin((uv1.x)*142+1.5*sign(uv1.y-mouth_y))-mopen*.008/abs(uv1.y-mouth_y);\n\nfloat eyes = clamp01(eyerad/length(uv1-eyepos));\neyes = pow(eyes,4);\nfloat mouth = clamp01(.05/sqrt(uv1.x*uv1.x*mwidth + (.05/(.01+mshape*uv1.x))*(1+q15)/mopen*pow(uv1.y-mouth_y,2)));\nmouth = pow(mouth,3);\nmod = eyes + mouth*mopen;\nhole = pow(max(eyes,mouth),1);\n\nvec3 eyeball = clamp01(cos(1.4/eyerad*length(uv1-eyepos)))/3*(2-direct)*roam_sin*2;\neyeball = eyeball - (length(uv1-eyepos-.02*vec2(q9*0,q10-eyepos.y)) < .01*q15);\n\nnoise3 = lum(texture(sampler_noise_lq,uv1))+.5;\nuv1 += mod/4;\nteeth *= (mouth);\n\nvec2 ang2= texture(sampler_noise_hq,uv1/4+uTime/180).xy;\n//uv6 = multiply(uv1,mat2(ang2.y,-ang2.x,ang2.x,ang2.y));\nuv6 = uv1 + .5*(uv1*4*ang2);\nfloat mus = cos(uv6.y*18)+(sin(uv6.x*18));\nnoise2 = abs(mus)/6*(1+abs(crumple/16))+.2;\nnoise2 *= vec3 (1,.9,.8);\nnoise2 = mix(noise2,teeth,mouth);\nnoise2 = mix(noise2,eyeball,eyes);\nblur2 = GetBlur2(fract(noise3));\n\nvec3 crisp = GetPixel(fract(vUv+dz*.003));\n//crisp = max(crisp, .8*vec3(1,1,1)*GetPixel(vUv*1+.3)*clamp01(1-2*lum(GetPixel(vUv+.31))));\ncrisp += -0.0*blur2 - length(dz)*.1;\n\n\nret = crisp * (.99-hole/2*direct) -  .01 + noise2*(.045+hole*direct)  ;\n//ret = hole;\n//ret = 1-eyes;\n//ret = texture(sampler_shub1,uv1);\n\n  fragColor = ret;\n}",
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\nret = GetBlur3(vUv);\n\nvec2 uv2 = vUv*(1-.2*GetBlur3(clamp01(ret.xy))-.05*GetBlur1(clamp01(ret.xy)));\nuv2 += .1*GetBlur3(clamp01(ret.xy))+.025*GetBlur1(clamp01(ret.xy));\n\nvUv = mix(vUv,uv2,.75);\n\nret = mix(vec3(1,1,.65),vec3(1,.25,1),GetPixel(vUv)-.5*GetBlur1(vUv));\nret = mix(ret,vec3(.4,.4,.9),1.5*GetBlur2(vUv)-1.2*GetPixel(vUv));\nret = mix(ret,vec3(.4,.4,0),1.25*GetBlur3(vUv)-1.2*GetBlur2(vUv));\n\nret = 1-clamp01(ret);\n\n//ret *= pow(hue_shader,3);\n//    ret = pow(ret,vec3(.3,.55,1.8)); //gamma\n//    ret *= ret; //darken\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "q5 = 30/fps;",
      "",
      "//############## THIS IS A CONSTRUCTION SITE #########",
      "",
      "dt = min (1/fps,0.1) ; //Stability !",
      "dec_m = 1-dt*4; dec_s = 1 - dt; dec_xs = 1-dt/6;",
      "t0 = time - tstart;",
      "",
      "bd_b =  bass; bd_bass_ = bd_bass_*dec_m + (1-dec_m)*bd_b; bd_bass = bd_b-bd_bass_;",
      "bd_m =  mid ; bd_mid_  = bd_mid_ *dec_m + (1-dec_m)*bd_m; bd_mid =  bd_m -bd_mid_;",
      "bd_t =  treb; bd_treb_ = bd_treb_*dec_m + (1-dec_m)*bd_t; bd_treb = bd_t-bd_treb_;",
      "",
      "n = 0; BPM = bd_minbpm;",
      "loop (bd_nres,",
      "  gmegabuf(50000+n*bd_recsz) = 0;",
      "  bd_arg = BPM/60*t0*6.283;",
      "  gmegabuf (bd_tab0+n*bd_recsz) = BPM;",
      "  BPM *= bd_finc;",
      "n+=1);",
      "",
      "bd_src=0;",
      "loop (3, bd_exc = bd_bass*(bd_src==0) + bd_mid*(bd_src==1) + bd_treb*(bd_src==2);",
      "  oct = 0;",
      "  loop (bd_oct,",
      "    bd_slot = 0;",
      "    bd_pk = 0; bd_mean = 0.0;",
      "    loop (bd_spo,",
      "      bd_tabptr = bd_tab0 +                 (oct*bd_spo+ bd_slot)*bd_recsz;",
      "      n        =  bd_dat0 + (bd_nres*bd_src +oct*bd_spo+ bd_slot)*bd_recsz;",
      "      BPM = gmegabuf(bd_tabptr); bd_omega = BPM/60*6.283;",
      "      Feder = sqr(bd_omega); //Res.f = sqrt (Feder)/2pi (Hz)",
      "      gmegabuf (n+4) = gmegabuf(n+2); //alte pos",
      "      gmegabuf (n+1) *= 1-.5*dt * sqrt (BPM/300); //damping",
      "",
      "      EC_Steps = int (1 + BPM/50)*2;",
      "      loop (EC_Steps, // Euler-Cauchy steps",
      "        Kraft = bd_exc - Feder*gmegabuf(n + 2) ;",
      "        gmegabuf (n+1) += Kraft         * dt/EC_Steps;",
      "        gmegabuf (n+2) += gmegabuf(n+1) * dt/EC_Steps;",
      "      );",
      "      beatcos = gmegabuf(n+1);  beatsin = gmegabuf(n+2)*bd_omega;",
      "      quad = sqrt (pow(beatsin,2) + pow(beatcos,2));",
      "      gmegabuf (n) = gmegabuf(n)*0.8 + 0.2*quad;",
      "      bd_ampl = gmegabuf(n);",
      "      bd_mean += bd_ampl;",
      "      if (bd_ampl > bd_pk, bd_pk=bd_ampl, 0);",
      "    bd_slot +=1;);",
      " // Komb. bass,mid,treb",
      "    bd_slot = 0;",
      "    bd_qual = pow(bd_pk/bd_mean*bd_spo-1,1);",
      "    gmegabuf((bd_src*bd_oct+oct)*2) = bd_qual;",
      "    loop (bd_spo,",
      "      m =  50000 + (bd_slot + 0*oct*bd_spo)*bd_recsz;",
      "      n =  bd_dat0 + (bd_nres*bd_src +oct*bd_spo+ bd_slot)*bd_recsz; //#2x berechnet",
      "      gmegabuf(m) += (bd_qual)*gmegabuf (n)/12;",
      "    bd_slot +=1;);",
      "  oct += 1;);",
      "bd_src +=1;);",
      "",
      "",
      "//Get maxind",
      "bd_slot = 0; maxind = 0; bd_pk = 0; bd_mean = 0;",
      "loop (bd_spo,",
      "   m =  50000 + bd_slot*bd_recsz;",
      "   gmegabuf(m) = pow(gmegabuf(m),1);",
      "   bd_mean += gmegabuf(m);",
      "   if (gmegabuf(m) > bd_pk, bd_pk = gmegabuf(m); maxind = bd_slot, 0);",
      "bd_slot += 1);",
      "quali = bd_pk/bd_mean*bd_spo-1;",
      "",
      "n = 0; loop (150, gmegabuf(50+n) *= 0; n+=1);",
      "",
      "//KREISE",
      "bd_src = 0; tsin = 0; tcos = 0;",
      "loop (3,",
      "  oct = 0;",
      "  loop (bd_oct,",
      "    n         =  bd_dat0 + (bd_nres*bd_src +oct*bd_spo+ maxind)*bd_recsz;",
      "    bd_tabptr = bd_tab0  +                 (oct*bd_spo+ maxind)*bd_recsz;",
      "    BPM = gmegabuf(bd_tabptr);",
      "",
      "    im =  gmegabuf(n+1);",
      "    re =  gmegabuf(n+2) * BPM/60*6.283;",
      "    bd_cos =  cos (BPM/60*6.28*time);",
      "    bd_sin = -sin (BPM/60*6.28*time);",
      "",
      "//Winkel zurueckdrehen. Das sind nun die Winkel relativ zu cos(oct*time).",
      "    re0 =  re*bd_cos + im*bd_sin;",
      "    im0 = -re*bd_sin + im*bd_cos;",
      "    bd_qual = gmegabuf((bd_src*bd_oct+oct)*2);",
      "    gmegabuf (50+oct*4)   +=  bd_qual * (im0)*1;",
      "    gmegabuf (50+oct*4+1) +=  bd_qual * (re0)*1;",
      "    gmegabuf (50+oct*4+2) +=  bd_qual;",
      "",
      "//Summe der besten Beitraege. Das ist der Referenzwinkel.",
      "    gmegabuf (100+0)  +=  bd_qual * im0;",
      "    gmegabuf (100+1)  +=  bd_qual * re0;",
      "",
      "//Nun sollten wir die Differenzwinkel zur Ref berechnen. Und was damit ? Dann kann ich die",
      "//Einzelwinkel auf Ref bringen - bringt doch nichts !",
      "//Ich kann alle auf Null drehen, daraus sinusse erzeuge und addieren ->besserer Takt ?",
      "    re =  (bd_cos*re0 + bd_sin*im0);",
      "    im =  (-bd_cos*im0 + bd_sin*re0);",
      "tsin += im*5;",
      "//rsin == re*5;",
      "",
      "  oct += 1);",
      "bd_src +=1);",
      "q27 = 10*bd_pk;",
      "q30 = tsin;",
      "",
      "q23 = quali;",
      "",
      "q24 = bd_ampl*10;",
      "",
      "volAmpl = volAmpl*(1 - .0225) + 10*bd_ampl*.0225;",
      "q25 = volAmpl;",
      "",
      "q22 = .98*pow(q23*q25, .02);",
      "",
      "vol = bass_att + mid_att + treb_att;",
      "vol_ = vol_*0.95 + 0.05*vol;",
      "q29 = vol-vol_;",
      "",
      "//Welche Oktave ???",
      "bd_src = 0; maxo = 0; maxs = 0; maxa = 0;",
      "loop (3,",
      "  oct = 1;",
      "  loop (bd_oct-1,",
      "    n =  bd_dat0 + (bd_nres*bd_src +oct*bd_spo+ maxind)*bd_recsz;",
      "    bd_qual = gmegabuf((bd_src*bd_oct+oct)*2);",
      "",
      "    ampl = bd_qual / (1+oct*(maxind/bd_oct)*0);",
      "    if (ampl>maxa, maxa = ampl; maxs = bd_src; maxo = oct;, 0);",
      "  oct += 1);",
      "bd_src +=1);",
      "",
      "q31 = bd_qual;",
      "//q31 = q28;",
      "q32 = 4/bd_qual;",
      "//if(above(q28,50),q28 = pow(5*sin(.5*bd_qual), 2), 0);",
      "",
      "//Beat-Flash",
      "testi = bd_nres*maxs +bd_spo*maxo + maxind;",
      "if (bor (beat && (prog==0), abs(testi-test0)<2),test0 = testi,0);",
      "n =  bd_dat0 + (test0)*bd_recsz;",
      "creep = gmegabuf(n+1);",
      "beat_foo =  (creep>0) * (creepo <0);",
      "//beatct = if (change, 0, beatct+beat);",
      "//prog = (prog+beat)%8;",
      "creepo = creep;",
      "show = if (beat, 1, show*0.5);",
      "q4 = (gmegabuf(n+1)/gmegabuf(n)*1000);",
      "",
      "",
      "if(beat_foo, timediff_h = time - time_st_h; time_st_h = time, timediff_h = timediff_h);",
      "if(above(timediff_h, 100), timediff_h = 1, timediff_h = timediff_h);",
      "q1 = timediff;",
      "avgtime_h = avgtime_h*(1 - .025*sqrt(q5)) + q1*.025;",
      "q2 = avgtime_h;",
      "",
      "",
      "finsComp_pf = finsComp;",
      "if((finsComp == floor((n - 100000)*.004)),",
      "    finTime_st = time; finTime = time - finTime_st; finsComp = floor((n - 100000)*.004),",
      "    if(finTime < 2.5,",
      "        finsComp_pf = finsComp; finTime = time - finTime_st,",
      "        finsComp = floor((n - 100000)*.004); finTime_st = time));",
      "if(above(finTime, 300), finTime_st = time, 0);",
      "q26 = floor(finsComp_pf);",
      "",
      "",
      "dt = min (time-otime,0.1) ; //Stability !",
      "otime = time;",
      "dec_f = 0.8; dec_m = 1 - 4*dt; dec_s = 1 - dt;dec_xs = 1 - dt/4;",
      "vol = (bass_att + mid_att + treb_att);",
      "avg = avg*dec_m + (1-dec_m)*vol;",
      "",
      "exc = atan(vol-avg)/3;",
      "exc_ = exc*0.8 + 0.2*exc*2;",
      "",
      "//exc = sin(time*6.283)*0.1;",
      "",
      "ring = 0; maxind = 0; maxv = 0; sum=0;",
      "",
      "loop (num_rings,",
      "  n = ring * ringsize;",
      "  size = megabuf(n+ringsize-1);;",
      "  excite = exc*(size)/size0;",
      "  memcpy (n+1,n,ringsize-5); //!!!wichtig",
      "  megabuf (n) = megabuf(n+size)*(1-0.003*size) + excite;",
      "  sig = megabuf(n);",
      "",
      "  dec = 1-0.4/size; //slow",
      "  m = n+ringsize-2;",
      "  megabuf (m) = dec*megabuf(m) + (1-dec)* pow(sig,2);",
      "  mean = sqrt(megabuf(m));",
      "  gmegabuf(5000+ring) = mean;",
      "  if (mean > maxv , maxv = mean; maxind = ring, 0);",
      "",
      "  dec = 1-2/size; //fast",
      "  m = n+ringsize-3;",
      "  megabuf (m) = dec*megabuf(m) + (1-dec)* pow(sig,2);",
      "  mean = sqrt(megabuf(m)); //fast",
      "  gmegabuf(6000+ring) = mean;",
      "",
      "  sig2 = (megabuf(n+size)+megabuf(n)+megabuf(n+1) )/3;",
      "  if (sig > 1.2*mean, trip=1, trip=0);",
      "  m = n+ringsize-4;",
      "  megabuf (m) = trip;",
      " ring += 1;",
      ");",
      "",
      "beat = megabuf(maxind*ringsize+ringsize-4);",
      "//t0 = if (beat, time, t0);",
      "//q8 = bor (beat, time-t0<0.1);",
      "//if (beat, t0=time, 0);",
      "q21 = mean;",
      "q17 = pow(mean/(q25), .35);",
      "",
      "n = 0;",
      "loop (num_rings*ringsize,",
      "  gmegabuf (n) = megabuf(n);",
      "n += 1);",
      "",
      "if(beat, timediff = time - time_st; time_st = time, timediff = timediff);",
      "if(above(timediff, 100), timediff = 1, timediff = timediff);",
      "q8 = timediff;",
      "//q2 = pow(.3, q8);",
      "avgtime = avgtime*(1 - .025*sqrt(q5)) + q8*.025;",
      "q9 = avgtime;",
      "",
      "",
      "//Selbst bei Barbie Girl fehlt manchmal der Rhythmus in Band 2,",
      "//obwohl das der gefuehlte Takt ist - >Problem mit Phasenkorrektur !",
      "//stehen Phasen bei doppelter Frequenz in Relation ? NEIN.",
      "",
      "",
      "",
      "",
      "",
      "//Problem: Fats Domino (1992) hat 55BPM -> Problem mit 110",
      "//Problem: 1991 London Beat I been thinking about you - geht nicht - solved",
      "//Problem: U96 - Love religion (1995) beginnt mit BPM < 20",
      "//Porblem: adiemus (1995)",
      "//Konflikt-Beat siehe Michale jackson b&W (1991)",
      "",
      "",
      "//q24 = bd_maxbpm;",
      "q18 = pixelsx;",
      "",
      "",
      "",
      "old_bass_flop=bass_flop;",
      "old_treb_flop=treb_flop;",
      "old_mid_flop=mid_flop;",
      "chaos=.9+.1*sin(pulse);",
      "entropy=if(equal(pulse,-20),1+bass_flop+treb_flop+mid_flop+q4*.002,entropy);",
      "bass_thresh = above(bass_att,bass_thresh)*2 + (1-above(bass_att,bass_thresh))*((bass_thresh-1.6)*chaos+1.6);",
      "bass_flop=abs(bass_flop-equal(bass_thresh,2));",
      "treb_thresh=above(treb_att,treb_thresh)*2 + (1-above(treb_att,treb_thresh))*((treb_thresh-1.6)*chaos+1.6);",
      "treb_flop=abs(treb_flop-equal(treb_thresh,2));",
      "mid_thresh=above(mid_att,mid_thresh)*2 + (1-above(mid_att,mid_thresh))*((mid_thresh-1.6)*chaos+1.6);",
      "mid_flop=abs(mid_flop-equal(mid_thresh,2));",
      "bass_changed=bnot(equal(old_bass_flop,bass_flop));",
      "mid_changed=bnot(equal(old_mid_flop,mid_flop));",
      "treb_changed=bnot(equal(old_treb_flop,treb_flop));",
      "bass_residual = bass_changed*sin(pulse*1.5) + bnot(bass_changed)*bass_residual;",
      "treb_residual = treb_changed*sin(pulse*1.5) + bnot(treb_changed)*treb_residual;",
      "mid_residual = mid_changed*sin(pulse*1.5) + bnot(mid_changed)*mid_residual;",
      "pulse=if(above(abs(pulse),20),-20,pulse+(bass_thresh+mid_thresh+treb_thresh)*.018);",
      "q11=mid_residual;",
      "q12=bass_residual;",
      "q13=treb_residual;",
      "q14=sin(pulse);",
      "q15=cos(pulse*(.5+.1*entropy));",
      "q16=sin(pulse*(.5+pow(.25,entropy)));",
      "if(above(mid + treb, bass*2), ib_r = .55 - abs(.6*sin( - 3*sqrt(q3 + q29)*bass_att*bass_att)), ib_r = .55 + abs(.55*sin( - 3*sqrt(q3 + q29)*bass_att*bass_att)));",
      "if(above(bass + treb, mid*2), ib_g = .55 - abs(.6*sin( - sqrt(q23)*mid*mid)), ib_g = .5 + abs(.55*sin( - sqrt(q23)*mid*mid)));",
      "if(above(mid + bass, treb*2), ib_b = .55 - abs(.6*sin( - sqrt(q29)*treb_att*treb_att)), ib_b = .55 + abs(.55*sin( - sqrt(q29)*treb_att*treb_att)));",
      "ob_r = .5 - .55*sin( - 3*sqrt(q3 + q29)*bass*_attbass_att);",
      "ob_g = .5 - .55*sin( - sqrt(q23)*mid*mid);",
      "ob_b = .5 - .55*sin( - sqrt(q29)*treb_att*treb_att);",
      "ib_size=.03+.02*q12;",
      "ob_size=.02+.015*sin(time*2.321+q12*.2);",
      "ob_a=.9+.1*q13;",
      "ib_a=.9+.1*sin(q12*.3+q14+q11*.5);",
      "rot=0;",
      "",
      "",
      "q10 = -.1*sqrt(q9*q2)*sign(q12);",
      "",
      "",
      "vol2 = pow(bass+mid+treb,2);",
      "basssum = vol2;",
      "",
      "stickybit = time%2;",
      "",
      "//avg vol",
      "//buffer 1",
      "volAvg = volAvg + vol2*equal(stickybit,1);",
      "//number of samples 1 or framerate",
      "sample1 = sample1 + equal(stickybit,1);",
      "//buffer 2",
      "volAvg2 = volAvg2 + vol2*equal(stickybit,0);",
      "//number of samples 2",
      "sample2 = sample2 + equal(stickybit,0);",
      "",
      "//transision",
      "edge = bnot(equal(bit2,stickybit));",
      "",
      "volAvg = volAvg - volAvg*edge*stickybit;",
      "volAvg2 = volAvg2 - volAvg2*edge*equal(stickybit,0);",
      "",
      "sample1 = sample1  - sample1*edge*stickybit;",
      "sample2 = sample2  - sample2*edge*equal(stickybit,0);",
      "",
      "//test vol against avg buffer lvl",
      "diff = if(equal(stickybit,1), (basssum/(volAvg2/sample2)) , 0);",
      "diff = if(equal(stickybit,0), (basssum/(volAvg/sample1)), diff);",
      "",
      "q3 = diff;",
      "",
      "pv_beat = 0.1*(pow(q3, .75) + q29)/sqrt(.3*q27);",
      "q6 = pv_beat;",
      "",
      "bit2 = time%2;",
      "",
      "difftime = difftime + diff*0.03;",
      "//q2 = difftime;",
      "",
      "warp = (bass*bass + mid*mid + treb*treb)*.001;",
      "",
      "",
      "",
      "//monitor = sqrt(q23 - .5*q27);",
      "monitor = q10;"
