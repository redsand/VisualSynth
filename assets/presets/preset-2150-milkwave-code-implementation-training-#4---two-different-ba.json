    "comp": null,
    "perFrameCode": [
      "timepeak = if(equal(time%0.1, 0),timepeak=timepeak+0.01, timepeak); //the timepeak variable increases using the time variable in sync",
      "timepeak2 = if(equal(time%0.1, 0),timepeak2=timepeak2+0.01, timepeak2); //another one, but the same thing.",
      "",
      "/////////////TRIGGER OPTION////////////////",
      "",
      "//Simple Bass Trigger//",
      "//timepeak = if(above(bass, 2),timepeak=0, timepeak); //reset the timepeak vaariable if the beat is below 2 (trigger algorithm) (commented this because not necessary)",
      "",
      "//Bass Trigger with Delay//",
      "bassdelay = timepeak>0.5; //declared the another variable with the simple condition",
      "beatdelaytrigger = if(bassdelay, if(above(bass, 2), timepeak=0, timepeak), bleh); //another simple declaration, if the beat triggered with the delay above 0.5, it actually resets the timepeak variable to 0.",
      "",
      "//Another Bass Trigger with Delay + count feature//",
      "bassdelay2 = timepeak2>1; //same as the 2nd option, but the delay of 1 second.",
      "beatdelaytrigger2 = if(bassdelay2, if(above(bass, 2), timepeak2=0, timepeak2), bleh);",
      "",
      "count = if(bassdelay2, if(above(bass, 2), count=count+1, count), count); //it increments if it triggered the bass with the delay of 1 second.",
      "count = if(count%8==0, count=0, count); //it resets to 0 if it passes to 8;",
      "",
      "//debugging",
      "monitor = count;",
      "q1=timepeak; //we carry this variable to custom shapes, waves etc.",
      "q2=timepeak2;",
      "q3=count;",
      "",
      "",
      "//for preset testing",
      "decay=0;",
      "wave_a=0;"
    ],
