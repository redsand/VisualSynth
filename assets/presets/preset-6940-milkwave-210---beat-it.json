  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "// -------------------------------- Beat Detective 007 ----------------------------------",
      "sure=if(equal(sure,0),.6,sure);",
      "interval=if(equal(interval,0),40,interval);",
      "lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);",
      "dbass=(bass-pbass)/FPS;",
      "beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);",
      "sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),",
      "min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);",
      "sure=max(.5,sure);",
      "cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);",
      "beat=if(cheat,1,beat);",
      "sure=if(cheat,.95*sure,sure);",
      "maxdbass=max(maxdbass*.999,dbass);",
      "maxdbass=max(.012,maxdbass);",
      "maxdbass=min(.02,maxdbass);",
      "interval=if(beat, frame-lastbeat,interval);",
      "lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);",
      "cheat=0;",
      "pbass=bass;",
      "// ----------------------------------------------------------------------------------------------",
      "warp=0; beats=beats+beat;",
      "wm = if( equal(beat,1), int(rand(8)),wm);",
      "",
      "wave_mode =if( equal(wm,wave_mode),(wm+1)%8,wm);",
      "wmy=if(equal(beat,1), .5 - int(rand(100))/100 ,wmy);",
      "wave_mystery = wmy;",
      "",
      "wave_r=abs(sin(time*1.3+1.23+cos(time*2.87+2.145)));",
      "wave_g=abs(sin(time*2.165+2.89+cos(time*.74+.78)));",
      "wave_b=abs(sin(time*.845+1.23+cos(time*1.6+3)));",
      "time=time-1;",
      "ob_r=abs(sin(time*1.3+1.23+cos(time*2.87+2.145)));",
      "ob_g=abs(sin(time*2.165+2.89+cos(time*.74+.78)));",
      "ob_b=abs(sin(time*.845+1.23+cos(time*1.6+3)));",
      "time=time+1;",
      "decay=.9;",
      "vol=bass+mid+treb; sgn=-1+2*equal(beats%2,1);",
      "wx=if( equal(beat,1), .25+int(rand(50))/100,wx);",
      "wy=if( equal(beat,1), .25+int(rand(50))/100,wy);",
      "wave_x=wx; wave_y =wy; cx=wx; cy=wy;",
      "lr=if( equal(beat,1), (.5-int(rand(100))/100)* .03*sgn,lr);",
      "ud=if( equal(beat,1), (.5-int(rand(100))/100)* .03*sgn,ud);",
      "r=if( equal(beat,1), int(rand(500))/1000-.25,r);",
      "q = min( 1, (frame-lastbeat)/interval );",
      "vol=(bass_att+mid_att+treb_att);",
      "myVol=.95*myVol+.05*vol;",
      "dx=dx+lr*log(myVol*(1-q));",
      "dy=dy+ud*log(myVol*(1-q));",
      "monitor=beats;",
      "",
      "rot=if(below(q,.5), r*log(1-(q/.5)),0);",
      "zoom=if(below(q,.5), 1- .03*exp(1-q/.5),zoom);",
      "zoom=if(above(q,.5)*below(q,.99), 1+ .03*exp((q-.5)/.5),zoom);",
      "decay = max(.9,(1.03-zoom)/.03);",
      "decay=min(decay,1);"
    ],
