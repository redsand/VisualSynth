  "_shaderData": {
    "warp": null,
    "comp": null,
    "perFrameCode": [
      "mv_l = 1.21894646*rand(int(ob_size * zoom));",
      "wave_y = bnot(wave_y + mv_b);",
      "zoomexp = -1.9620862*abs(1.40700197*log10(wave_b * wave_mode));",
      "mv_b = zoom * cx;",
      "dy = if(below(sy * ob_r , mv_b * mv_x) , sigmoid(mv_l * dy , ib_size * mv_y) , ob_a * mv_x);",
      "mv_l = mv_l * warp;",
      "mv_x = 0.68256116*abs(mv_a - mv_r);",
      "wave_y = sigmoid(sigmoid(wave_y * zoomexp , ib_a * ib_g) , ib_b + mv_l);",
      "zoomexp=if(below(zoomexp,0.01), 0.01, zoomexp);",
      "zoomexp=if(above(zoomexp,100.0), 100.0, zoomexp);",
      "dy=if(below(dy,-1), -1, dy);",
      "dy=if(above(dy,1.0), 1.0, dy);",
      "wave_y=if(below(wave_y,0.0), 0.0, wave_y);",
      "wave_y=if(above(wave_y,1.0), 1.0, wave_y);",
      "mv_b=if(below(mv_b,0.0), 0.0, mv_b);",
      "mv_b=if(above(mv_b,1.0), 1.0, mv_b);",
      "mv_x=if(below(mv_x,0.0), 0.0, mv_x);",
      "mv_x=if(above(mv_x,64.0), 64.0, mv_x);",
      "mv_l=if(below(mv_l,0.0), 0.0, mv_l);",
      "mv_l=if(above(mv_l,5.0), 5.0, mv_l);",
      "vol_now =  .4 * bass + 0.1 * (bass_att + treb + mid);",
      "vol_mean =  if(equal(frame%50,0),vol_mean - 0.5 * (vol_mean-vol_now),0.1 * (vol_mean * 9 + vol_now));",
      "beat = if(above(vol_now,1.15 * vol_mean),1,0);",
      "slowtime = slowtime + beat*time;",
      "q2=sin(slowtime);",
      "ob_a = q2*.2;",
      "temp_b = cos(slowtime)  + abs(cos(slowtime));",
      "temp_g = abs(sin(slowtime)) ;",
      "temp_r =  (-1 * cos(slowtime))  + abs(-1 * cos(slowtime)) + 0.2 * (cos(sin(slowtime))+(abs(cos(sin(slowtime)))+cos(sin(slowtime))));",
      "ob_r = if(above(temp_r,1),1,if(above(temp_r,0), abs(temp_r),0));",
      "ob_g = if(above(temp_g,.5),.5,if(above(temp_g,0), abs(temp_g),0));",
      "ob_b = if(above(temp_b,1),1,if(above(temp_b,0), abs(temp_b),0));",
      "ib_r =  1- if(above(temp_r,1),1,if(above(temp_r,0), abs(temp_r),0));",
      "ib_g =  1- if(above(temp_g,1),1,if(above(temp_g,0), abs(temp_g),0));",
      "ib_b =  1- if(above(temp_b,1),1,if(above(temp_b,0), abs(temp_b),0));",
      "wave_b = temp_b;",
      "wave_g = 1-temp_g;",
      "wave_r = 1-equal(ob_b,1)*temp_r;",
      "beatcount = beatcount + beat;",
      "q3 = beatcount;"
    ],
    "perFrameInitCode": [],
    "perPixelCode": [
      "warp = 0.36676717*pow(q2 - y , q2 * q1);",
      "warp = 1.82335234*pow(-0.69122636*log10(warp * q2) , q1 * x);",
      "cx = -0.51261795*sqrt(q3 * q1);",
      "warp=if(below(warp,0.01), 0.01, warp);",
      "warp=if(above(warp,100.0), 100.0, warp);",
      "cx=if(below(cx,-1.0), -1.0, cx);",
      "cx=if(above(cx,2.0), 2.0, cx);"
    ],
