  "_shaderData": {
    "warp": null,
    "comp": "#version 300 es\nprecision highp float;\n\n// VisualSynth uniforms\nuniform float uTime;\nuniform float uFrame;\nuniform float uFps;\nuniform float uRms;\n\n// Audio uniforms\nuniform float audioLow;      // bass\nuniform float audioLowSmooth; // bass_att\nuniform float audioMid;      // mid\nuniform float audioMidSmooth; // mid_att\nuniform float audioHigh;     // treb\nuniform float audioHighSmooth; // treb_att\n\n// Screen uniforms\nuniform float uAspectX;\nuniform float uAspectY;\nuniform vec2 uAspect;\nuniform vec2 uTexSize;\n\n// Random values\nuniform vec2 uRandomPreset;\nuniform vec2 uRandomFrame;\n\n// Input from vertex shader\nin vec2 vUv;\nin float vRadius;\nin float vAngle;\n\n// Output\nout vec4 fragColor;\n\n// Textures\nuniform sampler2D sampler_main;\nuniform sampler2D sampler_noise_lq;\nuniform sampler2D sampler_noise_mq;\nuniform sampler2D sampler_noise_hq;\nuniform sampler2D sampler_blur1;\nuniform sampler2D sampler_blur2;\nuniform sampler2D sampler_blur3;\n\n// Helper functions\nfloat clamp01(float x) { return clamp(x, 0.0, 1.0); }\nvec2 clamp01(vec2 x) { return clamp(x, vec2(0.0), vec2(1.0)); }\nvec3 clamp01(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nvec4 clamp01(vec4 x) { return clamp(x, vec4(0.0), vec4(1.0)); }\n\n// Texture helper functions\nvec4 GetPixel(vec2 uv) { return texture(sampler_main, uv); }\nvec4 GetBlur1(vec2 uv) { return texture(sampler_blur1, uv); }\nvec4 GetBlur2(vec2 uv) { return texture(sampler_blur2, uv); }\nvec4 GetBlur3(vec2 uv) { return texture(sampler_blur3, uv); }\n\n\nvoid main() {\n  vec4 ret = vec4(0.0);\n  vec2 uv = vUv;\n  float rad = vRadius;\n  \n\n//Code bits by Flexi and Geiss\n\n    vec2 d = uTexSize.zw*6;\n    vec3 dx = ( GetBlur1(vUv+vec2(1,0)*d)-GetBlur1(vUv-vec2(1,0)*d) );\n    vec3 dy = ( GetBlur1(vUv+vec2(0,1)*d)-GetBlur1(vUv-vec2(0,1)*d) );\nvec2 uv_y = vUv-.25*(vec2(lum(dx),lum(dy)));\nvec2 uv_y2 = vUv+.25*(vec2(lum(dx),lum(dy)));\n\n\nret = .8*GetBlur3(uv_y)-GetBlur1(uv_y);\nret += .6*GetBlur1(vUv);\nret -= (GetBlur2(uv_y2)-GetBlur1(uv_y2));\nret += 1.2*GetPixel(uv_y2)+.15*GetBlur1(uv_y2);\nret += .9;\nret = lum(ret);\nret -= .15*lum(tex2d(sampler_noise_hq,(vUv+.01*uTime)));\nret = mix(ret,.75*ret*lum(.6*GetBlur3(uv_y)-.7*GetPixel(vUv)-.3*GetBlur1(uv_y2)),pow(hue_shader,ret));\nret *= .8;\nret *= ret;\nret = sqrt(ret);\n\n\n  fragColor = ret;\n}",
    "perFrameCode": [
      "zoom = 1.001;  warp =0.075; decay = 0.993; vol = (bass+mid+treb)/3;",
      "b1x = if( equal( b1x, 0 ), .25+int(rand(50))/100, b1x );",
      "b1y = if( equal( b1y, 0 ), .25+int(rand(50))/100, b1y );",
      "b1vx = if( equal( b1vx, 0 ), 0.008*(-.5+int(rand(100))/100), b1vx );",
      "b1vy = if( equal( b1vy, 0 ), 0.008*(-.5+int(rand(100))/100), b1vy );",
      "b2x = if( equal( b2x, 0 ), .25+int(rand(50))/100, b2x );",
      "b2y = if( equal( b2y, 0 ), .25+int(rand(50))/100, b2y );",
      "b2vx = if( equal( b2vx, 0 ), 0.008*(-.5+int(rand(100))/100), b2vx );",
      "b2vy = if( equal( b2vy, 0 ), 0.008*(-.5+int(rand(100))/100), b2vy );",
      "",
      "// o Resolve forces",
      "distX = ( b1x -b2x ); distY = ( b1y - b2y ); fAngle = atan2( distY, distX );",
      "dist = sqrt(sqr(distX)+sqr(distY));",
      "k = vol/sqr(dist);k=max(0.001,k);k=min(0.02,k);",
      "k = if(above(fCrashPhase,0),0,k);",
      "b1vx=b1vx+k*cos(fAngle-3.14)/FPS;",
      "b1vy=b1vy+k*sin(fAngle-3.14)/FPS;",
      "b2vx=b2vx+k*cos(fAngle)/FPS;",
      "b2vy=b2vy+k*sin(fAngle)/FPS;",
      "Blue=if( above(sqrt(sqr(b2vx)+sqr(b2vy) ) , sqrt( sqr(b1vx)+sqr(b1vy) )), 1, 0);",
      "",
      "// o Apply motion",
      "iIndex = (frame%4);",
      "fScale = if( above(iIndex,1),(1+.3*bass)*30/FPS,(1+.3*treb)*30/FPS);",
      "b1x = b1x + b1vx*fScale;      b1y = b1y + b1vy*fScale;",
      "b2x = b2x + b2vx*fScale;      b2y = b2y + b2vy*fScale;",
      "",
      "// o Collision and \"keep-in-screen\" check",
      "b1vx = if( above( b1x, 1 ), -b1vx, b1vx );",
      "b1vx = if( below( b1x, 0 ), -b1vx, b1vx );",
      "b1vy = if( above( b1y, 1 ), -b1vy, b1vy );",
      "b1vy = if( below( b1y, 0 ), -b1vy, b1vy );",
      "b2vx = if( above( b2x, 1 ), -b2vx, b2vx );",
      "b2vx = if( below( b2x, 0 ), -b2vx, b2vx );",
      "b2vy = if( above( b2y, 1 ), -b2vy, b2vy );",
      "b2vy = if( below( b2y, 0 ), -b2vy, b2vy );",
      "bCrash = if( below(dist, 0.075), 1, 0);bCrash = if( above( frame, NoCheckUntil) ,bCrash, 0 );",
      "ob_size = bCrash;ob_a=bCrash*.4;",
      "kavb1vx = b1vx;     kavb1vy = b1vy;",
      "kavb2vx = b2vx;     kavb2vy = b2vy;",
      "DotProd1 = cos(fAngle-3.14)*kavb2vx + sin(fAngle-3.14)*kavb2vy;",
      "DotProd2 = cos(fAngle)*kavb1vx + sin(fAngle)*kavb1vy;",
      "b1vx=if( equal( bCrash,1), -cos(fAngle-3.14)*DotProd1 + kavb2vx, b1vx );",
      "b1vy=if( equal( bCrash,1), -cos(fAngle-3.14)*DotProd1 + kavb2vy, b1vy );",
      "b2vx=if( equal( bCrash,1), -cos(fAngle)*DotProd2 + kavb1vx, b2vx );",
      "b2vy=if( equal( bCrash,1), -sin(fAngle)*DotProd2 + kavb1vy, b2vy );",
      "NoCheckUntil = if(equal(bCrash,1),frame + 30,NoCheckUntil );",
      "NoCheckUntil = if( equal( frame-2,NoCheckUntil+60 ), 0, NoCheckUntil );",
      "",
      "// o Determine what to draw",
      "fCrashPhase = if( above(NoCheckUntil,0),(60 + NoCheckUntil - frame)/90, 0);",
      "decay = if( above( fCrashPhase,0), .993 + fCrashPhase*0.006,decay);",
      "wave_x = if( below( iIndex,2), b1x, wave_x);",
      "wave_y = if( below( iIndex,2), b1y, wave_y);",
      "wave_x = if( above( iIndex,1), b2x, wave_x);",
      "wave_y = if( above( iIndex,1), b2y, wave_y);",
      "wave_r = 1.0; wave_g = 1.0; wave_b = 1.0;",
      "wave_r = if( equal( iIndex,1 ), 1.0, wave_r );",
      "wave_g = if( equal( iIndex,1 ), 0.1, wave_g );",
      "wave_b = if( equal( iIndex,1 ), 0.1, wave_b );",
      "wave_r = if( equal( iIndex,3 ), 0.1, wave_r );",
      "wave_g = if( equal( iIndex,3 ), 0.1, wave_g );",
      "wave_b = if( equal( iIndex,3 ), 1.0, wave_b );",
      "wave_mystery = if( equal( iIndex%2,1) , -.55-(bass+prevBass)/60 , -.55 );",
      "warp = if( above(fCrashPhase,.96),warp+5*(totalv/0.03)*(1 - 4*(fCrashPhase-.96)),warp);",
      "wave_size = if( equal( iIndex%2, 0) ,  1, 0 );",
      "wave_a = if( equal( iIndex%2, 0 ), .75, 1.0 );",
      "totalv = if( equal(fCrashPhase,0),sqrt(sqr(b1vx)+sqr(b1vy))+sqrt(sqr(b2vx)+sqr(b2vy)),totalv);",
      "totalv= if(above(totalv,0.04),0.04,totalv);",
      "wave_mystery = if( above(fCrashPhase,.93), -7*(fCrashPhase-.93)*.45, wave_mystery);",
      "wave_r=if( above( fCrashPhase, .9 ), 1, wave_r );",
      "wave_g=if( above( fCrashPhase, .9 ), 1, wave_g );",
      "wave_b=if( above( fCrashPhase, .9 ), 1, wave_b );",
      "ob_r=0;ob_b=0;",
      "ob_r=if(above(Blue,0),0,1);",
      "ob_b=if(above(Blue,0),1,0);",
      "prevBass = if(equal( iIndex%2, 0 ), bass, 0 );"
    ],
