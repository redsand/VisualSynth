MILKDROP_PRESET_VERSION=201
PSVERSION=3
PSVERSION_WARP=3
PSVERSION_COMP=3
[preset00]
fRating=3.000
fGammaAdj=1.980
fDecay=0.500
zoom=0.99990
rot=0.00000
cx=0.500
cy=0.500
warp=0.01000
per_frame_1=q1 = bass;
per_frame_2=q2 = mid;
per_frame_3=q3 = treb;
per_frame_init_1=n = 0;
warp_1=`static const float2 centre = float2 (0.5, 0.5);
warp_2=`shader_body {
warp_3=`ret = lerp(GetPixel(uv),GetBlur1(uv),0.2)*0.75;
warp_4=`}
comp_1=`float3 lavcol (float t){return smoothstep(0,0.8,pow (t,float3(1,2,4)));}
comp_2=`shader_body {
comp_3=`ret = tex2D(sampler_main,uv).rgb;
comp_4=`}